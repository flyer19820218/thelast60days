[
  {
    "start": 0.0,
    "end": 3.12,
    "speaker": "彥君",
    "text": "各位衝A的戰士們"
  },
  {
    "start": 3.12,
    "end": 6.02,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 6.02,
    "end": 8.6,
    "speaker": "曉臻",
    "text": "戰士們大家好"
  },
  {
    "start": 8.6,
    "end": 11.24,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 11.24,
    "end": 14.5,
    "speaker": "彥君",
    "text": "翻開講義二十六頁"
  },
  {
    "start": 14.5,
    "end": 17.71,
    "speaker": "彥君",
    "text": "準備進入時光機了"
  },
  {
    "start": 17.71,
    "end": 21.09,
    "speaker": "彥君",
    "text": "這頁看起來很複雜"
  },
  {
    "start": 21.09,
    "end": 24.52,
    "speaker": "彥君",
    "text": "抓住『大標籤』就贏了"
  },
  {
    "start": 24.52,
    "end": 27.64,
    "speaker": "曉臻",
    "text": "彥君老師請看講義"
  },
  {
    "start": 27.64,
    "end": 30.58,
    "speaker": "曉臻",
    "text": "那些數字讓人頭暈"
  },
  {
    "start": 30.58,
    "end": 33.8,
    "speaker": "彥君",
    "text": "戰士們別管數字啦"
  },
  {
    "start": 33.8,
    "end": 36.96,
    "speaker": "彥君",
    "text": "古生代與中生代"
  },
  {
    "start": 36.96,
    "end": 40.15,
    "speaker": "彥君",
    "text": "還有最後新生代"
  },
  {
    "start": 40.15,
    "end": 43.86,
    "speaker": "彥君",
    "text": "每代都有『標準化石』"
  },
  {
    "start": 43.86,
    "end": 47.05,
    "speaker": "彥君",
    "text": "也就是當時的霸主"
  },
  {
    "start": 47.05,
    "end": 50.02,
    "speaker": "曉臻",
    "text": "什麼叫『標準化石』"
  },
  {
    "start": 50.02,
    "end": 52.9,
    "speaker": "曉臻",
    "text": "是長得很標準嗎"
  },
  {
    "start": 52.9,
    "end": 55.92,
    "speaker": "彥君",
    "text": "哈哈當然不是啦"
  },
  {
    "start": 55.92,
    "end": 59.13,
    "speaker": "彥君",
    "text": "第一生存時間要短"
  },
  {
    "start": 59.13,
    "end": 62.37,
    "speaker": "彥君",
    "text": "第二分布範圍要廣"
  },
  {
    "start": 62.37,
    "end": 65.46,
    "speaker": "彥君",
    "text": "只要在地層看到牠"
  },
  {
    "start": 65.46,
    "end": 68.74,
    "speaker": "彥君",
    "text": "就能立刻知道年代"
  },
  {
    "start": 68.74,
    "end": 71.93,
    "speaker": "彥君",
    "text": "就像看到三葉蟲"
  },
  {
    "start": 71.93,
    "end": 75.19,
    "speaker": "彥君",
    "text": "絕對就是古生代"
  },
  {
    "start": 75.19,
    "end": 78.24,
    "speaker": "曉臻",
    "text": "戰士們趕快拿起筆"
  },
  {
    "start": 78.24,
    "end": 81.21,
    "speaker": "曉臻",
    "text": "第一個抽屜古生代"
  },
  {
    "start": 81.21,
    "end": 84.32,
    "speaker": "曉臻",
    "text": "請在圖上寫三葉蟲"
  },
  {
    "start": 84.32,
    "end": 87.37,
    "speaker": "曉臻",
    "text": "牠可是海洋霸主喔"
  },
  {
    "start": 87.37,
    "end": 90.44,
    "speaker": "曉臻",
    "text": "看到牠就是古生代"
  },
  {
    "start": 90.44,
    "end": 93.65,
    "speaker": "彥君",
    "text": "第二個抽屜中生代"
  },
  {
    "start": 93.65,
    "end": 96.74,
    "speaker": "彥君",
    "text": "是大家最熟悉的喔"
  },
  {
    "start": 96.74,
    "end": 100.31,
    "speaker": "彥君",
    "text": "快寫下恐龍與菊石"
  },
  {
    "start": 100.31,
    "end": 103.64,
    "speaker": "彥君",
    "text": "恐龍生活在陸地上"
  },
  {
    "start": 103.64,
    "end": 107.24,
    "speaker": "彥君",
    "text": "菊石則是生活在海裡"
  },
  {
    "start": 107.24,
    "end": 110.19,
    "speaker": "曉臻",
    "text": "戰士們寫下恐龍了"
  },
  {
    "start": 110.19,
    "end": 113.21,
    "speaker": "曉臻",
    "text": "恐龍滅絕後誰當家"
  },
  {
    "start": 113.21,
    "end": 116.54,
    "speaker": "彥君",
    "text": "最後一個是新生代"
  },
  {
    "start": 116.54,
    "end": 119.85,
    "speaker": "彥君",
    "text": "大型哺乳類的天地"
  },
  {
    "start": 119.85,
    "end": 123.3,
    "speaker": "彥君",
    "text": "指標化石是長毛象"
  },
  {
    "start": 123.3,
    "end": 126.73,
    "speaker": "彥君",
    "text": "還有會考陷阱提醒"
  },
  {
    "start": 126.73,
    "end": 129.96,
    "speaker": "彥君",
    "text": "人類也是新生代喔"
  },
  {
    "start": 129.96,
    "end": 133.08,
    "speaker": "曉臻",
    "text": "老師講義右上角寫"
  },
  {
    "start": 133.08,
    "end": 136.12,
    "speaker": "曉臻",
    "text": "『活化石』是什麼呢"
  },
  {
    "start": 136.12,
    "end": 139.29,
    "speaker": "彥君",
    "text": "這也是愛考的觀念"
  },
  {
    "start": 139.29,
    "end": 142.55,
    "speaker": "彥君",
    "text": "有些生物都沒改變"
  },
  {
    "start": 142.55,
    "end": 146.89,
    "speaker": "彥君",
    "text": "比如銀杏、鱟、腔棘魚"
  },
  {
    "start": 146.89,
    "end": 150.22,
    "speaker": "彥君",
    "text": "牠們見證悠久歷史"
  },
  {
    "start": 150.22,
    "end": 153.84,
    "speaker": "彥君",
    "text": "所以叫作『活化石』"
  },
  {
    "start": 153.84,
    "end": 156.67,
    "speaker": "曉臻",
    "text": "演化過程先跳過"
  },
  {
    "start": 156.67,
    "end": 159.69,
    "speaker": "曉臻",
    "text": "先把年代記熟就好"
  },
  {
    "start": 159.69,
    "end": 162.59,
    "speaker": "曉臻",
    "text": "第一古生代三葉蟲"
  },
  {
    "start": 162.59,
    "end": 165.56,
    "speaker": "曉臻",
    "text": "第二中生代有恐龍"
  },
  {
    "start": 165.56,
    "end": 168.58,
    "speaker": "曉臻",
    "text": "還有海洋裡的菊石"
  },
  {
    "start": 168.58,
    "end": 171.58,
    "speaker": "曉臻",
    "text": "第三新生代長毛象"
  },
  {
    "start": 171.58,
    "end": 174.64,
    "speaker": "曉臻",
    "text": "生存短且分布要廣"
  },
  {
    "start": 174.64,
    "end": 178.02,
    "speaker": "彥君",
    "text": "戰士們請閉上眼睛"
  },
  {
    "start": 178.02,
    "end": 181.33,
    "speaker": "彥君",
    "text": "若同一地層被發現"
  },
  {
    "start": 181.33,
    "end": 184.88,
    "speaker": "彥君",
    "text": "挖出三葉蟲和恐龍"
  },
  {
    "start": 184.88,
    "end": 187.88,
    "speaker": "彥君",
    "text": "這樣合理嗎戰士們"
  },
  {
    "start": 187.88,
    "end": 190.73,
    "speaker": "曉臻",
    "text": "絕對是不合理的喔"
  },
  {
    "start": 190.73,
    "end": 193.77,
    "speaker": "曉臻",
    "text": "三葉蟲早就滅絕了"
  },
  {
    "start": 193.77,
    "end": 196.65,
    "speaker": "曉臻",
    "text": "不可能跟恐龍見面"
  },
  {
    "start": 196.65,
    "end": 199.84,
    "speaker": "彥君",
    "text": "答得漂亮這就對了"
  },
  {
    "start": 199.84,
    "end": 203.22,
    "speaker": "彥君",
    "text": "這是判斷年代邏輯"
  },
  {
    "start": 203.22,
    "end": 206.12,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 206.12,
    "end": 208.75,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 208.75,
    "end": 212.06,
    "speaker": "合聲",
    "text": "時空記清楚拿滿分"
  },
  {
    "start": 212.06,
    "end": 215.2,
    "speaker": "合聲",
    "text": "戰士們下一關見"
  }
]
[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.12,
    "speaker": "彥君",
    "text": "第 119 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.32,
    "end": 9.69,
    "speaker": "彥君",
    "text": "讀書 不能只看花多少時間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.89,
    "end": 13.33,
    "speaker": "彥君",
    "text": "方向對了 才叫作正功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.53,
    "end": 16.97,
    "speaker": "彥君",
    "text": "效率高了 才是大功率",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 17.17,
    "end": 19.77,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.97,
    "end": 21.7,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.9,
    "end": 24.24,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.44,
    "end": 26.9,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.1,
    "end": 30.13,
    "speaker": "彥君",
    "text": "作功 要看施力跟位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.33,
    "end": 33.19,
    "speaker": "曉臻",
    "text": "老師 左上角的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.39,
    "end": 36.33,
    "speaker": "曉臻",
    "text": "力量跟位移 都是向右",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.53,
    "end": 41.22,
    "speaker": "彥君",
    "text": "沒錯 同方向就是正功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.42,
    "end": 44.16,
    "speaker": "彥君",
    "text": "物體 會越來越快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.36,
    "end": 87.82,
    "speaker": "彥君",
    "text": "同向正功 -> 加速",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 48.43,
    "end": 51.49,
    "speaker": "曉臻",
    "text": "那左下角 力量往後拉耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.69,
    "end": 54.41,
    "speaker": "彥君",
    "text": "就像 摩擦力一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.61,
    "end": 57.64,
    "speaker": "彥君",
    "text": "反方向 就是作負功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.84,
    "end": 60.7,
    "speaker": "彥君",
    "text": "物體 當然會減速",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.9,
    "end": 87.82,
    "speaker": "彥君",
    "text": "反向負功 -> 減速",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 64.95,
    "end": 67.58,
    "speaker": "曉臻",
    "text": "右邊的圖 力量往上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.78,
    "end": 70.52,
    "speaker": "曉臻",
    "text": "可是 位移卻是向右",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.72,
    "end": 73.54,
    "speaker": "彥君",
    "text": "提著重物 往前走",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.74,
    "end": 77.61,
    "speaker": "彥君",
    "text": "互相垂直 物理上叫不作功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.81,
    "end": 87.82,
    "speaker": "彥君",
    "text": "垂直不作功",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 81.64,
    "end": 84.62,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘消化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.82,
    "end": 91.14,
    "speaker": "彥君",
    "text": "戰士們 魔王題來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.34,
    "end": 94.3,
    "speaker": "彥君",
    "text": "去年會考 考了功率",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.5,
    "end": 96.72,
    "speaker": "曉臻",
    "text": "功率 是什麼啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.92,
    "end": 99.66,
    "speaker": "彥君",
    "text": "就是 作功的效率",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.86,
    "end": 102.25,
    "speaker": "彥君",
    "text": "聽好題目",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.45,
    "end": 105.6,
    "speaker": "彥君",
    "text": "馬達用 200 牛頓的力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.8,
    "end": 109.0,
    "speaker": "彥君",
    "text": "把箱子 往前拉 10 公尺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.2,
    "end": 111.66,
    "speaker": "彥君",
    "text": "花了 5 秒鐘",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.86,
    "end": 114.72,
    "speaker": "彥君",
    "text": "請問 功率是多少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.92,
    "end": 118.26,
    "speaker": "曉臻",
    "text": "老師 第一步要先算作功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.46,
    "end": 123.1,
    "speaker": "彥君",
    "text": "沒錯 功等於力乘上位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.3,
    "end": 125.95,
    "speaker": "彥君",
    "text": "200 乘上 10",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.15,
    "end": 129.3,
    "speaker": "彥君",
    "text": "總共 作了兩千焦耳的功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.5,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "W=200x10=2000",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 133.96,
    "end": 137.33,
    "speaker": "彥君",
    "text": "戰士們 接下來看好了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.53,
    "end": 139.96,
    "speaker": "曉臻",
    "text": "功率 就是拿作功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.16,
    "end": 142.66,
    "speaker": "曉臻",
    "text": "除以 花掉的時間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.86,
    "end": 147.43,
    "speaker": "彥君",
    "text": "漂亮 兩千除以五秒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.63,
    "end": 150.52,
    "speaker": "彥君",
    "text": "答案是 400 瓦特",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.72,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "P=2000/5=400",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 155.15,
    "end": 158.52,
    "speaker": "曉臻",
    "text": "哇 一步一步拆解",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.72,
    "end": 161.49,
    "speaker": "曉臻",
    "text": "功率 根本一點都不難",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.69,
    "end": 165.13,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.33,
    "end": 167.93,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.13,
    "end": 170.46,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.66,
    "end": 174.01,
    "speaker": "合聲",
    "text": "同向正功 功率除秒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 174.21,
    "end": 177.74,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
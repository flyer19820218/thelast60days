[
  {
    "start": 0.0,
    "end": 5.36,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到第一百二十九集",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 5.56,
    "end": 9.43,

[
  {
    "start": 0.0,
    "end": 3.81,
    "speaker": "彥君",
    "text": "哈囉各位衝刺的戰士們"
  },
  {
    "start": 3.81,
    "end": 7.31,
    "speaker": "曉臻",
    "text": "大家好 我是曉臻助教"
  },
  {
    "start": 7.31,
    "end": 10.28,
    "speaker": "彥君",
    "text": "接續剛才的月相"
  },
  {
    "start": 10.28,
    "end": 13.47,
    "speaker": "彥君",
    "text": "我們要進攻大魔王"
  },
  {
    "start": 13.47,
    "end": 16.9,
    "speaker": "曉臻",
    "text": "會考每年必考的最難題"
  },
  {
    "start": 16.9,
    "end": 20.59,
    "speaker": "曉臻",
    "text": "每次考月亮時間就大崩潰"
  },
  {
    "start": 20.59,
    "end": 25.12,
    "speaker": "彥君",
    "text": "沒錯我們來破解它"
  },
  {
    "start": 25.12,
    "end": 28.58,
    "speaker": "曉臻",
    "text": "第一步 先找地球時間"
  },
  {
    "start": 28.58,
    "end": 32.12,
    "speaker": "彥君",
    "text": "看圖 太陽在右邊"
  },
  {
    "start": 32.12,
    "end": 35.48,
    "speaker": "曉臻",
    "text": "所以地球右半邊是白天"
  },
  {
    "start": 35.48,
    "end": 38.86,
    "speaker": "彥君",
    "text": "站在右邊面對太陽"
  },
  {
    "start": 38.86,
    "end": 41.95,
    "speaker": "曉臻",
    "text": "那裡就是中午十二點"
  },
  {
    "start": 41.95,
    "end": 45.31,
    "speaker": "彥君",
    "text": "地球是逆時針自轉"
  },
  {
    "start": 45.31,
    "end": 48.52,
    "speaker": "曉臻",
    "text": "轉到上面是傍晚六點"
  },
  {
    "start": 48.52,
    "end": 53.48,
    "speaker": "彥君",
    "text": "沒錯轉到左邊沒太陽"
  },
  {
    "start": 53.48,
    "end": 56.38,
    "speaker": "曉臻",
    "text": "那就是半夜十二點"
  },
  {
    "start": 56.38,
    "end": 59.91,
    "speaker": "彥君",
    "text": "轉到下面是清晨六點"
  },
  {
    "start": 59.91,
    "end": 63.1,
    "speaker": "曉臻",
    "text": "把四個時間畫十字架"
  },
  {
    "start": 63.1,
    "end": 67.08,
    "speaker": "彥君",
    "text": "時間找出來破關一半"
  },
  {
    "start": 67.08,
    "end": 70.31,
    "speaker": "曉臻",
    "text": "第二步 人對準月亮"
  },
  {
    "start": 70.31,
    "end": 73.4,
    "speaker": "彥君",
    "text": "我們看上面的月亮"
  },
  {
    "start": 73.4,
    "end": 76.45,
    "speaker": "曉臻",
    "text": "它是初七的上弦月"
  },
  {
    "start": 76.45,
    "end": 79.85,
    "speaker": "彥君",
    "text": "要看到它在正頭頂"
  },
  {
    "start": 79.85,
    "end": 83.09,
    "speaker": "曉臻",
    "text": "人必須站在地球上面"
  },
  {
    "start": 83.09,
    "end": 87.79,
    "speaker": "彥君",
    "text": "漂亮地球上面幾點？"
  },
  {
    "start": 87.79,
    "end": 91.31,
    "speaker": "曉臻",
    "text": "剛剛說過 是傍晚六點"
  },
  {
    "start": 91.31,
    "end": 94.02,
    "speaker": "彥君",
    "text": "完全正確"
  },
  {
    "start": 94.02,
    "end": 97.81,
    "speaker": "彥君",
    "text": "上弦月傍晚六點在頭頂"
  },
  {
    "start": 97.81,
    "end": 100.61,
    "speaker": "曉臻",
    "text": "再看左邊的滿月"
  },
  {
    "start": 100.61,
    "end": 104.3,
    "speaker": "彥君",
    "text": "人站在左邊半夜十二點"
  },
  {
    "start": 104.3,
    "end": 107.11,
    "speaker": "曉臻",
    "text": "滿月就在正頭頂"
  },
  {
    "start": 107.11,
    "end": 110.3,
    "speaker": "彥君",
    "text": "知道頭頂的時間後"
  },
  {
    "start": 110.3,
    "end": 113.39,
    "speaker": "曉臻",
    "text": "拿出終極秒殺公式"
  },
  {
    "start": 113.39,
    "end": 116.86,
    "speaker": "彥君",
    "text": "頭頂時間減六小時"
  },
  {
    "start": 116.86,
    "end": 119.91,
    "speaker": "曉臻",
    "text": "就是月亮升起時間"
  },
  {
    "start": 119.91,
    "end": 123.38,
    "speaker": "彥君",
    "text": "頭頂時間加六小時"
  },
  {
    "start": 123.38,
    "end": 126.36,
    "speaker": "曉臻",
    "text": "就是月亮落下時間"
  },
  {
    "start": 126.36,
    "end": 129.66,
    "speaker": "彥君",
    "text": "這樣畫圖根本無敵"
  },
  {
    "start": 129.66,
    "end": 133.19,
    "speaker": "曉臻",
    "text": "接下來 進階考題來了"
  },
  {
    "start": 133.19,
    "end": 136.38,
    "speaker": "彥君",
    "text": "月相到底是哪邊亮？"
  },
  {
    "start": 136.38,
    "end": 139.47,
    "speaker": "曉臻",
    "text": "這裡千萬不能背錯喔"
  },
  {
    "start": 139.47,
    "end": 142.73,
    "speaker": "彥君",
    "text": "想想太陽在哪裡"
  },
  {
    "start": 142.73,
    "end": 145.72,
    "speaker": "曉臻",
    "text": "太陽從西邊下山"
  },
  {
    "start": 145.72,
    "end": 149.54,
    "speaker": "彥君",
    "text": "所以上弦月是「西邊亮」"
  },
  {
    "start": 149.54,
    "end": 153.04,
    "speaker": "曉臻",
    "text": "面對南方看 西邊在右"
  },
  {
    "start": 153.04,
    "end": 157.11,
    "speaker": "彥君",
    "text": "沒錯 上弦月是右邊亮"
  },
  {
    "start": 157.11,
    "end": 160.23,
    "speaker": "曉臻",
    "text": "長得像大寫的字母Ｄ"
  },
  {
    "start": 160.23,
    "end": 163.94,
    "speaker": "彥君",
    "text": "那廿二下弦月在頭頂時"
  },
  {
    "start": 163.94,
    "end": 167.4,
    "speaker": "曉臻",
    "text": "人在下面 倒過來看了"
  },
  {
    "start": 167.4,
    "end": 170.9,
    "speaker": "彥君",
    "text": "太陽快從東邊升起"
  },
  {
    "start": 170.9,
    "end": 174.35,
    "speaker": "曉臻",
    "text": "所以下弦月是「東邊亮」"
  },
  {
    "start": 174.35,
    "end": 178.23,
    "speaker": "彥君",
    "text": "面對南方看 東邊在左"
  },
  {
    "start": 178.23,
    "end": 181.61,
    "speaker": "曉臻",
    "text": "所以變成是「左邊亮」"
  },
  {
    "start": 181.61,
    "end": 185.06,
    "speaker": "彥君",
    "text": "長得像反過來的字母Ｄ"
  },
  {
    "start": 185.06,
    "end": 188.47,
    "speaker": "曉臻",
    "text": "上右西亮 下左東亮"
  },
  {
    "start": 188.47,
    "end": 191.97,
    "speaker": "彥君",
    "text": "現在我們來實戰測驗"
  },
  {
    "start": 191.97,
    "end": 194.65,
    "speaker": "曉臻",
    "text": "晚上九點的夜空"
  },
  {
    "start": 194.65,
    "end": 198.06,
    "speaker": "彥君",
    "text": "你看到亮一半的月亮"
  },
  {
    "start": 198.06,
    "end": 201.03,
    "speaker": "曉臻",
    "text": "請問它是什麼月相？"
  },
  {
    "start": 201.03,
    "end": 204.84,
    "speaker": "彥君",
    "text": "晚上九點介於傍晚跟半夜"
  },
  {
    "start": 204.84,
    "end": 207.98,
    "speaker": "曉臻",
    "text": "人走到地球的左上角"
  },
  {
    "start": 207.98,
    "end": 211.55,
    "speaker": "彥君",
    "text": "這時候看偏西邊的天空"
  },
  {
    "start": 211.55,
    "end": 214.72,
    "speaker": "曉臻",
    "text": "哪個亮一半的月亮在那？"
  },
  {
    "start": 214.72,
    "end": 217.95,
    "speaker": "彥君",
    "text": "是上半夜的上弦月"
  },
  {
    "start": 217.95,
    "end": 220.71,
    "speaker": "曉臻",
    "text": "傍晚六點在頭頂"
  },
  {
    "start": 220.71,
    "end": 224.11,
    "speaker": "彥君",
    "text": "九點就準備要西下了"
  },
  {
    "start": 224.11,
    "end": 227.3,
    "speaker": "曉臻",
    "text": "而且它一定是亮右邊"
  },
  {
    "start": 227.3,
    "end": 231.16,
    "speaker": "彥君",
    "text": "那換個時間凌晨三點"
  },
  {
    "start": 231.16,
    "end": 233.99,
    "speaker": "曉臻",
    "text": "看到亮一半的月亮"
  },
  {
    "start": 233.99,
    "end": 236.82,
    "speaker": "彥君",
    "text": "這又會是哪一個呢？"
  },
  {
    "start": 236.82,
    "end": 239.84,
    "speaker": "曉臻",
    "text": "凌晨三點在左下角"
  },
  {
    "start": 239.84,
    "end": 243.24,
    "speaker": "彥君",
    "text": "介於半夜跟清晨之間"
  },
  {
    "start": 243.24,
    "end": 246.36,
    "speaker": "曉臻",
    "text": "抬頭看偏東方的天空"
  },
  {
    "start": 246.36,
    "end": 249.88,
    "speaker": "彥君",
    "text": "剛好看到下弦月升起了"
  },
  {
    "start": 249.88,
    "end": 253.24,
    "speaker": "曉臻",
    "text": "下弦月是下半夜的月相"
  },
  {
    "start": 253.24,
    "end": 256.81,
    "speaker": "彥君",
    "text": "而且它是亮左邊的半月"
  },
  {
    "start": 256.81,
    "end": 259.85,
    "speaker": "曉臻",
    "text": "還有一個常考的比喻"
  },
  {
    "start": 259.85,
    "end": 263.35,
    "speaker": "彥君",
    "text": "滿月和太陽的接力賽"
  },
  {
    "start": 263.35,
    "end": 267.36,
    "speaker": "曉臻",
    "text": "接力賽？他們不見面嗎？"
  },
  {
    "start": 267.36,
    "end": 272.15,
    "speaker": "彥君",
    "text": "對滿月在地球正後方"
  },
  {
    "start": 272.15,
    "end": 275.36,
    "speaker": "曉臻",
    "text": "太陽從西邊下山時"
  },
  {
    "start": 275.36,
    "end": 279.03,
    "speaker": "彥君",
    "text": "滿月剛好從東邊升起"
  },
  {
    "start": 279.03,
    "end": 282.34,
    "speaker": "曉臻",
    "text": "晚上滿月代班照亮天空"
  },
  {
    "start": 282.34,
    "end": 286.08,
    "speaker": "彥君",
    "text": "到了清晨 滿月西下"
  },
  {
    "start": 286.08,
    "end": 289.34,
    "speaker": "曉臻",
    "text": "太陽又從東邊升起了"
  },
  {
    "start": 289.34,
    "end": 292.98,
    "speaker": "彥君",
    "text": "滿月和太陽完全對稱"
  },
  {
    "start": 292.98,
    "end": 296.15,
    "speaker": "曉臻",
    "text": "永遠不會在天空相遇"
  },
  {
    "start": 296.15,
    "end": 299.62,
    "speaker": "彥君",
    "text": "這就是完美的接力遊戲"
  },
  {
    "start": 299.62,
    "end": 302.88,
    "speaker": "曉臻",
    "text": "最後補充一個超級必考"
  },
  {
    "start": 302.88,
    "end": 306.19,
    "speaker": "彥君",
    "text": "日月食發生的日期"
  },
  {
    "start": 306.19,
    "end": 309.26,
    "speaker": "曉臻",
    "text": "太陽被擋住是日食"
  },
  {
    "start": 309.26,
    "end": 313.0,
    "speaker": "彥君",
    "text": "月亮跑到太陽跟地球中間"
  },
  {
    "start": 313.0,
    "end": 316.88,
    "speaker": "曉臻",
    "text": "沒錯這就是Ａ月亮"
  },
  {
    "start": 316.88,
    "end": 320.14,
    "speaker": "彥君",
    "text": "也就是農曆初一的朔"
  },
  {
    "start": 320.14,
    "end": 323.28,
    "speaker": "曉臻",
    "text": "所以日食一定在初一"
  },
  {
    "start": 323.28,
    "end": 326.66,
    "speaker": "彥君",
    "text": "那月食發生在哪一天？"
  },
  {
    "start": 326.66,
    "end": 329.56,
    "speaker": "曉臻",
    "text": "地球擋住太陽的光"
  },
  {
    "start": 329.56,
    "end": 332.94,
    "speaker": "彥君",
    "text": "月亮要在地球正後方"
  },
  {
    "start": 332.94,
    "end": 335.84,
    "speaker": "曉臻",
    "text": "也就是月亮的位置"
  },
  {
    "start": 335.84,
    "end": 338.91,
    "speaker": "彥君",
    "text": "農曆十五的滿月"
  },
  {
    "start": 338.91,
    "end": 342.8,
    "speaker": "曉臻",
    "text": "太神了日一月十五"
  },
  {
    "start": 342.8,
    "end": 346.32,
    "speaker": "彥君",
    "text": "這個口訣一定要記熟"
  },
  {
    "start": 346.32,
    "end": 349.8,
    "speaker": "曉臻",
    "text": "一、畫十字找四個時間"
  },
  {
    "start": 349.8,
    "end": 353.7,
    "speaker": "彥君",
    "text": "二、頭頂減六升加六落"
  },
  {
    "start": 353.7,
    "end": 357.3,
    "speaker": "曉臻",
    "text": "三、上右西亮下左東亮"
  },
  {
    "start": 357.3,
    "end": 361.3,
    "speaker": "彥君",
    "text": "四、日食初一月食十五"
  },
  {
    "start": 361.3,
    "end": 364.85,
    "speaker": "彥君",
    "text": "滿月幾點從東邊升起？"
  },
  {
    "start": 364.85,
    "end": 367.73,
    "speaker": "曉臻",
    "text": "半夜十二點在頭頂"
  },
  {
    "start": 367.73,
    "end": 371.9,
    "speaker": "彥君",
    "text": "減六所以傍晚六點升起"
  },
  {
    "start": 371.9,
    "end": 375.78,
    "speaker": "曉臻",
    "text": "漂亮大魔王全拿了"
  },
  {
    "start": 375.78,
    "end": 378.68,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 378.68,
    "end": 381.32,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 381.32,
    "end": 384.63,
    "speaker": "曉臻",
    "text": "邏輯通透 地科神準"
  },
  {
    "start": 384.63,
    "end": 387.46,
    "speaker": "曉臻",
    "text": "下一張投影片見"
  }
]
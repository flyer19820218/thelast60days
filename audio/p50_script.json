[
  {
    "start": 0.0,
    "end": 2.3,
    "speaker": "彥君",
    "text": "哈囉"
  },
  {
    "start": 2.3,
    "end": 6.16,
    "speaker": "彥君",
    "text": "各位即將衝A的會考戰士們"
  },
  {
    "start": 6.16,
    "end": 9.66,
    "speaker": "曉臻",
    "text": "大家好 我是曉臻助教"
  },
  {
    "start": 9.66,
    "end": 12.75,
    "speaker": "彥君",
    "text": "接續剛才的月相"
  },
  {
    "start": 12.75,
    "end": 15.94,
    "speaker": "彥君",
    "text": "我們要進攻大魔王"
  },
  {
    "start": 15.94,
    "end": 19.37,
    "speaker": "曉臻",
    "text": "會考每年必考的最難題"
  },
  {
    "start": 19.37,
    "end": 23.06,
    "speaker": "曉臻",
    "text": "每次考月亮時間就大崩潰"
  },
  {
    "start": 23.06,
    "end": 27.59,
    "speaker": "彥君",
    "text": "沒錯我們來破解它"
  },
  {
    "start": 27.59,
    "end": 31.04,
    "speaker": "曉臻",
    "text": "第一步 先找地球時間"
  },
  {
    "start": 31.04,
    "end": 34.59,
    "speaker": "彥君",
    "text": "看圖 太陽在右邊"
  },
  {
    "start": 34.59,
    "end": 37.95,
    "speaker": "曉臻",
    "text": "所以地球右半邊是白天"
  },
  {
    "start": 37.95,
    "end": 41.33,
    "speaker": "彥君",
    "text": "站在右邊面對太陽"
  },
  {
    "start": 41.33,
    "end": 44.42,
    "speaker": "曉臻",
    "text": "那裡就是中午十二點"
  },
  {
    "start": 44.42,
    "end": 47.78,
    "speaker": "彥君",
    "text": "地球是逆時針自轉"
  },
  {
    "start": 47.78,
    "end": 50.99,
    "speaker": "曉臻",
    "text": "轉到上面是傍晚六點"
  },
  {
    "start": 50.99,
    "end": 55.95,
    "speaker": "彥君",
    "text": "沒錯轉到左邊沒太陽"
  },
  {
    "start": 55.95,
    "end": 58.85,
    "speaker": "曉臻",
    "text": "那就是半夜十二點"
  },
  {
    "start": 58.85,
    "end": 62.38,
    "speaker": "彥君",
    "text": "轉到下面是清晨六點"
  },
  {
    "start": 62.38,
    "end": 65.56,
    "speaker": "曉臻",
    "text": "把四個時間畫十字架"
  },
  {
    "start": 65.56,
    "end": 69.54,
    "speaker": "彥君",
    "text": "時間找出來破關一半"
  },
  {
    "start": 69.54,
    "end": 72.78,
    "speaker": "曉臻",
    "text": "第二步 人對準月亮"
  },
  {
    "start": 72.78,
    "end": 75.87,
    "speaker": "彥君",
    "text": "我們看上面的月亮"
  },
  {
    "start": 75.87,
    "end": 78.92,
    "speaker": "曉臻",
    "text": "它是初七的上弦月"
  },
  {
    "start": 78.92,
    "end": 82.32,
    "speaker": "彥君",
    "text": "要看到它在正頭頂"
  },
  {
    "start": 82.32,
    "end": 85.56,
    "speaker": "曉臻",
    "text": "人必須站在地球上面"
  },
  {
    "start": 85.56,
    "end": 90.26,
    "speaker": "彥君",
    "text": "漂亮地球上面幾點"
  },
  {
    "start": 90.26,
    "end": 93.78,
    "speaker": "曉臻",
    "text": "剛剛說過 是傍晚六點"
  },
  {
    "start": 93.78,
    "end": 96.49,
    "speaker": "彥君",
    "text": "完全正確"
  },
  {
    "start": 96.49,
    "end": 100.28,
    "speaker": "彥君",
    "text": "上弦月傍晚六點在頭頂"
  },
  {
    "start": 100.28,
    "end": 103.08,
    "speaker": "曉臻",
    "text": "再看左邊的滿月"
  },
  {
    "start": 103.08,
    "end": 106.77,
    "speaker": "彥君",
    "text": "人站在左邊半夜十二點"
  },
  {
    "start": 106.77,
    "end": 109.58,
    "speaker": "曉臻",
    "text": "滿月就在正頭頂"
  },
  {
    "start": 109.58,
    "end": 112.76,
    "speaker": "彥君",
    "text": "知道頭頂的時間後"
  },
  {
    "start": 112.76,
    "end": 115.86,
    "speaker": "曉臻",
    "text": "拿出終極秒殺公式"
  },
  {
    "start": 115.86,
    "end": 119.33,
    "speaker": "彥君",
    "text": "頭頂時間減六小時"
  },
  {
    "start": 119.33,
    "end": 122.38,
    "speaker": "曉臻",
    "text": "就是月亮升起時間"
  },
  {
    "start": 122.38,
    "end": 125.85,
    "speaker": "彥君",
    "text": "頭頂時間加六小時"
  },
  {
    "start": 125.85,
    "end": 128.82,
    "speaker": "曉臻",
    "text": "就是月亮落下時間"
  },
  {
    "start": 128.82,
    "end": 132.13,
    "speaker": "彥君",
    "text": "這樣畫圖根本無敵"
  },
  {
    "start": 132.13,
    "end": 135.66,
    "speaker": "曉臻",
    "text": "接下來 進階考題來了"
  },
  {
    "start": 135.66,
    "end": 138.84,
    "speaker": "彥君",
    "text": "月相到底是哪邊亮"
  },
  {
    "start": 138.84,
    "end": 141.94,
    "speaker": "曉臻",
    "text": "這裡千萬不能背錯喔"
  },
  {
    "start": 141.94,
    "end": 145.2,
    "speaker": "彥君",
    "text": "想想太陽在哪裡"
  },
  {
    "start": 145.2,
    "end": 148.19,
    "speaker": "曉臻",
    "text": "太陽從西邊下山"
  },
  {
    "start": 148.19,
    "end": 152.0,
    "speaker": "彥君",
    "text": "所以上弦月是「西邊亮」"
  },
  {
    "start": 152.0,
    "end": 155.5,
    "speaker": "曉臻",
    "text": "面對南方看 西邊在右"
  },
  {
    "start": 155.5,
    "end": 159.58,
    "speaker": "彥君",
    "text": "沒錯 上弦月是右邊亮"
  },
  {
    "start": 159.58,
    "end": 162.7,
    "speaker": "曉臻",
    "text": "長得像大寫的字母Ｄ"
  },
  {
    "start": 162.7,
    "end": 166.41,
    "speaker": "彥君",
    "text": "那廿二下弦月在頭頂時"
  },
  {
    "start": 166.41,
    "end": 169.86,
    "speaker": "曉臻",
    "text": "人在下面 倒過來看了"
  },
  {
    "start": 169.86,
    "end": 173.36,
    "speaker": "彥君",
    "text": "太陽快從東邊升起"
  },
  {
    "start": 173.36,
    "end": 176.82,
    "speaker": "曉臻",
    "text": "所以下弦月是「東邊亮」"
  },
  {
    "start": 176.82,
    "end": 180.7,
    "speaker": "彥君",
    "text": "面對南方看 東邊在左"
  },
  {
    "start": 180.7,
    "end": 184.08,
    "speaker": "曉臻",
    "text": "所以變成是「左邊亮」"
  },
  {
    "start": 184.08,
    "end": 187.53,
    "speaker": "彥君",
    "text": "長得像反過來的字母Ｄ"
  },
  {
    "start": 187.53,
    "end": 190.94,
    "speaker": "曉臻",
    "text": "上右西亮 下左東亮"
  },
  {
    "start": 190.94,
    "end": 194.44,
    "speaker": "彥君",
    "text": "現在我們來實戰測驗"
  },
  {
    "start": 194.44,
    "end": 197.12,
    "speaker": "曉臻",
    "text": "晚上九點的夜空"
  },
  {
    "start": 197.12,
    "end": 200.52,
    "speaker": "彥君",
    "text": "你看到亮一半的月亮"
  },
  {
    "start": 200.52,
    "end": 203.57,
    "speaker": "曉臻",
    "text": "請問它是什麼月相"
  },
  {
    "start": 203.57,
    "end": 207.38,
    "speaker": "彥君",
    "text": "晚上九點介於傍晚跟半夜"
  },
  {
    "start": 207.38,
    "end": 210.52,
    "speaker": "曉臻",
    "text": "人走到地球的左上角"
  },
  {
    "start": 210.52,
    "end": 214.09,
    "speaker": "彥君",
    "text": "這時候看偏西邊的天空"
  },
  {
    "start": 214.09,
    "end": 217.26,
    "speaker": "曉臻",
    "text": "哪個亮一半的月亮在那"
  },
  {
    "start": 217.26,
    "end": 220.49,
    "speaker": "彥君",
    "text": "是上半夜的上弦月"
  },
  {
    "start": 220.49,
    "end": 223.25,
    "speaker": "曉臻",
    "text": "傍晚六點在頭頂"
  },
  {
    "start": 223.25,
    "end": 226.65,
    "speaker": "彥君",
    "text": "九點就準備要西下了"
  },
  {
    "start": 226.65,
    "end": 229.84,
    "speaker": "曉臻",
    "text": "而且它一定是亮右邊"
  },
  {
    "start": 229.84,
    "end": 233.7,
    "speaker": "彥君",
    "text": "那換個時間凌晨三點"
  },
  {
    "start": 233.7,
    "end": 236.53,
    "speaker": "曉臻",
    "text": "看到亮一半的月亮"
  },
  {
    "start": 236.53,
    "end": 239.36,
    "speaker": "彥君",
    "text": "這又會是哪一個呢"
  },
  {
    "start": 239.36,
    "end": 242.38,
    "speaker": "曉臻",
    "text": "凌晨三點在左下角"
  },
  {
    "start": 242.38,
    "end": 245.78,
    "speaker": "彥君",
    "text": "介於半夜跟清晨之間"
  },
  {
    "start": 245.78,
    "end": 248.9,
    "speaker": "曉臻",
    "text": "抬頭看偏東方的天空"
  },
  {
    "start": 248.9,
    "end": 252.42,
    "speaker": "彥君",
    "text": "剛好看到下弦月升起了"
  },
  {
    "start": 252.42,
    "end": 255.78,
    "speaker": "曉臻",
    "text": "下弦月是下半夜的月相"
  },
  {
    "start": 255.78,
    "end": 259.35,
    "speaker": "彥君",
    "text": "而且它是亮左邊的半月"
  },
  {
    "start": 259.35,
    "end": 262.39,
    "speaker": "曉臻",
    "text": "還有一個常考的比喻"
  },
  {
    "start": 262.39,
    "end": 265.89,
    "speaker": "彥君",
    "text": "滿月和太陽的接力賽"
  },
  {
    "start": 265.89,
    "end": 269.9,
    "speaker": "曉臻",
    "text": "接力賽他們不見面嗎"
  },
  {
    "start": 269.9,
    "end": 274.69,
    "speaker": "彥君",
    "text": "對滿月在地球正後方"
  },
  {
    "start": 274.69,
    "end": 277.9,
    "speaker": "曉臻",
    "text": "太陽從西邊下山時"
  },
  {
    "start": 277.9,
    "end": 281.57,
    "speaker": "彥君",
    "text": "滿月剛好從東邊升起"
  },
  {
    "start": 281.57,
    "end": 284.88,
    "speaker": "曉臻",
    "text": "晚上滿月代班照亮天空"
  },
  {
    "start": 284.88,
    "end": 288.62,
    "speaker": "彥君",
    "text": "到了清晨 滿月西下"
  },
  {
    "start": 288.62,
    "end": 291.88,
    "speaker": "曉臻",
    "text": "太陽又從東邊升起了"
  },
  {
    "start": 291.88,
    "end": 295.52,
    "speaker": "彥君",
    "text": "滿月和太陽完全對稱"
  },
  {
    "start": 295.52,
    "end": 298.69,
    "speaker": "曉臻",
    "text": "永遠不會在天空相遇"
  },
  {
    "start": 298.69,
    "end": 302.16,
    "speaker": "彥君",
    "text": "這就是完美的接力遊戲"
  },
  {
    "start": 302.16,
    "end": 305.42,
    "speaker": "曉臻",
    "text": "最後補充一個超級必考"
  },
  {
    "start": 305.42,
    "end": 308.73,
    "speaker": "彥君",
    "text": "日月食發生的日期"
  },
  {
    "start": 308.73,
    "end": 311.8,
    "speaker": "曉臻",
    "text": "太陽被擋住是日食"
  },
  {
    "start": 311.8,
    "end": 315.54,
    "speaker": "彥君",
    "text": "月亮跑到太陽跟地球中間"
  },
  {
    "start": 315.54,
    "end": 319.3,
    "speaker": "曉臻",
    "text": "沒錯這就是月亮"
  },
  {
    "start": 319.3,
    "end": 322.56,
    "speaker": "彥君",
    "text": "也就是農曆初一的朔"
  },
  {
    "start": 322.56,
    "end": 325.7,
    "speaker": "曉臻",
    "text": "所以日食一定在初一"
  },
  {
    "start": 325.7,
    "end": 329.08,
    "speaker": "彥君",
    "text": "那月食發生在哪一天"
  },
  {
    "start": 329.08,
    "end": 331.98,
    "speaker": "曉臻",
    "text": "地球擋住太陽的光"
  },
  {
    "start": 331.98,
    "end": 335.36,
    "speaker": "彥君",
    "text": "月亮要在地球正後方"
  },
  {
    "start": 335.36,
    "end": 338.26,
    "speaker": "曉臻",
    "text": "也就是月亮的位置"
  },
  {
    "start": 338.26,
    "end": 341.33,
    "speaker": "彥君",
    "text": "農曆十五的滿月"
  },
  {
    "start": 341.33,
    "end": 345.22,
    "speaker": "曉臻",
    "text": "太神了日一月十五"
  },
  {
    "start": 345.22,
    "end": 348.74,
    "speaker": "彥君",
    "text": "這個口訣一定要記熟"
  },
  {
    "start": 348.74,
    "end": 352.22,
    "speaker": "曉臻",
    "text": "一、畫十字找四個時間"
  },
  {
    "start": 352.22,
    "end": 356.12,
    "speaker": "彥君",
    "text": "二、頭頂減六升加六落"
  },
  {
    "start": 356.12,
    "end": 359.72,
    "speaker": "曉臻",
    "text": "三、上右西亮下左東亮"
  },
  {
    "start": 359.72,
    "end": 363.72,
    "speaker": "彥君",
    "text": "四、日食初一月食十五"
  },
  {
    "start": 363.72,
    "end": 367.27,
    "speaker": "彥君",
    "text": "滿月幾點從東邊升起"
  },
  {
    "start": 367.27,
    "end": 370.15,
    "speaker": "曉臻",
    "text": "半夜十二點在頭頂"
  },
  {
    "start": 370.15,
    "end": 374.32,
    "speaker": "彥君",
    "text": "減六所以傍晚六點升起"
  },
  {
    "start": 374.32,
    "end": 378.2,
    "speaker": "曉臻",
    "text": "漂亮大魔王全拿了"
  },
  {
    "start": 378.2,
    "end": 381.1,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 381.1,
    "end": 383.74,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 383.74,
    "end": 387.53,
    "speaker": "合聲",
    "text": "邏輯通透 地科神準"
  },
  {
    "start": 387.53,
    "end": 390.79,
    "speaker": "合聲",
    "text": "下一張投影片見"
  }
]
[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.38,
    "speaker": "彥君",
    "text": "今天來到 第八十五集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.58,
    "end": 16.31,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.51,
    "end": 18.85,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.05,
    "end": 21.89,
    "speaker": "曉臻",
    "text": "老師 元素這麼多",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.09,
    "end": 24.42,
    "speaker": "曉臻",
    "text": "金屬跟 非金屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.62,
    "end": 26.82,
    "speaker": "曉臻",
    "text": "到底 怎麼分啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.02,
    "end": 29.47,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.67,
    "end": 32.78,
    "speaker": "彥君",
    "text": "金屬 有金屬光澤",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.98,
    "end": 35.67,
    "speaker": "彥君",
    "text": "大多是 銀白色",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.87,
    "end": 38.42,
    "speaker": "彥君",
    "text": "富有 延展性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.62,
    "end": 41.32,
    "speaker": "彥君",
    "text": "而且 容易導電",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.52,
    "end": 44.62,
    "speaker": "曉臻",
    "text": "喔 那非金屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.82,
    "end": 47.23,
    "speaker": "曉臻",
    "text": "就是 容易碎掉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.43,
    "end": 49.53,
    "speaker": "曉臻",
    "text": "顏色 很多種",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.73,
    "end": 52.06,
    "speaker": "曉臻",
    "text": "也 不容易導電囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.26,
    "end": 54.65,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.85,
    "end": 57.38,
    "speaker": "彥君",
    "text": "講到 導電性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.58,
    "end": 60.13,
    "speaker": "彥君",
    "text": "必考的 排名來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.33,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{導電} \\rightarrow \\text{銀} > \\text{銅} > \\text{金} > \\text{鋁}",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 65.05,
    "end": 67.26,
    "speaker": "曉臻",
    "text": "原來 銀的導電",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.46,
    "end": 69.8,
    "speaker": "曉臻",
    "text": "比銅 還要好啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.0,
    "end": 74.02,
    "speaker": "彥君",
    "text": "沒錯 接下來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.22,
    "end": 76.94,
    "speaker": "彥君",
    "text": "我們來 快速點名",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.14,
    "end": 80.26,
    "speaker": "彥君",
    "text": "金 延展性最好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.46,
    "end": 83.62,
    "speaker": "彥君",
    "text": "鐵 使用最廣泛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.82,
    "end": 87.18,
    "speaker": "彥君",
    "text": "鋅 常常鍍在鐵上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.38,
    "end": 90.1,
    "speaker": "彥君",
    "text": "可以 防止生鏽",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.3,
    "end": 92.38,
    "speaker": "曉臻",
    "text": "那鎢 跟鈦呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.58,
    "end": 95.1,
    "speaker": "彥君",
    "text": "鎢的 熔點最高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.3,
    "end": 98.1,
    "speaker": "彥君",
    "text": "用來做 燈泡燈絲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.3,
    "end": 100.9,
    "speaker": "彥君",
    "text": "鈦 輕又堅固",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.1,
    "end": 104.03,
    "speaker": "彥君",
    "text": "常用在 航太醫學",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.23,
    "end": 106.93,
    "speaker": "曉臻",
    "text": "老師 還有水銀",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.13,
    "end": 109.78,
    "speaker": "彥君",
    "text": "水銀 就是汞",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.98,
    "end": 112.7,
    "speaker": "彥君",
    "text": "它是 唯一常溫下",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.9,
    "end": 115.71,
    "speaker": "彥君",
    "text": "呈現 液態的金屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.91,
    "end": 119.11,
    "speaker": "曉臻",
    "text": "哇 那非金屬呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.31,
    "end": 122.51,
    "speaker": "彥君",
    "text": "磷 用來做火柴",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.71,
    "end": 125.72,
    "speaker": "彥君",
    "text": "矽 是半導體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.92,
    "end": 128.54,
    "speaker": "彥君",
    "text": "做 電腦晶片的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.74,
    "end": 132.16,
    "speaker": "彥君",
    "text": "氯 是黃綠色毒氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.36,
    "end": 135.06,
    "speaker": "彥君",
    "text": "可以 用來殺菌",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.26,
    "end": 138.19,
    "speaker": "曉臻",
    "text": "老師 那非金屬裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.39,
    "end": 140.54,
    "speaker": "曉臻",
    "text": "也有 液態的嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.74,
    "end": 144.51,
    "speaker": "彥君",
    "text": "有 就是溴",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.71,
    "end": 147.55,
    "speaker": "彥君",
    "text": "溴是 暗紅色液體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.75,
    "end": 150.88,
    "speaker": "彥君",
    "text": "戰士們 記起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.08,
    "end": 153.9,
    "speaker": "彥君",
    "text": "常溫下 是液態的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.1,
    "end": 156.58,
    "speaker": "彥君",
    "text": "只有 汞跟溴",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.78,
    "end": 159.04,
    "speaker": "曉臻",
    "text": "這樣 快速點名",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.24,
    "end": 161.79,
    "speaker": "曉臻",
    "text": "元素特性 超清楚",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.99,
    "end": 165.43,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.63,
    "end": 168.23,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.43,
    "end": 170.77,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.97,
    "end": 174.43,
    "speaker": "合聲",
    "text": "導電銀銅 液態溴汞",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 174.63,
    "end": 178.17,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
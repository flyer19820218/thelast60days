    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.21,
    "speaker": "彥君",
    "text": "今天來到 第九十一集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.41,
    "end": 16.14,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.34,
    "end": 18.68,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.88,
    "end": 21.98,
    "speaker": "曉臻",
    "text": "老師 上面好多離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.18,
    "end": 24.54,
    "speaker": "曉臻",
    "text": "看得 我頭都暈了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.74,
    "end": 27.75,
    "speaker": "彥君",
    "text": "戰士們， 撐住啊！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.95,
    "end": 30.98,
    "speaker": "彥君",
    "text": "這些 常見的原子團",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.18,
    "end": 34.5,
    "speaker": "彥君",
    "text": "絕對 要背到直覺反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.7,
    "end": 37.42,
    "speaker": "彥君",
    "text": "我們 快速來點名",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.62,
    "end": 40.32,
    "speaker": "曉臻",
    "text": "CO₃²⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.52,
    "end": 43.53,
    "speaker": "曉臻",
    "text": "SO₄²⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.73,
    "end": 48.1,
    "speaker": "彥君",
    "text": "沒錯 那如果氧變少呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.3,
    "end": 50.95,
    "speaker": "彥君",
    "text": "像是 SO₃²⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.15,
    "end": 53.75,
    "speaker": "彥君",
    "text": "還有 NO₂⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.95,
    "end": 57.46,
    "speaker": "彥君",
    "text": "少一個氧 就加個亞字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.66,
    "end": 60.91,
    "speaker": "曉臻",
    "text": "喔 還有 OH⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.11,
    "end": 63.06,
    "speaker": "曉臻",
    "text": "跟 CH₃COO⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.26,
    "end": 66.01,
    "speaker": "彥君",
    "text": "那唯一 帶正電的根呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.21,
    "end": 68.06,
    "speaker": "曉臻",
    "text": "就是 NH₄⁺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.26,
    "end": 72.23,
    "speaker": "彥君",
    "text": "漂亮 接下來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.43,
    "end": 75.22,
    "speaker": "彥君",
    "text": "我們進入 電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.42,
    "end": 78.26,
    "speaker": "彥君",
    "text": "什麼 叫做電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.46,
    "end": 81.06,
    "speaker": "曉臻",
    "text": "就是 正電的總電量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.26,
    "end": 83.79,
    "speaker": "曉臻",
    "text": "等於 負電的總電量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.99,
    "end": 86.38,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.58,
    "end": 89.68,
    "speaker": "彥君",
    "text": "我們來寫 氯化鎂的解離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.88,
    "end": 118.69,
    "speaker": "彥君",
    "text": "MgCl₂ → Mg²⁺ + 2Cl⁻",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 95.13,
    "end": 98.18,
    "speaker": "曉臻",
    "text": "老師 為什麼氯前面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.38,
    "end": 100.72,
    "speaker": "曉臻",
    "text": "要 寫上數字 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.92,
    "end": 103.59,
    "speaker": "彥君",
    "text": "因為 鎂是正 2 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.79,
    "end": 106.34,
    "speaker": "彥君",
    "text": "氯 只有負 1 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.54,
    "end": 109.02,
    "speaker": "彥君",
    "text": "必須要 2 個氯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.22,
    "end": 111.9,
    "speaker": "彥君",
    "text": "才能 抵銷 1 個鎂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.1,
    "end": 115.49,
    "speaker": "曉臻",
    "text": "哇 這就是電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.69,
    "end": 119.01,
    "speaker": "彥君",
    "text": "戰士們， 隨堂考來了！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.21,
    "end": 121.9,
    "speaker": "彥君",
    "text": "硫酸鈉的 解離式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.1,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "Na₂SO₄ → 2Na⁺ + SO₄²⁻",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 127.38,
    "end": 129.57,
    "speaker": "曉臻",
    "text": "鈉是 正 1 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.77,
    "end": 132.32,
    "speaker": "曉臻",
    "text": "硫酸根 是負 2 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.52,
    "end": 134.54,
    "speaker": "曉臻",
    "text": "為了 電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.74,
    "end": 137.18,
    "speaker": "曉臻",
    "text": "鈉的前面 要寫 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.38,
    "end": 140.02,
    "speaker": "彥君",
    "text": "那如果 有 100 個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.22,
    "end": 142.99,
    "speaker": "彥君",
    "text": "硫酸鈉 丟進水裡呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.19,
    "end": 145.38,
    "speaker": "曉臻",
    "text": "100 乘上 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.58,
    "end": 148.5,
    "speaker": "曉臻",
    "text": "會產生 200 個鈉離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.7,
    "end": 151.22,
    "speaker": "曉臻",
    "text": "還有 100 個硫酸根",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.42,
    "end": 154.67,
    "speaker": "彥君",
    "text": "總共 產生 300 個離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.87,
    "end": 157.66,
    "speaker": "彥君",
    "text": "助教 算得太快了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.86,
    "end": 161.3,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.5,
    "end": 164.1,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.3,
    "end": 166.64,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 166.84,
    "end": 170.35,
    "speaker": "合聲",
    "text": "正負相抵 解離無敵",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.55,
    "end": 174.09,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }

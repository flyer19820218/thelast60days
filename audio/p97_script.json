[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.74,
    "speaker": "彥君",
    "text": "各位即將衝A的會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.94,
    "end": 8.54,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.74,
    "end": 11.91,
    "speaker": "彥君",
    "text": "今天來到 第九十七集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.11,
    "end": 13.85,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.05,
    "end": 16.38,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.58,
    "end": 19.04,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.24,
    "end": 22.56,
    "speaker": "彥君",
    "text": "今天這集 是超常考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.76,
    "end": 25.79,
    "speaker": "彥君",
    "text": "我們要來 破解聚合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.99,
    "end": 29.1,
    "speaker": "曉臻",
    "text": "老師 講義標題寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.3,
    "end": 32.21,
    "speaker": "曉臻",
    "text": "聚合物 是單體構成的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.41,
    "end": 34.98,
    "speaker": "曉臻",
    "text": "單體 是什麼意思啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.18,
    "end": 38.14,
    "speaker": "彥君",
    "text": "單體 就像是一塊樂高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.34,
    "end": 41.28,
    "speaker": "彥君",
    "text": "當你把 幾千幾萬塊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.48,
    "end": 44.46,
    "speaker": "彥君",
    "text": "小樂高 拼在一起",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.66,
    "end": 47.74,
    "speaker": "彥君",
    "text": "變成 一個巨大的城堡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.94,
    "end": 51.1,
    "speaker": "彥君",
    "text": "那個城堡 就是聚合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.3,
    "end": 54.62,
    "speaker": "曉臻",
    "text": "哇 原來聚合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.82,
    "end": 57.46,
    "speaker": "曉臻",
    "text": "分子量 超級巨大的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.66,
    "end": 62.11,
    "speaker": "彥君",
    "text": "沒錯 接下來看分類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.31,
    "end": 65.66,
    "speaker": "彥君",
    "text": "先看 左邊的天然聚合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.86,
    "end": 69.03,
    "speaker": "彥君",
    "text": "這是 大自然自己做的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.23,
    "end": 72.14,
    "speaker": "曉臻",
    "text": "像是 澱粉跟蛋白質嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.34,
    "end": 76.67,
    "speaker": "彥君",
    "text": "答對了 還有纖維素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.87,
    "end": 79.42,
    "speaker": "彥君",
    "text": "以及 天然橡膠",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.62,
    "end": 109.66,
    "speaker": "彥君",
    "text": "天然：澱粉、蛋白質、纖維素",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 84.39,
    "end": 87.28,
    "speaker": "曉臻",
    "text": "那 下面的合成聚合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.48,
    "end": 90.25,
    "speaker": "曉臻",
    "text": "就是 人類做出來的囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.45,
    "end": 94.9,
    "speaker": "彥君",
    "text": "沒錯 像是各種塑膠",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.1,
    "end": 98.37,
    "speaker": "彥君",
    "text": "還有 耐綸等合成纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.57,
    "end": 109.66,
    "speaker": "彥君",
    "text": "合成：塑膠、耐綸、合成纖維",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 103.48,
    "end": 106.46,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.66,
    "end": 112.86,
    "speaker": "曉臻",
    "text": "老師 右邊的結構分類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.06,
    "end": 115.78,
    "speaker": "曉臻",
    "text": "感覺 很容易搞混耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.98,
    "end": 120.24,
    "speaker": "彥君",
    "text": "別怕 我們先看上面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.44,
    "end": 123.04,
    "speaker": "彥君",
    "text": "鏈狀聚合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.24,
    "end": 126.1,
    "speaker": "曉臻",
    "text": "後面括號 寫著熱塑性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.3,
    "end": 128.78,
    "speaker": "彥君",
    "text": "鏈狀的結構",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.98,
    "end": 132.11,
    "speaker": "彥君",
    "text": "就像是 一盤義大利麵",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.31,
    "end": 135.34,
    "speaker": "彥君",
    "text": "一條一條 疊在一起",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.54,
    "end": 138.22,
    "speaker": "曉臻",
    "text": "那 加熱會變成怎樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.42,
    "end": 140.82,
    "speaker": "彥君",
    "text": "只要 一加熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.02,
    "end": 144.13,
    "speaker": "彥君",
    "text": "麵條之間 就會滑動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.33,
    "end": 147.1,
    "speaker": "彥君",
    "text": "它就會 軟化融化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.3,
    "end": 150.47,
    "speaker": "曉臻",
    "text": "喔 軟了就可以",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.67,
    "end": 153.49,
    "speaker": "曉臻",
    "text": "重新塑形 回收利用",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.69,
    "end": 158.52,
    "speaker": "彥君",
    "text": "完全正確 所以叫熱塑性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.72,
    "end": 162.02,
    "speaker": "彥君",
    "text": "像是 寶特瓶跟塑膠袋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.22,
    "end": 175.23,
    "speaker": "彥君",
    "text": "鏈狀",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 169.05,
    "end": 172.03,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.23,
    "end": 178.22,
    "speaker": "曉臻",
    "text": "那下面的 網狀聚合物呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 178.42,
    "end": 180.82,
    "speaker": "曉臻",
    "text": "括號寫著 熱固性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.02,
    "end": 184.34,
    "speaker": "彥君",
    "text": "它的結構 像立體烤肉網",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 184.54,
    "end": 187.91,
    "speaker": "彥君",
    "text": "分子之間 緊緊扣在一起",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 188.11,
    "end": 190.98,
    "speaker": "曉臻",
    "text": "那它 加熱也會融化嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 191.18,
    "end": 195.7,
    "speaker": "彥君",
    "text": "不會 它就像烤熟的蛋糕",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 195.9,
    "end": 198.93,
    "speaker": "彥君",
    "text": "再加熱 它只會烤焦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 199.13,
    "end": 201.78,
    "speaker": "彥君",
    "text": "絕對 不會融化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 201.98,
    "end": 205.63,
    "speaker": "曉臻",
    "text": "哇 那就 不能回收了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 205.83,
    "end": 210.28,
    "speaker": "彥君",
    "text": "沒錯 所以叫熱固性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 210.48,
    "end": 213.94,
    "speaker": "曉臻",
    "text": "老師 生活中有什麼例子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 214.14,
    "end": 216.98,
    "speaker": "彥君",
    "text": "它們 都超級耐高溫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 217.18,
    "end": 219.95,
    "speaker": "彥君",
    "text": "像是 汽車的輪胎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 220.15,
    "end": 223.47,
    "speaker": "彥君",
    "text": "還有 炒菜鍋的黑色把手",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 223.67,
    "end": 226.3,
    "speaker": "彥君",
    "text": "以及 絕緣的電木",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 226.5,
    "end": 246.55,
    "speaker": "彥君",
    "text": "網狀",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 233.21,
    "end": 237.37,
    "speaker": "曉臻",
    "text": "哇 用義大利麵 跟蛋糕來記",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 237.57,
    "end": 240.17,
    "speaker": "曉臻",
    "text": "真的 秒懂不會忘耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 240.37,
    "end": 243.35,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 246.55,
    "end": 249.99,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 250.19,
    "end": 252.79,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 252.99,
    "end": 255.33,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 255.53,
    "end": 258.94,
    "speaker": "合聲",
    "text": "鏈狀融化 網狀不怕",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 259.14,
    "end": 262.68,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
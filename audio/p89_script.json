[
  {
    "start": 0.0,
    "end": 4.66,
    "speaker": "彥君",
    "text": "各位準備在理化考場大展身手的會考戰士們",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 4.86,
    "end": 7.46,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 7.66,
    "end": 9.95,
    "speaker": "曉臻",
    "text": "戰士們大家好",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 10.15,
    "end": 12.49,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 12.69,
    "end": 18.91,
    "speaker": "彥君",
    "text": "歡迎來到第八十九集進入計算大魔王關卡",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 19.11,
    "end": 23.32,
    "speaker": "曉臻",
    "text": "老師講義第一行寫著「碳定為 $12$」",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 23.52,
    "end": 25.93,
    "speaker": "曉臻",
    "text": "這是什麼意思啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 26.13,
    "end": 30.7,
    "speaker": "彥君",
    "text": "戰士們注意因為原子實在是太小太小了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 30.9,
    "end": 36.09,
    "speaker": "彥君",
    "text": "所以科學家就找了碳原子當作大家比較的標準",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 36.29,
    "end": 39.61,
    "speaker": "彥君",
    "text": "規定碳的原子量就是 $$12$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 39.81,
    "end": 45.53,
    "speaker": "曉臻",
    "text": "喔原來是當作體重計的標準大家都跟碳來比",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 45.73,
    "end": 50.39,
    "speaker": "曉臻",
    "text": "那下面這題葡萄糖的分子量到底要填多少",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 50.59,
    "end": 54.63,
    "speaker": "彥君",
    "text": "戰士們這題絕對是經典必考",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 54.83,
    "end": 60.22,
    "speaker": "彥君",
    "text": "葡萄糖的化學式是 $C_6H_{12}O_6$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$C_6H_{12}O_6$"
    ]
  },
  {
    "start": 60.42,
    "end": 64.62,
    "speaker": "彥君",
    "text": "碳是 $12$氫是 $1$氧則是 $16$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 64.82,
    "end": 67.54,
    "speaker": "曉臻",
    "text": "老師這題交給我算",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 67.74,
    "end": 71.26,
    "speaker": "曉臻",
    "text": "$12 \\times 6$加上 $1 \\times 12$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$12 \\times 6$",
      "$1 \\times 12$"
    ]
  },
  {
    "start": 71.46,
    "end": 74.18,
    "speaker": "曉臻",
    "text": "最後再加 $16 \\times 6$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$16 \\times 6$"
    ]
  },
  {
    "start": 74.38,
    "end": 78.18,
    "speaker": "曉臻",
    "text": "全部加起來總共是 $180$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 78.38,
    "end": 80.74,
    "speaker": "彥君",
    "text": "算得太好了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 80.94,
    "end": 200.2,
    "speaker": "彥君",
    "text": "$C_6H_{12}O_6 \\rightarrow 180$",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選",
      "$C_6H_{12}O_6 \\rightarrow 180$"
    ]
  },
  {
    "start": 85.01,
    "end": 89.53,
    "speaker": "彥君",
    "text": "接下來我們要進入真正的理化大魔王",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 89.73,
    "end": 92.95,
    "speaker": "彥君",
    "text": "「莫耳」到底是什麼東西",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 93.15,
    "end": 97.96,
    "speaker": "曉臻",
    "text": "講義上寫 $1$ 莫耳是 $6 \\times 10^{23}$ 個",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$6 \\times 10^{23}$"
    ]
  },
  {
    "start": 98.16,
    "end": 101.98,
    "speaker": "曉臻",
    "text": "天啊這個數字也大得太誇張了吧",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 102.18,
    "end": 107.71,
    "speaker": "彥君",
    "text": "別怕你把它想成「一打」這種單位就好",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 107.91,
    "end": 112.19,
    "speaker": "彥君",
    "text": "一打是 $12$ 個而 $1$ 莫耳就是這麼多個",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 112.39,
    "end": 117.49,
    "speaker": "曉臻",
    "text": "可是老師為什麼科學家要定一個這麼醜的數字啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 117.69,
    "end": 121.08,
    "speaker": "曉臻",
    "text": "難道是為了方便換算重量嗎",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 121.28,
    "end": 125.92,
    "speaker": "彥君",
    "text": "沒錯助教超級聰明",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 126.12,
    "end": 131.62,
    "speaker": "彥君",
    "text": "只要湊齊 $1$ 莫耳的數量原子量就可以直接變成功克",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 131.82,
    "end": 200.2,
    "speaker": "彥君",
    "text": "$1$ 莫耳質量 $=$ 原子量加公克",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選",
      "$1$ 莫耳質量 $=$ 原子量加公克"
    ]
  },
  {
    "start": 136.42,
    "end": 141.98,
    "speaker": "曉臻",
    "text": "喔我徹底懂了碳的原子量是 $12$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 142.18,
    "end": 146.26,
    "speaker": "曉臻",
    "text": "所以 $1$ 莫耳的碳剛好就是 $12$ 克",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 146.46,
    "end": 148.85,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 149.05,
    "end": 153.35,
    "speaker": "彥君",
    "text": "那最後一個空格$1$ 莫耳的氧氣是幾克",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 153.55,
    "end": 158.07,
    "speaker": "曉臻",
    "text": "這太簡單了氧的原子量是 $16$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 158.27,
    "end": 161.93,
    "speaker": "曉臻",
    "text": "所以 $1$ 莫耳的氧氣就是 $16$ 克",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 162.13,
    "end": 165.76,
    "speaker": "彥君",
    "text": "戰士們超級大陷阱來了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 165.96,
    "end": 170.14,
    "speaker": "彥君",
    "text": "仔細看題目問的可是「氧氣」",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 170.34,
    "end": 173.5,
    "speaker": "彥君",
    "text": "氧氣的化學式是 $O_2$ 喔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$O_2$"
    ]
  },
  {
    "start": 173.7,
    "end": 179.22,
    "speaker": "曉臻",
    "text": "啊我差點忘記了氧氣是兩個氧原子結合的",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 179.42,
    "end": 183.25,
    "speaker": "曉臻",
    "text": "所以應該是 $16 \\times 2 = 32$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$16 \\times 2 = 32$"
    ]
  },
  {
    "start": 183.45,
    "end": 186.46,
    "speaker": "曉臻",
    "text": "正確答案是 $32$ 克",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 186.66,
    "end": 192.47,
    "speaker": "彥君",
    "text": "差點被騙了吧大考最愛玩這種文字遊戲",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 192.67,
    "end": 200.2,
    "speaker": "彥君",
    "text": "氧氣 $O_2 \\rightarrow 32$ 克",
    "is_pinned": true,
    "pin_level": 3,
    "commands": [

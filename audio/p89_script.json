[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.38,
    "speaker": "彥君",
    "text": "今天來到 第八十九集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.58,
    "end": 16.31,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.51,
    "end": 18.85,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.05,
    "end": 21.91,
    "speaker": "曉臻",
    "text": "老師 第一行寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.11,
    "end": 24.21,
    "speaker": "曉臻",
    "text": "碳定為 12",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.41,
    "end": 26.86,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.06,
    "end": 29.83,
    "speaker": "彥君",
    "text": "原子 實在太小了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.03,
    "end": 32.85,
    "speaker": "彥君",
    "text": "科學家 就找了碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.05,
    "end": 35.82,
    "speaker": "彥君",
    "text": "當作 比較的標準",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.02,
    "end": 39.1,
    "speaker": "彥君",
    "text": "碳的原子量 定為 12",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.3,
    "end": 42.47,
    "speaker": "曉臻",
    "text": "喔 大家跟碳比",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.67,
    "end": 45.2,
    "speaker": "曉臻",
    "text": "那下面 葡萄糖的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.4,
    "end": 47.86,
    "speaker": "曉臻",
    "text": "分子量 要填多少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.06,
    "end": 50.85,
    "speaker": "彥君",
    "text": "這題 是經典必考",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.05,
    "end": 53.89,
    "speaker": "彥君",
    "text": "葡萄糖的 化學式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.09,
    "end": 57.82,
    "speaker": "彥君",
    "text": "是 $C_6H_{12}O_6$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.02,
    "end": 61.0,
    "speaker": "彥君",
    "text": "碳是 12 氫是 1",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.2,
    "end": 63.7,
    "speaker": "彥君",
    "text": "氧則是 16",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.9,
    "end": 65.64,
    "speaker": "曉臻",
    "text": "我來算",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.84,
    "end": 67.89,
    "speaker": "曉臻",
    "text": "$12 \\times 6$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.09,
    "end": 70.09,
    "speaker": "曉臻",
    "text": "加上 $1 \\times 12$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.29,
    "end": 72.36,
    "speaker": "曉臻",
    "text": "再加 $16 \\times 6$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.56,
    "end": 75.14,
    "speaker": "曉臻",
    "text": "總共 是 180",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.34,
    "end": 77.48,
    "speaker": "彥君",
    "text": "算得好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.68,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$C_6H_{12}O_6 \\rightarrow 180$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 81.75,
    "end": 84.83,
    "speaker": "彥君",
    "text": "接下來 進入大魔王",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 85.03,
    "end": 87.78,
    "speaker": "彥君",
    "text": "莫耳 是什麼東西",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.98,
    "end": 90.26,
    "speaker": "曉臻",
    "text": "上面寫 1 莫耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.46,
    "end": 95.08,
    "speaker": "曉臻",
    "text": "是 $6 \\times 10^{23}$（六乘十的二十三次方） 個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.28,
    "end": 97.74,
    "speaker": "曉臻",
    "text": "數字 也太大了吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.94,
    "end": 100.73,
    "speaker": "彥君",
    "text": "把它 想成一打就好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.93,
    "end": 103.48,
    "speaker": "彥君",
    "text": "一打 是 12 個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.68,
    "end": 106.35,
    "speaker": "彥君",
    "text": "1 莫耳 就是這麼多",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.55,
    "end": 109.32,
    "speaker": "彥君",
    "text": "為什麼 定這個數字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.52,
    "end": 111.98,
    "speaker": "曉臻",
    "text": "為了 換算重量嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.18,
    "end": 116.38,
    "speaker": "彥君",
    "text": "沒錯 湊齊 1 莫耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.58,
    "end": 119.62,
    "speaker": "彥君",
    "text": "原子量 直接變公克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.82,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$1 \\text{mole} \\rightarrow \\text{原子量",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 125.02,
    "end": 128.5,
    "speaker": "曉臻",
    "text": "喔 碳原子量 12",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.7,
    "end": 131.69,
    "speaker": "曉臻",
    "text": "1 莫耳碳 就是 12 克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.89,
    "end": 134.27,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.47,
    "end": 137.29,
    "speaker": "彥君",
    "text": "那最後 一個空格",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.49,
    "end": 140.18,
    "speaker": "彥君",
    "text": "1 莫耳氧氣 幾克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.38,
    "end": 143.1,
    "speaker": "曉臻",
    "text": "氧的原子量 是 16",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.3,
    "end": 145.74,
    "speaker": "曉臻",
    "text": "所以 是 16 克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.94,
    "end": 149.14,
    "speaker": "彥君",
    "text": "戰士們 陷阱來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.34,
    "end": 152.1,
    "speaker": "彥君",
    "text": "題目問的 是氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.3,
    "end": 155.7,
    "speaker": "彥君",
    "text": "氧氣 是 $O_2$（Ｏ兔） 喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.9,
    "end": 159.38,
    "speaker": "曉臻",
    "text": "啊 是兩個氧原子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.58,
    "end": 162.57,
    "speaker": "曉臻",
    "text": "所以 $16 \\times 2 = 32$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.77,
    "end": 165.3,
    "speaker": "曉臻",
    "text": "答案 是 32 克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.5,
    "end": 168.02,
    "speaker": "彥君",
    "text": "差點 被騙了吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.22,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$O_2 \\rightarrow 32\\text{g}$",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 172.66,
    "end": 176.1,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 176.3,
    "end": 178.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 179.1,
    "end": 181.43,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.63,
    "end": 185.12,
    "speaker": "合聲",
    "text": "原子比碳 莫耳換算",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.32,
    "end": 188.86,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.38,
    "speaker": "彥君",
    "text": "今天來到 第八十九集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.58,
    "end": 16.31,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.51,
    "end": 18.85,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.05,
    "end": 21.91,
    "speaker": "曉臻",
    "text": "老師 第一行寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.11,
    "end": 24.21,
    "speaker": "曉臻",
    "text": "碳定為 12",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.41,
    "end": 26.86,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.06,
    "end": 29.83,
    "speaker": "彥君",
    "text": "原子 實在太小了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.03,
    "end": 32.85,
    "speaker": "彥君",
    "text": "科學家 就找了碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.05,
    "end": 35.82,
    "speaker": "彥君",
    "text": "當作 比較的標準",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.02,
    "end": 39.1,
    "speaker": "彥君",
    "text": "碳的原子量 定為 12",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.3,
    "end": 42.47,
    "speaker": "曉臻",
    "text": "喔 大家跟碳比",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.67,
    "end": 45.2,
    "speaker": "曉臻",
    "text": "那下面 葡萄糖的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.4,
    "end": 47.86,
    "speaker": "曉臻",
    "text": "分子量 要填多少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.06,
    "end": 50.85,
    "speaker": "彥君",
    "text": "這題 是經典必考",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.05,
    "end": 53.89,
    "speaker": "彥君",
    "text": "葡萄糖的 化學式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.09,
    "end": 60.77,
    "speaker": "彥君",
    "text": "是 C₆H₁₂O₆（西六、Ｈ十二、Ｏ六）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.97,
    "end": 63.95,
    "speaker": "彥君",
    "text": "碳是 12 氫是 1",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.15,
    "end": 66.66,
    "speaker": "彥君",
    "text": "氧則是 16",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.86,
    "end": 68.59,
    "speaker": "曉臻",
    "text": "我來算",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.79,
    "end": 73.41,
    "speaker": "曉臻",
    "text": "12 × 6（十二乘六）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.61,
    "end": 78.49,
    "speaker": "曉臻",
    "text": "加上 1 × 12（一乘十二）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.69,
    "end": 83.66,
    "speaker": "曉臻",
    "text": "再加 16 × 6（十六乘六）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.86,
    "end": 86.44,
    "speaker": "曉臻",
    "text": "總共 是 180",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.64,
    "end": 88.78,
    "speaker": "彥君",
    "text": "算得好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.98,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "C₆H₁₂O₆ → 180",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 93.06,
    "end": 96.14,
    "speaker": "彥君",
    "text": "接下來 進入大魔王",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.34,
    "end": 99.08,
    "speaker": "彥君",
    "text": "莫耳 是什麼東西",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.28,
    "end": 101.57,
    "speaker": "曉臻",
    "text": "上面寫 1 莫耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.77,
    "end": 107.56,
    "speaker": "曉臻",
    "text": "是 6 × 10²³（六乘十的二十三次方） 個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.76,
    "end": 110.22,
    "speaker": "曉臻",
    "text": "數字 也太大了吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 110.42,
    "end": 113.21,
    "speaker": "彥君",
    "text": "把它 想成一打就好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.41,
    "end": 115.96,
    "speaker": "彥君",
    "text": "一打 是 12 個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.16,
    "end": 118.83,
    "speaker": "彥君",
    "text": "1 莫耳 就是這麼多",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.03,
    "end": 121.8,
    "speaker": "彥君",
    "text": "為什麼 定這個數字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.0,
    "end": 124.46,
    "speaker": "曉臻",
    "text": "為了 換算重量嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.66,
    "end": 128.86,
    "speaker": "彥君",
    "text": "沒錯 湊齊 1 莫耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.06,
    "end": 132.1,
    "speaker": "彥君",
    "text": "原子量 直接變公克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.3,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[1 mole → \\text{原子量",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 138.05,
    "end": 141.54,
    "speaker": "曉臻",
    "text": "喔 碳原子量 12",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.74,
    "end": 144.72,
    "speaker": "曉臻",
    "text": "1 莫耳碳 就是 12 克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.92,
    "end": 147.3,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.5,
    "end": 150.32,
    "speaker": "彥君",
    "text": "那最後 一個空格",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.52,
    "end": 153.22,
    "speaker": "彥君",
    "text": "1 莫耳氧氣 幾克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.42,
    "end": 156.14,
    "speaker": "曉臻",
    "text": "氧的原子量 是 16",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.34,
    "end": 158.77,
    "speaker": "曉臻",
    "text": "所以 是 16 克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.97,
    "end": 162.17,
    "speaker": "彥君",
    "text": "戰士們 陷阱來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.37,
    "end": 165.14,
    "speaker": "彥君",
    "text": "題目問的 是氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.34,
    "end": 169.81,
    "speaker": "彥君",
    "text": "氧氣 是 O₂（Ｏ兔） 喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.01,
    "end": 173.5,
    "speaker": "曉臻",
    "text": "啊 是兩個氧原子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.7,
    "end": 180.28,
    "speaker": "曉臻",
    "text": "所以 16 × 2 = 32（十六乘二等於三十二）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 180.48,
    "end": 183.01,
    "speaker": "曉臻",
    "text": "答案 是 32 克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 183.21,
    "end": 185.74,
    "speaker": "彥君",
    "text": "差點 被騙了吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.94,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "O₂ → 32g",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 190.37,
    "end": 193.81,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 194.01,
    "end": 196.61,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 196.81,
    "end": 199.14,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 199.34,
    "end": 202.83,
    "speaker": "合聲",
    "text": "原子比碳 莫耳換算",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 203.03,
    "end": 206.57,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }

  {
    "start": 5.17,
    "end": 7.62,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 7.82,
    "end": 10.42,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 10.62,
    "end": 13.92,
    "speaker": "彥君",
    "text": "今天來到 第七十六集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.12,
    "end": 15.86,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.06,
    "end": 18.39,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.59,
    "end": 21.5,
    "speaker": "曉臻",
    "text": "老師 今天的圖上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.7,
    "end": 24.42,
    "speaker": "曉臻",
    "text": "有好多條 線跟角喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.62,
    "end": 28.04,
    "speaker": "彥君",
    "text": "戰士們， 拿出螢光筆！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.24,
    "end": 31.03,
    "speaker": "彥君",
    "text": "遇到折射 第一步",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.23,
    "end": 34.17,
    "speaker": "彥君",
    "text": "先把虛線 畫出來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.37,
    "end": 37.18,
    "speaker": "曉臻",
    "text": "虛線 就是法線對吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.38,
    "end": 41.66,
    "speaker": "彥君",
    "text": "沒錯 所有的角度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.86,
    "end": 44.46,
    "speaker": "彥君",
    "text": "都要跟 法線來夾",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.66,
    "end": 47.94,
    "speaker": "彥君",
    "text": "入射線 跟法線的夾角",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.14,
    "end": 50.62,
    "speaker": "彥君",
    "text": "就是 入射角",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.82,
    "end": 54.11,
    "speaker": "彥君",
    "text": "折射線 跟法線的夾角",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.31,
    "end": 56.82,
    "speaker": "彥君",
    "text": "就是 折射角",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.02,
    "end": 59.81,
    "speaker": "曉臻",
    "text": "絕對不能 跟界面夾喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.01,
    "end": 63.69,
    "speaker": "彥君",
    "text": "沒錯 這是必考陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.89,
    "end": 66.78,
    "speaker": "曉臻",
    "text": "老師 那旁邊寫的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.98,
    "end": 69.67,
    "speaker": "曉臻",
    "text": "大角快、 小角慢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.87,
    "end": 72.18,
    "speaker": "曉臻",
    "text": "是什麼 意思啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.38,
    "end": 74.89,
    "speaker": "彥君",
    "text": "折射 是因為",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.09,
    "end": 77.74,
    "speaker": "彥君",
    "text": "光的速度 改變了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.94,
    "end": 81.45,
    "speaker": "彥君",
    "text": "戰士們， 記住這個訣竅！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.65,
    "end": 84.3,
    "speaker": "彥君",
    "text": "角度越大的 地方",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.5,
    "end": 87.19,
    "speaker": "彥君",
    "text": "代表 光速越快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.39,
    "end": 90.04,
    "speaker": "彥君",
    "text": "角度越小的 地方",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.24,
    "end": 92.86,
    "speaker": "彥君",
    "text": "代表 光速越慢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.06,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{大角} \\rightarrow \\text{速度快}",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 96.68,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{小角} \\rightarrow \\text{速度慢}",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 100.01,
    "end": 103.33,
    "speaker": "曉臻",
    "text": "哇 所以看角度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.53,
    "end": 105.98,
    "speaker": "曉臻",
    "text": "就能比 速度大小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.18,
    "end": 109.14,
    "speaker": "彥君",
    "text": "右邊 切三層的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.34,
    "end": 112.14,
    "speaker": "彥君",
    "text": "你看 哪一層最快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.34,
    "end": 114.91,
    "speaker": "曉臻",
    "text": "先畫法線 比一比",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.11,
    "end": 117.76,
    "speaker": "曉臻",
    "text": "最下面的 角度最大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.96,
    "end": 120.58,
    "speaker": "曉臻",
    "text": "所以 最下面最快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.78,
    "end": 124.92,
    "speaker": "彥君",
    "text": "漂亮 完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.12,
    "end": 127.72,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 127.92,
    "end": 130.26,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.46,
    "end": 133.87,
    "speaker": "合聲",
    "text": "法線為伴 大快小慢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.07,
    "end": 137.61,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }

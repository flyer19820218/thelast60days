    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 11.94,
    "end": 15.24,
    "speaker": "彥君",
    "text": "歡迎來到第八十六集",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 15.44,
    "end": 18.98,
    "speaker": "彥君",
    "text": "這次我們要解密原子與離子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 19.18,
    "end": 22.71,
    "speaker": "曉臻",
    "text": "老師這張投影片的標題",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 22.91,
    "end": 26.14,
    "speaker": "曉臻",
    "text": "旁邊打了整整五顆星星耶",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 26.34,
    "end": 30.64,
    "speaker": "彥君",
    "text": "戰士們注意這絕對是必考神題",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 30.84,
    "end": 34.14,
    "speaker": "彥君",
    "text": "我們先來看什麼是質量數",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 34.34,
    "end": 38.71,
    "speaker": "彥君",
    "text": "原子的重量全部集中在原子核",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 38.91,
    "end": 43.02,
    "speaker": "彥君",
    "text": "質量數就等於質子加上中子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 43.22,
    "end": 200.19,
    "speaker": "彥君",
    "text": "質量數 $$=$$ 質子 $$+$$ 中子",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選",
      "質量數 $$=$$ 質子 $$+$$ 中子"
    ]
  },
  {
    "start": 46.77,
    "end": 51.14,
    "speaker": "曉臻",
    "text": "喔因為外圍的電子實在太輕了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 51.34,
    "end": 54.86,
    "speaker": "曉臻",
    "text": "所以重量就可以忽略不計對吧",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 55.06,
    "end": 59.77,
    "speaker": "彥君",
    "text": "沒錯助教的觀念非常好",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 59.97,
    "end": 63.19,
    "speaker": "彥君",
    "text": "接著我們來看什麼是離子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 63.39,
    "end": 67.65,
    "speaker": "彥君",
    "text": "正常的原子本身都是電中性的",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 67.85,
    "end": 71.77,
    "speaker": "曉臻",
    "text": "也就是質子數剛好等於電子數",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 71.97,
    "end": 76.85,
    "speaker": "彥君",
    "text": "對但是原子有時候會交朋友",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 77.05,
    "end": 80.58,
    "speaker": "彥君",
    "text": "身上的電子就會跑來跑去",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 80.78,
    "end": 84.42,
    "speaker": "彥君",
    "text": "戰士們超級大陷阱來了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 84.62,
    "end": 88.63,
    "speaker": "彥君",
    "text": "會跑來跑去的永遠只有電子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 88.83,
    "end": 92.42,
    "speaker": "彥君",
    "text": "中間的質子是絕對不會動的",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 92.62,
    "end": 95.72,
    "speaker": "曉臻",
    "text": "為什麼質子不能跟著動啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 95.92,
    "end": 98.64,
    "speaker": "彥君",
    "text": "因為質子一旦動了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 98.84,
    "end": 102.33,
    "speaker": "彥君",
    "text": "它就直接變成別種元素啦",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 102.53,
    "end": 104.55,
    "speaker": "曉臻",
    "text": "原來如此",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 104.75,
    "end": 108.0,
    "speaker": "曉臻",
    "text": "所以原子如果失去了電子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 108.2,
    "end": 111.74,
    "speaker": "曉臻",
    "text": "負電變少它就變成陽離子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 111.94,
    "end": 114.32,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 114.52,
    "end": 117.79,
    "speaker": "彥君",
    "text": "反過來如果得到了電子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 117.99,
    "end": 121.65,
    "speaker": "彥君",
    "text": "負電變多它就變成陰離子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 121.85,
    "end": 200.19,
    "speaker": "彥君",
    "text": "失電子 $$\\rightarrow$$ 陽離子，得電子 $$\\rightarrow$$ 陰離子",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選",
      "失電子 $$\\rightarrow$$ 陽離子，得電子 $$\\rightarrow$$ 陰離子"
    ]
  },
  {
    "start": 126.74,
    "end": 130.66,
    "speaker": "彥君",
    "text": "觀念有了我們直接來解這題",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 130.86,
    "end": 134.61,
    "speaker": "曉臻",
    "text": "題目是鎂離子代號 $$Mg^{2+}$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$$Mg^{2+}$$"
    ]
  },
  {
    "start": 134.81,
    "end": 137.7,
    "speaker": "曉臻",
    "text": "它的原子序寫著十二",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 137.9,
    "end": 142.06,
    "speaker": "彥君",
    "text": "原子序就像是元素的身分證",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 142.26,
    "end": 146.3,
    "speaker": "彥君",
    "text": "這代表它的質子剛好有十二個",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 146.5,
    "end": 149.43,
    "speaker": "曉臻",
    "text": "那中子的數量要怎麼算",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 149.63,
    "end": 153.02,
    "speaker": "彥君",
    "text": "題目給的質量數是二十四",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 153.22,
    "end": 156.98,
    "speaker": "彥君",
    "text": "減掉剛剛算出來的十二個質子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 157.18,
    "end": 160.98,
    "speaker": "彥君",
    "text": "剩下的十二當然就是中子啦",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 161.18,
    "end": 164.78,
    "speaker": "曉臻",
    "text": "最後是最容易錯的電子數",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 164.98,
    "end": 167.8,
    "speaker": "曉臻",
    "text": "鎂的右上角寫著 $$2+$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$$2+$$"
    ]
  },
  {
    "start": 168.0,
    "end": 171.63,
    "speaker": "彥君",
    "text": "戰士們這個 $$2+$$ 代表什麼",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$$2+$$"
    ]
  },
  {
    "start": 171.83,
    "end": 175.42,
    "speaker": "曉臻",
    "text": "代表它失去了兩個帶負電的電子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 175.62,
    "end": 177.66,
    "speaker": "彥君",
    "text": "漂亮",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 177.86,
    "end": 181.64,
    "speaker": "彥君",
    "text": "所以原本應該要有十二個電子",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 181.84,
    "end": 185.88,
    "speaker": "彥君",
    "text": "扣掉跑掉的兩個就只剩下十個",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 186.08,
    "end": 200.19,
    "speaker": "彥君",
    "text": "$$Mg^{2+} \\rightarrow$$ 電子剩下 $$10$$ 個",
    "is_pinned": true,
    "pin_level": 3,
    "commands": [
      "釘選",
      "$$Mg^{2+} \\rightarrow$$ 電子剩下 $$10$$ 個"
    ]
  },
  {
    "start": 190.1,
    "end": 193.9,
    "speaker": "曉臻",
    "text": "哇這樣一步一步跟著解",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 194.1,
    "end": 196.99,
    "speaker": "曉臻",
    "text": "邏輯真的超級清楚耶",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {

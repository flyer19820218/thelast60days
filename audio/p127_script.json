[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.12,
    "speaker": "彥君",
    "text": "第 127 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.32,
    "end": 9.38,
    "speaker": "彥君",
    "text": "人生 就像一塊磁鐵",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.58,
    "end": 12.54,
    "speaker": "彥君",
    "text": "只要 你的核心不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.74,
    "end": 15.77,
    "speaker": "彥君",
    "text": "就能 吸引對的人事物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.97,
    "end": 18.57,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.77,
    "end": 20.5,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.7,
    "end": 23.04,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.24,
    "end": 25.7,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.9,
    "end": 28.71,
    "speaker": "彥君",
    "text": "磁場 基本功來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.91,
    "end": 31.73,
    "speaker": "曉臻",
    "text": "老師 所有的金屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.93,
    "end": 34.43,
    "speaker": "曉臻",
    "text": "都能 變成磁鐵嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.63,
    "end": 38.79,
    "speaker": "彥君",
    "text": "不行喔 只有這三種",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.99,
    "end": 42.07,
    "speaker": "彥君",
    "text": "鐵、 鈷、 鎳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.27,
    "end": 45.4,
    "speaker": "彥君",
    "text": "它們 才是磁化三劍客",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.6,
    "end": 62.9,
    "speaker": "彥君",
    "text": "$\\text{磁化三劍客} \\rightarrow \\text{鐵、 鈷、 鎳}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 50.99,
    "end": 53.5,
    "speaker": "曉臻",
    "text": "那黃金 或鋁罐呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.7,
    "end": 56.54,
    "speaker": "彥君",
    "text": "完全 不會被磁化喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.74,
    "end": 59.7,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘記憶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.9,
    "end": 65.98,
    "speaker": "曉臻",
    "text": "老師 磁鐵的磁力線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.18,
    "end": 68.99,
    "speaker": "曉臻",
    "text": "為什麼 都是從Ｎ出發",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.19,
    "end": 71.98,
    "speaker": "彥君",
    "text": "因為 物理學定義",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.18,
    "end": 75.02,
    "speaker": "彥君",
    "text": "Ｎ極 所指的方向",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.22,
    "end": 77.99,
    "speaker": "彥君",
    "text": "就是 磁場的方向",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.19,
    "end": 110.98,
    "speaker": "彥君",
    "text": "$\\text{Ｎ極方向} \\rightarrow \\text{磁場方向}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 82.48,
    "end": 85.15,
    "speaker": "曉臻",
    "text": "圖上 越靠近磁極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 85.35,
    "end": 87.93,
    "speaker": "曉臻",
    "text": "線 畫得越密集耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.13,
    "end": 92.98,
    "speaker": "彥君",
    "text": "沒錯 越密代表磁場越強",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.18,
    "end": 96.1,
    "speaker": "彥君",
    "text": "而且 每一點的切線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.3,
    "end": 99.4,
    "speaker": "彥君",
    "text": "就是 該點的磁場方向",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.6,
    "end": 110.98,
    "speaker": "彥君",
    "text": "$\\text{密則強， 切線為方向}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 104.56,
    "end": 107.78,
    "speaker": "彥君",
    "text": "戰士們 趕快抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 110.98,
    "end": 113.8,
    "speaker": "曉臻",
    "text": "老師 來看右邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.0,
    "end": 116.86,
    "speaker": "曉臻",
    "text": "地球 也是一顆大磁鐵",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.06,
    "end": 119.74,
    "speaker": "曉臻",
    "text": "但 為什麼地磁北極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.94,
    "end": 122.61,
    "speaker": "曉臻",
    "text": "畫在 地理南極旁邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.81,
    "end": 125.94,
    "speaker": "彥君",
    "text": "這是 必考的最強陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.14,
    "end": 128.86,
    "speaker": "彥君",
    "text": "地理 北極的附近",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.06,
    "end": 132.14,
    "speaker": "彥君",
    "text": "其實 是磁鐵的Ｓ極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.34,
    "end": 135.7,
    "speaker": "曉臻",
    "text": "喔 因為異性相吸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.9,
    "end": 138.26,
    "speaker": "曉臻",
    "text": "指北針 的Ｎ極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.46,
    "end": 141.33,
    "speaker": "曉臻",
    "text": "才會 被地理北極吸引",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.53,
    "end": 146.1,
    "speaker": "彥君",
    "text": "聰明 所以地磁北極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.3,
    "end": 149.38,
    "speaker": "彥君",
    "text": "其實 是在地理南極喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.58,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{地理北極} \\approx \\text{地磁Ｓ極}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 154.2,
    "end": 157.64,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.84,
    "end": 160.44,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.64,
    "end": 162.98,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 163.18,
    "end": 166.62,
    "speaker": "合聲",
    "text": "鐵鈷鎳三 Ｎ極指北",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 166.82,
    "end": 170.35,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
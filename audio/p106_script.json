[
  {
    "start": 0.0,
    "end": 3.27,
    "speaker": "彥君",
    "text": "戰士們 歡迎回到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.47,
    "end": 6.34,
    "speaker": "彥君",
    "text": "液體壓力的 下半場",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.54,
    "end": 9.14,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.34,
    "end": 11.07,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.27,
    "end": 13.61,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.81,
    "end": 16.26,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.46,
    "end": 19.33,
    "speaker": "彥君",
    "text": "上一集 我們學到了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.53,
    "end": 22.7,
    "speaker": "彥君",
    "text": "壓力 是由深度決定的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.9,
    "end": 25.82,
    "speaker": "曉臻",
    "text": "老師 左邊這張圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.02,
    "end": 28.69,
    "speaker": "曉臻",
    "text": "有好多 紅色的箭頭",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.89,
    "end": 32.23,
    "speaker": "彥君",
    "text": "仔細看 這些箭頭的方向",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.43,
    "end": 35.44,
    "speaker": "彥君",
    "text": "不管物體 怎麼傾斜",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.64,
    "end": 38.96,
    "speaker": "彥君",
    "text": "箭頭 永遠垂直於表面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.16,
    "end": 99.19,
    "speaker": "彥君",
    "text": "$\\text{液體壓力} \\rightarrow \\text{垂直於表面}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 43.4,
    "end": 46.96,
    "speaker": "曉臻",
    "text": "真的耶 都是 90 度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.16,
    "end": 49.78,
    "speaker": "曉臻",
    "text": "而且 越下面的箭頭",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.98,
    "end": 52.18,
    "speaker": "曉臻",
    "text": "畫得 越長耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.38,
    "end": 55.58,
    "speaker": "彥君",
    "text": "這就是 我們的核心觀念",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.78,
    "end": 58.38,
    "speaker": "彥君",
    "text": "因為 越深的地方",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.58,
    "end": 61.85,
    "speaker": "彥君",
    "text": "上方壓著的 水就越重",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.05,
    "end": 65.01,
    "speaker": "彥君",
    "text": "所以 壓力就會越大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.21,
    "end": 99.19,
    "speaker": "彥君",
    "text": "$\\text{深度越深} \\rightarrow \\text{壓力越大}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 69.4,
    "end": 72.48,
    "speaker": "曉臻",
    "text": "老師 那水庫的水壩",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.68,
    "end": 75.64,
    "speaker": "曉臻",
    "text": "底下承受的 壓力超大吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.84,
    "end": 80.36,
    "speaker": "彥君",
    "text": "沒錯 為了防止被衝垮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.56,
    "end": 83.11,
    "speaker": "彥君",
    "text": "水壩的底部",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.31,
    "end": 86.06,
    "speaker": "彥君",
    "text": "一定要 蓋得特別厚",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.26,
    "end": 89.62,
    "speaker": "彥君",
    "text": "呈現 上窄下寬的形狀",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.82,
    "end": 92.74,
    "speaker": "曉臻",
    "text": "原來 建築也充滿物理",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.94,
    "end": 95.99,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘看圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.19,
    "end": 102.06,
    "speaker": "彥君",
    "text": "接下來 看到右邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.26,
    "end": 105.46,
    "speaker": "彥君",
    "text": "這是必考的 連通管原理",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.66,
    "end": 108.57,
    "speaker": "曉臻",
    "text": "這些管子 長得好奇怪",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.77,
    "end": 111.63,
    "speaker": "曉臻",
    "text": "有粗有細 還有彎曲的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.83,
    "end": 114.96,
    "speaker": "曉臻",
    "text": "可是 水面竟然都一樣高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.16,
    "end": 117.9,
    "speaker": "彥君",
    "text": "這就是 水的魔法",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.1,
    "end": 120.97,
    "speaker": "彥君",
    "text": "只要 底部互相連通",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.17,
    "end": 124.03,
    "speaker": "彥君",
    "text": "裝著 同一種液體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.23,
    "end": 126.62,
    "speaker": "彥君",
    "text": "靜止的時候",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.82,
    "end": 130.11,
    "speaker": "彥君",
    "text": "水面 一定會保持齊平",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.31,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{連通管} \\rightarrow \\text{水面等高}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 134.58,
    "end": 136.96,
    "speaker": "曉臻",
    "text": "為什麼 會這樣啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.16,
    "end": 140.34,
    "speaker": "彥君",
    "text": "這是為了 維持力平衡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.54,
    "end": 143.62,
    "speaker": "彥君",
    "text": "每個管子 底部的壓力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.82,
    "end": 146.58,
    "speaker": "彥君",
    "text": "必須 要一模一樣大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.78,
    "end": 149.91,
    "speaker": "彥君",
    "text": "我們剛剛說 壓力看什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.11,
    "end": 152.86,
    "speaker": "曉臻",
    "text": "壓力 只看垂直深度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.06,
    "end": 158.01,
    "speaker": "彥君",
    "text": "答對了 所以深度必須相同",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.21,
    "end": 161.02,
    "speaker": "彥君",
    "text": "水面 才會一樣高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.22,
    "end": 164.62,
    "speaker": "曉臻",
    "text": "哇 跟管子的形狀",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.82,
    "end": 167.46,
    "speaker": "曉臻",
    "text": "一點 關係都沒有耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 167.66,
    "end": 172.3,
    "speaker": "彥君",
    "text": "沒錯 像是家裡的茶壺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 172.5,
    "end": 175.25,
    "speaker": "彥君",
    "text": "或是 頂樓的水塔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.45,
    "end": 178.22,
    "speaker": "彥君",
    "text": "都是 連通管的應用喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 178.42,
    "end": 182.0,
    "speaker": "彥君",
    "text": "圖形看懂 陷阱全破",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 182.2,
    "end": 185.64,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.84,
    "end": 188.44,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 188.64,
    "end": 190.98,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 191.18,
    "end": 194.76,
    "speaker": "合聲",
    "text": "垂直作用 連通齊平",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 194.96,
    "end": 198.5,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
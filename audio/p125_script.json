[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.12,
    "speaker": "彥君",
    "text": "第 125 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.32,
    "end": 9.35,
    "speaker": "彥君",
    "text": "人生 就像一個電阻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.55,
    "end": 12.61,
    "speaker": "彥君",
    "text": "雖然 會有重重阻礙",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.81,
    "end": 15.82,
    "speaker": "彥君",
    "text": "但就是 因為有電阻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.02,
    "end": 19.1,
    "speaker": "彥君",
    "text": "燈泡 才會發出光芒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.3,
    "end": 21.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.1,
    "end": 23.83,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.03,
    "end": 26.37,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.57,
    "end": 29.02,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.22,
    "end": 32.57,
    "speaker": "彥君",
    "text": "今天要 認識電學三劍客",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.77,
    "end": 35.75,
    "speaker": "曉臻",
    "text": "老師 第一個是電流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.95,
    "end": 38.77,
    "speaker": "曉臻",
    "text": "為什麼 安培計要串聯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.97,
    "end": 42.55,
    "speaker": "彥君",
    "text": "電流 就像水流或是車流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.75,
    "end": 46.0,
    "speaker": "彥君",
    "text": "要算 每秒鐘過去幾台車",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.2,
    "end": 49.47,
    "speaker": "彥君",
    "text": "計數器 必須裝在路中間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.67,
    "end": 52.68,
    "speaker": "彥君",
    "text": "這就是 所謂的串聯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.88,
    "end": 86.36,
    "speaker": "彥君",
    "text": "$\\text{電流 } I \\rightarrow \\text{安培計串聯}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 57.43,
    "end": 59.7,
    "speaker": "曉臻",
    "text": "那第二個電壓",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.9,
    "end": 62.76,
    "speaker": "曉臻",
    "text": "伏特計 為什麼要並聯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.96,
    "end": 66.18,
    "speaker": "彥君",
    "text": "電壓 是推動電流的能力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.38,
    "end": 69.39,
    "speaker": "彥君",
    "text": "就像 瀑布的高度落差",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.59,
    "end": 72.67,
    "speaker": "彥君",
    "text": "我們要 跨過去量高低差",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.87,
    "end": 75.83,
    "speaker": "彥君",
    "text": "所以 伏特計要並聯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.03,
    "end": 86.36,
    "speaker": "彥君",
    "text": "$\\text{電壓 } V \\rightarrow \\text{伏特計並聯}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 80.22,
    "end": 83.16,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘思考",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.36,
    "end": 89.03,
    "speaker": "曉臻",
    "text": "最後 第三點是電阻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.23,
    "end": 92.17,
    "speaker": "曉臻",
    "text": "歐姆定律 $V=I \\times R$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.37,
    "end": 96.89,
    "speaker": "彥君",
    "text": "沒錯 這是電學大絕招",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.09,
    "end": 100.65,
    "speaker": "彥君",
    "text": "戰士們 換你們動手畫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.85,
    "end": 104.0,
    "speaker": "彥君",
    "text": "把左邊 亂糟糟的實物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.2,
    "end": 107.64,
    "speaker": "彥君",
    "text": "變成 右邊整齊的電路圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.84,
    "end": 110.99,
    "speaker": "曉臻",
    "text": "老師 實物圖的電池",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.19,
    "end": 113.65,
    "speaker": "曉臻",
    "text": "在電路圖 怎麼畫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.85,
    "end": 118.34,
    "speaker": "彥君",
    "text": "記住口訣 長正短負",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.54,
    "end": 122.54,
    "speaker": "彥君",
    "text": "長的線是正極 短的是負極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.74,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{電池} \\rightarrow \\text{長正短負}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 127.72,
    "end": 130.37,
    "speaker": "曉臻",
    "text": "那如果是 電阻器呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.57,
    "end": 133.84,
    "speaker": "彥君",
    "text": "畫一條 鋸齒狀的折線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.04,
    "end": 137.17,
    "speaker": "彥君",
    "text": "就像 崎嶇不平的馬路",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.37,
    "end": 140.54,
    "speaker": "曉臻",
    "text": "圓圈裡面 寫個 A 或 V",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.74,
    "end": 143.7,
    "speaker": "曉臻",
    "text": "就是 安培計或伏特計",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.9,
    "end": 148.35,
    "speaker": "彥君",
    "text": "漂亮 快把這兩張圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.55,
    "end": 151.68,
    "speaker": "彥君",
    "text": "畫在 講義的白框框裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.88,
    "end": 155.32,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.52,
    "end": 158.12,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.32,
    "end": 160.66,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.86,
    "end": 164.25,
    "speaker": "合聲",
    "text": "串聯安培 並聯伏特",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.45,
    "end": 167.98,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.22,
    "speaker": "彥君",
    "text": "直線運動的 世界",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.42,
    "end": 9.02,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.22,
    "end": 10.95,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.15,
    "end": 13.49,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.69,
    "end": 16.34,
    "speaker": "彥君",
    "text": "[戰士們注意 ]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.54,
    "end": 19.71,
    "speaker": "彥君",
    "text": "這一集 是大考送分題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.91,
    "end": 23.06,
    "speaker": "彥君",
    "text": "絕對不能 在這裡失血",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.26,
    "end": 26.25,
    "speaker": "曉臻",
    "text": "老師 第一個是位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.45,
    "end": 29.41,
    "speaker": "曉臻",
    "text": "跟路徑長 有什麼不一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.61,
    "end": 33.02,
    "speaker": "彥君",
    "text": "想像你 從家裡走到學校",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.22,
    "end": 36.66,
    "speaker": "彥君",
    "text": "實際走過的 腳印總長度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.86,
    "end": 39.61,
    "speaker": "彥君",
    "text": "就是 你的路徑長",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.81,
    "end": 70.75,
    "speaker": "彥君",
    "text": "[$\\text{路徑長} \\rightarrow \\text{走過的實際距離}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 44.29,
    "end": 46.19,
    "speaker": "曉臻",
    "text": "那位移呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.39,
    "end": 49.74,
    "speaker": "彥君",
    "text": "位移 是直接拉一條直線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.94,
    "end": 53.18,
    "speaker": "彥君",
    "text": "從起點 直接指向終點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.38,
    "end": 56.51,
    "speaker": "彥君",
    "text": "記得 它是包含方向的喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.71,
    "end": 70.75,
    "speaker": "彥君",
    "text": "[$\\text{位移} \\rightarrow \\text{起點到終點直線}$]",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 61.05,
    "end": 64.92,
    "speaker": "曉臻",
    "text": "原來如此 腳印是路徑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.12,
    "end": 67.55,
    "speaker": "曉臻",
    "text": "直線 就是位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.75,
    "end": 71.0,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘抄寫]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.2,
    "end": 74.3,
    "speaker": "彥君",
    "text": "接下來 講速度跟速率",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.5,
    "end": 77.87,
    "speaker": "曉臻",
    "text": "老師 平均速度跟速率",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.07,
    "end": 80.65,
    "speaker": "曉臻",
    "text": "聽起來 根本一樣啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.85,
    "end": 83.78,
    "speaker": "彥君",
    "text": "只要 看到「度」這個字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.98,
    "end": 86.92,
    "speaker": "彥君",
    "text": "它就跟 方向有關係",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.12,
    "end": 90.44,
    "speaker": "彥君",
    "text": "所以 速度要用位移去算",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.64,
    "end": 111.12,
    "speaker": "彥君",
    "text": "[$\\text{平均速度} \\rightarrow \\frac{\\text{位移}}{\\text{時間}}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 94.74,
    "end": 97.6,
    "speaker": "曉臻",
    "text": "那「速率」沒有方向",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.8,
    "end": 100.64,
    "speaker": "曉臻",
    "text": "就是用 路徑長去算囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.84,
    "end": 103.51,
    "speaker": "彥君",
    "text": "助教 舉一反三喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.71,
    "end": 111.12,
    "speaker": "彥君",
    "text": "[$\\text{平均速率} \\rightarrow \\frac{\\text{路徑長}}{\\text{時間}}$]",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 108.12,
    "end": 111.61,
    "speaker": "彥君",
    "text": "[戰士們 換下一組]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.81,
    "end": 115.27,
    "speaker": "曉臻",
    "text": "老師 那瞬時是什麼意思",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.47,
    "end": 118.82,
    "speaker": "彥君",
    "text": "瞬時 就是看測速照相",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.02,
    "end": 121.93,
    "speaker": "彥君",
    "text": "被拍到的 那一個瞬間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.13,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$\\text{瞬時} \\rightarrow \\text{特定的時間點}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 126.9,
    "end": 129.54,
    "speaker": "曉臻",
    "text": "最後一個 是軌跡圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.74,
    "end": 132.78,
    "speaker": "曉臻",
    "text": "加速度運動 長什麼樣子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.98,
    "end": 136.32,
    "speaker": "彥君",
    "text": "想像 打點計時器的紙帶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.52,
    "end": 139.53,
    "speaker": "彥君",
    "text": "只要 點跟點的距離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.73,
    "end": 142.93,
    "speaker": "彥君",
    "text": "越來越大 越拉越開",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.13,
    "end": 146.33,
    "speaker": "彥君",
    "text": "代表 車子正在加速中",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.53,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$\\text{加速度} \\rightarrow \\text{點的間距改變}$]",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 151.15,
    "end": 154.59,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.79,
    "end": 157.39,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.59,
    "end": 159.93,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.13,
    "end": 163.5,
    "speaker": "合聲",
    "text": "腳印路徑 直線位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 163.7,
    "end": 167.23,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
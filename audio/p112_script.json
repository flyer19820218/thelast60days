[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.22,
    "speaker": "彥君",
    "text": "直線運動的 世界",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.42,
    "end": 9.02,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.22,
    "end": 10.95,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.15,
    "end": 13.49,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.69,
    "end": 16.14,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.34,
    "end": 19.52,
    "speaker": "彥君",
    "text": "這一集 是大考送分題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.72,
    "end": 22.87,
    "speaker": "彥君",
    "text": "絕對不能 在這裡失血",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.07,
    "end": 26.06,
    "speaker": "曉臻",
    "text": "老師 第一個是位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.26,
    "end": 29.22,
    "speaker": "曉臻",
    "text": "跟路徑長 有什麼不一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.42,
    "end": 32.83,
    "speaker": "彥君",
    "text": "想像你 從家裡走到學校",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.03,
    "end": 36.47,
    "speaker": "彥君",
    "text": "實際走過的 腳印總長度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.67,
    "end": 39.42,
    "speaker": "彥君",
    "text": "就是 你的路徑長",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.62,
    "end": 73.74,
    "speaker": "彥君",
    "text": "$\\text{路徑長} \\rightarrow \\text{走過的實際距離}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 44.1,
    "end": 46.0,
    "speaker": "曉臻",
    "text": "那位移呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.2,
    "end": 49.54,
    "speaker": "彥君",
    "text": "位移 是直接拉一條直線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.74,
    "end": 52.99,
    "speaker": "彥君",
    "text": "從起點 直接指向終點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.19,
    "end": 56.32,
    "speaker": "彥君",
    "text": "記得 它是包含方向的喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.52,
    "end": 73.74,
    "speaker": "彥君",
    "text": "$\\text{位移} \\rightarrow \\text{起點到終點直線}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 60.86,
    "end": 64.73,
    "speaker": "曉臻",
    "text": "原來如此 腳印是路徑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.93,
    "end": 67.36,
    "speaker": "曉臻",
    "text": "直線 就是位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.56,
    "end": 70.54,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.74,
    "end": 76.85,
    "speaker": "彥君",
    "text": "接下來 講速度跟速率",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.05,
    "end": 80.42,
    "speaker": "曉臻",
    "text": "老師 平均速度跟速率",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.62,
    "end": 83.19,
    "speaker": "曉臻",
    "text": "聽起來 根本一樣啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.39,
    "end": 86.33,
    "speaker": "彥君",
    "text": "只要 看到「度」這個字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.53,
    "end": 89.46,
    "speaker": "彥君",
    "text": "它就跟 方向有關係",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.66,
    "end": 92.98,
    "speaker": "彥君",
    "text": "所以 速度要用位移去算",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.18,
    "end": 117.09,
    "speaker": "彥君",
    "text": "$\\text{平均速度} \\rightarrow \\frac{\\text{位移}}{\\text{時間}}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 97.28,
    "end": 100.14,
    "speaker": "曉臻",
    "text": "那「速率」沒有方向",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.34,
    "end": 103.18,
    "speaker": "曉臻",
    "text": "就是用 路徑長去算囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.38,
    "end": 106.06,
    "speaker": "彥君",
    "text": "助教 舉一反三喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.26,
    "end": 117.09,
    "speaker": "彥君",
    "text": "$\\text{平均速率} \\rightarrow \\frac{\\text{路徑長}}{\\text{時間}}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 110.66,
    "end": 113.89,
    "speaker": "彥君",
    "text": "戰士們 換下一組",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.09,
    "end": 120.55,
    "speaker": "曉臻",
    "text": "老師 那瞬時是什麼意思",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.75,
    "end": 124.1,
    "speaker": "彥君",
    "text": "瞬時 就是看測速照相",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.3,
    "end": 127.21,
    "speaker": "彥君",
    "text": "被拍到的 那一個瞬間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 127.41,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{瞬時} \\rightarrow \\text{特定的時間點}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 132.18,
    "end": 134.82,
    "speaker": "曉臻",
    "text": "最後一個 是軌跡圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.02,
    "end": 138.06,
    "speaker": "曉臻",
    "text": "加速度運動 長什麼樣子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.26,
    "end": 141.6,
    "speaker": "彥君",
    "text": "想像 打點計時器的紙帶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.8,
    "end": 144.81,
    "speaker": "彥君",
    "text": "只要 點跟點的距離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.01,
    "end": 148.21,
    "speaker": "彥君",
    "text": "越來越大 越拉越開",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.41,
    "end": 151.61,
    "speaker": "彥君",
    "text": "代表 車子正在加速中",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.81,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{加速度} \\rightarrow \\text{點的間距改變}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 156.43,
    "end": 159.87,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.07,
    "end": 162.67,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.87,
    "end": 165.21,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.41,
    "end": 168.78,
    "speaker": "合聲",
    "text": "腳印路徑 直線位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.98,
    "end": 172.51,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
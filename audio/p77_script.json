  },
  {
    "start": 11.1,
    "end": 14.35,
    "speaker": "彥君",
    "text": "今天來到 第七十七集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.55,
    "end": 16.29,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.49,
    "end": 18.82,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.02,
    "end": 21.82,
    "speaker": "曉臻",
    "text": "老師 今天的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.02,
    "end": 24.88,
    "speaker": "曉臻",
    "text": "是不同形狀的 透鏡耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.08,
    "end": 29.26,
    "speaker": "彥君",
    "text": "沒錯 判斷透鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.46,
    "end": 32.21,
    "speaker": "彥君",
    "text": "有一個 最強秘訣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.41,
    "end": 34.86,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.06,
    "end": 37.64,
    "speaker": "彥君",
    "text": "摸中間 就對了！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.84,
    "end": 40.63,
    "speaker": "彥君",
    "text": "只要 中間比較厚",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.83,
    "end": 43.5,
    "speaker": "彥君",
    "text": "旁邊 比較薄",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.7,
    "end": 46.42,
    "speaker": "彥君",
    "text": "它就是 凸透鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.62,
    "end": 49.85,
    "speaker": "曉臻",
    "text": "喔 所以左邊的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.05,
    "end": 53.08,
    "speaker": "曉臻",
    "text": "雙凸、 平凸、 凹凸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.28,
    "end": 55.98,
    "speaker": "曉臻",
    "text": "通通都是 凸透鏡嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.18,
    "end": 58.56,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.76,
    "end": 61.29,
    "speaker": "彥君",
    "text": "它們的 功能是",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.49,
    "end": 64.4,
    "speaker": "彥君",
    "text": "把光線 集中起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.6,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{凸透鏡} \\rightarrow \\text{集中光線}",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 68.36,
    "end": 70.31,
    "speaker": "曉臻",
    "text": "那右邊的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.51,
    "end": 73.57,
    "speaker": "曉臻",
    "text": "雙凹、 凸凹、 平凹",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.77,
    "end": 75.96,
    "speaker": "曉臻",
    "text": "中間 比較薄",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.16,
    "end": 78.45,
    "speaker": "曉臻",
    "text": "都是 凹透鏡囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.65,
    "end": 82.66,
    "speaker": "彥君",
    "text": "沒錯 凹透鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.86,
    "end": 86.02,
    "speaker": "彥君",
    "text": "會讓光線 發散出去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.22,
    "end": 89.18,
    "speaker": "曉臻",
    "text": "老師 上面的空格",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.38,
    "end": 91.74,
    "speaker": "曉臻",
    "text": "近視眼鏡 那裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.94,
    "end": 94.37,
    "speaker": "曉臻",
    "text": "要填 什麼光線啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.57,
    "end": 97.46,
    "speaker": "彥君",
    "text": "既然它是 凹透鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.66,
    "end": 100.59,
    "speaker": "彥君",
    "text": "當然就是 填發散囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.79,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{凹透鏡} \\rightarrow \\text{發散光線}",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 104.46,
    "end": 106.79,
    "speaker": "曉臻",
    "text": "原來 近視眼鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.99,
    "end": 109.33,
    "speaker": "曉臻",
    "text": "就是 凹透鏡啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.53,
    "end": 113.33,
    "speaker": "彥君",
    "text": "對 近視的人",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.53,
    "end": 116.3,
    "speaker": "彥君",
    "text": "光線太早 集中了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.5,
    "end": 119.43,
    "speaker": "彥君",
    "text": "所以要用 凹透鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.63,
    "end": 122.5,
    "speaker": "彥君",
    "text": "把光線 發散一點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.7,
    "end": 125.3,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.5,
    "end": 127.83,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.03,
    "end": 131.47,

[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.86,
    "speaker": "彥君",
    "text": "最後的 第 134 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 7.06,
    "end": 9.5,
    "speaker": "彥君",
    "text": "電 產生的熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.7,
    "end": 12.63,
    "speaker": "彥君",
    "text": "能 溫暖一整個冬天",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.83,
    "end": 15.22,
    "speaker": "彥君",
    "text": "大家的 努力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.42,
    "end": 18.5,
    "speaker": "彥君",
    "text": "也能 照亮未來的前程",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.7,
    "end": 21.3,
    "speaker": "彥君",
    "text": "我是 彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.5,
    "end": 23.23,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.43,
    "end": 25.77,
    "speaker": "曉臻",
    "text": "我是 曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.97,
    "end": 28.86,
    "speaker": "彥君",
    "text": "這是 電學 的最後一關",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.06,
    "end": 32.02,
    "speaker": "曉臻",
    "text": "老師 講義第一點說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.22,
    "end": 34.82,
    "speaker": "曉臻",
    "text": "電 竟然可以產生熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.02,
    "end": 39.39,
    "speaker": "彥君",
    "text": "沒錯 就像 雙手磨擦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.59,
    "end": 42.31,
    "speaker": "彥君",
    "text": "電子 經過電阻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.51,
    "end": 45.11,
    "speaker": "彥君",
    "text": "消耗 的電能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.31,
    "end": 48.32,
    "speaker": "彥君",
    "text": "就會 變成熱能釋放",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.52,
    "end": 51.84,
    "speaker": "曉臻",
    "text": "喔 難怪 吹風機",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.04,
    "end": 54.38,
    "speaker": "曉臻",
    "text": "用 久了會發燙",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.58,
    "end": 57.73,
    "speaker": "彥君",
    "text": "戰士們 公式來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.93,
    "end": 61.18,
    "speaker": "彥君",
    "text": "電能 等於 功率乘上時間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.38,
    "end": 67.82,
    "speaker": "彥君",
    "text": "$E = P \\times t$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 67.82,
    "end": 70.66,
    "speaker": "曉臻",
    "text": "老師 第二點寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.86,
    "end": 73.97,
    "speaker": "曉臻",
    "text": "一一零 伏特、 五百瓦特",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.17,
    "end": 76.6,
    "speaker": "曉臻",
    "text": "這是 什麼意思呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.8,
    "end": 79.74,
    "speaker": "彥君",
    "text": "這是 電器的身分證",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.94,
    "end": 83.23,
    "speaker": "彥君",
    "text": "代表 接在一一零伏特下",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.43,
    "end": 86.54,
    "speaker": "彥君",
    "text": "每秒 消耗五百焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.74,
    "end": 89.91,
    "speaker": "曉臻",
    "text": "哇 數字越大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.11,
    "end": 92.74,
    "speaker": "曉臻",
    "text": "產生 的熱就越多囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.94,
    "end": 97.48,
    "speaker": "彥君",
    "text": "漂亮 這就是 功率的奧義",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.68,
    "end": 108.63,
    "speaker": "彥君",
    "text": "$500\\text{W} \\rightarrow \\text{每秒 } 500\\text{J}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 102.14,
    "end": 105.43,
    "speaker": "彥君",
    "text": "戰士們 來看電費單",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.63,
    "end": 111.69,
    "speaker": "曉臻",
    "text": "老師 什麼是 一度電",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.89,
    "end": 114.49,
    "speaker": "曉臻",
    "text": "家裡 的電費怎麼算",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.69,
    "end": 118.18,
    "speaker": "彥君",
    "text": "一度電 就是能量單位",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.38,
    "end": 120.9,
    "speaker": "彥君",
    "text": "一千瓦 的電器",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.1,
    "end": 123.92,
    "speaker": "彥君",
    "text": "用 了整整一小時",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.12,
    "end": 126.31,
    "speaker": "曉臻",
    "text": "換算 成焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.51,
    "end": 129.57,
    "speaker": "曉臻",
    "text": "竟然 有三百六十萬焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.77,
    "end": 134.29,
    "speaker": "彥君",
    "text": "沒錯 數字 雖然很大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.49,
    "end": 137.09,
    "speaker": "彥君",
    "text": "但 只值幾塊錢喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.29,
    "end": 144.41,
    "speaker": "彥君",
    "text": "$1\\text{kWh} = 3.6 \\times 10^{6}\\text{J}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 144.41,
    "end": 147.99,
    "speaker": "曉臻",
    "text": "老師 第四點 提到電力輸送",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.19,
    "end": 151.22,
    "speaker": "曉臻",
    "text": "為什麼 電線要掛得這麼高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.42,
    "end": 154.36,
    "speaker": "彥君",
    "text": "為了 減少能量損耗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.56,
    "end": 157.42,
    "speaker": "彥君",
    "text": "輸送 電力的過程",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.62,
    "end": 160.68,
    "speaker": "彥君",
    "text": "高 電壓 低電流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.88,
    "end": 163.94,
    "speaker": "曉臻",
    "text": "喔 電流 越小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.14,
    "end": 167.14,
    "speaker": "曉臻",
    "text": "在 電線上產生的熱越少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 167.34,
    "end": 172.03,
    "speaker": "彥君",
    "text": "沒錯 這就是 能量守恆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 172.23,
    "end": 179.81,
    "speaker": "彥君",
    "text": "$\\text{高壓電} \\rightarrow \\text{減少能量損耗}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 179.81,
    "end": 182.82,
    "speaker": "曉臻",
    "text": "直流電 與 交流電的差異",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 183.02,
    "end": 185.98,
    "speaker": "曉臻",
    "text": "老師 插座 是哪一種",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 186.18,
    "end": 189.38,
    "speaker": "彥君",
    "text": "家裡 牆壁的是交流電",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 189.58,
    "end": 192.75,
    "speaker": "彥君",
    "text": "方向 會隨時間改變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 192.95,
    "end": 196.03,
    "speaker": "曉臻",
    "text": "電池 則是 直流電囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 196.23,
    "end": 200.8,
    "speaker": "彥君",
    "text": "正確 方向 永遠不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 201.0,
    "end": 204.01,
    "speaker": "彥君",
    "text": "還有 為了用電安全",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 204.21,
    "end": 206.69,
    "speaker": "曉臻",
    "text": "必須 安裝保險絲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 206.89,
    "end": 209.82,
    "speaker": "彥君",
    "text": "電流 過大就會熔斷",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 210.02,
    "end": 213.32,
    "speaker": "彥君",
    "text": "幫 大家的家守住安全",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 213.52,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{保險絲} \\rightarrow \\text{電流過大熔斷}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 217.78,
    "end": 221.34,
    "speaker": "彥君",
    "text": "到這裡 理化 大觀念通了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 221.54,
    "end": 224.62,
    "speaker": "彥君",
    "text": "所有的 考題 都能秒殺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 224.82,
    "end": 228.05,
    "speaker": "彥君",
    "text": "戰士們 抬起頭來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 228.25,
    "end": 231.3,
    "speaker": "曉臻",
    "text": "老師 這集講完了嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 231.5,
    "end": 234.37,
    "speaker": "彥君",
    "text": "課程 雖然 講完了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 234.57,
    "end": 237.84,
    "speaker": "彥君",
    "text": "但 我們的故事 還沒結束",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 238.04,
    "end": 241.22,
    "speaker": "彥君",
    "text": "下課 前 有些話",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 241.42,
    "end": 244.33,
    "speaker": "彥君",
    "text": "老師 想跟 戰士們說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 244.53,
    "end": 246.82,
    "speaker": "曉臻",
    "text": "還有 小朋友們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 247.02,
    "end": 249.57,
    "speaker": "曉臻",
    "text": "助教 也有話想說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 249.77,
    "end": 253.09,
    "speaker": "彥君",
    "text": "從 第一集 到 一三四集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 253.29,
    "end": 256.44,
    "speaker": "彥君",
    "text": "老師 看見 你們的堅持",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 256.64,
    "end": 259.62,
    "speaker": "彥君",
    "text": "從 牛頓 三大定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 259.82,
    "end": 262.76,
    "speaker": "彥君",
    "text": "到 今天的 電熱效應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 262.96,
    "end": 265.92,
    "speaker": "彥君",
    "text": "你們 走過 最長的路",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 266.12,
    "end": 269.01,
    "speaker": "彥君",
    "text": "累積 了 最厚的實力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 269.21,
    "end": 272.65,
    "speaker": "彥君",
    "text": "會考 只是 一場測驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 272.85,
    "end": 275.78,
    "speaker": "彥君",
    "text": "它 定義不了你的未來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 275.98,
    "end": 278.54,
    "speaker": "彥君",
    "text": "只有 你的態度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 278.74,
    "end": 281.65,
    "speaker": "彥君",
    "text": "才能 決定 你的高度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 281.85,
    "end": 285.14,
    "speaker": "彥君",
    "text": "遇到 難題 不要害怕",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 285.34,
    "end": 287.92,
    "speaker": "彥君",
    "text": "找 到 你的支點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 288.12,
    "end": 291.22,
    "speaker": "彥君",
    "text": "用 合力 等於零的冷靜",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 291.42,
    "end": 294.48,
    "speaker": "彥君",
    "text": "去 破解 所有的考驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 294.68,
    "end": 297.69,
    "speaker": "彥君",
    "text": "你們 是最棒的戰士",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 297.89,
    "end": 300.75,
    "speaker": "彥君",
    "text": "每一 個 深夜的努力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 300.95,
    "end": 304.03,
    "speaker": "彥君",
    "text": "每 一 張 寫滿的考卷",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 304.23,
    "end": 307.34,
    "speaker": "彥君",
    "text": "都是 成功的 能量守恆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 307.54,
    "end": 311.17,
    "speaker": "彥君",
    "text": "戰士們 老師 為你們驕傲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 311.37,
    "end": 314.45,
    "speaker": "彥君",
    "text": "帶著 這份 物理的精神",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 314.65,
    "end": 317.92,
    "speaker": "彥君",
    "text": "去 開創 屬於你們的時代",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 318.12,
    "end": 320.12,
    "speaker": "曉臻",
    "text": "小朋友們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 320.32,
    "end": 322.73,
    "speaker": "曉臻",
    "text": "你們 真的 辛苦了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 322.93,
    "end": 325.72,
    "speaker": "曉臻",
    "text": "助教 一直 在螢幕這端",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 325.92,
    "end": 328.59,
    "speaker": "曉臻",
    "text": "看著 你們 慢慢變強",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 328.79,
    "end": 331.63,
    "speaker": "曉臻",
    "text": "雖然 物理 有時候很難",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 331.83,
    "end": 335.03,
    "speaker": "曉臻",

[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.86,
    "speaker": "彥君",
    "text": "最後的 第 134 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 7.06,
    "end": 9.5,
    "speaker": "彥君",
    "text": "電 產生的熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.7,
    "end": 12.63,
    "speaker": "彥君",
    "text": "能 溫暖一整個冬天",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.83,
    "end": 15.22,
    "speaker": "彥君",
    "text": "大家的 努力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.42,
    "end": 18.5,
    "speaker": "彥君",
    "text": "也能 照亮未來的前程",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.7,
    "end": 21.3,
    "speaker": "彥君",
    "text": "我是 彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.5,
    "end": 23.23,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.43,
    "end": 25.77,
    "speaker": "曉臻",
    "text": "我是 曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.97,
    "end": 28.86,
    "speaker": "彥君",
    "text": "這是 電學 的最後一關",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.06,
    "end": 32.02,
    "speaker": "曉臻",
    "text": "老師 講義第一點說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.22,
    "end": 34.82,
    "speaker": "曉臻",
    "text": "電 竟然可以產生熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.02,
    "end": 39.39,
    "speaker": "彥君",
    "text": "沒錯 就像 雙手磨擦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.59,
    "end": 42.31,
    "speaker": "彥君",
    "text": "電子 經過電阻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.51,
    "end": 45.11,
    "speaker": "彥君",
    "text": "消耗 的電能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.31,
    "end": 48.32,
    "speaker": "彥君",
    "text": "就會 變成熱能釋放",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.52,
    "end": 51.84,
    "speaker": "曉臻",
    "text": "喔 難怪 吹風機",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.04,
    "end": 54.38,
    "speaker": "曉臻",
    "text": "用 久了會發燙",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.58,
    "end": 57.73,
    "speaker": "彥君",
    "text": "戰士們 公式來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.93,
    "end": 61.18,
    "speaker": "彥君",
    "text": "電能 等於 功率乘上時間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.38,
    "end": 67.82,
    "speaker": "彥君",
    "text": "[$E = P \\times t$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 64.82,
    "end": 68.07,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘抄寫]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.27,
    "end": 71.11,
    "speaker": "曉臻",
    "text": "老師 第二點寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.31,
    "end": 74.42,
    "speaker": "曉臻",
    "text": "一一零 伏特、 五百瓦特",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.62,
    "end": 77.05,
    "speaker": "曉臻",
    "text": "這是 什麼意思呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.25,
    "end": 80.18,
    "speaker": "彥君",
    "text": "這是 電器的身分證",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.38,
    "end": 83.68,
    "speaker": "彥君",
    "text": "代表 接在一一零伏特下",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.88,
    "end": 86.98,
    "speaker": "彥君",
    "text": "每秒 消耗五百焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.18,
    "end": 90.36,
    "speaker": "曉臻",
    "text": "哇 數字越大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.56,
    "end": 93.18,
    "speaker": "曉臻",
    "text": "產生 的熱就越多囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.38,
    "end": 97.93,
    "speaker": "彥君",
    "text": "漂亮 這就是 功率的奧義",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.13,
    "end": 105.58,
    "speaker": "彥君",
    "text": "[$500\\text{W} \\rightarrow \\text{每秒 } 500\\text{J}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 102.58,
    "end": 106.31,
    "speaker": "彥君",
    "text": "[戰士們 來看電費單]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.51,
    "end": 109.57,
    "speaker": "曉臻",
    "text": "老師 什麼是 一度電",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.77,
    "end": 112.37,
    "speaker": "曉臻",
    "text": "家裡 的電費怎麼算",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.57,
    "end": 116.06,
    "speaker": "彥君",
    "text": "一度電 就是能量單位",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.26,
    "end": 118.78,
    "speaker": "彥君",
    "text": "一千瓦 的電器",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.98,
    "end": 121.8,
    "speaker": "彥君",
    "text": "用 了整整一小時",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.0,
    "end": 124.19,
    "speaker": "曉臻",
    "text": "換算 成焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.39,
    "end": 127.45,
    "speaker": "曉臻",
    "text": "竟然 有三百六十萬焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 127.65,
    "end": 132.17,
    "speaker": "彥君",
    "text": "沒錯 數字 雖然很大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.37,
    "end": 134.97,
    "speaker": "彥君",
    "text": "但 只值幾塊錢喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.17,
    "end": 142.29,
    "speaker": "彥君",
    "text": "[$1\\text{kWh} = 3.6 \\times 10^{6}\\text{J}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 139.29,
    "end": 142.63,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘換算]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.83,
    "end": 146.42,
    "speaker": "曉臻",
    "text": "老師 第四點 提到電力輸送",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.62,
    "end": 149.65,
    "speaker": "曉臻",
    "text": "為什麼 電線要掛得這麼高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.85,
    "end": 152.78,
    "speaker": "彥君",
    "text": "為了 減少能量損耗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.98,
    "end": 155.85,
    "speaker": "彥君",
    "text": "輸送 電力的過程",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.05,
    "end": 159.1,
    "speaker": "彥君",
    "text": "高 電壓 低電流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.3,
    "end": 162.36,
    "speaker": "曉臻",
    "text": "喔 電流 越小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.56,
    "end": 165.57,
    "speaker": "曉臻",
    "text": "在 電線上產生的熱越少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.77,
    "end": 170.46,
    "speaker": "彥君",
    "text": "沒錯 這就是 能量守恆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.66,
    "end": 178.23,
    "speaker": "彥君",
    "text": "[$\\text{高壓電} \\rightarrow \\text{減少能(ㄋㄥˊ)量損耗}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 175.23,
    "end": 179.06,
    "speaker": "彥君",
    "text": "[戰士們 注意最後兩點]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 179.26,
    "end": 182.26,
    "speaker": "曉臻",
    "text": "直流電 與 交流電的差異",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 182.46,
    "end": 185.42,
    "speaker": "曉臻",
    "text": "老師 插座 是哪一種",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.62,
    "end": 188.82,
    "speaker": "彥君",
    "text": "家裡 牆壁的是交流電",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 189.02,
    "end": 192.2,
    "speaker": "彥君",
    "text": "方向 會隨時間改變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 192.4,
    "end": 195.48,
    "speaker": "曉臻",
    "text": "電池 則是 直流電囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 195.68,
    "end": 200.25,
    "speaker": "彥君",
    "text": "正確 方向 永遠不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 200.45,
    "end": 203.46,
    "speaker": "彥君",
    "text": "還有 為了用電安全",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 203.66,
    "end": 206.14,
    "speaker": "曉臻",
    "text": "必須 安裝保險絲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 206.34,
    "end": 209.27,
    "speaker": "彥君",
    "text": "電流 過大就會熔斷",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 209.47,
    "end": 212.77,
    "speaker": "彥君",
    "text": "幫 大家的家守住安全",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 212.97,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$\\text{保險絲} \\rightarrow \\text{電流過大熔斷}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 217.23,
    "end": 220.79,
    "speaker": "彥君",
    "text": "到這裡 理化 大觀念通了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 220.99,
    "end": 224.07,
    "speaker": "彥君",
    "text": "所有的 考題 都能秒殺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 224.27,
    "end": 227.81,
    "speaker": "彥君",
    "text": "[戰士們 抬起頭來]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 228.01,
    "end": 231.06,
    "speaker": "曉臻",
    "text": "老師 這集講完了嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 231.26,
    "end": 234.13,
    "speaker": "彥君",
    "text": "課程 雖然 講完了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 234.33,
    "end": 237.6,
    "speaker": "彥君",
    "text": "但 我們的故事 還沒結束",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 237.8,
    "end": 240.98,
    "speaker": "彥君",
    "text": "下課 前 有些話",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 241.18,
    "end": 244.09,
    "speaker": "彥君",
    "text": "老師 想跟 戰士們說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 244.29,
    "end": 246.58,
    "speaker": "曉臻",
    "text": "還有 小朋友們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 246.78,
    "end": 249.33,
    "speaker": "曉臻",
    "text": "助教 也有話想說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 249.53,
    "end": 252.85,
    "speaker": "彥君",
    "text": "從 第一集 到 一三四集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 253.05,
    "end": 256.2,
    "speaker": "彥君",
    "text": "老師 看見 你們的堅持",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 256.4,
    "end": 259.38,
    "speaker": "彥君",
    "text": "從 牛頓 三大定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 259.58,
    "end": 262.52,
    "speaker": "彥君",
    "text": "到 今天的 電熱效應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 262.72,
    "end": 265.68,
    "speaker": "彥君",
    "text": "你們 走過 最長的路",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 265.88,
    "end": 268.77,
    "speaker": "彥君",
    "text": "累積 了 最厚的實力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 268.97,
    "end": 272.41,
    "speaker": "彥君",
    "text": "會考 只是 一場測驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 272.61,
    "end": 275.54,
    "speaker": "彥君",
    "text": "它 定義不了你的未來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 275.74,
    "end": 278.3,
    "speaker": "彥君",
    "text": "只有 你的態度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 278.5,
    "end": 281.41,
    "speaker": "彥君",
    "text": "才能 決定 你的高度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 281.61,
    "end": 284.9,
    "speaker": "彥君",
    "text": "遇到 難題 不要害怕",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 285.1,
    "end": 287.68,
    "speaker": "彥君",
    "text": "找 到 你的支點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 287.88,
    "end": 290.98,
    "speaker": "彥君",
    "text": "用 合力 等於零的冷靜",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 291.18,
    "end": 294.24,
    "speaker": "彥君",
    "text": "去 破解 所有的考驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 294.44,
    "end": 297.45,
    "speaker": "彥君",
    "text": "你們 是最棒的戰士",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 297.65,
    "end": 300.51,
    "speaker": "彥君",
    "text": "每一 個 深夜的努力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 300.71,
    "end": 303.79,
    "speaker": "彥君",
    "text": "每 一 張 寫滿的考卷",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 303.99,
    "end": 307.1,
    "speaker": "彥君",
    "text": "都是 成功的 能量守恆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 307.3,
    "end": 310.93,
    "speaker": "彥君",
    "text": "戰士們 老師 為你們驕傲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 311.13,
    "end": 314.21,
    "speaker": "彥君",
    "text": "帶著 這份 物理的精神",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 314.41,
    "end": 317.68,
    "speaker": "彥君",
    "text": "去 開創 屬於你們的時代",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 317.88,
    "end": 319.88,
    "speaker": "曉臻",
    "text": "小朋友們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 320.08,
    "end": 322.49,
    "speaker": "曉臻",
    "text": "你們 真的 辛苦了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 322.69,
    "end": 325.48,
    "speaker": "曉臻",
    "text": "助教 一直 在螢幕這端",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 325.68,
    "end": 328.35,
    "speaker": "曉臻",
    "text": "看著 你們 慢慢變強",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 328.55,
    "end": 331.39,
    "speaker": "曉臻",
    "text": "雖然 物理 有時候很難",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 331.59,
    "end": 334.79,
    "speaker": "曉臻",
    "text": "雖然 題目 有時候很討厭",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 334.99,
    "end": 337.59,
    "speaker": "曉臻",
    "text": "但 你們 都撐過來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 337.79,
    "end": 340.58,
    "speaker": "曉臻",
    "text": "不要 忘記 學習的快樂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 340.78,
    "end": 344.03,
    "speaker": "曉臻",
    "text": "不要 忘記 追求真相的好奇",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 344.23,
    "end": 347.26,
    "speaker": "曉臻",
    "text": "到 了 考場 放鬆心情",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 347.46,
    "end": 350.21,
    "speaker": "曉臻",
    "text": "把 助教 的口訣唸一遍",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 350.41,
    "end": 353.08,
    "speaker": "曉臻",
    "text": "讓 腦袋 充滿 正能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 353.28,
    "end": 356.12,
    "speaker": "曉臻",
    "text": "你們 的夢想 正在充電",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 356.32,
    "end": 358.92,
    "speaker": "曉臻",
    "text": "等著 你們 去點亮它",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 359.12,
    "end": 362.13,
    "speaker": "曉臻",
    "text": "加油 每一位 準考生",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 362.33,
    "end": 365.07,
    "speaker": "曉臻",
    "text": "我們 一直 為你們加油",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 365.27,
    "end": 368.76,
    "speaker": "彥君",
    "text": "戰士們 下課時間到了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 368.96,
    "end": 372.47,
    "speaker": "彥君",
    "text": "這一次 我們不說再見",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 372.67,
    "end": 375.87,
    "speaker": "彥君",
    "text": "我們 說 頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 376.07,
    "end": 379.34,
    "speaker": "彥君",
    "text": "觀念 通了 人生就通",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 379.54,
    "end": 382.14,
    "speaker": "彥君",
    "text": "我是 彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 382.34,
    "end": 384.68,
    "speaker": "曉臻",

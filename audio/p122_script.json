[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.17,
    "speaker": "彥君",
    "text": "第 122 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.37,
    "end": 9.88,
    "speaker": "彥君",
    "text": "讀書 沒有不勞而獲的捷徑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 10.08,
    "end": 13.38,
    "speaker": "彥君",
    "text": "就像 物理學的簡單機械",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.58,
    "end": 17.09,
    "speaker": "彥君",
    "text": "想省力 就要多花時間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 17.29,
    "end": 20.06,
    "speaker": "彥君",
    "text": "但只要 腳踏實地",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.26,
    "end": 23.55,
    "speaker": "彥君",
    "text": "每一分努力 都不會白費",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.75,
    "end": 26.35,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.55,
    "end": 28.29,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.49,
    "end": 30.82,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.02,
    "end": 33.48,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.68,
    "end": 36.81,
    "speaker": "彥君",
    "text": "簡單機械 原理最重要",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.01,
    "end": 40.5,
    "speaker": "曉臻",
    "text": "老師 上面紅色的字寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.7,
    "end": 43.63,
    "speaker": "曉臻",
    "text": "想要省力 就得費時耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.83,
    "end": 48.3,
    "speaker": "彥君",
    "text": "沒錯 這是宇宙鐵則",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.5,
    "end": 51.8,
    "speaker": "彥君",
    "text": "世界上 沒有白吃的午餐",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.0,
    "end": 55.32,
    "speaker": "彥君",
    "text": "機械 絕對不可能「省功」",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.52,
    "end": 91.62,
    "speaker": "彥君",
    "text": "$\\text{機械鐵則} \\rightarrow \\text{絕對不省功}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 59.9,
    "end": 63.15,
    "speaker": "曉臻",
    "text": "也就是說 力量變小了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.35,
    "end": 66.14,
    "speaker": "曉臻",
    "text": "距離 就要拉得更長囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.34,
    "end": 71.13,
    "speaker": "彥君",
    "text": "漂亮 看看中間的動滑輪",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.33,
    "end": 74.5,
    "speaker": "彥君",
    "text": "它可以 幫你省下一半的力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.7,
    "end": 77.23,
    "speaker": "彥君",
    "text": "但是 你的繩子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.43,
    "end": 80.42,
    "speaker": "彥君",
    "text": "必須要 拉兩倍的長度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.62,
    "end": 91.62,
    "speaker": "彥君",
    "text": "$\\text{動滑輪} \\rightarrow \\text{省一半力, 多兩倍距}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 85.48,
    "end": 88.42,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘思考",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.62,
    "end": 94.62,
    "speaker": "曉臻",
    "text": "那旁邊的 輪軸跟斜面呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.82,
    "end": 97.86,
    "speaker": "彥君",
    "text": "原理 完全一模一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.06,
    "end": 101.69,
    "speaker": "彥君",
    "text": "轉動大圈的輪 比較省力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.89,
    "end": 105.76,
    "speaker": "彥君",
    "text": "斜坡越平緩 推起來越輕鬆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.96,
    "end": 108.56,
    "speaker": "曉臻",
    "text": "可是 斜坡越平緩",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.76,
    "end": 111.38,
    "speaker": "曉臻",
    "text": "就要走 越遠的路耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.58,
    "end": 116.37,
    "speaker": "彥君",
    "text": "沒錯 這就是省力必費時",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.57,
    "end": 119.5,
    "speaker": "彥君",
    "text": "還有 右下角的螺絲釘",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.7,
    "end": 122.57,
    "speaker": "彥君",
    "text": "仔細看 它的螺紋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.77,
    "end": 126.26,
    "speaker": "彥君",
    "text": "其實 就是捲起來的斜面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.46,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{螺旋} \\rightarrow \\text{變形的斜面}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 130.67,
    "end": 134.52,
    "speaker": "曉臻",
    "text": "哇 原來這些生活工具",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.72,
    "end": 137.8,
    "speaker": "曉臻",
    "text": "全部 都是在玩代價交換",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.0,
    "end": 141.78,
    "speaker": "彥君",
    "text": "記住 原理比死背更重要",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.98,
    "end": 145.42,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.62,
    "end": 148.22,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.42,
    "end": 150.75,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.95,
    "end": 154.42,
    "speaker": "合聲",
    "text": "省力費時 作功不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.62,
    "end": 158.15,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.17,
    "speaker": "彥君",
    "text": "第 122 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.37,
    "end": 9.88,
    "speaker": "彥君",
    "text": "讀書 沒有不勞而獲的捷徑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 10.08,
    "end": 13.38,
    "speaker": "彥君",
    "text": "就像 物理學的簡單機械",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.58,
    "end": 17.09,
    "speaker": "彥君",
    "text": "想省力 就要多花時間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 17.29,
    "end": 20.06,
    "speaker": "彥君",
    "text": "但只要 腳踏實地",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.26,
    "end": 23.55,
    "speaker": "彥君",
    "text": "每一分努力 都不會白費",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.75,
    "end": 26.35,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.55,
    "end": 28.29,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.49,
    "end": 30.82,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.02,
    "end": 33.67,
    "speaker": "彥君",
    "text": "[戰士們注意 ]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.87,
    "end": 37.0,
    "speaker": "彥君",
    "text": "簡單機械 原理最重要",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.2,
    "end": 40.69,
    "speaker": "曉臻",
    "text": "老師 上面紅色的字寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.89,
    "end": 43.82,
    "speaker": "曉臻",
    "text": "想要省力 就得費時耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.02,
    "end": 48.5,
    "speaker": "彥君",
    "text": "沒錯 這是宇宙鐵則",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.7,
    "end": 51.99,
    "speaker": "彥君",
    "text": "世界上 沒有白吃的午餐",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.19,
    "end": 55.51,
    "speaker": "彥君",
    "text": "機械 絕對不可能「省功」",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.71,
    "end": 88.67,
    "speaker": "彥君",
    "text": "[$\\text{機械鐵則} \\rightarrow \\text{絕對不省功}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 60.1,
    "end": 63.34,
    "speaker": "曉臻",
    "text": "也就是說 力量變小了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.54,
    "end": 66.34,
    "speaker": "曉臻",
    "text": "距離 就要拉得更長囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.54,
    "end": 71.32,
    "speaker": "彥君",
    "text": "漂亮 看看中間的動滑輪",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.52,
    "end": 74.7,
    "speaker": "彥君",
    "text": "它可以 幫你省下一半的力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.9,
    "end": 77.42,
    "speaker": "彥君",
    "text": "但是 你的繩子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.62,
    "end": 80.61,
    "speaker": "彥君",
    "text": "必須要 拉兩倍的長度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.81,
    "end": 88.67,
    "speaker": "彥君",
    "text": "[$\\text{動滑輪} \\rightarrow \\text{省一半力, 多兩倍距}$]",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 85.67,
    "end": 88.94,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘思考]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.14,
    "end": 92.15,
    "speaker": "曉臻",
    "text": "那旁邊的 輪軸跟斜面呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.35,
    "end": 95.38,
    "speaker": "彥君",
    "text": "原理 完全一模一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.58,
    "end": 99.22,
    "speaker": "彥君",
    "text": "轉動大圈的輪 比較省力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.42,
    "end": 103.29,
    "speaker": "彥君",
    "text": "斜坡越平緩 推起來越輕鬆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.49,
    "end": 106.09,
    "speaker": "曉臻",
    "text": "可是 斜坡越平緩",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.29,
    "end": 108.91,
    "speaker": "曉臻",
    "text": "就要走 越遠的路耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.11,
    "end": 113.9,
    "speaker": "彥君",
    "text": "沒錯 這就是省力必費時",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.1,
    "end": 117.03,
    "speaker": "彥君",
    "text": "還有 右下角的螺絲釘",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.23,
    "end": 120.1,
    "speaker": "彥君",
    "text": "仔細看 它的螺紋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.3,
    "end": 123.78,
    "speaker": "彥君",
    "text": "其實 就是捲起來的斜面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.98,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$\\text{螺旋} \\rightarrow \\text{變形的斜面}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 128.2,
    "end": 132.05,
    "speaker": "曉臻",
    "text": "哇 原來這些生活工具",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.25,
    "end": 135.33,
    "speaker": "曉臻",
    "text": "全部 都是在玩代價交換",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.53,
    "end": 139.3,
    "speaker": "彥君",
    "text": "記住 原理比死背更重要",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.5,
    "end": 142.94,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.14,
    "end": 145.74,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.94,
    "end": 148.28,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.48,
    "end": 151.94,
    "speaker": "合聲",
    "text": "省力費時 作功不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.14,
    "end": 155.68,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
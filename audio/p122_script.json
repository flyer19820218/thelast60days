    "commands": []
  },
  {
    "start": 79.26,
    "end": 82.62,
    "speaker": "彥君",
    "text": "它可以幫你省下一半的施力",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 82.82,
    "end": 86.34,

  {
    "start": 86.54,
    "end": 89.93,
    "speaker": "彥君",
    "text": "必須要往上拉兩倍的長度喔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 90.13,
    "end": 97.44,
    "speaker": "彥君",
    "text": "② $\\text{動滑輪} \\rightarrow \\text{省一半力， 多兩倍距}$",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選",
      "② $\\text{動滑輪} \\rightarrow \\text{省一半力， 多兩倍距}$"
    ]
  },
  {
    "start": 97.44,
    "end": 101.07,

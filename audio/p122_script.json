[
  {
    "start": 0.0,
    "end": 5.34,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到第一百二十二集",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 5.54,
    "end": 9.31,
    "speaker": "彥君",
    "text": "讀書絕對沒有不勞而獲的捷徑",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 9.51,
    "end": 13.1,
    "speaker": "彥君",
    "text": "就像物理學裡的簡單機械一樣",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 13.3,
    "end": 17.05,
    "speaker": "彥君",
    "text": "想要省力氣就必須要多花時間",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 17.25,
    "end": 20.52,
    "speaker": "彥君",
    "text": "但只要肯腳踏實地去努力",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 20.72,
    "end": 24.54,
    "speaker": "彥君",
    "text": "每一分汗水都絕對不會白費的",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 24.74,
    "end": 28.45,
    "speaker": "彥君",
    "text": "各位準備衝向 $A^{++}$ 的戰士們",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$A^{++}$"
    ]
  },
  {
    "start": 28.65,
    "end": 31.25,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 31.45,
    "end": 34.74,
    "speaker": "曉臻",
    "text": "大家好啊 我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 34.94,
    "end": 38.6,
    "speaker": "彥君",
    "text": "戰士們請把注意力集中過來",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 38.8,
    "end": 42.41,
    "speaker": "彥君",
    "text": "簡單機械的鐵則觀念最重要",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 42.61,
    "end": 46.05,
    "speaker": "曉臻",
    "text": "老師講義上面紅色的字寫著",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 46.25,
    "end": 49.69,
    "speaker": "曉臻",
    "text": "想要省力的話就得要費時耶",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 49.89,
    "end": 54.98,
    "speaker": "彥君",
    "text": "沒錯 這是理學上的宇宙鐵則",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 55.18,
    "end": 58.65,
    "speaker": "彥君",
    "text": "這個世界上沒有白吃的午餐",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 58.85,
    "end": 62.22,
    "speaker": "彥君",
    "text": "機械絕對不可能幫你省功喔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 62.42,
    "end": 97.44,
    "speaker": "彥君",
    "text": "① $\\text{機械鐵則} \\rightarrow \\text{絕對不省功}$",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選",
      "① $\\text{機械鐵則} \\rightarrow \\text{絕對不省功}$"

  },
  {
    "start": 66.3,
    "end": 70.0,
    "speaker": "曉臻",
    "text": "也就是說如果你施的力量變小了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 70.2,
    "end": 73.64,
    "speaker": "曉臻",
    "text": "拉的距離就要跟著拉得更長囉",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 73.84,
    "end": 79.06,

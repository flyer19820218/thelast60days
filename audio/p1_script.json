    "commands": []
  },
  {
    "start": 2.2,
    "end": 7.46,
    "speaker": "彥君",
    "text": "各位即將衝 A 的會考戰士們 我是彥君老師",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 7.66,
    "end": 10.19,
    "speaker": "彥君",
    "text": "我們第一堂課",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 10.39,
    "end": 14.22,
    "speaker": "彥君",
    "text": "就是要解決 顯微鏡這個必考題",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 14.42,
    "end": 16.34,
    "speaker": "曉臻",
    "text": "準備好了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 16.54,
    "end": 20.7,
    "speaker": "曉臻",
    "text": "這單元雖然基礎 但裡面陷阱超多",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 20.9,
    "end": 23.46,
    "speaker": "曉臻",
    "text": "大家筆記本準備好",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 23.66,
    "end": 27.41,
    "speaker": "曉臻",
    "text": "顯微鏡最常考的 第一點就是倍率",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 27.61,
    "end": 31.34,
    "speaker": "曉臻",
    "text": "學生常混淆 長短跟倍率的關係",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 31.54,
    "end": 34.54,
    "speaker": "彥君",
    "text": "記住這條絕對規律",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 34.74,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "目短、 物長， 倍率高。",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選"
    ]
  },
  {
    "start": 38.65,
    "end": 42.52,
    "speaker": "彥君",
    "text": "目鏡靠近眼睛 越短倍率越高",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 42.72,
    "end": 46.69,
    "speaker": "彥君",
    "text": "物鏡靠近標本 越長倍率越高",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 46.89,
    "end": 51.12,
    "speaker": "曉臻",
    "text": "老師 為什麼物鏡是 越長倍率越高啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 51.32,
    "end": 54.04,
    "speaker": "彥君",
    "text": "因為物鏡越長",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 54.24,
    "end": 57.66,
    "speaker": "彥君",
    "text": "代表裡面的 透鏡組越複雜",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 57.86,
    "end": 60.82,
    "speaker": "彥君",
    "text": "可以把影像放得更大",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 61.02,
    "end": 64.98,
    "speaker": "彥君",
    "text": "所以考題 如果給你一組鏡頭組合",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 65.18,
    "end": 68.02,
    "speaker": "彥君",
    "text": "要選倍率最高的",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 68.22,
    "end": 72.5,
    "speaker": "彥君",
    "text": "就挑最短的目鏡 配上最長的物鏡",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 72.7,
    "end": 77.13,
    "speaker": "曉臻",
    "text": "大家想像一下 長長的物鏡 快撞到玻片",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 77.33,
    "end": 79.54,
    "speaker": "曉臻",
    "text": "那個就是高倍",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 79.74,
    "end": 82.46,
    "speaker": "曉臻",
    "text": "那總倍率要怎麼計算",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 82.66,
    "end": 85.12,
    "speaker": "彥君",
    "text": "相乘就對了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "清除釘選"
    ]
  },
  {
    "start": 85.32,
    "end": 88.93,
    "speaker": "彥君",
    "text": "這時候視野會發生 四個變化",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 89.13,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "第一， 亮度變暗、 進光量變少。",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選"
    ]
  },
  {
    "start": 93.46,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "第二， 範圍變小、 看到的細胞數量變少。",
    "is_pinned": true,
    "pin_level": 3,
    "commands": [
      "釘選"
    ]
  },
  {
    "start": 98.38,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "第三， 細節變大、 細胞看起來 變清晰變大了。",
    "is_pinned": true,
    "pin_level": 4,
    "commands": [
      "釘選"
    ]
  },
  {
    "start": 103.84,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "第四， 焦距變短、 物鏡會非常 靠近玻片。",
    "is_pinned": true,
    "pin_level": 5,
    "commands": [
      "釘選"
    ]
  },
  {
    "start": 109.16,
    "end": 112.31,
    "speaker": "曉臻",
    "text": "戰士們停一下 腦袋想一遍",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 112.51,
    "end": 115.57,
    "speaker": "曉臻",
    "text": "倍率高就是看得很清楚",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 115.77,
    "end": 118.27,
    "speaker": "曉臻",
    "text": "但視野變窄變暗",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 118.47,
    "end": 121.38,
    "speaker": "曉臻",
    "text": "所以衝刺期只要記住",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 121.58,
    "end": 126.2,
    "speaker": "曉臻",
    "text": "倍率越高 除了細節 其他都變少變暗",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "清除釘選"
    ]
  },
  {
    "start": 126.4,
    "end": 131.04,
    "speaker": "曉臻",
    "text": "老師 複式顯微鏡的 成像最容易 轉不過來",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 131.24,
    "end": 133.36,
    "speaker": "彥君",
    "text": "沒錯",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 133.56,
    "end": 138.01,
    "speaker": "彥君",
    "text": "複式顯微鏡 是上下顛倒、 左右相反",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 138.21,
    "end": 141.07,
    "speaker": "彥君",
    "text": "紙上寫小寫的 ｐ",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 141.27,
    "end": 144.69,
    "speaker": "彥君",
    "text": "目鏡看起來 就是小寫的 ｄ",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 144.89,
    "end": 148.21,
    "speaker": "曉臻",
    "text": "老師 如果是大寫的 Ｐ 呢",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 148.41,
    "end": 152.42,
    "speaker": "彥君",
    "text": "如果是大寫的 Ｐ 轉180度",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 152.62,
    "end": 155.85,
    "speaker": "彥君",
    "text": "看起來就會 像小寫的 ｄ 喔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 156.05,
    "end": 158.65,
    "speaker": "彥君",
    "text": "最簡單的方法",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 158.85,
    "end": 162.86,
    "speaker": "彥君",
    "text": "就是直接把考卷 旋轉180度",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 163.06,
    "end": 167.37,
    "speaker": "曉臻",
    "text": "那移動法則呢 這一定要背下來",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 167.57,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "物在哪裡， 就往哪裡移。",
    "is_pinned": true,
    "pin_level": 6,
    "commands": [
      "釘選"
    ]
  },
  {
    "start": 171.23,
    "end": 176.02,
    "speaker": "彥君",
    "text": "目標在左下方 你就把玻片 往左下方移",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 176.22,
    "end": 181.02,
    "speaker": "彥君",
    "text": "目標在右上方 你就把玻片 往右上方移",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 181.22,
    "end": 184.47,
    "speaker": "曉臻",
    "text": "為什麼要 往一樣的方向移啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 184.67,
    "end": 187.87,
    "speaker": "彥君",
    "text": "因為顯微鏡裡面是反的",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 188.07,
    "end": 192.45,
    "speaker": "彥君",
    "text": "你往左下移 影像其實是 往右上跑",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 192.65,
    "end": 195.9,
    "speaker": "彥君",
    "text": "這樣影像 才會回到中間",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 196.1,
    "end": 200.93,
    "speaker": "曉臻",
    "text": "喔 所以戰士們 看到生物在右上",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 201.13,
    "end": 204.45,
    "speaker": "曉臻",
    "text": "你就追著它 往右上移就對了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "清除釘選"
    ]
  },
  {
    "start": 204.65,
    "end": 207.68,
    "speaker": "曉臻",
    "text": "那如果是 解剖顯微鏡呢",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 207.88,
    "end": 211.15,
    "speaker": "彥君",
    "text": "解剖顯微鏡 沒有顛倒",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 211.35,
    "end": 214.07,
    "speaker": "彥君",
    "text": "所見即所得",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 214.27,
    "end": 218.17,
    "speaker": "彥君",
    "text": "這通常用來看 比較大、 不透光",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 218.37,
    "end": 221.28,
    "speaker": "彥君",
    "text": "不需要切片的物體",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 221.48,
    "end": 224.68,
    "speaker": "曉臻",
    "text": "老師 由低倍換到高倍",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 224.88,
    "end": 227.36,
    "speaker": "曉臻",
    "text": "一定要照順序嗎",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 227.56,
    "end": 231.91,
    "speaker": "彥君",
    "text": "當然 這是保命符",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 232.11,
    "end": 9999.0,
    "speaker": "彥君",

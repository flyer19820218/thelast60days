    "pin_level": 0,
    "commands": []
  },
  {
    "start": 287.3,
    "end": 290.17,
    "speaker": "彥君",
    "text": "甚至撞壞鏡頭",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [

    "text": "位移 物在哪 就往哪移",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 317.29,
    "end": 321.16,
    "speaker": "彥君",
    "text": "高倍 先置中、 後換鏡、",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 321.36,

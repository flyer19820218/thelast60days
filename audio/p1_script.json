    "pin_level": 0,
    "commands": []
  },
  {
    "start": 267.1,
    "end": 270.06,
    "speaker": "彥君",
    "text": "最後一步調焦距",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {

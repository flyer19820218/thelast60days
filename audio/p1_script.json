    "pin_level": 0,
    "commands": []
  },
  {
    "start": 271.66,
    "end": 275.9,
    "speaker": "曉臻",
    "text": "大家記住 高倍就是要 大光圈配 凹面鏡",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 276.1,

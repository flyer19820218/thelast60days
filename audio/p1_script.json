    "pin_level": 0,
    "commands": []
  },
  {
    "start": 239.08,
    "end": 243.22,
    "speaker": "曉臻",
    "text": "這步超重要 如果不先置中",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 243.42,
    "end": 247.0,
    "speaker": "曉臻",
    "text": "一換高倍 目標會直接消失",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 247.2,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "第二步換物鏡。",
    "is_pinned": true,
    "pin_level": 8,
    "commands": [
      "釘選"
    ]
  },
  {
    "start": 249.98,
    "end": 253.03,
    "speaker": "彥君",
    "text": "直接轉動旋轉盤",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 253.23,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "第三步調亮度。",
    "is_pinned": true,
    "pin_level": 9,
    "commands": [
      "釘選"
    ]
  },
  {
    "start": 256.15,
    "end": 258.97,
    "speaker": "彥君",
    "text": "換到高倍會變暗",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 259.17,

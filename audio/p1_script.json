    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 293.72,
    "end": 297.18,
    "speaker": "彥君",
    "text": "鏡頭目短物長 倍率最強",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 297.38,
    "end": 300.99,
    "speaker": "彥君",
    "text": "成像複式全反 解剖相同",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },

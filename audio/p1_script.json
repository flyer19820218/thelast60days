    "start": 301.19,
    "end": 304.63,
    "speaker": "彥君",
    "text": "位移 物在哪 就往哪移",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 304.83,
    "end": 308.7,
    "speaker": "彥君",
    "text": "高倍 先置中、 後換鏡、",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 308.9,

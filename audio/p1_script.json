    "pin_level": 0,
    "commands": []
  },
  {
    "start": 280.12,
    "end": 283.08,
    "speaker": "彥君",
    "text": "因為高倍物鏡很長",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {

[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.74,
    "speaker": "彥君",
    "text": "各位即將衝A的會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.94,
    "end": 8.54,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.74,
    "end": 11.91,
    "speaker": "彥君",
    "text": "今天來到 第九十四集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.11,
    "end": 13.85,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.05,
    "end": 16.38,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.58,
    "end": 19.04,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.24,
    "end": 22.44,
    "speaker": "彥君",
    "text": "這一集 絕對是送分題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.64,
    "end": 25.55,
    "speaker": "彥君",
    "text": "只要 聽懂生活例子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.75,
    "end": 28.86,
    "speaker": "彥君",
    "text": "閉著眼睛 都能拿滿分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.06,
    "end": 31.85,
    "speaker": "曉臻",
    "text": "老師 上面寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.05,
    "end": 34.82,
    "speaker": "曉臻",
    "text": "碰撞學說 兩個條件",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.02,
    "end": 39.44,
    "speaker": "彥君",
    "text": "沒錯 就像打撞球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.64,
    "end": 42.5,
    "speaker": "彥君",
    "text": "你的 力道要夠大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.7,
    "end": 45.64,
    "speaker": "彥君",
    "text": "撞擊的 角度還要對",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.84,
    "end": 48.87,
    "speaker": "彥君",
    "text": "這樣 才會發生反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.07,
    "end": 51.86,
    "speaker": "曉臻",
    "text": "那下面 五個影響因素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.06,
    "end": 54.38,
    "speaker": "曉臻",
    "text": "第一個 物質本性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.58,
    "end": 57.68,
    "speaker": "彥君",
    "text": "這是 物質天生的個性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.88,
    "end": 61.13,
    "speaker": "彥君",
    "text": "像鉀 碰到水會爆炸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.33,
    "end": 64.17,
    "speaker": "彥君",
    "text": "鐵 卻是慢慢生鏽",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.37,
    "end": 66.8,
    "speaker": "曉臻",
    "text": "還有 什麼例子嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.0,
    "end": 69.89,
    "speaker": "彥君",
    "text": "像是 煙火裡的火藥",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.09,
    "end": 72.9,
    "speaker": "彥君",
    "text": "一點火 就瞬間爆發",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.1,
    "end": 76.16,
    "speaker": "彥君",
    "text": "但 暖暖包裡的鐵粉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.36,
    "end": 79.56,
    "speaker": "彥君",
    "text": "卻是 慢慢發熱一整天",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.76,
    "end": 83.39,
    "speaker": "曉臻",
    "text": "喔 還有古蹟的銅屋頂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.59,
    "end": 86.6,
    "speaker": "曉臻",
    "text": "要好幾年 才會變綠色",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.8,
    "end": 89.54,
    "speaker": "彥君",
    "text": "但如果 把鈉切開",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.74,
    "end": 92.82,
    "speaker": "彥君",
    "text": "幾秒鐘 表面就變暗了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.02,
    "end": 95.91,
    "speaker": "彥君",
    "text": "這就是 本性的差異",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.11,
    "end": 98.98,
    "speaker": "曉臻",
    "text": "第二個 因素是表面積",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.18,
    "end": 101.73,
    "speaker": "曉臻",
    "text": "就像 糖粉比方糖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.93,
    "end": 104.24,
    "speaker": "曉臻",
    "text": "溶得 更快對吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.44,
    "end": 108.67,
    "speaker": "彥君",
    "text": "沒錯 接觸面越大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.87,
    "end": 111.81,
    "speaker": "彥君",
    "text": "碰撞的 機會就越多",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.01,
    "end": 114.94,
    "speaker": "彥君",
    "text": "烤肉的時候 劈柴",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.14,
    "end": 118.34,
    "speaker": "彥君",
    "text": "木片 絕對比整根原木",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.54,
    "end": 121.14,
    "speaker": "彥君",
    "text": "還要 容易生火",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.34,
    "end": 123.7,
    "speaker": "曉臻",
    "text": "難怪 醫生都說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.9,
    "end": 126.82,
    "speaker": "曉臻",
    "text": "胃藥 咬碎吃會更快好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 127.02,
    "end": 130.07,
    "speaker": "彥君",
    "text": "因為 咬碎增加表面積",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.27,
    "end": 133.33,
    "speaker": "彥君",
    "text": "中和胃酸 的速度就快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 133.53,
    "end": 136.58,
    "speaker": "曉臻",
    "text": "那第三個 濃度跟壓力呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.78,
    "end": 139.7,
    "speaker": "彥君",
    "text": "房間裡 人擠得越多",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.9,
    "end": 143.07,
    "speaker": "彥君",
    "text": "越容易 互相撞在一起",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.27,
    "end": 146.21,
    "speaker": "彥君",
    "text": "例如 洗廁所的時候",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.41,
    "end": 149.61,
    "speaker": "彥君",
    "text": "濃鹽酸 冒泡超級快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.81,
    "end": 153.01,
    "speaker": "彥君",
    "text": "稀鹽酸 就慢慢咬污垢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.21,
    "end": 155.95,
    "speaker": "曉臻",
    "text": "如果是 氣體的壓力呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.15,
    "end": 159.16,
    "speaker": "彥君",
    "text": "仙女棒 在空氣中燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.36,
    "end": 162.25,
    "speaker": "彥君",
    "text": "亮度 只有普通亮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.45,
    "end": 165.62,
    "speaker": "彥君",
    "text": "但如果 丟進純氧瓶裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.82,
    "end": 168.95,
    "speaker": "彥君",
    "text": "濃度極高 就會爆閃亮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 169.15,
    "end": 172.21,
    "speaker": "曉臻",
    "text": "老師 第五個催化劑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 172.41,
    "end": 174.98,
    "speaker": "曉臻",
    "text": "空格 到底要填什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.18,
    "end": 178.38,
    "speaker": "彥君",
    "text": "催化劑 最偉大的功能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 178.58,
    "end": 181.38,
    "speaker": "彥君",
    "text": "就是 降低活化能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.58,
    "end": 188.28,
    "speaker": "彥君",
    "text": "降低活化能、質量不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 188.48,
    "end": 190.96,
    "speaker": "曉臻",
    "text": "什麼是 活化能啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 191.16,
    "end": 194.22,
    "speaker": "彥君",
    "text": "它就像 一座很高的大山",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 194.42,
    "end": 197.88,
    "speaker": "彥君",
    "text": "催化劑 就是幫你開隧道",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 198.08,
    "end": 200.92,
    "speaker": "彥君",
    "text": "讓你 抄捷徑過去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 201.12,
    "end": 203.82,
    "speaker": "彥君",
    "text": "所以 反應變快了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 204.02,
    "end": 206.66,
    "speaker": "曉臻",
    "text": "那它 會被消耗掉嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 206.86,
    "end": 211.22,
    "speaker": "彥君",
    "text": "絕對不會 質量不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 211.42,
    "end": 214.28,
    "speaker": "彥君",
    "text": "而且 它有專一性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 214.48,
    "end": 217.58,
    "speaker": "彥君",
    "text": "唾液 只能分解澱粉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 217.78,
    "end": 220.55,
    "speaker": "彥君",
    "text": "對蛋白質 就沒輒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 220.75,
    "end": 223.42,
    "speaker": "曉臻",
    "text": "最後 右邊那個圖標",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 223.62,
    "end": 226.66,
    "speaker": "曉臻",
    "text": "溫度曲線 往上衝好快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 226.86,
    "end": 230.08,
    "speaker": "彥君",
    "text": "戰士們， 畫三顆星！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 230.28,
    "end": 233.24,
    "speaker": "彥君",
    "text": "增加 速率殺手鐧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 233.44,
    "end": 236.18,
    "speaker": "彥君",
    "text": "絕對 就是加熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 236.38,
    "end": 239.3,
    "speaker": "彥君",
    "text": "溫度 只要上升一點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 239.5,
    "end": 242.58,
    "speaker": "彥君",
    "text": "速率 就會指數狂飆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 242.78,
    "end": 245.28,
    "speaker": "曉臻",
    "text": "難怪 夏天的便當",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 245.48,
    "end": 248.3,
    "speaker": "曉臻",
    "text": "一個下午 就酸掉壞了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 248.5,
    "end": 252.73,
    "speaker": "彥君",
    "text": "沒錯 所以我們要",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 252.93,
    "end": 256.15,
    "speaker": "彥君",
    "text": "把食物 放進冰箱冷凍",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 256.35,
    "end": 259.5,
    "speaker": "彥君",
    "text": "降溫 就能減緩腐敗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 259.7,
    "end": 262.35,
    "speaker": "曉臻",
    "text": "還有 我們感冒發燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 262.55,
    "end": 265.01,
    "speaker": "曉臻",
    "text": "只要 體溫一變高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 265.21,
    "end": 268.46,
    "speaker": "曉臻",
    "text": "心跳呼吸 也會跟著變快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 268.66,
    "end": 271.69,
    "speaker": "彥君",
    "text": "這就是 生理反應變快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 271.89,
    "end": 274.78,
    "speaker": "彥君",
    "text": "溫度 真的決定一切",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 274.98,
    "end": 278.42,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 278.62,
    "end": 281.22,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 281.42,
    "end": 283.75,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 283.95,
    "end": 287.3,
    "speaker": "合聲",
    "text": "開鑿隧道 加熱狂飆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 287.5,
    "end": 291.03,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 4.81,
    "speaker": "彥君",
    "text": "戰士們 光明就在不遠的前方",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 5.01,
    "end": 8.59,
    "speaker": "彥君",
    "text": "只要順著光走就能看見希望",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 8.79,
    "end": 12.35,
    "speaker": "彥君",
    "text": "各位衝刺 $A^{++}$ 級的戰士們",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$A^{++}$"
    ]
  },
  {
    "start": 12.55,
    "end": 15.97,
    "speaker": "彥君",
    "text": "恭喜大家來到第七十四集囉",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 16.17,
    "end": 19.68,
    "speaker": "彥君",
    "text": "戰士們好 我是彥君老師",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 19.88,
    "end": 23.18,
    "speaker": "曉臻",
    "text": "大家好啊 我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 23.38,
    "end": 26.91,
    "speaker": "曉臻",
    "text": "老師終於進入光學基本單元",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 27.11,
    "end": 30.84,
    "speaker": "彥君",
    "text": "戰士們光學基礎就在這張圖",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 31.04,
    "end": 34.74,
    "speaker": "彥君",
    "text": "光的傳播絕對是直線前進的",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 34.94,
    "end": 38.72,
    "speaker": "彥君",
    "text": "所以我們常常稱呼它為光線",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 38.92,
    "end": 42.22,
    "speaker": "曉臻",
    "text": "因為光走直線被擋住的地方",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 42.42,
    "end": 45.83,
    "speaker": "曉臻",
    "text": "就會產生黑黑的影子出來了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 46.03,
    "end": 51.08,
    "speaker": "彥君",
    "text": "沒錯 影子就是光直線前進",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 51.28,
    "end": 54.72,
    "speaker": "彥君",
    "text": "在自然界裡面最好的證明喔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 54.92,
    "end": 58.43,
    "speaker": "曉臻",
    "text": "右邊那棵大樹就是非常經典",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 58.63,
    "end": 61.88,
    "speaker": "曉臻",
    "text": "考試愛考的針孔成像對吧",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 62.08,
    "end": 67.15,
    "speaker": "彥君",
    "text": "是的 記住光學的一個大原則",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 67.35,
    "end": 70.84,
    "speaker": "彥君",
    "text": "只要有一個小洞就會有一個像",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 71.04,
    "end": 74.31,
    "speaker": "曉臻",
    "text": "所以講義的空格如果三個洞",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 74.51,
    "end": 78.02,
    "speaker": "曉臻",
    "text": "照理說就會產生三個像出來",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 78.22,
    "end": 83.18,
    "speaker": "彥君",
    "text": "舉一反三喔 老師補充大考點",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 83.38,
    "end": 86.89,
    "speaker": "彥君",
    "text": "大家有沒有注意過大太陽天",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 87.09,
    "end": 90.65,
    "speaker": "彥君",
    "text": "在大樹底下的陰影處地面上",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 90.85,
    "end": 94.53,
    "speaker": "彥君",
    "text": "常常看到很多圓形的亮白點",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 94.73,
    "end": 98.24,
    "speaker": "曉臻",
    "text": "有啊以前都以為只是光斑耶",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 98.44,
    "end": 101.83,
    "speaker": "彥君",
    "text": "其實那每一個圓形的亮白點",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 102.03,
    "end": 105.35,
    "speaker": "彥君",
    "text": "全部都是大太陽的成像喔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 105.55,
    "end": 108.97,
    "speaker": "彥君",
    "text": "因為樹葉之間的每個小縫隙",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 109.17,
    "end": 112.75,
    "speaker": "彥君",
    "text": "都可以看成是一個小小針孔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 112.95,
    "end": 116.66,
    "speaker": "彥君",
    "text": "每個小洞都是一個針孔成像",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 116.86,
    "end": 120.39,
    "speaker": "彥君",
    "text": "所以上面有幾個樹葉的縫隙",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 120.59,
    "end": 124.25,
    "speaker": "彥君",
    "text": "底下就會看到幾個圓形亮點",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 124.45,
    "end": 127.79,
    "speaker": "彥君",
    "text": "也就是出現幾個太陽的像喔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 127.99,
    "end": 132.32,
    "speaker": "曉臻",
    "text": "哇 洞多像多這連結太厲害了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 132.52,
    "end": 135.67,
    "speaker": "彥君",
    "text": "那如果我們把洞挖得很大呢",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 135.87,
    "end": 139.53,
    "speaker": "曉臻",
    "text": "洞變大光線重疊就會變模糊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 139.73,
    "end": 143.1,
    "speaker": "曉臻",
    "text": "所以就會變成模糊不清的像",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 143.3,
    "end": 147.1,
    "speaker": "彥君",
    "text": "非常好我們把空格答案釘上",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 147.3,
    "end": 207.26,
    "speaker": "彥君",
    "text": "① 填空： $3$ 個像、模糊的像",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選",
      "① 填空： $3$ 個像、模糊的像"
    ]
  },
  {
    "start": 151.44,
    "end": 155.07,
    "speaker": "彥君",
    "text": "這裡有個超級重點寫進筆記",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 155.27,
    "end": 159.0,
    "speaker": "彥君",
    "text": "針孔成像所產生出來的成像",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 159.2,
    "end": 162.78,
    "speaker": "彥君",
    "text": "它一定是上下顛倒左右相反",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 162.98,
    "end": 207.26,
    "speaker": "彥君",
    "text": "② 針孔成像必為上下顛倒左右相反",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選",
      "② 針孔成像必為上下顛倒左右相反"
    ]
  },
  {
    "start": 167.34,
    "end": 170.76,
    "speaker": "曉臻",
    "text": "原來上下左右全部都顛倒啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 170.96,
    "end": 174.35,
    "speaker": "曉臻",
    "text": "記起來了針孔就是顛倒顛倒",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 174.55,
    "end": 179.6,
    "speaker": "彥君",
    "text": "沒錯 接著看左下角的圖形",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 179.8,
    "end": 183.46,
    "speaker": "彥君",
    "text": "反射定律在任何表面都成立",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 183.66,
    "end": 186.98,
    "speaker": "曉臻",
    "text": "入射角等於反射角這個定律",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 187.18,
    "end": 190.4,
    "speaker": "曉臻",
    "text": "也就是 $i=r$ 對不對啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$i=r$"
    ]
  },
  {
    "start": 190.6,
    "end": 195.67,
    "speaker": "彥君",
    "text": "沒錯 戰士們特別注意角度",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 195.87,
    "end": 199.6,
    "speaker": "彥君",
    "text": "必須是和中間那條法線夾角",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 199.8,
    "end": 207.26,
    "speaker": "彥君",
    "text": "③ 反射定律： $\\angle i = \\angle r$ (與法線夾角)",
    "is_pinned": true,
    "pin_level": 3,
    "commands": [
      "釘選",
      "③ 反射定律： $\\angle i = \\angle r$ (與法線夾角)"
    ]
  },
  {
    "start": 207.26,
    "end": 211.7,
    "speaker": "曉臻",
    "text": "哇 這集光學基礎補充考點後",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 211.9,
    "end": 215.25,
    "speaker": "曉臻",
    "text": "整個觀念變得超級好懂了耶",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 215.45,
    "end": 219.34,
    "speaker": "彥君",
    "text": "觀念全通了秒殺考題沒問題",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 219.54,
    "end": 222.82,
    "speaker": "彥君",
    "text": "帶著這份底氣迎戰會考吧",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 223.02,
    "end": 226.5,
    "speaker": "彥君",
    "text": "戰士們 我是彥君老師",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {

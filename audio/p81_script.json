    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 11.9,
    "end": 17.4,
    "speaker": "彥君",
    "text": "歡迎來到第八十一集熱學大挑戰",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 17.6,
    "end": 21.02,
    "speaker": "曉臻",
    "text": "老師講義上第一個空格",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 21.22,
    "end": 24.85,
    "speaker": "曉臻",
    "text": "熱量到底是從哪裡傳到哪裡啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 25.05,
    "end": 29.21,
    "speaker": "彥君",
    "text": "戰士們注意熱量就像水流一樣",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 29.41,
    "end": 33.52,
    "speaker": "彥君",
    "text": "它一定是由高溫傳向低溫的地方",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 33.72,
    "end": 160.9,
    "speaker": "彥君",
    "text": "熱量傳遞：高溫 $$\\rightarrow$$ 低溫",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選",
      "熱量傳遞：高溫 $$\\rightarrow$$ 低溫"
    ]
  },
  {
    "start": 37.6,
    "end": 42.38,
    "speaker": "曉臻",
    "text": "喔所以絕對不是熱量多傳給熱量少",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 42.58,
    "end": 47.7,
    "speaker": "彥君",
    "text": "沒錯這是理化超級必考題",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 47.9,
    "end": 52.3,
    "speaker": "彥君",
    "text": "熱量流動只看溫度高低不看熱量多寡",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 52.5,
    "end": 55.46,
    "speaker": "曉臻",
    "text": "那熱的傳播方式有三種",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 55.66,
    "end": 59.15,
    "speaker": "曉臻",
    "text": "分別是傳導、對流跟輻射",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 59.35,
    "end": 63.3,
    "speaker": "彥君",
    "text": "傳導最簡單就是互相接觸",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 63.5,
    "end": 66.53,
    "speaker": "彥君",
    "text": "通常發生在固體",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 66.73,
    "end": 160.9,
    "speaker": "彥君",
    "text": "傳導：固體為主，需互相接觸",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選",
      "傳導：固體為主，需互相接觸"
    ]
  },
  {
    "start": 71.18,
    "end": 74.84,
    "speaker": "曉臻",
    "text": "就像是不小心摸到熱鍋子被燙到",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 75.04,
    "end": 79.99,
    "speaker": "彥君",
    "text": "對其中又以金屬傳導最快",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 80.19,
    "end": 84.86,
    "speaker": "彥君",
    "text": "所以鍋子的把手都會用塑膠或木頭來做",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 85.06,
    "end": 89.1,
    "speaker": "曉臻",
    "text": "因為它們傳導很慢才不會燙傷手",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 89.3,
    "end": 93.05,
    "speaker": "曉臻",
    "text": "老師我想到一個生活陷阱題",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 93.25,
    "end": 96.76,
    "speaker": "曉臻",
    "text": "為什麼冬天光腳踩在磁磚上",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 96.96,
    "end": 100.02,
    "speaker": "曉臻",
    "text": "感覺比木地板還要冷啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 100.22,
    "end": 105.89,
    "speaker": "彥君",
    "text": "戰士們這是超級經典陷阱看好了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 106.09,
    "end": 110.01,
    "speaker": "彥君",
    "text": "同一個房間裡磁磚跟木地板",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 110.21,
    "end": 113.24,
    "speaker": "彥君",
    "text": "溫度其實是一模一樣的喔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 113.44,
    "end": 118.46,
    "speaker": "曉臻",
    "text": "溫度明明一樣那為什麼踩磁磚會覺得冷",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 118.66,
    "end": 122.42,
    "speaker": "彥君",
    "text": "因為磁磚傳導熱量的速度太快了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 122.62,
    "end": 126.39,
    "speaker": "彥君",
    "text": "它瞬間把腳底的熱給傳導帶走",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 126.59,
    "end": 129.53,
    "speaker": "彥君",
    "text": "你才會覺得特別冷",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 129.73,
    "end": 134.13,
    "speaker": "曉臻",
    "text": "哇原來一切都是大腦的錯覺",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 134.33,
    "end": 138.56,
    "speaker": "彥君",
    "text": "而木頭傳導比較慢熱量不容易流失",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 138.76,
    "end": 143.02,
    "speaker": "彥君",
    "text": "另外空氣也是傳導非常慢的物質喔",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 143.22,
    "end": 145.36,
    "speaker": "曉臻",
    "text": "空氣也算嗎",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 145.56,
    "end": 150.39,
    "speaker": "彥君",
    "text": "對冬天我們穿蓬鬆的羽絨衣",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 150.59,
    "end": 154.13,
    "speaker": "彥君",
    "text": "就是把空氣抓在衣服裡面",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 154.33,
    "end": 157.7,
    "speaker": "彥君",
    "text": "讓身體的熱量傳不出去",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 160.9,
    "end": 164.1,
    "speaker": "曉臻",
    "text": "哇原來是這樣",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 164.3,
    "end": 169.03,
    "speaker": "曉臻",
    "text": "那對流呢旁邊的圖為什麼箭頭往上",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 169.23,
    "end": 173.01,
    "speaker": "彥君",
    "text": "對流主要發生在氣體還有液體",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 173.21,
    "end": 178.33,
    "speaker": "彥君",
    "text": "它們變熱就會膨脹密度變小就會往上浮",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 178.53,
    "end": 324.45,
    "speaker": "彥君",
    "text": "對流：流體受熱膨脹，密度變小上升",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選",
      "對流：流體受熱膨脹，密度變小上升"
    ]
  },
  {
    "start": 183.32,
    "end": 187.41,
    "speaker": "曉臻",
    "text": "所以變冷密度變大就會往下沉囉",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 187.61,
    "end": 193.14,
    "speaker": "彥君",
    "text": "答對了戰士們注意生活考題來了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 193.34,
    "end": 197.09,
    "speaker": "彥君",
    "text": "冷氣機應該要裝在房間的哪裡",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 197.29,
    "end": 201.9,
    "speaker": "曉臻",
    "text": "冷空氣會往下沉所以冷氣要裝在高處",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 202.1,
    "end": 207.99,
    "speaker": "彥君",
    "text": "沒錯裝在上面冷風下沉吹到人",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 208.19,
    "end": 211.27,
    "speaker": "彥君",
    "text": "整個房間才會涼得快",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 211.47,
    "end": 215.7,
    "speaker": "曉臻",
    "text": "那冬天的暖氣機熱空氣會往上飄",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 215.9,
    "end": 219.46,
    "speaker": "曉臻",
    "text": "所以暖氣機要放在地上最有效",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 219.66,
    "end": 224.95,
    "speaker": "彥君",
    "text": "完全正確這就是對流的完美應用",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 225.15,
    "end": 229.38,
    "speaker": "彥君",
    "text": "講到對流還有一個超常考的大魔王",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 229.58,
    "end": 234.25,
    "speaker": "曉臻",
    "text": "是海水跟沙子白天晚上的海陸風考題嗎",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 234.45,
    "end": 239.81,
    "speaker": "彥君",
    "text": "沒錯這題完美結合了比熱的觀念",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 240.01,
    "end": 243.83,
    "speaker": "彥君",
    "text": "水的比熱很大難冷又難熱",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 244.03,
    "end": 248.19,
    "speaker": "彥君",
    "text": "沙子的比熱小容易冷也容易熱",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 248.39,
    "end": 251.64,
    "speaker": "曉臻",
    "text": "所以白天出大太陽的時候",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 251.84,
    "end": 254.37,
    "speaker": "曉臻",
    "text": "陸地會變得很燙",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 254.57,
    "end": 258.22,
    "speaker": "彥君",
    "text": "陸地溫度高空氣受熱上升",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 258.42,
    "end": 261.19,
    "speaker": "彥君",
    "text": "就會形成低氣壓",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 261.39,
    "end": 265.98,
    "speaker": "彥君",
    "text": "相反的海水溫度低空氣下沉",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 266.18,
    "end": 269.02,
    "speaker": "彥君",
    "text": "就會形成高氣壓",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 269.22,
    "end": 272.4,
    "speaker": "曉臻",
    "text": "風是從高壓吹向低壓的",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 272.6,
    "end": 277.14,
    "speaker": "曉臻",
    "text": "所以白天風從海吹向陸地就是吹海風",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 277.34,
    "end": 324.45,
    "speaker": "彥君",
    "text": "白天：陸熱海冷 $$\\rightarrow$$ 吹海風",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選",
      "白天：陸熱海冷 $$\\rightarrow$$ 吹海風"
    ]
  },
  {
    "start": 281.34,
    "end": 287.52,
    "speaker": "彥君",
    "text": "完全正確風從海上吹過來就叫做海風",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 287.72,
    "end": 292.07,
    "speaker": "曉臻",
    "text": "那晚上沒有太陽情況就剛好相反囉",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 292.27,
    "end": 298.09,
    "speaker": "彥君",
    "text": "對晚上沙子冷得很快陸地變成高氣壓",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 298.29,
    "end": 303.02,
    "speaker": "彥君",
    "text": "而海水還溫溫的空氣上升變成低氣壓",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 303.22,
    "end": 306.69,
    "speaker": "曉臻",
    "text": "風從陸地的滿滿高壓吹出去",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 306.89,
    "end": 309.75,
    "speaker": "曉臻",
    "text": "所以晚上就吹陸風",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 309.95,
    "end": 324.45,
    "speaker": "彥君",
    "text": "夜晚：陸冷海熱 $$\\rightarrow$$ 吹陸風",
    "is_pinned": true,
    "pin_level": 3,
    "commands": [
      "釘選",
      "夜晚：陸冷海熱 $$\\rightarrow$$ 吹陸風"
    ]
  },
  {
    "start": 314.07,
    "end": 316.53,
    "speaker": "彥君",
    "text": "助教一百分",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 316.73,
    "end": 321.25,
    "speaker": "彥君",
    "text": "把對流結合地科氣壓大考絕對難不倒你",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 324.45,
    "end": 329.28,
    "speaker": "曉臻",
    "text": "老師最後的輻射又是什麼神奇原理啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 329.48,
    "end": 333.71,
    "speaker": "彥君",
    "text": "輻射最特別它完全不需要介質",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 333.91,
    "end": 337.78,
    "speaker": "彥君",
    "text": "它是以光波的形式直接傳遞熱量",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 337.98,
    "end": 400.25,
    "speaker": "彥君",
    "text": "輻射：不需介質，以電磁波傳遞",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選",
      "輻射：不需介質，以電磁波傳遞"
    ]
  },
  {
    "start": 342.63,
    "end": 345.47,
    "speaker": "曉臻",
    "text": "不用任何交通工具嗎",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 345.67,
    "end": 351.46,
    "speaker": "彥君",

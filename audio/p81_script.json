    "pin_level": 0
  },
  {
    "start": 312.31,
    "end": 315.39,
    "speaker": "彥君",
    "text": "完全 不需要介質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 315.59,
    "end": 318.67,
    "speaker": "彥君",
    "text": "是以 光波形式傳遞",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 318.87,
    "end": 321.35,
    "speaker": "曉臻",
    "text": "不用 交通工具嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 321.55,
    "end": 325.59,
    "speaker": "彥君",

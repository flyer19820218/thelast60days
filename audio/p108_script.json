[
  {
    "start": 0.0,
    "end": 3.66,
    "speaker": "彥君",
    "text": "戰士們 深深吸一口氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.86,
    "end": 6.48,
    "speaker": "彥君",
    "text": "覺得 快要斷氣了嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.68,
    "end": 9.76,
    "speaker": "曉臻",
    "text": "老師 學完液體壓力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.96,
    "end": 12.54,
    "speaker": "曉臻",
    "text": "腦袋 已經快爆炸了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.74,
    "end": 17.45,
    "speaker": "彥君",
    "text": "撐住 把剛吸進去的空氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 17.65,
    "end": 20.73,
    "speaker": "彥君",
    "text": "想像成 超輕的液體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.93,
    "end": 24.22,
    "speaker": "彥君",
    "text": "歡迎來到 第 108 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.42,
    "end": 27.07,
    "speaker": "彥君",
    "text": "[戰士們注意 ]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.27,
    "end": 30.02,
    "speaker": "彥君",
    "text": "其實 我們都活在",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.22,
    "end": 33.56,
    "speaker": "彥君",
    "text": "一片 深深的空氣海底部",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.76,
    "end": 36.07,
    "speaker": "曉臻",
    "text": "所以 大氣壓力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.27,
    "end": 39.28,
    "speaker": "曉臻",
    "text": "就是 頭頂空氣的重量嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.48,
    "end": 41.86,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.06,
    "end": 44.83,
    "speaker": "彥君",
    "text": "可是 空氣抓不到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.03,
    "end": 47.63,
    "speaker": "彥君",
    "text": "要怎麼 測量壓力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.83,
    "end": 50.53,
    "speaker": "曉臻",
    "text": "左邊的圖 畫了管子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.73,
    "end": 53.5,
    "speaker": "曉臻",
    "text": "這是 托里切利實驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.7,
    "end": 58.31,
    "speaker": "彥君",
    "text": "沒錯 他用了 最重的液體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.51,
    "end": 61.45,
    "speaker": "彥君",
    "text": "也就是 水銀來測量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.65,
    "end": 91.39,
    "speaker": "彥君",
    "text": "[$P_{大} = 76 \\text{ cm-Hg}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 66.2,
    "end": 69.14,
    "speaker": "曉臻",
    "text": "老師 左邊的管子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.34,
    "end": 71.84,
    "speaker": "曉臻",
    "text": "就算 弄得斜斜的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.04,
    "end": 75.19,
    "speaker": "曉臻",
    "text": "高度 還是 76 公分耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.39,
    "end": 78.47,
    "speaker": "彥君",
    "text": "這就是 剛學過的觀念",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.67,
    "end": 81.68,
    "speaker": "彥君",
    "text": "壓力 只看垂直深度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.88,
    "end": 84.94,
    "speaker": "彥君",
    "text": "不管 管子怎麼傾斜",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 85.14,
    "end": 88.19,
    "speaker": "彥君",
    "text": "垂直高度 絕對不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.39,
    "end": 91.88,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘深呼吸]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.08,
    "end": 95.81,
    "speaker": "彥君",
    "text": "[戰士們 終極挑戰來了]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.01,
    "end": 98.8,
    "speaker": "彥君",
    "text": "看看 右邊的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.0,
    "end": 101.96,
    "speaker": "彥君",
    "text": "如果 把水銀換成水呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.16,
    "end": 105.22,
    "speaker": "曉臻",
    "text": "算式寫著 水的密度是 1",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.42,
    "end": 108.16,
    "speaker": "曉臻",
    "text": "乘上 水柱的高度 H",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.36,
    "end": 111.58,
    "speaker": "曉臻",
    "text": "會等於 1033.6",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.78,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$1 \\times H = 1033.6$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 116.46,
    "end": 118.89,
    "speaker": "彥君",
    "text": "換算下來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.09,
    "end": 121.74,
    "speaker": "彥君",
    "text": "大約是 10 公尺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.94,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$P_{大} \\approx 10 \\text{ m}$]",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 126.25,
    "end": 129.33,
    "speaker": "曉臻",
    "text": "哇 十公尺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.53,
    "end": 132.22,
    "speaker": "曉臻",
    "text": "那可是 三層樓高耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.42,
    "end": 135.74,
    "speaker": "彥君",
    "text": "所以 如果用水做實驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.94,
    "end": 138.88,
    "speaker": "彥君",
    "text": "管子 會捅破天花板",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.08,
    "end": 142.16,
    "speaker": "彥君",
    "text": "托里切利 真的很聰明",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.36,
    "end": 145.8,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.0,
    "end": 148.6,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.8,
    "end": 151.14,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.34,
    "end": 154.82,
    "speaker": "合聲",
    "text": "水銀七六 水柱十米",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.02,
    "end": 158.56,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
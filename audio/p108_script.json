[
  {
    "start": 0.0,
    "end": 3.66,
    "speaker": "彥君",
    "text": "戰士們 深深吸一口氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.86,
    "end": 6.48,
    "speaker": "彥君",
    "text": "覺得 快要斷氣了嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.68,
    "end": 9.76,
    "speaker": "曉臻",
    "text": "老師 學完液體壓力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.96,
    "end": 12.54,
    "speaker": "曉臻",
    "text": "腦袋 已經快爆炸了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.74,
    "end": 17.45,
    "speaker": "彥君",
    "text": "撐住 把剛吸進去的空氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 17.65,
    "end": 20.73,
    "speaker": "彥君",
    "text": "想像成 超輕的液體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.93,
    "end": 24.22,
    "speaker": "彥君",
    "text": "歡迎來到 第 108 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.42,
    "end": 26.88,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.08,
    "end": 29.82,
    "speaker": "彥君",
    "text": "其實 我們都活在",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.02,
    "end": 33.37,
    "speaker": "彥君",
    "text": "一片 深深的空氣海底部",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.57,
    "end": 35.88,
    "speaker": "曉臻",
    "text": "所以 大氣壓力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.08,
    "end": 39.09,
    "speaker": "曉臻",
    "text": "就是 頭頂空氣的重量嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.29,
    "end": 41.67,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.87,
    "end": 44.64,
    "speaker": "彥君",
    "text": "可是 空氣抓不到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.84,
    "end": 47.44,
    "speaker": "彥君",
    "text": "要怎麼 測量壓力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.64,
    "end": 50.34,
    "speaker": "曉臻",
    "text": "左邊的圖 畫了管子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.54,
    "end": 53.3,
    "speaker": "曉臻",
    "text": "這是 托里切利實驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.5,
    "end": 58.12,
    "speaker": "彥君",
    "text": "沒錯 他用了 最重的液體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.32,
    "end": 61.26,
    "speaker": "彥君",
    "text": "也就是 水銀來測量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.46,
    "end": 94.55,
    "speaker": "彥君",
    "text": "$P_{大} = 76 \\text{ cm-Hg}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 66.01,
    "end": 68.94,
    "speaker": "曉臻",
    "text": "老師 左邊的管子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.14,
    "end": 71.65,
    "speaker": "曉臻",
    "text": "就算 弄得斜斜的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.85,
    "end": 75.0,
    "speaker": "曉臻",
    "text": "高度 還是 76 公分耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.2,
    "end": 78.28,
    "speaker": "彥君",
    "text": "這就是 剛學過的觀念",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.48,
    "end": 81.49,
    "speaker": "彥君",
    "text": "壓力 只看垂直深度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.69,
    "end": 84.74,
    "speaker": "彥君",
    "text": "不管 管子怎麼傾斜",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.94,
    "end": 88.0,
    "speaker": "彥君",
    "text": "垂直高度 絕對不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.2,
    "end": 91.35,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘深呼吸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.55,
    "end": 98.02,
    "speaker": "彥君",
    "text": "戰士們 終極挑戰來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.22,
    "end": 101.01,
    "speaker": "彥君",
    "text": "看看 右邊的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.21,
    "end": 104.17,
    "speaker": "彥君",
    "text": "如果 把水銀換成水呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.37,
    "end": 107.42,
    "speaker": "曉臻",
    "text": "算式寫著 水的密度是 1",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.62,
    "end": 110.37,
    "speaker": "曉臻",
    "text": "乘上 水柱的高度 H",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 110.57,
    "end": 113.79,
    "speaker": "曉臻",
    "text": "會等於 1033.6",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.99,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$1 \\times H = 1033.6$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 118.66,
    "end": 121.1,
    "speaker": "彥君",
    "text": "換算下來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.3,
    "end": 123.94,
    "speaker": "彥君",
    "text": "大約是 10 公尺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.14,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$P_{大} \\approx 10 \\text{ m}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 128.46,
    "end": 131.54,
    "speaker": "曉臻",
    "text": "哇 十公尺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.74,
    "end": 134.43,
    "speaker": "曉臻",
    "text": "那可是 三層樓高耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.63,
    "end": 137.95,
    "speaker": "彥君",
    "text": "所以 如果用水做實驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.15,
    "end": 141.09,
    "speaker": "彥君",
    "text": "管子 會捅破天花板",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.29,
    "end": 144.37,
    "speaker": "彥君",
    "text": "托里切利 真的很聰明",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.57,
    "end": 148.01,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.21,
    "end": 150.81,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.01,
    "end": 153.34,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.54,
    "end": 157.03,
    "speaker": "合聲",
    "text": "水銀七六 水柱十米",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.23,
    "end": 160.77,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
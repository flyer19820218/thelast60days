[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.12,
    "speaker": "彥君",
    "text": "第 116 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.32,
    "end": 9.62,
    "speaker": "彥君",
    "text": "準備會考 就像畫圖形",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.82,
    "end": 13.3,
    "speaker": "彥君",
    "text": "有時靜止 有時加速",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.5,
    "end": 16.58,
    "speaker": "彥君",
    "text": "只要看懂 自己的座標",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.78,
    "end": 20.01,
    "speaker": "彥君",
    "text": "填空題 絕對能拿滿分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.21,
    "end": 22.81,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.01,
    "end": 24.74,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.94,
    "end": 27.28,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.48,
    "end": 29.94,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.14,
    "end": 33.19,
    "speaker": "彥君",
    "text": "這是必考的 雙圖對決",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.39,
    "end": 36.16,
    "speaker": "曉臻",
    "text": "老師 左邊寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.36,
    "end": 39.46,
    "speaker": "曉臻",
    "text": "速度圖的面積 等於位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.66,
    "end": 44.47,
    "speaker": "彥君",
    "text": "沒錯 只要算出藍色面積",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.67,
    "end": 47.58,
    "speaker": "彥君",
    "text": "就能 知道跑了多遠",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.78,
    "end": 57.78,
    "speaker": "彥君",
    "text": "$v-t \\text{ 面積} \\rightarrow \\text{位移}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 51.62,
    "end": 54.58,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘記憶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.78,
    "end": 61.05,
    "speaker": "彥君",
    "text": "接著看 右上角位置圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.25,
    "end": 64.14,
    "speaker": "曉臻",
    "text": "旁邊有 三個填空題耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.34,
    "end": 67.01,
    "speaker": "彥君",
    "text": "我們來 一個個破解",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.21,
    "end": 70.24,
    "speaker": "彥君",
    "text": "第一段 位置穩定增加",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.44,
    "end": 73.23,
    "speaker": "彥君",
    "text": "這是 等速度運動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.43,
    "end": 111.1,
    "speaker": "彥君",
    "text": "$\\text{位置圖 } 1 \\rightarrow \\text{等速}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 77.72,
    "end": 80.61,
    "speaker": "曉臻",
    "text": "第二段 是平平的橫線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.81,
    "end": 84.01,
    "speaker": "曉臻",
    "text": "位置沒變 當然是靜止",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.21,
    "end": 88.2,
    "speaker": "彥君",
    "text": "漂亮 填上去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.4,
    "end": 111.1,
    "speaker": "彥君",
    "text": "$\\text{位置圖 } 2 \\rightarrow \\text{靜止}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 92.45,
    "end": 95.1,
    "speaker": "曉臻",
    "text": "第三段 往下折返了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.3,
    "end": 97.78,
    "speaker": "曉臻",
    "text": "也是 等速度運動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.98,
    "end": 100.07,
    "speaker": "彥君",
    "text": "沒錯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.27,
    "end": 111.1,
    "speaker": "彥君",
    "text": "$\\text{位置圖 } 3 \\rightarrow \\text{等速}$",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 104.68,
    "end": 107.9,
    "speaker": "彥君",
    "text": "戰士們 趕快抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.1,
    "end": 114.16,
    "speaker": "彥君",
    "text": "來看 右下角速度圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.36,
    "end": 117.34,
    "speaker": "曉臻",
    "text": "老師 第一段往上衝",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.54,
    "end": 120.82,
    "speaker": "曉臻",
    "text": "速度變快了 是等加速",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.02,
    "end": 123.4,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.6,
    "end": 169.99,
    "speaker": "彥君",
    "text": "$\\text{速度圖 } 1 \\rightarrow \\text{等加速}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 128.06,
    "end": 130.87,
    "speaker": "曉臻",
    "text": "第二段 變成平平的線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.07,
    "end": 134.25,
    "speaker": "曉臻",
    "text": "速度維持 是等速度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.45,
    "end": 139.18,
    "speaker": "彥君",
    "text": "非常好 這就是最大陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.38,
    "end": 142.56,
    "speaker": "彥君",
    "text": "位置圖的平線 是靜止",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.76,
    "end": 146.27,
    "speaker": "彥君",
    "text": "速度圖的平線 卻是等速",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.47,
    "end": 169.99,
    "speaker": "彥君",
    "text": "$\\text{速度圖 } 2 \\rightarrow \\text{等速}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 150.78,
    "end": 153.46,
    "speaker": "曉臻",
    "text": "第三段 速度往下掉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.66,
    "end": 156.81,
    "speaker": "曉臻",
    "text": "變慢了 是減速度運動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.01,
    "end": 159.58,
    "speaker": "彥君",
    "text": "助教 太聰明了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.78,
    "end": 169.99,
    "speaker": "彥君",
    "text": "$\\text{速度圖 } 3 \\rightarrow \\text{減速}$",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 164.1,
    "end": 166.79,
    "speaker": "彥君",
    "text": "再給你們 3 秒鐘",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 169.99,
    "end": 173.43,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.63,
    "end": 176.23,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 176.43,
    "end": 178.77,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 178.97,
    "end": 182.29,
    "speaker": "合聲",
    "text": "看清座標 填空秒殺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 182.49,
    "end": 186.02,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.05,
    "speaker": "彥君",
    "text": "第 130 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.25,
    "end": 9.38,
    "speaker": "彥君",
    "text": "有些知識 雖然考得少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.58,
    "end": 12.75,
    "speaker": "彥君",
    "text": "卻是 現代文明的基石",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.95,
    "end": 16.56,
    "speaker": "彥君",
    "text": "多學一點 視野就寬一點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.76,
    "end": 19.36,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.56,
    "end": 21.3,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.5,
    "end": 23.83,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.03,
    "end": 26.49,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.69,
    "end": 29.98,
    "speaker": "彥君",
    "text": "今天 來看法拉第的奇蹟",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.18,
    "end": 32.9,
    "speaker": "曉臻",
    "text": "老師 講義第一點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.1,
    "end": 35.87,
    "speaker": "曉臻",
    "text": "只要 磁場發生變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.07,
    "end": 39.06,
    "speaker": "曉臻",
    "text": "就會 產生感應電流耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.26,
    "end": 44.11,
    "speaker": "彥君",
    "text": "沒錯 重點在於「變化」",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.31,
    "end": 47.73,
    "speaker": "彥君",
    "text": "磁鐵不動 什麼都沒有",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.93,
    "end": 59.17,
    "speaker": "彥君",
    "text": "$\\text{磁場變化} \\rightarrow \\text{產生感應電流}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 52.91,
    "end": 55.97,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘想像",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.17,
    "end": 61.77,
    "speaker": "曉臻",
    "text": "那第二點 發電機呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.97,
    "end": 64.98,
    "speaker": "曉臻",
    "text": "它是 把動能轉成電能嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.18,
    "end": 69.58,
    "speaker": "彥君",
    "text": "答對了 讓線圈轉動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.78,
    "end": 72.95,
    "speaker": "彥君",
    "text": "穿過線圈的 磁力線變了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.15,
    "end": 76.47,
    "speaker": "彥君",
    "text": "電流 就源源不絕出現",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.67,
    "end": 80.04,
    "speaker": "曉臻",
    "text": "喔 交流電的頻率",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.24,
    "end": 83.25,
    "speaker": "曉臻",
    "text": "就是 發電機旋轉的頻率",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.45,
    "end": 88.18,
    "speaker": "彥君",
    "text": "沒錯 就像 腳踏車發電燈",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.38,
    "end": 91.58,
    "speaker": "彥君",
    "text": "踩越快 燈就越亮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.78,
    "end": 103.31,
    "speaker": "彥君",
    "text": "$\\text{發電機} \\rightarrow \\text{動能變電能}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 96.67,
    "end": 100.11,
    "speaker": "彥君",
    "text": "戰士們 來看變壓器",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.31,
    "end": 106.25,
    "speaker": "曉臻",
    "text": "第三點 變壓器好酷喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.45,
    "end": 109.67,
    "speaker": "曉臻",
    "text": "兩邊線圈 竟然沒連在一起",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.87,
    "end": 113.29,
    "speaker": "彥君",
    "text": "這是 電磁感應的最高境界",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.49,
    "end": 117.24,
    "speaker": "彥君",
    "text": "左邊電流變 磁通量就變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.44,
    "end": 120.74,
    "speaker": "彥君",
    "text": "透過鐵芯 傳給右邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.94,
    "end": 124.54,
    "speaker": "曉臻",
    "text": "哇 右邊感受到磁變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.74,
    "end": 127.99,
    "speaker": "曉臻",
    "text": "感應電流 就這樣生出來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.19,
    "end": 131.22,
    "speaker": "彥君",
    "text": "這就是 變壓器的奧義",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.42,
    "end": 134.05,
    "speaker": "彥君",
    "text": "雖然 考題不多",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.25,
    "end": 137.54,
    "speaker": "彥君",
    "text": "但 懂了你就是理化大神",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.74,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{變壓器} \\rightarrow \\text{利用磁通量傳遞}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 142.51,
    "end": 145.95,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.15,
    "end": 148.75,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.95,
    "end": 151.29,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.49,
    "end": 154.81,
    "speaker": "合聲",
    "text": "磁變生電 變壓奧義",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.01,
    "end": 158.54,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.22,
    "speaker": "彥君",
    "text": "第 132 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.42,
    "end": 9.57,
    "speaker": "彥君",
    "text": "想要 讓分數充滿電力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.77,
    "end": 13.23,
    "speaker": "彥君",
    "text": "你 必須先學會釋放能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.43,
    "end": 16.46,
    "speaker": "彥君",
    "text": "找對 自己的活性位置",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.66,
    "end": 19.96,
    "speaker": "彥君",
    "text": "就能 創造出最強的電壓",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.16,
    "end": 22.76,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.96,
    "end": 24.7,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.9,
    "end": 27.23,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.43,
    "end": 29.89,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.09,
    "end": 33.26,
    "speaker": "彥君",
    "text": "這是 100 顆星的必考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.46,
    "end": 36.66,
    "speaker": "曉臻",
    "text": "老師 電池的構造裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.86,
    "end": 39.82,
    "speaker": "曉臻",
    "text": "氧化還原 到底在幹嘛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.02,
    "end": 43.51,
    "speaker": "彥君",
    "text": "簡單來說 就是搶電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.71,
    "end": 47.61,
    "speaker": "彥君",
    "text": "活性大的金屬 喜歡丟電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.81,
    "end": 51.68,
    "speaker": "彥君",
    "text": "活性小的離子 喜歡拿電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.88,
    "end": 54.91,
    "speaker": "曉臻",
    "text": "就像 講義裡面的鋅跟銅",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.11,
    "end": 59.68,
    "speaker": "彥君",
    "text": "沒錯 鋅的活性比較大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.88,
    "end": 63.49,
    "speaker": "彥君",
    "text": "所以 鋅原子會變成鋅離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.69,
    "end": 67.06,
    "speaker": "彥君",
    "text": "順便 把兩顆電子丟出去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.26,
    "end": 114.66,
    "speaker": "彥君",
    "text": "[$\\text{Zn} \\rightarrow \\text{Zn}^{2+} + 2\\text{e}^{-}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 72.67,
    "end": 75.73,
    "speaker": "曉臻",
    "text": "老師 丟出去的電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.93,
    "end": 78.12,
    "speaker": "曉臻",
    "text": "跑到哪裡去了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.32,
    "end": 81.66,
    "speaker": "彥君",
    "text": "它們 順著導線跑向銅片",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.86,
    "end": 85.09,
    "speaker": "彥君",
    "text": "這就是 我們學過的電流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 85.29,
    "end": 88.51,
    "speaker": "曉臻",
    "text": "喔 銅片那一邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.71,
    "end": 91.72,
    "speaker": "曉臻",
    "text": "銅離子 已經在那裡等了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.92,
    "end": 96.61,
    "speaker": "彥君",
    "text": "沒錯 銅離子拿到電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.81,
    "end": 99.58,
    "speaker": "彥君",
    "text": "就會 變成銅原子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.78,
    "end": 102.66,
    "speaker": "彥君",
    "text": "附著 在銅片上面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.86,
    "end": 114.66,
    "speaker": "彥君",
    "text": "[$\\text{Cu}^{2+} + 2\\text{e}^{-} \\rightarrow \\text{Cu}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 108.23,
    "end": 111.46,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄算式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.66,
    "end": 117.74,
    "speaker": "曉臻",
    "text": "老師 那誰是正極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.94,
    "end": 120.13,
    "speaker": "曉臻",
    "text": "誰是負極啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.33,
    "end": 122.69,
    "speaker": "彥君",
    "text": "記住 口訣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.89,
    "end": 125.61,
    "speaker": "彥君",
    "text": "丟電子 的是負極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.81,
    "end": 128.53,
    "speaker": "彥君",
    "text": "拿電子 的是正極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.73,
    "end": 132.12,
    "speaker": "曉臻",
    "text": "鋅丟電子 所以是負極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.32,
    "end": 135.71,
    "speaker": "曉臻",
    "text": "銅拿電子 所以是正極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.91,
    "end": 140.48,
    "speaker": "彥君",
    "text": "漂亮 而且負極會變輕",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.68,
    "end": 144.31,
    "speaker": "彥君",
    "text": "正極 因為長肉 會變重",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.51,
    "end": 170.14,
    "speaker": "彥君",
    "text": "$\\text{負極變輕， 正極變重}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 148.85,
    "end": 151.69,
    "speaker": "曉臻",
    "text": "那離子濃度 會怎麼變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.89,
    "end": 155.21,
    "speaker": "彥君",
    "text": "鋅那一杯 離子變多了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.41,
    "end": 158.68,
    "speaker": "彥君",
    "text": "銅那一杯 離子變少了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.88,
    "end": 170.14,
    "speaker": "彥君",
    "text": "$\\text{Zn}^{2+} \\uparrow, \\text{ Cu}^{2+} \\downarrow$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 163.34,
    "end": 166.94,
    "speaker": "彥君",
    "text": "戰士們 注意鹽橋走向",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.14,
    "end": 173.37,
    "speaker": "曉臻",
    "text": "老師 那鹽橋是幹嘛的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.57,
    "end": 176.41,
    "speaker": "曉臻",
    "text": "拿掉 它會發生什麼事",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 176.61,
    "end": 179.95,
    "speaker": "彥君",
    "text": "拿掉 鹽橋 電路就斷了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 180.15,
    "end": 183.3,
    "speaker": "彥君",
    "text": "它 負責維持電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 183.5,
    "end": 186.42,
    "speaker": "曉臻",
    "text": "鹽橋 裡面的離子怎麼走",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 186.62,
    "end": 189.96,
    "speaker": "彥君",
    "text": "正離子 往正極跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 190.16,
    "end": 193.46,
    "speaker": "彥君",
    "text": "負離子 往負極跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 193.66,
    "end": 222.76,
    "speaker": "彥君",
    "text": "$\\text{鹽橋： 正往正， 負往負}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 198.59,
    "end": 201.91,
    "speaker": "曉臻",
    "text": "哇 名字對名字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 202.11,
    "end": 204.69,
    "speaker": "曉臻",
    "text": "這樣 就不會記錯了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 204.89,
    "end": 209.55,
    "speaker": "彥君",
    "text": "沒錯 只有接通鹽橋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 209.75,
    "end": 212.88,
    "speaker": "彥君",
    "text": "電池 才能持續放電",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 213.08,
    "end": 216.5,
    "speaker": "彥君",
    "text": "這就是 化學能轉成電能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 216.7,
    "end": 219.56,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘吸收",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 222.76,
    "end": 226.2,
    "speaker": "彥君",
    "text": "戰士們 隨堂測驗來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 226.4,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "現在 有 X 和 Y 兩塊金屬。",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 230.06,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "放入 硫酸鹽溶液中。",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 233.2,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "老師， 實驗結果出來了！",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 236.65,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "導線 的電子是從 Y 往 X 跑。",
    "is_pinned": true,
    "pin_level": 4
  },
  {
    "start": 240.14,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "聽清楚 助教說的話。",
    "is_pinned": true,
    "pin_level": 5
  },
  {
    "start": 243.26,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "電子 是從 Y 跑向 X 喔！",
    "is_pinned": true,
    "pin_level": 6
  },
  {
    "start": 246.46,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "請問 誰是負極？ 誰是正極？",
    "is_pinned": true,
    "pin_level": 7
  },
  {
    "start": 251.5,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "給電子 的是負極。",
    "is_pinned": true,
    "pin_level": 8
  },
  {
    "start": 254.2,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "所以 Y 是負極！",
    "is_pinned": true,
    "pin_level": 9
  },
  {
    "start": 256.81,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "拿電子 的是正極。",
    "is_pinned": true,
    "pin_level": 10
  },
  {
    "start": 259.61,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "所以 X 是正極！",
    "is_pinned": true,
    "pin_level": 11
  },
  {
    "start": 262.36,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{Y為負極， X為正極}$",
    "is_pinned": true,
    "pin_level": 12
  },
  {
    "start": 267.46,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "答對了！ 那誰的活性大？",
    "is_pinned": true,
    "pin_level": 13
  },
  {
    "start": 271.94,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "負極 喜歡丟電子。",
    "is_pinned": true,
    "pin_level": 14
  },
  {
    "start": 274.67,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "所以 Y 的活性比較大！",
    "is_pinned": true,
    "pin_level": 15
  },
  {
    "start": 277.76,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "漂亮！ 最後一個問題。",
    "is_pinned": true,
    "pin_level": 16
  },
  {
    "start": 282.36,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "誰的質量 會逐漸減輕？",
    "is_pinned": true,
    "pin_level": 17
  },
  {
    "start": 285.78,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "活性大 的金屬會溶解。",
    "is_pinned": true,
    "pin_level": 18
  },
  {
    "start": 288.9,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "所以 答案是 Y 金屬！",
    "is_pinned": true,
    "pin_level": 19
  },
  {
    "start": 291.77,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{活性： Y } > \\text{ X， Y片變輕}$",
    "is_pinned": true,
    "pin_level": 20
  },
  {
    "start": 296.42,
    "end": 299.54,
    "speaker": "彥君",
    "text": "這就是 A 級考點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 299.74,
    "end": 302.58,
    "speaker": "彥君",
    "text": "答案 釘在黑板上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 302.78,
    "end": 306.06,
    "speaker": "彥君",
    "text": "自己對 對完下課",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 306.26,
    "end": 309.48,
    "speaker": "彥君",
    "text": "沒對準的 不准走",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 309.68,
    "end": 312.28,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 312.48,
    "end": 314.82,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 315.02,
    "end": 318.24,
    "speaker": "合聲",
    "text": "活性大小 電能爆發",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 318.44,
    "end": 321.98,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.22,
    "speaker": "彥君",
    "text": "第 132 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.42,
    "end": 9.57,
    "speaker": "彥君",
    "text": "想要 讓分數充滿電力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.77,
    "end": 13.23,
    "speaker": "彥君",
    "text": "你 必須先學會釋放能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.43,
    "end": 16.46,
    "speaker": "彥君",
    "text": "找對 自己的活性位置",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.66,
    "end": 19.96,
    "speaker": "彥君",
    "text": "就能 創造出最強的電壓",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.16,
    "end": 22.76,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.96,
    "end": 24.7,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.9,
    "end": 27.23,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.43,
    "end": 29.89,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.09,
    "end": 33.26,
    "speaker": "彥君",
    "text": "這是 100 顆星的必考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.46,
    "end": 36.66,
    "speaker": "曉臻",
    "text": "老師 電池的構造裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.86,
    "end": 39.82,
    "speaker": "曉臻",
    "text": "氧化還原 到底在幹嘛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.02,
    "end": 43.51,
    "speaker": "彥君",
    "text": "簡單來說 就是搶電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.71,
    "end": 47.61,
    "speaker": "彥君",
    "text": "活性大的金屬 喜歡丟電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.81,
    "end": 51.68,
    "speaker": "彥君",
    "text": "活性小的離子 喜歡拿電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.88,
    "end": 54.91,
    "speaker": "曉臻",
    "text": "就像 講義裡面的鋅跟銅",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.11,
    "end": 59.68,
    "speaker": "彥君",
    "text": "沒錯 鋅的活性比較大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.88,
    "end": 63.49,
    "speaker": "彥君",
    "text": "所以 鋅原子會變成鋅離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.69,
    "end": 67.06,
    "speaker": "彥君",
    "text": "順便 把兩顆電子丟出去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.26,
    "end": 114.66,
    "speaker": "彥君",
    "text": "[$\\text{Zn} \\rightarrow \\text{Zn}^{2+} + 2\\text{e}^{-}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 72.67,
    "end": 75.73,
    "speaker": "曉臻",
    "text": "老師 丟出去的電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.93,
    "end": 78.12,
    "speaker": "曉臻",
    "text": "跑到哪裡去了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.32,
    "end": 81.66,
    "speaker": "彥君",
    "text": "它們 順著導線跑向銅片",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.86,
    "end": 85.09,
    "speaker": "彥君",
    "text": "這就是 我們學過的電流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 85.29,
    "end": 88.51,
    "speaker": "曉臻",
    "text": "喔 銅片那一邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.71,
    "end": 91.72,
    "speaker": "曉臻",
    "text": "銅離子 已經在那裡等了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.92,
    "end": 96.61,
    "speaker": "彥君",
    "text": "沒錯 銅離子拿到電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.81,
    "end": 99.58,
    "speaker": "彥君",
    "text": "就會 變成銅原子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.78,
    "end": 102.66,
    "speaker": "彥君",
    "text": "附著 在銅片上面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.86,
    "end": 114.66,
    "speaker": "彥君",
    "text": "[$\\text{Cu}^{2+} + 2\\text{e}^{-} \\rightarrow \\text{Cu}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 108.23,
    "end": 111.46,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄算式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.66,
    "end": 117.74,
    "speaker": "曉臻",
    "text": "老師 那誰是正極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.94,
    "end": 120.13,
    "speaker": "曉臻",
    "text": "誰是負極啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.33,
    "end": 123.48,
    "speaker": "彥君",
    "text": "記住 補教天王的口訣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.68,
    "end": 126.4,
    "speaker": "彥君",
    "text": "丟電子 的是負極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.6,
    "end": 129.32,
    "speaker": "彥君",
    "text": "拿電子 的是正極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.52,
    "end": 132.91,
    "speaker": "曉臻",
    "text": "鋅丟電子 所以是負極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 133.11,
    "end": 136.5,
    "speaker": "曉臻",
    "text": "銅拿電子 所以是正極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.7,
    "end": 141.27,
    "speaker": "彥君",
    "text": "漂亮 而且負極會變輕",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.47,
    "end": 145.1,
    "speaker": "彥君",
    "text": "正極 因為長肉 會變重",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.3,
    "end": 170.94,
    "speaker": "彥君",
    "text": "$\\text{負極變輕， 正極變重}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 149.64,
    "end": 152.48,
    "speaker": "曉臻",
    "text": "那離子濃度 會怎麼變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.68,
    "end": 156.0,
    "speaker": "彥君",
    "text": "鋅那一杯 離子變多了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.2,
    "end": 159.47,
    "speaker": "彥君",
    "text": "銅那一杯 離子變少了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.67,
    "end": 170.94,
    "speaker": "彥君",
    "text": "$\\text{Zn}^{2+} \\uparrow, \\text{ Cu}^{2+} \\downarrow$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 164.13,
    "end": 167.74,
    "speaker": "彥君",
    "text": "戰士們 注意鹽橋走向",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.94,
    "end": 174.16,
    "speaker": "曉臻",
    "text": "老師 那鹽橋是幹嘛的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 174.36,
    "end": 177.2,
    "speaker": "曉臻",
    "text": "拿掉 它會發生什麼事",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.4,
    "end": 180.74,
    "speaker": "彥君",
    "text": "拿掉 鹽橋 電路就斷了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 180.94,
    "end": 184.1,
    "speaker": "彥君",
    "text": "它 負責維持電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 184.3,
    "end": 187.21,
    "speaker": "曉臻",
    "text": "鹽橋 裡面的離子怎麼走",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 187.41,
    "end": 190.75,
    "speaker": "彥君",
    "text": "正離子 往正極跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 190.95,
    "end": 194.25,
    "speaker": "彥君",
    "text": "負離子 往負極跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 194.45,
    "end": 223.55,
    "speaker": "彥君",
    "text": "$\\text{鹽橋： 正往正， 負往負}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 199.38,
    "end": 202.7,
    "speaker": "曉臻",
    "text": "哇 名字對名字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 202.9,
    "end": 205.48,
    "speaker": "曉臻",
    "text": "這樣 就不會記錯了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 205.68,
    "end": 210.34,
    "speaker": "彥君",
    "text": "沒錯 只有接通鹽橋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 210.54,
    "end": 213.67,
    "speaker": "彥君",
    "text": "電池 才能持續放電",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 213.87,
    "end": 217.29,
    "speaker": "彥君",
    "text": "這就是 化學能轉成電能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 217.49,
    "end": 220.35,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘吸收",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 223.55,
    "end": 226.99,
    "speaker": "彥君",
    "text": "戰士們 隨堂測驗來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 227.19,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "現在 有 X 和 Y 兩塊金屬。",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 230.86,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "放入 硫酸鹽溶液中。",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 233.99,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "老師， 實驗結果出來了！",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 237.44,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "導線 的電子是從 Y 往 X 跑。",
    "is_pinned": true,
    "pin_level": 4
  },
  {
    "start": 240.94,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "聽清楚 助教說的話。",
    "is_pinned": true,
    "pin_level": 5
  },
  {
    "start": 244.05,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "電子 是從 Y 跑向 X 喔！",
    "is_pinned": true,
    "pin_level": 6
  },
  {
    "start": 247.26,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "請問 誰是負極？ 誰是正極？",
    "is_pinned": true,
    "pin_level": 7
  },
  {
    "start": 252.29,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "給電子 的是負極。",
    "is_pinned": true,
    "pin_level": 8
  },
  {
    "start": 254.99,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "所以 Y 是負極！",
    "is_pinned": true,
    "pin_level": 9
  },
  {
    "start": 257.6,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "拿電子 的是正極。",
    "is_pinned": true,
    "pin_level": 10
  },
  {
    "start": 260.4,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "所以 X 是正極！",
    "is_pinned": true,
    "pin_level": 11
  },
  {
    "start": 263.15,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{Y為負極， X為正極}$",
    "is_pinned": true,
    "pin_level": 12
  },
  {
    "start": 268.26,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "答對了！ 那誰的活性大？",
    "is_pinned": true,
    "pin_level": 13
  },
  {
    "start": 272.74,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "負極 喜歡丟電子。",
    "is_pinned": true,
    "pin_level": 14
  },
  {
    "start": 275.46,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "所以 Y 的活性比較大！",
    "is_pinned": true,
    "pin_level": 15
  },
  {
    "start": 278.55,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "漂亮！ 最後一個問題。",
    "is_pinned": true,
    "pin_level": 16
  },
  {
    "start": 283.15,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "誰的質量 會逐漸減輕？",
    "is_pinned": true,
    "pin_level": 17
  },
  {
    "start": 286.58,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "活性大 的金屬會溶解。",
    "is_pinned": true,
    "pin_level": 18
  },
  {
    "start": 289.69,
    "end": 9999.0,
    "speaker": "曉臻",
    "text": "所以 答案是 Y 金屬！",
    "is_pinned": true,
    "pin_level": 19
  },
  {
    "start": 292.56,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{活性： Y } > \\text{ X， Y片變輕}$",
    "is_pinned": true,
    "pin_level": 20
  },
  {
    "start": 297.21,
    "end": 300.34,
    "speaker": "彥君",
    "text": "這就是 A 級考點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 300.54,
    "end": 303.38,
    "speaker": "彥君",
    "text": "答案 釘在黑板上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 303.58,
    "end": 306.85,
    "speaker": "彥君",
    "text": "自己對 對完下課",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 307.05,
    "end": 310.27,
    "speaker": "彥君",
    "text": "沒對準的 不准走",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 310.47,
    "end": 313.07,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 313.27,
    "end": 315.61,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 315.81,
    "end": 319.03,
    "speaker": "合聲",
    "text": "活性大小 電能爆發",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 319.23,
    "end": 322.77,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.19,
    "speaker": "彥君",
    "text": "第 131 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.39,
    "end": 9.28,
    "speaker": "彥君",
    "text": "就像 磁鐵的兩極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.48,
    "end": 12.61,
    "speaker": "彥君",
    "text": "只要 你的志向夠堅定",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.81,
    "end": 15.96,
    "speaker": "彥君",
    "text": "就能 吸引所有的機會",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.16,
    "end": 18.76,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.96,
    "end": 20.7,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.9,
    "end": 23.23,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.43,
    "end": 25.89,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.09,
    "end": 29.0,
    "speaker": "彥君",
    "text": "電磁學 最終章來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.2,
    "end": 32.23,
    "speaker": "曉臻",
    "text": "老師 第一點磁力線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.43,
    "end": 34.84,
    "speaker": "曉臻",
    "text": "到底是 N 到 S 嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.04,
    "end": 39.68,
    "speaker": "彥君",
    "text": "記住 磁鐵外部 N 到 S",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.88,
    "end": 42.84,
    "speaker": "彥君",
    "text": "內部 則是 S 回到 N",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.04,
    "end": 46.0,
    "speaker": "彥君",
    "text": "它們 可是封閉的曲線喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.2,
    "end": 56.91,
    "speaker": "彥君",
    "text": "$\\text{外部 } N \\rightarrow S, \\text{ 內部 } S \\rightarrow N$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 50.66,
    "end": 53.71,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘想像",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.91,
    "end": 59.87,
    "speaker": "曉臻",
    "text": "那第二點 安培右手定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.07,
    "end": 63.44,
    "speaker": "曉臻",
    "text": "到底是 比讚 還是抓東西",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.64,
    "end": 66.12,
    "speaker": "彥君",
    "text": "兩種都可以",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.32,
    "end": 70.58,
    "speaker": "彥君",
    "text": "直導線比讚 大拇指是 $I$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.78,
    "end": 75.1,
    "speaker": "彥君",
    "text": "線圈用抓的 大拇指是 $B$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.3,
    "end": 87.98,
    "speaker": "彥君",
    "text": "[$\\text{大拇指} \\rightarrow \\text{直的",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 81.46,
    "end": 84.78,
    "speaker": "彥君",
    "text": "戰士們 伸出右手",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.98,
    "end": 91.02,
    "speaker": "曉臻",
    "text": "第三點 右手開掌定則",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.22,
    "end": 94.58,
    "speaker": "曉臻",
    "text": "四根手指 又要變磁場了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.78,
    "end": 99.42,
    "speaker": "彥君",
    "text": "沒錯 這是算受力方向",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.62,
    "end": 103.26,
    "speaker": "彥君",
    "text": "大拇指電流 四指磁場",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.46,
    "end": 106.49,
    "speaker": "曉臻",
    "text": "那 掌心推出去的方向呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.69,
    "end": 109.31,
    "speaker": "彥君",
    "text": "就是 受力方向 $F$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.51,
    "end": 113.41,
    "speaker": "彥君",
    "text": "記住 必須三者互相垂直",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.61,
    "end": 124.7,
    "speaker": "彥君",
    "text": "$\\text{拇指 } I, \\text{ 四指 } B, \\text{ 掌心 } F$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 118.54,
    "end": 121.5,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘拍手",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.7,
    "end": 127.81,
    "speaker": "曉臻",
    "text": "老師 最後一點最難",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.01,
    "end": 130.51,
    "speaker": "曉臻",
    "text": "什麼 是感應電流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.71,
    "end": 133.89,
    "speaker": "彥君",
    "text": "這是 懶惰的最高境界",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.09,
    "end": 137.14,
    "speaker": "彥君",
    "text": "磁場 只要發生變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.34,
    "end": 140.95,
    "speaker": "彥君",
    "text": "導線 就會產生電流來抵抗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.15,
    "end": 144.4,
    "speaker": "曉臻",
    "text": "老師 講義寫得好複雜",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.6,
    "end": 147.2,
    "speaker": "曉臻",
    "text": "有沒有 簡單的口訣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.4,
    "end": 151.7,
    "speaker": "彥君",
    "text": "當然有 記住這句話",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.9,
    "end": 155.2,
    "speaker": "彥君",
    "text": "磁鐵要來 我就推開",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.4,
    "end": 158.74,
    "speaker": "彥君",
    "text": "磁鐵要走 我就拉住",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.94,
    "end": 162.22,
    "speaker": "曉臻",
    "text": "哇 這根本就是",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.42,
    "end": 165.28,
    "speaker": "曉臻",
    "text": "欲擒故縱的 戀愛大師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.48,
    "end": 170.26,
    "speaker": "彥君",
    "text": "沒錯 產生磁場去抵抗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.46,
    "end": 173.21,
    "speaker": "彥君",
    "text": "這就是 冷次定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.41,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{磁場變} \\rightarrow \\text{產生感應電流抵抗}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 178.18,
    "end": 182.67,
    "speaker": "彥君",
    "text": "磁場變化的愈快 感應電流就愈強",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 182.87,
    "end": 186.48,
    "speaker": "曉臻",
    "text": "磁場不變 感應電流就歸0",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 186.68,
    "end": 190.12,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 190.32,
    "end": 192.92,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 193.12,
    "end": 195.46,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 195.66,
    "end": 198.95,
    "speaker": "合聲",
    "text": "右手三變 電磁通殺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 199.15,
    "end": 202.69,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
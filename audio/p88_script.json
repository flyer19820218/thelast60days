    "start": 256.0,
    "end": 259.9,
    "speaker": "曉臻",
    "text": "這樣右邊加起來總共有 $$4$$ 個氧",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 260.1,

[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 ㄟ 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.26,
    "speaker": "彥君",
    "text": "今天來到 第八十八集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.46,
    "end": 16.19,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.39,
    "end": 18.73,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.93,
    "end": 21.38,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.58,
    "end": 24.59,
    "speaker": "彥君",
    "text": "化學反應 發生時",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.79,
    "end": 27.7,
    "speaker": "彥君",
    "text": "質量 絕對會守恆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.9,
    "end": 30.0,
    "speaker": "曉臻",
    "text": "可是 老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.2,
    "end": 32.7,
    "speaker": "曉臻",
    "text": "為什麼 鐵絲燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.9,
    "end": 35.29,
    "speaker": "曉臻",
    "text": "或是 鐵釘生鏽",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.49,
    "end": 37.78,
    "speaker": "曉臻",
    "text": "重量 卻變重了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.98,
    "end": 40.82,
    "speaker": "彥君",
    "text": "因為 鐵絲燃燒時",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.02,
    "end": 43.88,
    "speaker": "彥君",
    "text": "結合了 空氣中的氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.08,
    "end": 47.3,
    "speaker": "彥君",
    "text": "氧氣的重量 也算進去了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.5,
    "end": 50.78,
    "speaker": "曉臻",
    "text": "喔 那木炭燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.98,
    "end": 53.36,
    "speaker": "曉臻",
    "text": "燒完 剩下灰燼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.56,
    "end": 55.99,
    "speaker": "曉臻",
    "text": "重量 怎麼變輕了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.19,
    "end": 58.62,
    "speaker": "彥君",
    "text": "因為 木炭燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.82,
    "end": 61.62,
    "speaker": "彥君",
    "text": "產生了 二氧化碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.82,
    "end": 64.63,
    "speaker": "彥君",
    "text": "氣體 跑進空氣裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.83,
    "end": 67.24,
    "speaker": "彥君",
    "text": "當然 量不到啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.44,
    "end": 69.46,
    "speaker": "曉臻",
    "text": "原來如此",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.66,
    "end": 72.05,
    "speaker": "曉臻",
    "text": "如果 把它關在",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.25,
    "end": 74.78,
    "speaker": "曉臻",
    "text": "密閉 容器裡面量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.98,
    "end": 77.6,
    "speaker": "曉臻",
    "text": "重量 就一樣了對吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.8,
    "end": 80.18,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.38,
    "end": 83.54,
    "speaker": "彥君",
    "text": "接著看 投影片表格",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.74,
    "end": 86.55,
    "speaker": "曉臻",
    "text": "老師 表格裡的甲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.75,
    "end": 89.45,
    "speaker": "曉臻",
    "text": "反應後 變成問號了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.65,
    "end": 92.61,
    "speaker": "彥君",
    "text": "根據 質量守恆定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.81,
    "end": 95.6,
    "speaker": "彥君",
    "text": "反應前 總重量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.8,
    "end": 98.71,
    "speaker": "彥君",
    "text": "等於 反應後 總重量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.91,
    "end": 101.27,
    "speaker": "曉臻",
    "text": "反應前 加起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.47,
    "end": 106.64,
    "speaker": "曉臻",
    "text": "6+1+2+32（六加一加二加三十二）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.84,
    "end": 110.57,
    "speaker": "曉臻",
    "text": "總共 是 41（四十一）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 110.77,
    "end": 114.81,
    "speaker": "彥君",
    "text": "沒錯 反應後",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.01,
    "end": 119.22,
    "speaker": "彥君",
    "text": "也要是 41（四十一）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.42,
    "end": 121.85,
    "speaker": "曉臻",
    "text": "可是 後面三個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.05,
    "end": 126.93,
    "speaker": "曉臻",
    "text": "25+2+14（二十五加二加十四）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 127.13,
    "end": 132.13,
    "speaker": "曉臻",
    "text": "加起來 已經是 41（四十一）了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.33,
    "end": 134.93,
    "speaker": "彥君",
    "text": "所以 甲的問號",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.13,
    "end": 140.42,
    "speaker": "彥君",
    "text": "就是 0（零） 它用光了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.62,
    "end": 144.75,
    "speaker": "曉臻",
    "text": "老師 丙都是 2（二）耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.95,
    "end": 147.65,
    "speaker": "彥君",
    "text": "丙有 參與反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.85,
    "end": 150.76,
    "speaker": "彥君",
    "text": "只是 不會被消耗掉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.96,
    "end": 153.73,
    "speaker": "彥君",
    "text": "它 就是催化劑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.93,
    "end": 157.01,
    "speaker": "彥君",
    "text": "接下來 進入重頭戲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.21,
    "end": 160.67,
    "speaker": "彥君",
    "text": "戰士們 準備寫筆記",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.87,
    "end": 163.81,
    "speaker": "彥君",
    "text": "平衡係數 觀察法",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.01,
    "end": 167.47,
    "speaker": "彥君",
    "text": "第一題 氫氣加氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 167.67,
    "end": 215.26,
    "speaker": "彥君",
    "text": "H₂ + O₂ → H₂O",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 171.43,
    "end": 174.82,
    "speaker": "曉臻",
    "text": "左邊 2（兩）個氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.02,
    "end": 178.63,
    "speaker": "曉臻",
    "text": "右邊 只有 1（一）個氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 178.83,
    "end": 181.74,
    "speaker": "彥君",
    "text": "所以在 水的前面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.94,
    "end": 185.74,
    "speaker": "彥君",
    "text": "補上 係數 2（二）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.94,
    "end": 215.26,
    "speaker": "彥君",
    "text": "H₂ + O₂ → 2H₂O",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 189.42,
    "end": 193.67,
    "speaker": "曉臻",
    "text": "那右邊 變成 4（四）個氫了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 193.87,
    "end": 198.1,
    "speaker": "彥君",
    "text": "很好 所以左邊的氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 198.3,
    "end": 202.34,
    "speaker": "彥君",
    "text": "也要 補上係數 2（二）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 202.54,
    "end": 215.26,
    "speaker": "彥君",
    "text": "2H₂ + O₂ → 2H₂O",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 206.02,
    "end": 208.9,
    "speaker": "彥君",
    "text": "第一題 完美平衡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 209.1,
    "end": 212.06,
    "speaker": "彥君",
    "text": "給你們 三秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 215.26,
    "end": 218.01,
    "speaker": "彥君",
    "text": "接下來 第二題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 218.21,
    "end": 221.24,
    "speaker": "彥君",
    "text": "氮氣加氫氣 變氨氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 221.44,
    "end": 268.78,
    "speaker": "彥君",
    "text": "N₂ + H₂ → NH₃",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 225.25,
    "end": 228.66,
    "speaker": "曉臻",
    "text": "左邊 2（兩）個氮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 228.86,
    "end": 232.38,
    "speaker": "曉臻",
    "text": "右邊 只有 1（一）個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 232.58,
    "end": 236.9,
    "speaker": "彥君",
    "text": "所以 氨氣前面寫 2（二）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 237.1,
    "end": 268.78,
    "speaker": "彥君",
    "text": "N₂ + H₂ → 2NH₃",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 240.58,
    "end": 244.54,
    "speaker": "曉臻",
    "text": "這樣 右邊有 6（六）個氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 244.74,
    "end": 249.29,
    "speaker": "彥君",
    "text": "左邊 氫氣前面寫 3（三）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 249.49,
    "end": 255.21,
    "speaker": "彥君",
    "text": "3 × 2 = 6（三乘二等於六）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 255.41,
    "end": 268.78,
    "speaker": "彥君",
    "text": "N₂ + 3H₂ → 2NH₃",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 258.93,
    "end": 261.82,
    "speaker": "彥君",
    "text": "第二題 輕鬆解決",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 262.02,
    "end": 265.58,
    "speaker": "彥君",
    "text": "戰士們 準備下一題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 268.78,
    "end": 271.52,
    "speaker": "彥君",
    "text": "第三題 甲烷燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 271.72,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "CH₄ + O₂ → CO₂ + H₂O",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 276.1,
    "end": 279.59,
    "speaker": "曉臻",
    "text": "左邊 4（四）個氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 279.79,
    "end": 283.81,
    "speaker": "彥君",
    "text": "水的 前面寫 2（二）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 284.01,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "CH₄ + O₂ → CO₂ + 2H₂O",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 287.53,
    "end": 291.57,
    "speaker": "曉臻",
    "text": "這樣 右邊有 4（四）個氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 291.77,
    "end": 296.14,
    "speaker": "彥君",
    "text": "所以 左邊氧氣寫 2（二）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 296.34,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "CH₄ + 2O₂ → CO₂ + 2H₂O",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 299.84,
    "end": 302.99,
    "speaker": "彥君",
    "text": "觀察法 就是這麼簡單",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 303.19,
    "end": 306.63,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 306.83,
    "end": 309.43,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 309.63,
    "end": 311.97,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 312.17,
    "end": 315.75,
    "speaker": "合聲",
    "text": "質量守恆 係數平衡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 315.95,
    "end": 319.49,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
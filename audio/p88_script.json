    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 12.3,
    "end": 18.1,
    "speaker": "彥君",
    "text": "歡迎來到第八十八集化學反應的秘密",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 18.3,
    "end": 22.43,
    "speaker": "彥君",
    "text": "戰士們注意化學反應發生時",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 22.63,
    "end": 26.19,
    "speaker": "彥君",
    "text": "質量絕對會遵守守恆定律",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 26.39,
    "end": 29.98,
    "speaker": "曉臻",
    "text": "可是老師為什麼鐵絲燃燒",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 30.18,
    "end": 34.1,
    "speaker": "曉臻",
    "text": "或是鐵釘生鏽重量卻變重了啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 34.3,
    "end": 37.57,
    "speaker": "彥君",
    "text": "因為鐵絲在燃燒的時候",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 37.77,
    "end": 41.42,
    "speaker": "彥君",
    "text": "結合了空氣中看不見的氧氣",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 41.62,
    "end": 45.06,
    "speaker": "彥君",
    "text": "氧氣的重量也被算進去了呀",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 45.26,
    "end": 49.21,
    "speaker": "曉臻",
    "text": "喔那木炭燃燒剩下灰燼",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 49.41,
    "end": 52.18,
    "speaker": "曉臻",
    "text": "重量怎麼反而變輕了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 52.38,
    "end": 56.13,
    "speaker": "彥君",
    "text": "因為木炭燃燒產生了二氧化碳",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 56.33,
    "end": 60.87,
    "speaker": "彥君",
    "text": "氣體偷偷跑進空氣裡磅秤當然量不到",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 61.07,
    "end": 63.1,
    "speaker": "曉臻",
    "text": "原來如此",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 63.3,
    "end": 66.98,
    "speaker": "曉臻",
    "text": "如果把它關在密閉容器裡面量",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 67.18,
    "end": 70.11,
    "speaker": "曉臻",
    "text": "重量就一模一樣了對吧",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 70.31,
    "end": 75.77,
    "speaker": "彥君",
    "text": "完全正確這就是質量守恆的鐵則",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 75.97,
    "end": 79.86,
    "speaker": "彥君",
    "text": "接著我們來看投影片上的實驗表格",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 80.06,
    "end": 84.92,
    "speaker": "曉臻",
    "text": "老師表格裡的甲反應後怎麼變成問號了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 85.12,
    "end": 88.06,
    "speaker": "彥君",
    "text": "根據質量守恆定律",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 88.26,
    "end": 93.02,
    "speaker": "彥君",
    "text": "反應前的總重量一定等於反應後的總重量",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 93.22,
    "end": 97.54,
    "speaker": "曉臻",
    "text": "反應前加起來$$6+1+2+32$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 97.74,
    "end": 100.51,
    "speaker": "曉臻",
    "text": "總共是 $$41$$ 公克",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 100.71,
    "end": 107.15,
    "speaker": "彥君",
    "text": "沒錯所以反應後全部加起來也要是 $$41$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 107.35,
    "end": 112.09,
    "speaker": "曉臻",
    "text": "可是後面三個加起來$$25+2+14$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 112.29,
    "end": 115.34,
    "speaker": "曉臻",
    "text": "已經剛好是 $$41$$ 了耶",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 115.54,
    "end": 123.06,
    "speaker": "彥君",
    "text": "漂亮所以甲的問號就是 $$0$$代表它全部用光了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 123.26,
    "end": 127.3,
    "speaker": "曉臻",
    "text": "老師那丙反應前後都是 $$2$$ 耶",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 127.5,
    "end": 131.88,
    "speaker": "彥君",
    "text": "丙有參與反應只是它不會被消耗掉",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 132.08,
    "end": 136.0,
    "speaker": "彥君",
    "text": "這種物質我們就叫做催化劑",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 136.2,
    "end": 139.71,
    "speaker": "彥君",
    "text": "接下來進入今天的重頭戲",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 139.91,
    "end": 143.38,
    "speaker": "彥君",
    "text": "戰士們準備寫筆記了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 143.58,
    "end": 148.05,
    "speaker": "彥君",
    "text": "我們來學化學必考的「平衡係數觀察法」",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 148.25,
    "end": 152.24,
    "speaker": "彥君",
    "text": "第一題氫氣加氧氣變成水",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 152.44,
    "end": 192.17,
    "speaker": "彥君",
    "text": "$$H_2 + O_2 \\rightarrow H_2O$$",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選",
      "$$H_2 + O_2 \\rightarrow H_2O$$"
    ]
  },
  {
    "start": 156.2,
    "end": 161.08,
    "speaker": "曉臻",
    "text": "老師左邊有 $$2$$ 個氧右邊卻只有 $$1$$ 個氧耶",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 161.28,
    "end": 165.66,
    "speaker": "彥君",
    "text": "所以我們要在水的前面補上係數 $$2$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 165.86,
    "end": 192.17,
    "speaker": "彥君",
    "text": "$$H_2 + O_2 \\rightarrow 2H_2O$$",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選",
      "$$H_2 + O_2 \\rightarrow 2H_2O$$"
    ]
  },
  {
    "start": 169.33,
    "end": 173.18,
    "speaker": "曉臻",
    "text": "可是這樣右邊就變成 $$4$$ 個氫了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 173.38,
    "end": 179.22,
    "speaker": "彥君",
    "text": "很好所以左邊的氫氣也要補上係數 $$2$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 179.42,
    "end": 192.17,
    "speaker": "彥君",
    "text": "$$2H_2 + O_2 \\rightarrow 2H_2O$$",
    "is_pinned": true,
    "pin_level": 3,
    "commands": [
      "釘選",
      "$$2H_2 + O_2 \\rightarrow 2H_2O$$"
    ]
  },
  {
    "start": 183.08,
    "end": 188.97,
    "speaker": "彥君",
    "text": "第一題完美平衡給你們三秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 192.17,
    "end": 195.03,
    "speaker": "彥君",
    "text": "我們準備看第二題",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 195.23,
    "end": 198.46,
    "speaker": "彥君",
    "text": "氮氣加氫氣變成氨氣",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 198.66,
    "end": 231.71,
    "speaker": "彥君",
    "text": "$$N_2 + H_2 \\rightarrow NH_3$$",
    "is_pinned": true,
    "pin_level": 1,
    "commands": [
      "釘選",
      "$$N_2 + H_2 \\rightarrow NH_3$$"
    ]
  },
  {
    "start": 202.46,
    "end": 206.05,
    "speaker": "曉臻",
    "text": "左邊有 $$2$$ 個氮右邊只有 $$1$$ 個",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 206.25,
    "end": 210.07,
    "speaker": "彥君",
    "text": "沒錯所以氨氣前面寫 $$2$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 210.27,
    "end": 231.71,
    "speaker": "彥君",
    "text": "$$N_2 + H_2 \\rightarrow 2NH_3$$",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選",
      "$$N_2 + H_2 \\rightarrow 2NH_3$$"
    ]
  },
  {
    "start": 213.74,
    "end": 216.78,
    "speaker": "曉臻",
    "text": "這樣右邊就會有 $$6$$ 個氫",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 216.98,
    "end": 221.52,
    "speaker": "彥君",
    "text": "左邊氫氣前面寫 $$3$$因為 $$3 \\times 2 = 6$$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 221.72,
    "end": 231.71,
    "speaker": "彥君",
    "text": "$$N_2 + 3H_2 \\rightarrow 2NH_3$$",
    "is_pinned": true,
    "pin_level": 3,
    "commands": [
      "釘選",
      "$$N_2 + 3H_2 \\rightarrow 2NH_3$$"
    ]
  },
  {
    "start": 225.24,
    "end": 228.51,
    "speaker": "彥君",
    "text": "第二題輕鬆解決",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 231.71,
    "end": 235.87,

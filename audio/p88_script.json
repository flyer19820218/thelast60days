[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.26,
    "speaker": "彥君",
    "text": "今天來到 第八十八集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.46,
    "end": 16.19,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.39,
    "end": 18.73,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.93,
    "end": 21.38,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.58,
    "end": 24.59,
    "speaker": "彥君",
    "text": "化學反應 發生時",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.79,
    "end": 27.66,
    "speaker": "彥君",
    "text": "會產生 新的物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.86,
    "end": 30.31,
    "speaker": "曉臻",
    "text": "像是 冒出氣泡、",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.51,
    "end": 33.33,
    "speaker": "曉臻",
    "text": "變色 或是產生沉澱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.53,
    "end": 37.86,
    "speaker": "彥君",
    "text": "沒錯 接著看表格",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.06,
    "end": 40.87,
    "speaker": "曉臻",
    "text": "老師 表格裡的甲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.07,
    "end": 43.77,
    "speaker": "曉臻",
    "text": "反應後 變成問號了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.97,
    "end": 46.88,
    "speaker": "彥君",
    "text": "這是 質量守恆定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.08,
    "end": 49.87,
    "speaker": "彥君",
    "text": "反應前 總重量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.07,
    "end": 52.98,
    "speaker": "彥君",
    "text": "等於 反應後 總重量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.18,
    "end": 55.54,
    "speaker": "曉臻",
    "text": "反應前 加起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.74,
    "end": 58.63,
    "speaker": "曉臻",
    "text": "6 加 1 加 2 加 32",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.83,
    "end": 61.24,
    "speaker": "曉臻",
    "text": "總共 是 41",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.44,
    "end": 65.48,
    "speaker": "彥君",
    "text": "沒錯 反應後",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.68,
    "end": 68.16,
    "speaker": "彥君",
    "text": "也要是 41",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.36,
    "end": 71.34,
    "speaker": "曉臻",
    "text": "可是 後面三個加起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.54,
    "end": 74.17,
    "speaker": "曉臻",
    "text": "已經是 41 了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.37,
    "end": 76.97,
    "speaker": "彥君",
    "text": "所以 甲的問號",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.17,
    "end": 81.23,
    "speaker": "彥君",
    "text": "就是 0 它用光了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.43,
    "end": 84.32,
    "speaker": "曉臻",
    "text": "老師 丙都是 2 耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.52,
    "end": 87.22,
    "speaker": "彥君",
    "text": "丙有 參與反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.42,
    "end": 90.33,
    "speaker": "彥君",
    "text": "只是 不會被消耗掉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.53,
    "end": 93.3,
    "speaker": "彥君",
    "text": "它 就是催化劑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.5,
    "end": 96.58,
    "speaker": "彥君",
    "text": "接下來 進入重頭戲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.78,
    "end": 100.24,
    "speaker": "彥君",
    "text": "戰士們， 準備寫筆記！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.44,
    "end": 103.38,
    "speaker": "彥君",
    "text": "平衡係數 觀察法",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.58,
    "end": 107.04,
    "speaker": "彥君",
    "text": "第一題 氫氣加氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.24,
    "end": 144.86,
    "speaker": "彥君",
    "text": "H₂ + O₂ → H₂O",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 111.0,
    "end": 113.05,
    "speaker": "曉臻",
    "text": "左邊 2 個氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.25,
    "end": 115.56,
    "speaker": "曉臻",
    "text": "右邊 只有 1 個氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.76,
    "end": 118.67,
    "speaker": "彥君",
    "text": "所以在 水的前面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.87,
    "end": 121.28,
    "speaker": "彥君",
    "text": "補上 係數 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.48,
    "end": 144.86,
    "speaker": "彥君",
    "text": "H₂ + O₂ → 2H₂O",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 124.95,
    "end": 127.84,
    "speaker": "曉臻",
    "text": "那右邊 變成 4 個氫了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.04,
    "end": 132.27,
    "speaker": "彥君",
    "text": "很好 所以左邊的氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.47,
    "end": 135.1,
    "speaker": "彥君",
    "text": "也要 補上係數 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.3,
    "end": 144.86,
    "speaker": "彥君",
    "text": "2H₂ + O₂ → 2H₂O",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 138.77,
    "end": 141.66,
    "speaker": "彥君",
    "text": "第一題 完美平衡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.86,
    "end": 144.82,
    "speaker": "彥君",
    "text": "給你們 三秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.02,
    "end": 147.76,
    "speaker": "彥君",
    "text": "接下來 第二題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.96,
    "end": 150.99,
    "speaker": "彥君",
    "text": "氮氣加氫氣 變氨氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.19,
    "end": 184.93,
    "speaker": "彥君",
    "text": "N₂ + H₂ → NH₃",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 155.0,
    "end": 157.1,
    "speaker": "曉臻",
    "text": "左邊 2 個氮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.3,
    "end": 159.54,
    "speaker": "曉臻",
    "text": "右邊 只有 1 個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.74,
    "end": 162.65,
    "speaker": "彥君",
    "text": "所以 氨氣前面寫 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.85,
    "end": 184.93,
    "speaker": "彥君",
    "text": "N₂ + H₂ → 2NH₃",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 166.32,
    "end": 168.94,
    "speaker": "曉臻",
    "text": "這樣 右邊有 6 個氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 169.14,
    "end": 172.18,
    "speaker": "彥君",
    "text": "左邊 氫氣前面寫 3",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 172.38,
    "end": 175.12,
    "speaker": "彥君",
    "text": "3 乘 2 等於 6",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.32,
    "end": 184.93,
    "speaker": "彥君",
    "text": "N₂ + 3H₂ → 2NH₃",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 178.84,
    "end": 181.73,
    "speaker": "彥君",
    "text": "第二題 輕鬆解決",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.93,
    "end": 185.49,
    "speaker": "彥君",
    "text": "戰士們， 準備下一題。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.69,
    "end": 188.43,
    "speaker": "彥君",
    "text": "第三題 甲烷燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 188.63,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "CH₄ + O₂ → CO₂ + H₂O",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 193.02,
    "end": 195.09,
    "speaker": "曉臻",
    "text": "左邊 4 個氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 195.29,
    "end": 197.94,
    "speaker": "彥君",
    "text": "水的 前面寫 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 198.14,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "CH₄ + O₂ → CO₂ + 2H₂O",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 201.66,
    "end": 204.28,
    "speaker": "曉臻",
    "text": "這樣 右邊有 4 個氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 204.48,
    "end": 207.49,
    "speaker": "彥君",
    "text": "所以 左邊氧氣寫 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 207.69,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "CH₄ + 2O₂ → CO₂ + 2H₂O",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 211.18,
    "end": 214.34,
    "speaker": "彥君",
    "text": "觀察法 就是這麼簡單",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 214.54,
    "end": 217.98,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 218.18,
    "end": 220.78,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 220.98,
    "end": 223.31,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 223.51,
    "end": 227.1,
    "speaker": "合聲",
    "text": "質量守恆 係數平衡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 227.3,
    "end": 230.83,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
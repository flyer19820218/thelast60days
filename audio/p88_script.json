[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.26,
    "speaker": "彥君",
    "text": "今天來到 第八十八集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.46,
    "end": 16.19,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.39,
    "end": 18.73,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.93,
    "end": 21.38,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.58,
    "end": 24.59,
    "speaker": "彥君",
    "text": "化學反應 發生時",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.79,
    "end": 27.7,
    "speaker": "彥君",
    "text": "質量 絕對會守恆",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.9,
    "end": 30.0,
    "speaker": "曉臻",
    "text": "可是 老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.2,
    "end": 32.7,
    "speaker": "曉臻",
    "text": "為什麼 鐵絲燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.9,
    "end": 35.29,
    "speaker": "曉臻",
    "text": "或是 鐵釘生鏽",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.49,
    "end": 37.78,
    "speaker": "曉臻",
    "text": "重量 卻變重了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.98,
    "end": 40.82,
    "speaker": "彥君",
    "text": "因為 鐵絲燃燒時",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.02,
    "end": 43.88,
    "speaker": "彥君",
    "text": "結合了 空氣中的氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.08,
    "end": 47.3,
    "speaker": "彥君",
    "text": "氧氣的重量 也算進去了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.5,
    "end": 50.78,
    "speaker": "曉臻",
    "text": "喔 那木炭燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.98,
    "end": 53.36,
    "speaker": "曉臻",
    "text": "燒完 剩下灰燼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.56,
    "end": 55.99,
    "speaker": "曉臻",
    "text": "重量 怎麼變輕了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.19,
    "end": 58.62,
    "speaker": "彥君",
    "text": "因為 木炭燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.82,
    "end": 61.62,
    "speaker": "彥君",
    "text": "產生了 二氧化碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.82,
    "end": 64.63,
    "speaker": "彥君",
    "text": "氣體 跑進空氣裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.83,
    "end": 67.24,
    "speaker": "彥君",
    "text": "當然 量不到啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.44,
    "end": 69.46,
    "speaker": "曉臻",
    "text": "原來如此",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.66,
    "end": 72.05,
    "speaker": "曉臻",
    "text": "如果 把它關在",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.25,
    "end": 74.78,
    "speaker": "曉臻",
    "text": "密閉 容器裡面量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.98,
    "end": 77.6,
    "speaker": "曉臻",
    "text": "重量 就一樣了對吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.8,
    "end": 80.18,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.38,
    "end": 83.54,
    "speaker": "彥君",
    "text": "接著看 投影片表格",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.74,
    "end": 86.55,
    "speaker": "曉臻",
    "text": "老師 表格裡的甲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.75,
    "end": 89.45,
    "speaker": "曉臻",
    "text": "反應後 變成問號了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.65,
    "end": 92.61,
    "speaker": "彥君",
    "text": "根據 質量守恆定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.81,
    "end": 95.6,
    "speaker": "彥君",
    "text": "反應前 總重量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.8,
    "end": 98.71,
    "speaker": "彥君",
    "text": "等於 反應後 總重量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.91,
    "end": 101.27,
    "speaker": "曉臻",
    "text": "反應前 加起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.47,
    "end": 104.34,
    "speaker": "曉臻",
    "text": "$6+1+2+32$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.54,
    "end": 106.54,
    "speaker": "曉臻",
    "text": "總共 是 $41$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.74,
    "end": 110.78,
    "speaker": "彥君",
    "text": "沒錯 反應後",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 110.98,
    "end": 113.43,
    "speaker": "彥君",
    "text": "也要是 $41$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.63,
    "end": 116.06,
    "speaker": "曉臻",
    "text": "可是 後面三個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.26,
    "end": 118.94,
    "speaker": "曉臻",
    "text": "$25+2+14$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.14,
    "end": 122.36,
    "speaker": "曉臻",
    "text": "加起來 已經是 $41$ 了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.56,
    "end": 125.16,
    "speaker": "彥君",
    "text": "所以 甲的問號",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.36,
    "end": 129.42,
    "speaker": "彥君",
    "text": "就是 $0$ 它用光了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.62,
    "end": 132.51,
    "speaker": "曉臻",
    "text": "老師 丙都是 $2$ 耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.71,
    "end": 135.41,
    "speaker": "彥君",
    "text": "丙有 參與反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.61,
    "end": 138.52,
    "speaker": "彥君",
    "text": "只是 不會被消耗掉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.72,
    "end": 141.49,
    "speaker": "彥君",
    "text": "它 就是催化劑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.69,
    "end": 144.77,
    "speaker": "彥君",
    "text": "接下來 進入重頭戲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.97,
    "end": 148.43,
    "speaker": "彥君",
    "text": "戰士們 準備寫筆記",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.63,
    "end": 151.57,
    "speaker": "彥君",
    "text": "平衡係數 觀察法",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.77,
    "end": 155.23,
    "speaker": "彥君",
    "text": "第一題 氫氣加氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.43,
    "end": 197.19,
    "speaker": "彥君",
    "text": "$H_2 + O_2 \\rightarrow H_2O$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 159.19,
    "end": 162.13,
    "speaker": "曉臻",
    "text": "左邊 $2$（兩）個氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.33,
    "end": 164.74,
    "speaker": "曉臻",
    "text": "右邊 只有 $1$個氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.94,
    "end": 167.85,
    "speaker": "彥君",
    "text": "所以在 水的前面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.05,
    "end": 170.46,
    "speaker": "彥君",
    "text": "補上 係數 $2$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.66,
    "end": 197.19,
    "speaker": "彥君",
    "text": "$H_2 + O_2 \\rightarrow 2H_2O$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 174.13,
    "end": 177.02,
    "speaker": "曉臻",
    "text": "那右邊 變成 $4$ 個氫了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.22,
    "end": 181.45,
    "speaker": "彥君",
    "text": "很好 所以左邊的氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.65,
    "end": 184.27,
    "speaker": "彥君",
    "text": "也要 補上係數 $2$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 184.47,
    "end": 197.19,
    "speaker": "彥君",
    "text": "$2H_2 + O_2 \\rightarrow 2H_2O$",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 187.94,
    "end": 190.83,
    "speaker": "彥君",
    "text": "第一題 完美平衡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 191.03,
    "end": 193.99,
    "speaker": "彥君",
    "text": "給你們 三秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 197.19,
    "end": 199.94,
    "speaker": "彥君",
    "text": "接下來 第二題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 200.14,
    "end": 203.17,
    "speaker": "彥君",
    "text": "氮氣加氫氣 變氨氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 203.37,
    "end": 240.89,
    "speaker": "彥君",
    "text": "$N_2 + H_2 \\rightarrow NH_3$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 207.18,
    "end": 209.27,
    "speaker": "曉臻",
    "text": "左邊 $2$個氮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 209.47,
    "end": 211.78,
    "speaker": "曉臻",
    "text": "右邊 只有 $1$個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 211.98,
    "end": 214.9,
    "speaker": "彥君",
    "text": "所以 氨氣前面寫 $2$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 215.1,
    "end": 240.89,
    "speaker": "彥君",
    "text": "$N_2 + H_2 \\rightarrow 2NH_3$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 218.57,
    "end": 221.17,
    "speaker": "曉臻",
    "text": "這樣 右邊有 $6$個氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 221.37,
    "end": 224.4,
    "speaker": "彥君",
    "text": "左邊 氫氣前面寫 $3$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 224.6,
    "end": 227.32,
    "speaker": "彥君",
    "text": "$3 \\times 2 = 6$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 227.52,
    "end": 240.89,
    "speaker": "彥君",
    "text": "$N_2 + 3H_2 \\rightarrow 2NH_3$",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 231.04,
    "end": 233.93,
    "speaker": "彥君",
    "text": "第二題 輕鬆解決",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 234.13,
    "end": 237.69,
    "speaker": "彥君",
    "text": "戰士們 準備下一題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 240.89,
    "end": 243.63,
    "speaker": "彥君",
    "text": "第三題 甲烷燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 243.83,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$CH_4 + O_2 \\rightarrow CO_2 + H_2O$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 248.22,
    "end": 250.31,
    "speaker": "曉臻",
    "text": "左邊 $4$個氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 250.51,
    "end": 253.16,
    "speaker": "彥君",
    "text": "水的 前面寫 $2$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 253.36,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$CH_4 + O_2 \\rightarrow CO_2 + 2H_2O$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 256.88,
    "end": 259.55,
    "speaker": "曉臻",
    "text": "這樣 右邊有 $4$個氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 259.75,
    "end": 262.76,
    "speaker": "彥君",
    "text": "所以 左邊氧氣寫 $2$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 262.96,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$CH_4 + 2O_2 \\rightarrow CO_2 + 2H_2O$",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 266.46,
    "end": 269.61,
    "speaker": "彥君",
    "text": "觀察法 就是這麼簡單",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 269.81,
    "end": 273.25,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 273.45,
    "end": 276.05,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 276.25,
    "end": 278.58,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 278.78,
    "end": 282.37,
    "speaker": "合聲",
    "text": "質量守恆 係數平衡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 282.57,
    "end": 286.1,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
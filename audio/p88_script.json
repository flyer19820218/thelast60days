      "$$CH_4 + O_2 \\rightarrow CO_2 + H_2O$$"
    ]
  },
  {
    "start": 245.01,
    "end": 248.74,
    "speaker": "曉臻",
    "text": "我看到了左邊有 $$4$$ 個氫",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 248.94,
    "end": 252.28,

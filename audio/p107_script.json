[
  {
    "start": 0.0,
    "end": 3.61,
    "speaker": "彥君",
    "text": "戰士們 伸出你的一隻手",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.81,
    "end": 7.06,
    "speaker": "彥君",
    "text": "你有辦法 舉起一輛汽車嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 7.26,
    "end": 9.9,
    "speaker": "曉臻",
    "text": "老師 怎麼可能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 10.1,
    "end": 13.09,
    "speaker": "曉臻",
    "text": "汽車 可是有兩噸重耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.29,
    "end": 16.51,
    "speaker": "彥君",
    "text": "只要學會 帕斯卡原理",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.71,
    "end": 19.86,
    "speaker": "彥君",
    "text": "你就是 物理界的超人",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.06,
    "end": 23.41,
    "speaker": "彥君",
    "text": "歡迎來到 第 107 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.61,
    "end": 26.81,
    "speaker": "曉臻",
    "text": "大家好 我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.01,
    "end": 29.46,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.66,
    "end": 33.15,
    "speaker": "彥君",
    "text": "看看這張 千斤頂的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.35,
    "end": 36.12,
    "speaker": "曉臻",
    "text": "左邊 是小小的活塞",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.32,
    "end": 39.21,
    "speaker": "曉臻",
    "text": "右邊 是超級大的活塞",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.41,
    "end": 42.54,
    "speaker": "彥君",
    "text": "帕斯卡 發現了一個秘密",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.74,
    "end": 45.72,
    "speaker": "彥君",
    "text": "在密閉的 液體裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.92,
    "end": 49.19,
    "speaker": "彥君",
    "text": "壓力會 原封不動傳遞",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.39,
    "end": 106.34,
    "speaker": "彥君",
    "text": "$\\text{帕斯卡} \\rightarrow \\text{壓力同等傳遞}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 53.51,
    "end": 56.4,
    "speaker": "曉臻",
    "text": "所以 左邊產生的壓力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.6,
    "end": 59.22,
    "speaker": "曉臻",
    "text": "會等於 右邊的壓力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.42,
    "end": 64.28,
    "speaker": "彥君",
    "text": "沒錯 壓力是力量除以面積",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.48,
    "end": 106.34,
    "speaker": "彥君",
    "text": "$\\frac{F_{小}}{A_{小}} = \\frac{F_{大}}{A_{大}}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 68.74,
    "end": 72.14,
    "speaker": "曉臻",
    "text": "老師 如果左邊面積是 1",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.34,
    "end": 74.96,
    "speaker": "曉臻",
    "text": "右邊 面積是 100 呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.16,
    "end": 78.43,
    "speaker": "彥君",
    "text": "那你只要 在左邊推 1 公斤",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.63,
    "end": 81.81,
    "speaker": "彥君",
    "text": "右邊就會 舉起 100 公斤",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.01,
    "end": 85.95,
    "speaker": "曉臻",
    "text": "哇 力量直接 放大一百倍",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.15,
    "end": 89.23,
    "speaker": "彥君",
    "text": "這就是 帕斯卡的魔法",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.43,
    "end": 106.34,
    "speaker": "彥君",
    "text": "$\\text{面積越大} \\rightarrow \\text{力量越大}$",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 93.62,
    "end": 96.51,
    "speaker": "彥君",
    "text": "只要 活塞面積夠大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.71,
    "end": 99.89,
    "speaker": "彥君",
    "text": "單手舉車 絕對不是夢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.09,
    "end": 103.14,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘想像",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.34,
    "end": 109.78,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.98,
    "end": 112.58,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.78,
    "end": 115.12,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.32,
    "end": 118.66,
    "speaker": "合聲",
    "text": "壓力傳遞 以小搏大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.86,
    "end": 122.4,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
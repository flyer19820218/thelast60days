[
  {
    "start": 0.0,
    "end": 3.81,
    "speaker": "彥君",
    "text": "戰士們 你有沒有想過"
  },
  {
    "start": 3.81,
    "end": 7.0,
    "speaker": "彥君",
    "text": "吃下去的 炸雞排"
  },
  {
    "start": 7.0,
    "end": 10.19,
    "speaker": "彥君",
    "text": "為什麼 不會在肚子裡"
  },
  {
    "start": 10.19,
    "end": 12.99,
    "speaker": "彥君",
    "text": "塞上 好幾年"
  },
  {
    "start": 12.99,
    "end": 16.06,
    "speaker": "彥君",
    "text": "這一切 都是因為"
  },
  {
    "start": 16.06,
    "end": 19.34,
    "speaker": "彥君",
    "text": "體內的 魔術師 在發功"
  },
  {
    "start": 19.34,
    "end": 22.63,
    "speaker": "彥君",
    "text": "歡迎來到 第七集"
  },
  {
    "start": 22.63,
    "end": 25.53,
    "speaker": "彥君",
    "text": "我是 彥君老師"
  },
  {
    "start": 25.53,
    "end": 27.56,
    "speaker": "曉臻",
    "text": "大家好"
  },
  {
    "start": 27.56,
    "end": 30.2,
    "speaker": "曉臻",
    "text": "我是 曉臻助教"
  },
  {
    "start": 30.2,
    "end": 33.44,
    "speaker": "彥君",
    "text": "請翻到 講義第七頁"
  },
  {
    "start": 33.44,
    "end": 37.46,
    "speaker": "彥君",
    "text": "我們要來 聊聊 [酵素]"
  },
  {
    "start": 37.46,
    "end": 40.94,
    "speaker": "彥君",
    "text": "它是 生物體內的 催化劑"
  },
  {
    "start": 40.94,
    "end": 44.39,
    "speaker": "彥君",
    "text": "專門用來 加速反應"
  },
  {
    "start": 44.39,
    "end": 47.8,
    "speaker": "曉臻",
    "text": "老師 我看 第一點寫著"
  },
  {
    "start": 47.8,
    "end": 51.42,
    "speaker": "曉臻",
    "text": "[酵素]的成分 是蛋白質"
  },
  {
    "start": 51.42,
    "end": 55.04,
    "speaker": "曉臻",
    "text": "這是不是代表 它非常怕熱啊"
  },
  {
    "start": 55.04,
    "end": 59.9,
    "speaker": "彥君",
    "text": "沒錯 這是 第一個大考點"
  },
  {
    "start": 59.9,
    "end": 63.12,
    "speaker": "彥君",
    "text": "溫度對 活性的影響"
  },
  {
    "start": 63.12,
    "end": 66.18,
    "speaker": "彥君",
    "text": "蛋白質 遇到高溫"
  },
  {
    "start": 66.18,
    "end": 69.64,
    "speaker": "彥君",
    "text": "會產生 永久的 變性"
  },
  {
    "start": 69.64,
    "end": 76.57,
    "speaker": "彥君",
    "text": "酵素變性]"
  },
  {
    "start": 76.57,
    "end": 79.66,
    "speaker": "彥君",
    "text": "形狀 一旦改變"
  },
  {
    "start": 79.66,
    "end": 82.73,
    "speaker": "彥君",
    "text": "就像 煮熟的雞蛋"
  },
  {
    "start": 82.73,
    "end": 85.51,
    "speaker": "彥君",
    "text": "永遠 回不去了"
  },
  {
    "start": 85.51,
    "end": 87.88,
    "speaker": "曉臻",
    "text": "所以老師"
  },
  {
    "start": 87.88,
    "end": 91.07,
    "speaker": "曉臻",
    "text": "這就是 實驗題 常考的"
  },
  {
    "start": 91.07,
    "end": 93.63,
    "speaker": "曉臻",
    "text": "加熱口水 對吧"
  },
  {
    "start": 93.63,
    "end": 98.07,
    "speaker": "彥君",
    "text": "賓果 戰士們注意"
  },
  {
    "start": 98.07,
    "end": 101.4,
    "speaker": "彥君",
    "text": "唾液 拿去 滾水煮沸"
  },
  {
    "start": 101.4,
    "end": 104.73,
    "speaker": "彥君",
    "text": "澱粉酶 就 永久報廢了"
  },
  {
    "start": 104.73,
    "end": 108.26,
    "speaker": "彥君",
    "text": "就算 冷卻回來 也沒用"
  },
  {
    "start": 108.26,
    "end": 111.18,
    "speaker": "曉臻",
    "text": "那我們在 試管裡面"
  },
  {
    "start": 111.18,
    "end": 114.51,
    "speaker": "曉臻",
    "text": "加入碘液 顏色會怎麼變"
  },
  {
    "start": 114.51,
    "end": 118.11,
    "speaker": "彥君",
    "text": "因為 [酵素]壞了"
  },
  {
    "start": 118.11,
    "end": 121.08,
    "speaker": "彥君",
    "text": "澱粉 沒被分解"
  },
  {
    "start": 121.08,
    "end": 124.05,
    "speaker": "彥君",
    "text": "所以 滴入碘液"
  },
  {
    "start": 124.05,
    "end": 127.38,
    "speaker": "彥君",
    "text": "依然會 呈現藍黑色"
  },
  {
    "start": 127.38,
    "end": 133.07,
    "speaker": "彥君",
    "text": "呈現藍黑色]"
  },
  {
    "start": 133.07,
    "end": 136.42,
    "speaker": "彥君",
    "text": "如果改用 本氏液 加熱"
  },
  {
    "start": 136.42,
    "end": 139.54,
    "speaker": "彥君",
    "text": "因為 沒有產生糖"
  },
  {
    "start": 139.54,
    "end": 143.21,
    "speaker": "彥君",
    "text": "所以會 維持 原本的藍色"
  },
  {
    "start": 143.21,
    "end": 148.96,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘消化] [清空釘選]"
  },
  {
    "start": 148.96,
    "end": 151.29,
    "speaker": "曉臻",
    "text": "原來如此"
  },
  {
    "start": 151.29,
    "end": 155.1,
    "speaker": "曉臻",
    "text": "那如果是 放在 冰塊裡的口水呢"
  },
  {
    "start": 155.1,
    "end": 157.83,
    "speaker": "彥君",
    "text": "戰士們注意"
  },
  {
    "start": 157.83,
    "end": 161.98,
    "speaker": "彥君",
    "text": "低溫 只是讓 [酵素] 睡著了"
  },
  {
    "start": 161.98,
    "end": 164.62,
    "speaker": "彥君",
    "text": "活性降低"
  },
  {
    "start": 164.62,
    "end": 167.52,
    "speaker": "彥君",
    "text": "只要 恢復常溫"
  },
  {
    "start": 167.52,
    "end": 171.04,
    "speaker": "彥君",
    "text": "它還是可以 繼續工作的"
  },
  {
    "start": 171.04,
    "end": 177.85,
    "speaker": "彥君",
    "text": "活性降低 ]"
  },
  {
    "start": 177.85,
    "end": 180.61,
    "speaker": "彥君",
    "text": "[清空釘選]"
  },
  {
    "start": 180.61,
    "end": 184.68,
    "speaker": "曉臻",
    "text": "老師 那第三點的 pH值"
  },
  {
    "start": 184.68,
    "end": 187.34,
    "speaker": "曉臻",
    "text": "又是 怎麼回事"
  },
  {
    "start": 187.34,
    "end": 191.23,
    "speaker": "彥君",
    "text": "[酵素] 非常挑剔 環境"
  },
  {
    "start": 191.23,
    "end": 194.87,
    "speaker": "彥君",
    "text": "每一種 [酵素]"
  },
  {
    "start": 194.87,
    "end": 198.76,
    "speaker": "彥君",
    "text": "都有 自己喜歡的 pH值"
  },
  {
    "start": 198.76,
    "end": 202.45,
    "speaker": "彥君",
    "text": "就像 胃蛋白酶 喜歡酸性"
  },
  {
    "start": 202.45,
    "end": 206.0,
    "speaker": "彥君",
    "text": "唾液澱粉酶 喜歡中性"
  },
  {
    "start": 206.0,
    "end": 211.51,
    "speaker": "彥君",
    "text": "中性]"
  },
  {
    "start": 211.51,
    "end": 214.7,
    "speaker": "彥君",
    "text": "如果我們在 口水裡"
  },
  {
    "start": 214.7,
    "end": 217.36,
    "speaker": "彥君",
    "text": "加入強酸"
  },
  {
    "start": 217.36,
    "end": 221.41,
    "speaker": "彥君",
    "text": "[酵素]的形狀 同樣會改變"
  },
  {
    "start": 221.41,
    "end": 224.38,
    "speaker": "彥君",
    "text": "導致它 徹底罷工"
  },
  {
    "start": 224.38,
    "end": 227.14,
    "speaker": "彥君",
    "text": "[清空釘選]"
  },
  {
    "start": 227.14,
    "end": 230.18,
    "speaker": "曉臻",
    "text": "老師 圖上畫的"
  },
  {
    "start": 230.18,
    "end": 233.06,
    "speaker": "曉臻",
    "text": "那個像 拼圖的東西"
  },
  {
    "start": 233.06,
    "end": 235.65,
    "speaker": "曉臻",
    "text": "就是 專一性 嗎"
  },
  {
    "start": 235.65,
    "end": 238.04,
    "speaker": "彥君",
    "text": "沒錯"
  },
  {
    "start": 238.04,
    "end": 242.65,
    "speaker": "彥君",
    "text": "這就是 [酵素] 最神奇的地方"
  },
  {
    "start": 242.65,
    "end": 245.84,
    "speaker": "彥君",
    "text": "一把鑰匙 開一把鎖"
  },
  {
    "start": 245.84,
    "end": 249.0,
    "speaker": "彥君",
    "text": "[酵素]的形狀"
  },
  {
    "start": 249.0,
    "end": 252.36,
    "speaker": "彥君",
    "text": "必須跟 受質相符"
  },
  {
    "start": 252.36,
    "end": 256.14,
    "speaker": "彥君",
    "text": "分解澱粉的 [酵素]"
  },
  {
    "start": 256.14,
    "end": 259.79,
    "speaker": "彥君",
    "text": "絕對不會去 分解蛋白質"
  },
  {
    "start": 259.79,
    "end": 263.24,
    "speaker": "彥君",
    "text": "這種 非你不可 的特性"
  },
  {
    "start": 263.24,
    "end": 266.5,
    "speaker": "彥君",
    "text": "我們就稱為 專一性"
  },
  {
    "start": 266.5,
    "end": 273.48,
    "speaker": "彥君",
    "text": "一把鑰匙開一把鎖]"
  },
  {
    "start": 273.48,
    "end": 276.12,
    "speaker": "曉臻",
    "text": "難怪我看圖上"
  },
  {
    "start": 276.12,
    "end": 279.26,
    "speaker": "曉臻",
    "text": "綠色的受質 剛好卡進"
  },
  {
    "start": 279.26,
    "end": 283.21,
    "speaker": "曉臻",
    "text": "黃色[酵素]的 反應區域"
  },
  {
    "start": 283.21,
    "end": 285.87,
    "speaker": "曉臻",
    "text": "如果形狀不對"
  },
  {
    "start": 285.87,
    "end": 289.04,
    "speaker": "曉臻",
    "text": "就沒辦法 產生反應了"
  },
  {
    "start": 289.04,
    "end": 292.7,
    "speaker": "彥君",
    "text": "戰士們 最後來整理"
  },
  {
    "start": 292.7,
    "end": 296.16,
    "speaker": "彥君",
    "text": "第一 它是蛋白質"
  },
  {
    "start": 296.16,
    "end": 299.34,
    "speaker": "彥君",
    "text": "高溫 會永久壞掉"
  },
  {
    "start": 299.34,
    "end": 302.68,
    "speaker": "彥君",
    "text": "第二 它有專一性"
  },
  {
    "start": 302.68,
    "end": 307.26,
    "speaker": "彥君",
    "text": "一種[酵素] 只能做一種工作"
  },
  {
    "start": 307.26,
    "end": 310.71,
    "speaker": "彥君",
    "text": "第三 反應前後"
  },
  {
    "start": 310.71,
    "end": 314.71,
    "speaker": "彥君",
    "text": "[酵素]本身的 質量跟性質"
  },
  {
    "start": 314.71,
    "end": 317.42,
    "speaker": "彥君",
    "text": "都不會改變"
  },
  {
    "start": 317.42,
    "end": 319.72,
    "speaker": "曉臻",
    "text": "也就是說"
  },
  {
    "start": 319.72,
    "end": 323.03,
    "speaker": "曉臻",
    "text": "[酵素] 就像是 工具"
  },
  {
    "start": 323.03,
    "end": 326.22,
    "speaker": "曉臻",
    "text": "用 螺絲起子 鎖完螺絲"
  },
  {
    "start": 326.22,
    "end": 329.04,
    "speaker": "曉臻",
    "text": "它還是 螺絲起子"
  },
  {
    "start": 329.04,
    "end": 331.49,
    "speaker": "彥君",
    "text": "聰明"
  },
  {
    "start": 331.49,
    "end": 334.6,
    "speaker": "彥君",
    "text": "它可以 重複使用"
  },
  {
    "start": 334.6,
    "end": 337.79,
    "speaker": "彥君",
    "text": "直到它 損壞為止"
  },
  {
    "start": 337.79,
    "end": 343.93,
    "speaker": "彥君",
    "text": "成分是蛋白質、 具有專衣性、 而且可以重複使用)"
  },
  {
    "start": 343.93,
    "end": 346.69,
    "speaker": "彥君",
    "text": "[清空釘選]"
  },
  {
    "start": 346.69,
    "end": 349.66,
    "speaker": "曉臻",
    "text": "那老師 生活中"
  },
  {
    "start": 349.66,
    "end": 352.22,
    "speaker": "曉臻",
    "text": "還有 哪些地方"
  },
  {
    "start": 352.22,
    "end": 355.48,
    "speaker": "曉臻",
    "text": "買得到 [酵素] 嗎"
  },
  {
    "start": 355.48,
    "end": 357.9,
    "speaker": "彥君",
    "text": "當然有"
  },
  {
    "start": 357.9,
    "end": 361.02,
    "speaker": "彥君",
    "text": "像是 嫩肉粉裡面"
  },
  {
    "start": 361.02,
    "end": 363.66,
    "speaker": "彥君",
    "text": "有蛋白酶"
  },
  {
    "start": 363.66,
    "end": 367.44,
    "speaker": "彥君",
    "text": "可以先幫你 分解肉的纖維"
  },
  {
    "start": 367.44,
    "end": 371.95,
    "speaker": "彥君",
    "text": "還有 洗衣精裡面 加入[酵素]"
  },
  {
    "start": 371.95,
    "end": 375.62,
    "speaker": "彥君",
    "text": "也是為了 拆解 汗漬跟油垢"
  },
  {
    "start": 375.62,
    "end": 379.34,
    "speaker": "曉臻",
    "text": "戰士們 閉上眼睛 想一下"
  },
  {
    "start": 379.34,
    "end": 382.21,
    "speaker": "曉臻",
    "text": "為什麼我們 發高燒"
  },
  {
    "start": 382.21,
    "end": 385.57,
    "speaker": "曉臻",
    "text": "到 四十度以上 會很危險"
  },
  {
    "start": 385.57,
    "end": 389.31,
    "speaker": "彥君",
    "text": "因為體內的 [酵素]"
  },
  {
    "start": 389.31,
    "end": 392.5,
    "speaker": "彥君",
    "text": "會因為 高溫變性"
  },
  {
    "start": 392.5,
    "end": 395.68,
    "speaker": "彥君",
    "text": "生命反應 就停擺了"
  },
  {
    "start": 395.68,
    "end": 399.4,
    "speaker": "彥君",
    "text": "低溫暫停 高溫報廢"
  },
  {
    "start": 399.4,
    "end": 402.92,
    "speaker": "彥君",
    "text": "專一性像 鎖頭與鑰匙"
  },
  {
    "start": 402.92,
    "end": 416.65,
    "speaker": "彥君",
    "text": "[釘選] [低溫暫停高溫報廢專一性像鎖與鑰匙]"
  },
  {
    "start": 416.65,
    "end": 419.55,
    "speaker": "彥君",
    "text": "我是 彥君老師"
  },
  {
    "start": 419.55,
    "end": 422.18,
    "speaker": "曉臻",
    "text": "我是 曉臻助教"
  },
  {
    "start": 422.18,
    "end": 426.26,
    "speaker": "曉臻",
    "text": "掌握[酵素] 反應神速"
  },
  {
    "start": 426.26,
    "end": 429.57,
    "speaker": "曉臻",
    "text": "戰士們 下個單元見"
  }
]
[
  {
    "start": 0.0,
    "end": 3.27,
    "speaker": "彥君",
    "text": "戰士們 歡迎回到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.47,
    "end": 6.48,
    "speaker": "彥君",
    "text": "浮力大魔王的 下半場",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.68,
    "end": 9.28,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.48,
    "end": 11.22,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.42,
    "end": 13.75,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.95,
    "end": 16.6,
    "speaker": "彥君",
    "text": "[戰士們注意 ]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.8,
    "end": 19.86,
    "speaker": "彥君",
    "text": "這集 要教你們開外掛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.06,
    "end": 22.66,
    "speaker": "曉臻",
    "text": "老師 這張圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.86,
    "end": 25.82,
    "speaker": "曉臻",
    "text": "把沉下去 還有浮起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.02,
    "end": 28.62,
    "speaker": "曉臻",
    "text": "分成 兩種算法耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.82,
    "end": 33.5,
    "speaker": "彥君",
    "text": "沒錯 先看左邊的沉體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.7,
    "end": 36.42,
    "speaker": "彥君",
    "text": "因為 它整塊滅頂了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.62,
    "end": 40.14,
    "speaker": "彥君",
    "text": "排開水的體積 就是最大值",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.34,
    "end": 44.14,
    "speaker": "彥君",
    "text": "帶入公式 就能算出浮力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.34,
    "end": 47.27,
    "speaker": "曉臻",
    "text": "可是 浮力還是不夠大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.47,
    "end": 50.65,
    "speaker": "曉臻",
    "text": "撐不住重量 就沉底了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.85,
    "end": 55.3,
    "speaker": "彥君",
    "text": "觀念很好 那右邊的浮體呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.5,
    "end": 57.88,
    "speaker": "曉臻",
    "text": "它浮在水面上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.08,
    "end": 61.16,
    "speaker": "曉臻",
    "text": "代表 浮力把它撐起來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.36,
    "end": 63.84,
    "speaker": "彥君",
    "text": "既然撐得住",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.04,
    "end": 67.26,
    "speaker": "彥君",
    "text": "代表 浮力剛好抵銷重量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.46,
    "end": 70.38,
    "speaker": "彥君",
    "text": "所以 只要遇到浮體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.58,
    "end": 73.75,
    "speaker": "彥君",
    "text": "直接找 物體的重量就好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.95,
    "end": 85.58,
    "speaker": "彥君",
    "text": "[$\\text{浮體} \\rightarrow B_{浮力} = \\text{物重}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 78.34,
    "end": 82.38,
    "speaker": "曉臻",
    "text": "哇 連公式 都不用算了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.58,
    "end": 85.82,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘抄寫]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.02,
    "end": 89.63,
    "speaker": "彥君",
    "text": "[戰士們 情境題來了]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.83,
    "end": 92.7,
    "speaker": "彥君",
    "text": "一艘 巨大的貨輪",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.9,
    "end": 96.19,
    "speaker": "彥君",
    "text": "從海裡 開進了淡水河",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.39,
    "end": 99.5,
    "speaker": "彥君",
    "text": "請問 船受到的浮力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.7,
    "end": 102.37,
    "speaker": "彥君",
    "text": "變大 還是變小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.57,
    "end": 105.02,
    "speaker": "曉臻",
    "text": "淡水 密度比較小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.22,
    "end": 108.45,
    "speaker": "曉臻",
    "text": "公式算起來 浮力應該變小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.65,
    "end": 112.57,
    "speaker": "彥君",
    "text": "嗶嗶 掉進陷阱了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.77,
    "end": 115.49,
    "speaker": "彥君",
    "text": "船 在海裡跟河裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.69,
    "end": 118.74,
    "speaker": "彥君",
    "text": "是不是 都浮在水面上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.94,
    "end": 122.22,
    "speaker": "曉臻",
    "text": "對耶 都是浮體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.42,
    "end": 125.98,
    "speaker": "彥君",
    "text": "既然是浮體 船有變輕嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.18,
    "end": 129.93,
    "speaker": "曉臻",
    "text": "沒有 所以浮力一樣大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.13,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$\\text{海入河} \\rightarrow \\text{浮力不變}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 134.7,
    "end": 137.86,
    "speaker": "彥君",
    "text": "可是 淡水密度比較小啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.06,
    "end": 141.04,
    "speaker": "彥君",
    "text": "為了 維持一樣大的浮力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.24,
    "end": 144.3,
    "speaker": "彥君",
    "text": "船 只能排開更多水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.5,
    "end": 148.54,
    "speaker": "曉臻",
    "text": "喔 所以船會往下沉一點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.74,
    "end": 151.24,
    "speaker": "曉臻",
    "text": "吃水 變得更深了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.44,
    "end": 156.27,
    "speaker": "彥君",
    "text": "完全正確 這就是大考最愛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.47,
    "end": 159.91,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.11,
    "end": 162.71,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.91,
    "end": 165.25,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.45,
    "end": 168.96,
    "speaker": "合聲",
    "text": "浮體看重 沉體看體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 169.16,
    "end": 172.7,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.12,
    "speaker": "彥君",
    "text": "第 117 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.32,
    "end": 10.19,
    "speaker": "彥君",
    "text": "物理學說 你付出多少作用力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 10.39,
    "end": 13.98,
    "speaker": "彥君",
    "text": "分數就會 給你多少反作用力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.18,
    "end": 17.45,
    "speaker": "彥君",
    "text": "所有的努力 都不會白費",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 17.65,
    "end": 20.25,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.45,
    "end": 22.18,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.38,
    "end": 24.72,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.92,
    "end": 27.38,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.58,
    "end": 30.44,
    "speaker": "彥君",
    "text": "牛頓第三定律 來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.64,
    "end": 34.06,
    "speaker": "曉臻",
    "text": "老師 俗話說打人一拳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.26,
    "end": 36.93,
    "speaker": "曉臻",
    "text": "自己的手 也會痛耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.13,
    "end": 41.94,
    "speaker": "彥君",
    "text": "沒錯 力量永遠是互相的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.14,
    "end": 45.36,
    "speaker": "彥君",
    "text": "而且 它們會同時出現",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.56,
    "end": 48.16,
    "speaker": "彥君",
    "text": "也會 同時消失喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.36,
    "end": 98.51,
    "speaker": "彥君",
    "text": "$\\text{牛三} \\rightarrow \\text{同時發生與消失}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 53.1,
    "end": 56.33,
    "speaker": "曉臻",
    "text": "講義上寫著 大小相等、",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.53,
    "end": 58.89,
    "speaker": "曉臻",
    "text": "而且 方向相反",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.09,
    "end": 62.41,
    "speaker": "曉臻",
    "text": "那加起來 不就抵消變成零了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.61,
    "end": 67.13,
    "speaker": "彥君",
    "text": "嗶嗶 這是超級大陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.33,
    "end": 70.29,
    "speaker": "彥君",
    "text": "注意看 講義的第二點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.49,
    "end": 73.5,
    "speaker": "彥君",
    "text": "作用力 跟反作用力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.7,
    "end": 77.04,
    "speaker": "彥君",
    "text": "是作用在 不同的物體上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.24,
    "end": 80.99,
    "speaker": "彥君",
    "text": "就像 你打牆壁 牆壁打你",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.19,
    "end": 84.42,
    "speaker": "彥君",
    "text": "受傷的 是不一樣的東西",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.62,
    "end": 87.41,
    "speaker": "彥君",
    "text": "絕對 不可以抵消",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.61,
    "end": 98.51,
    "speaker": "彥君",
    "text": "$\\text{不同物體} \\rightarrow \\text{不可抵消}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 92.14,
    "end": 95.31,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘打星號",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.51,
    "end": 101.52,
    "speaker": "曉臻",
    "text": "老師 那下面這個圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.72,
    "end": 104.7,
    "speaker": "曉臻",
    "text": "有 A 跟 B 兩個木塊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.9,
    "end": 108.13,
    "speaker": "彥君",
    "text": "我們用 90 牛頓的力去推",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.33,
    "end": 111.48,
    "speaker": "彥君",
    "text": "這裡 觀念比計算重要",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.68,
    "end": 114.93,
    "speaker": "彥君",
    "text": "注意看 中間的兩個箭頭",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.13,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$F_{AB}$ \\text{ 與 } $F_{BA}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 119.75,
    "end": 122.93,
    "speaker": "曉臻",
    "text": "喔 A 推 B",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.13,
    "end": 125.44,
    "speaker": "曉臻",
    "text": "B 同時也推 A",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.64,
    "end": 129.8,
    "speaker": "彥君",
    "text": "完全正確 記住",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.0,
    "end": 133.44,
    "speaker": "彥君",
    "text": "不管是 碰在一起的接觸力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 133.64,
    "end": 137.13,
    "speaker": "彥君",
    "text": "還是 隔空吸引的萬有引力、",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.33,
    "end": 140.41,
    "speaker": "彥君",
    "text": "甚至是 磁鐵的磁力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.61,
    "end": 144.12,
    "speaker": "彥君",
    "text": "全部都 遵守牛頓第三定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.32,
    "end": 147.76,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.96,
    "end": 150.56,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.76,
    "end": 153.1,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.3,
    "end": 156.66,
    "speaker": "合聲",
    "text": "不同物體 絕不抵消",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.86,
    "end": 160.4,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.33,
    "speaker": "彥君",
    "text": "今天來到 第 103 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.53,
    "end": 16.26,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.46,
    "end": 18.8,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.0,
    "end": 21.65,
    "speaker": "彥君",
    "text": "[戰士們注意 ]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.85,
    "end": 24.64,
    "speaker": "彥君",
    "text": "這集 要講摩擦力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.84,
    "end": 27.9,
    "speaker": "彥君",
    "text": "這裡有 必殺陷阱題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.1,
    "end": 30.94,
    "speaker": "曉臻",
    "text": "老師 右邊的圖表",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.14,
    "end": 33.76,
    "speaker": "曉臻",
    "text": "一開始 是一條斜線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.96,
    "end": 38.36,
    "speaker": "彥君",
    "text": "沒錯 只要物體沒動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.56,
    "end": 41.11,
    "speaker": "彥君",
    "text": "這條 斜直線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.31,
    "end": 43.91,
    "speaker": "彥君",
    "text": "就是 靜摩擦力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.11,
    "end": 47.12,
    "speaker": "曉臻",
    "text": "為什麼 角度是 45 度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.32,
    "end": 50.18,
    "speaker": "彥君",
    "text": "因為 只要物體靜止",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.38,
    "end": 53.1,
    "speaker": "彥君",
    "text": "推力 等於摩擦力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.3,
    "end": 97.0,
    "speaker": "彥君",
    "text": "[$\\text{靜止} \\rightarrow \\text{推力} = \\text{摩擦力}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 57.4,
    "end": 60.58,
    "speaker": "曉臻",
    "text": "喔 我推 5 公斤",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.78,
    "end": 63.02,
    "speaker": "曉臻",
    "text": "摩擦力 就是 5",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.22,
    "end": 67.3,
    "speaker": "彥君",
    "text": "答對了 靜摩擦力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.5,
    "end": 70.34,
    "speaker": "彥君",
    "text": "是 會跟著改變的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.54,
    "end": 73.6,
    "speaker": "彥君",
    "text": "一直推 到斜線頂點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.8,
    "end": 76.33,
    "speaker": "彥君",
    "text": "那一點 叫什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.53,
    "end": 79.22,
    "speaker": "曉臻",
    "text": "叫做 最大靜摩擦力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.42,
    "end": 82.24,
    "speaker": "彥君",
    "text": "突破 這一點之後",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.44,
    "end": 85.26,
    "speaker": "彥君",
    "text": "物體 就開始滑動了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 85.46,
    "end": 88.22,
    "speaker": "曉臻",
    "text": "滑動之後 的水平線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.42,
    "end": 90.69,
    "speaker": "曉臻",
    "text": "就是 動摩擦力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.89,
    "end": 93.8,
    "speaker": "彥君",
    "text": "助教 觀察很敏銳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.0,
    "end": 97.32,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘看圖]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.52,
    "end": 100.17,
    "speaker": "彥君",
    "text": "接下來 看左邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.37,
    "end": 102.97,
    "speaker": "彥君",
    "text": "什麼 是正向力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.17,
    "end": 105.62,
    "speaker": "曉臻",
    "text": "講義 寫著代號 [$N$]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.82,
    "end": 108.18,
    "speaker": "曉臻",
    "text": "是讓 兩個物體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.38,
    "end": 110.82,
    "speaker": "曉臻",
    "text": "夾在一起 的力量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.02,
    "end": 114.19,
    "speaker": "彥君",
    "text": "想像一下 壓著橡皮擦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.39,
    "end": 117.3,
    "speaker": "彥君",
    "text": "你往下 壓得越大力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.5,
    "end": 120.39,
    "speaker": "彥君",
    "text": "是不是 越難往前推",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.59,
    "end": 123.82,
    "speaker": "曉臻",
    "text": "真的耶 壓越緊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.02,
    "end": 126.23,
    "speaker": "曉臻",
    "text": "就越難 推得動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.43,
    "end": 129.27,
    "speaker": "彥君",
    "text": "這就是 核心觀念",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.47,
    "end": 132.36,
    "speaker": "彥君",
    "text": "正向力 越大的時候",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.56,
    "end": 135.16,
    "speaker": "彥君",
    "text": "最大 靜摩擦力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.36,
    "end": 138.03,
    "speaker": "彥君",
    "text": "還有 動摩擦力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.23,
    "end": 140.78,
    "speaker": "彥君",
    "text": "都會 跟著變大喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.98,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$N\\text{越大} \\rightarrow \\text{摩擦力變大}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 145.18,
    "end": 148.81,
    "speaker": "曉臻",
    "text": "哇 用壓橡皮擦來想",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.01,
    "end": 151.42,
    "speaker": "曉臻",
    "text": "瞬間 就秒懂了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.62,
    "end": 155.06,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.26,
    "end": 157.86,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.06,
    "end": 160.39,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.59,
    "end": 164.2,
    "speaker": "合聲",
    "text": "靜止相抵 正向無敵",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.4,
    "end": 167.94,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
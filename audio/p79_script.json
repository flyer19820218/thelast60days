  },
  {
    "start": 18.93,
    "end": 21.5,
    "speaker": "曉臻",
    "text": "老師 這張表",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.7,
    "end": 24.3,
    "speaker": "曉臻",
    "text": "星號打得 滿滿的耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.5,
    "end": 26.91,
    "speaker": "曉臻",
    "text": "真的要 全部背嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.11,
    "end": 29.23,
    "speaker": "彥君",
    "text": "戰士們， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.43,
    "end": 32.03,
    "speaker": "彥君",
    "text": "千萬 不要死背！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.23,
    "end": 34.93,
    "speaker": "彥君",
    "text": "我們用 找規律的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.13,
    "end": 37.49,
    "speaker": "彥君",
    "text": "速度最快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.69,
    "end": 40.6,
    "speaker": "彥君",
    "text": "先看 右邊的性質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.8,
    "end": 43.28,
    "speaker": "彥君",
    "text": "只要是 實像",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.48,
    "end": 45.72,
    "speaker": "彥君",
    "text": "一定配什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.92,
    "end": 48.02,
    "speaker": "曉臻",
    "text": "一定配 倒立",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.22,
    "end": 52.18,
    "speaker": "彥君",
    "text": "沒錯 那虛像呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.38,
    "end": 54.94,
    "speaker": "曉臻",
    "text": "虛像 一定配 正立",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.14,
    "end": 57.93,
    "speaker": "彥君",
    "text": "這就是 第一個規律！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.13,
    "end": 61.62,
    "speaker": "彥君",
    "text": "實像必倒 虛像必正",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.82,
    "end": 65.06,
    "speaker": "曉臻",
    "text": "哇 這樣就省了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.26,
    "end": 67.72,
    "speaker": "曉臻",
    "text": "好多 記憶容量了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.92,
    "end": 70.71,
    "speaker": "彥君",
    "text": "接著看 凸透鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.91,
    "end": 73.82,
    "speaker": "彥君",
    "text": "什麼時候 會一樣大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.02,
    "end": 75.71,
    "speaker": "曉臻",
    "text": "放在",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.91,
    "end": 78.44,
    "speaker": "曉臻",
    "text": "2f 的時候",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.64,
    "end": 80.71,
    "speaker": "彥君",
    "text": "答對了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.91,
    "end": 84.28,
    "speaker": "彥君",
    "text": "2f 是大小的分界",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.48,
    "end": 87.15,
    "speaker": "彥君",
    "text": "放得 比兩倍遠",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.35,
    "end": 89.76,
    "speaker": "彥君",
    "text": "像就 縮小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.96,
    "end": 92.63,
    "speaker": "彥君",
    "text": "放得 比兩倍近",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.83,
    "end": 95.19,
    "speaker": "彥君",
    "text": "像就 放大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.39,
    "end": 97.22,
    "speaker": "曉臻",
    "text": "那 f 呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.42,
    "end": 100.46,
    "speaker": "彥君",
    "text": "f 是虛實的分界",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.66,
    "end": 103.4,
    "speaker": "彥君",
    "text": "衝進 焦點之內",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.6,
    "end": 106.27,
    "speaker": "彥君",
    "text": "就會變成 虛像了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.47,
    "end": 109.14,
    "speaker": "曉臻",
    "text": "所以 凹透鏡最乖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.34,
    "end": 111.42,
    "speaker": "曉臻",
    "text": "永遠都是",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.62,
    "end": 113.93,
    "speaker": "曉臻",
    "text": "正立縮小 虛像",
    "is_pinned": false,
    "pin_level": 0

  },
  {
    "start": 2.18,
    "end": 6.17,
    "speaker": "彥君",
    "text": "各位即將衝A的 會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.37,
    "end": 8.97,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.17,
    "end": 12.32,
    "speaker": "彥君",
    "text": "今天來到 第九十二集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.52,
    "end": 14.26,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.46,
    "end": 16.79,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.99,
    "end": 20.1,
    "speaker": "曉臻",
    "text": "老師 上面好多離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.3,
    "end": 22.66,
    "speaker": "曉臻",
    "text": "看得 我頭都暈了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.86,
    "end": 25.86,
    "speaker": "彥君",
    "text": "戰士們， 撐住啊！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.06,
    "end": 29.1,
    "speaker": "彥君",
    "text": "這些 常見的原子團",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.3,
    "end": 32.62,
    "speaker": "彥君",
    "text": "絕對 要背到直覺反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.82,
    "end": 35.54,
    "speaker": "彥君",
    "text": "我們 快速來點名",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.74,
    "end": 38.43,
    "speaker": "曉臻",
    "text": "CO₃²⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.63,
    "end": 41.64,
    "speaker": "曉臻",
    "text": "SO₄²⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.84,
    "end": 46.22,
    "speaker": "彥君",
    "text": "沒錯 那如果氧變少呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.42,
    "end": 49.06,
    "speaker": "彥君",
    "text": "像是 SO₃²⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.26,
    "end": 51.86,
    "speaker": "彥君",
    "text": "還有 NO₂⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.06,
    "end": 55.58,
    "speaker": "彥君",
    "text": "少一個氧 就加個亞字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.78,
    "end": 59.02,
    "speaker": "曉臻",
    "text": "喔 還有 OH⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.22,
    "end": 61.18,
    "speaker": "曉臻",
    "text": "跟 CH₃COO⁻",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.38,
    "end": 64.12,
    "speaker": "彥君",
    "text": "那唯一 帶正電的根呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.32,
    "end": 66.18,
    "speaker": "曉臻",
    "text": "就是 NH₄⁺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.38,
    "end": 70.34,
    "speaker": "彥君",
    "text": "漂亮 接下來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.54,
    "end": 73.34,
    "speaker": "彥君",
    "text": "我們進入 電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.54,
    "end": 76.38,
    "speaker": "彥君",
    "text": "什麼 叫做電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.58,
    "end": 79.18,
    "speaker": "曉臻",
    "text": "就是 正電的總電量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.38,
    "end": 81.9,
    "speaker": "曉臻",
    "text": "等於 負電的總電量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.1,
    "end": 84.49,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.69,
    "end": 87.79,
    "speaker": "彥君",
    "text": "我們來寫 氯化鎂的解離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.99,
    "end": 116.8,
    "speaker": "彥君",
    "text": "MgCl₂ → Mg²⁺ + 2Cl⁻",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 93.24,
    "end": 96.3,
    "speaker": "曉臻",
    "text": "老師 為什麼氯前面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.5,
    "end": 98.83,
    "speaker": "曉臻",
    "text": "要 寫上數字 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.03,
    "end": 101.7,
    "speaker": "彥君",
    "text": "因為 鎂是正 2 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.9,
    "end": 104.46,
    "speaker": "彥君",
    "text": "氯 只有負 1 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.66,
    "end": 107.14,
    "speaker": "彥君",
    "text": "必須要 2 個氯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.34,
    "end": 110.01,
    "speaker": "彥君",
    "text": "才能 抵銷 1 個鎂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 110.21,
    "end": 113.6,
    "speaker": "曉臻",
    "text": "哇 這就是電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.8,
    "end": 117.12,
    "speaker": "彥君",
    "text": "戰士們， 隨堂考來了！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.32,
    "end": 120.02,
    "speaker": "彥君",
    "text": "硫酸鈉的 解離式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.22,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "Na₂SO₄ → 2Na⁺ + SO₄²⁻",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 125.49,
    "end": 127.68,
    "speaker": "曉臻",
    "text": "鈉是 正 1 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 127.88,
    "end": 130.43,
    "speaker": "曉臻",
    "text": "硫酸根 是負 2 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.63,
    "end": 132.66,
    "speaker": "曉臻",
    "text": "為了 電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.86,
    "end": 135.29,
    "speaker": "曉臻",
    "text": "鈉的前面 要寫 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.49,
    "end": 138.14,
    "speaker": "彥君",
    "text": "那如果 有 100 個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.34,
    "end": 141.1,
    "speaker": "彥君",
    "text": "硫酸鈉 丟進水裡呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.3,
    "end": 143.5,
    "speaker": "曉臻",
    "text": "100 乘上 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.7,
    "end": 146.61,
    "speaker": "曉臻",
    "text": "會產生 200 個鈉離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.81,
    "end": 149.34,
    "speaker": "曉臻",
    "text": "還有 100 個硫酸根",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.54,
    "end": 152.78,
    "speaker": "彥君",
    "text": "總共 產生 300 個離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.98,
    "end": 155.78,
    "speaker": "彥君",
    "text": "助教 算得太快了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.98,
    "end": 159.42,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.62,
    "end": 162.22,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.42,
    "end": 164.75,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.95,
    "end": 168.46,
    "speaker": "合聲",
    "text": "正負相抵 解離無敵",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.66,
    "end": 172.2,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
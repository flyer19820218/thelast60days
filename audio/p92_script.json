[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 6.17,
    "speaker": "彥君",
    "text": "各位即將衝A的 會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.37,
    "end": 8.97,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.17,
    "end": 12.32,
    "speaker": "彥君",
    "text": "今天來到 第九十二集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.52,
    "end": 14.26,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.46,
    "end": 16.79,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.99,
    "end": 20.1,
    "speaker": "曉臻",
    "text": "老師 上面好多離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.3,
    "end": 22.66,
    "speaker": "曉臻",
    "text": "看得 我頭都暈了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.86,
    "end": 25.86,
    "speaker": "彥君",
    "text": "戰士們 撐住啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.06,
    "end": 29.1,
    "speaker": "彥君",
    "text": "這些 常見的原子團",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.3,
    "end": 32.62,
    "speaker": "彥君",
    "text": "絕對 要背到直覺反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.82,
    "end": 35.54,
    "speaker": "彥君",
    "text": "我們 快速來點名",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.74,
    "end": 38.43,
    "speaker": "曉臻",
    "text": "$CO_3^{2}$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.63,
    "end": 41.64,
    "speaker": "曉臻",
    "text": "$SO_4^{2}$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.84,
    "end": 46.22,
    "speaker": "彥君",
    "text": "沒錯 那如果氧變少呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.42,
    "end": 48.68,
    "speaker": "彥君",
    "text": "像是 $SO_3^{2}$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.88,
    "end": 51.17,
    "speaker": "彥君",
    "text": "還有 $NO_2^$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.37,
    "end": 54.88,
    "speaker": "彥君",
    "text": "少一個氧 就加個亞字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.08,
    "end": 56.86,
    "speaker": "曉臻",
    "text": "喔 還有 $OH^$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.06,
    "end": 58.9,
    "speaker": "曉臻",
    "text": "跟 $CH_3COO^$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.1,
    "end": 61.84,
    "speaker": "彥君",
    "text": "那唯一 帶正電的根呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.04,
    "end": 63.61,
    "speaker": "曉臻",
    "text": "就是 $NH_4^+$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.81,
    "end": 67.78,
    "speaker": "彥君",
    "text": "漂亮 接下來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.98,
    "end": 70.77,
    "speaker": "彥君",
    "text": "我們進入 電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.97,
    "end": 73.81,
    "speaker": "彥君",
    "text": "什麼 叫做電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.01,
    "end": 76.61,
    "speaker": "曉臻",
    "text": "就是 正電的總電量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.81,
    "end": 79.34,
    "speaker": "曉臻",
    "text": "等於 負電的總電量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.54,
    "end": 81.92,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.12,
    "end": 85.22,
    "speaker": "彥君",
    "text": "我們來寫 氯化鎂的解離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 85.42,
    "end": 117.75,
    "speaker": "彥君",
    "text": "$MgCl_2 \\rightarrow Mg^{2+} + 2Cl^-$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 90.67,
    "end": 93.73,
    "speaker": "曉臻",
    "text": "老師 為什麼氯前面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.93,
    "end": 96.26,
    "speaker": "曉臻",
    "text": "要 寫上數字 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.46,
    "end": 99.14,
    "speaker": "彥君",
    "text": "因為 鎂是正 2 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.34,
    "end": 101.89,
    "speaker": "彥君",
    "text": "氯 只有負 1 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.09,
    "end": 104.57,
    "speaker": "彥君",
    "text": "必須要 2 個氯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.77,
    "end": 107.44,
    "speaker": "彥君",
    "text": "才能 抵銷 1 個鎂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.64,
    "end": 111.03,
    "speaker": "曉臻",
    "text": "哇 這就是電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.23,
    "end": 114.55,
    "speaker": "彥君",
    "text": "戰士們 隨堂考來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.75,
    "end": 120.45,
    "speaker": "彥君",
    "text": "硫酸鈉的 解離式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.65,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$Na_2SO_4 \\rightarrow 2Na^+ + SO_4^{2-}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 125.92,
    "end": 128.11,
    "speaker": "曉臻",
    "text": "鈉是 正 1 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.31,
    "end": 130.86,
    "speaker": "曉臻",
    "text": "硫酸根 是負 2 價",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.06,
    "end": 133.09,
    "speaker": "曉臻",
    "text": "為了 電中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 133.29,
    "end": 135.72,
    "speaker": "曉臻",
    "text": "鈉的前面 要寫 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.92,
    "end": 138.57,
    "speaker": "彥君",
    "text": "那如果 有 100 個",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.77,
    "end": 141.54,
    "speaker": "彥君",
    "text": "硫酸鈉 丟進水裡呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.74,
    "end": 143.93,
    "speaker": "曉臻",
    "text": "100 乘上 2",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.13,
    "end": 147.04,
    "speaker": "曉臻",
    "text": "會產生 200 個鈉離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.24,
    "end": 149.77,
    "speaker": "曉臻",
    "text": "還有 100 個硫酸根",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.97,
    "end": 153.22,
    "speaker": "彥君",
    "text": "總共 產生 300 個離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.42,
    "end": 156.21,
    "speaker": "彥君",
    "text": "助教 算得太快了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.41,
    "end": 159.85,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.05,
    "end": 162.65,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.85,
    "end": 165.18,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.38,
    "end": 168.9,
    "speaker": "合聲",
    "text": "正負相抵 解離無敵",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 169.1,
    "end": 172.63,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.93,
    "end": 21.38,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.58,
    "end": 24.78,
    "speaker": "彥君",
    "text": "我們 正式進入酸鹼鹽",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.98,
    "end": 27.92,
    "speaker": "曉臻",
    "text": "老師 講義上寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.12,
    "end": 30.6,
    "speaker": "曉臻",
    "text": "強酸 完全解離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.8,
    "end": 33.26,
    "speaker": "曉臻",
    "text": "可是 不代表很酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.46,
    "end": 37.93,
    "speaker": "彥君",
    "text": "沒錯 這是必考陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.13,
    "end": 41.76,
    "speaker": "彥君",
    "text": "強酸 代表 100% 解離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.96,
    "end": 44.97,
    "speaker": "彥君",
    "text": "但如果 只有 1 滴強酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.17,
    "end": 48.2,
    "speaker": "彥君",
    "text": "滴在 100 公升的水裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.4,
    "end": 52.06,
    "speaker": "曉臻",
    "text": "哇 那濃度 超級低耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.26,
    "end": 54.98,
    "speaker": "彥君",
    "text": "所以 到底酸不酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.18,
    "end": 58.09,
    "speaker": "彥君",
    "text": "是由 濃度來決定的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.29,
    "end": 61.44,
    "speaker": "曉臻",
    "text": "喔 所以弱酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.64,
    "end": 64.0,
    "speaker": "曉臻",
    "text": "只有 部分解離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.2,
    "end": 66.75,
    "speaker": "曉臻",
    "text": "但如果是 濃醋酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.95,
    "end": 69.79,
    "speaker": "曉臻",
    "text": "濃度很高 一樣會受傷",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.99,
    "end": 72.76,
    "speaker": "彥君",
    "text": "觀念 非常清楚",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.96,
    "end": 75.9,
    "speaker": "彥君",

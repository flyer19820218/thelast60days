    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.14,
    "end": 102.88,
    "speaker": "彥君",
    "text": "助教 整理得太好了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.08,

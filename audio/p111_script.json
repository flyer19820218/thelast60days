[
  {
    "start": 0.0,
    "end": 3.27,
    "speaker": "彥君",
    "text": "戰士們 歡迎回到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.47,
    "end": 6.48,
    "speaker": "彥君",
    "text": "浮力大魔王的 下半場",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.68,
    "end": 9.28,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.48,
    "end": 11.22,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.42,
    "end": 13.75,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.95,
    "end": 16.41,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.61,
    "end": 19.66,
    "speaker": "彥君",
    "text": "這集 要教你們開外掛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.86,
    "end": 22.46,
    "speaker": "曉臻",
    "text": "老師 這張圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.66,
    "end": 25.62,
    "speaker": "曉臻",
    "text": "把沉下去 還有浮起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.82,
    "end": 28.42,
    "speaker": "曉臻",
    "text": "分成 兩種算法耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.62,
    "end": 33.31,
    "speaker": "彥君",
    "text": "沒錯 先看左邊的沉體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.51,
    "end": 36.23,
    "speaker": "彥君",
    "text": "因為 它整塊滅頂了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.43,
    "end": 39.94,
    "speaker": "彥君",
    "text": "排開水的體積 就是最大值",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.14,
    "end": 43.94,
    "speaker": "彥君",
    "text": "帶入公式 就能算出浮力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.14,
    "end": 47.08,
    "speaker": "曉臻",
    "text": "可是 浮力還是不夠大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.28,
    "end": 50.46,
    "speaker": "曉臻",
    "text": "撐不住重量 就沉底了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.66,
    "end": 55.1,
    "speaker": "彥君",
    "text": "觀念很好 那右邊的浮體呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.3,
    "end": 57.69,
    "speaker": "曉臻",
    "text": "它浮在水面上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.89,
    "end": 60.97,
    "speaker": "曉臻",
    "text": "代表 浮力把它撐起來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.17,
    "end": 63.65,
    "speaker": "彥君",
    "text": "既然撐得住",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.85,
    "end": 67.07,
    "speaker": "彥君",
    "text": "代表 浮力剛好抵銷重量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.27,
    "end": 70.18,
    "speaker": "彥君",
    "text": "所以 只要遇到浮體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.38,
    "end": 73.56,
    "speaker": "彥君",
    "text": "直接找 物體的重量就好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.76,
    "end": 88.57,
    "speaker": "彥君",
    "text": "$\\text{浮體} \\rightarrow B_{浮力} = \\text{物重}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 78.14,
    "end": 82.18,
    "speaker": "曉臻",
    "text": "哇 連公式 都不用算了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.38,
    "end": 85.37,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.57,
    "end": 91.91,
    "speaker": "彥君",
    "text": "戰士們 情境題來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.11,
    "end": 94.98,
    "speaker": "彥君",
    "text": "一艘 巨大的貨輪",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.18,
    "end": 98.47,
    "speaker": "彥君",
    "text": "從海裡 開進了淡水河",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.67,
    "end": 101.78,
    "speaker": "彥君",
    "text": "請問 船受到的浮力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.98,
    "end": 104.65,
    "speaker": "彥君",
    "text": "變大 還是變小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.85,
    "end": 107.3,
    "speaker": "曉臻",
    "text": "淡水 密度比較小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.5,
    "end": 110.73,
    "speaker": "曉臻",
    "text": "公式算起來 浮力應該變小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 110.93,
    "end": 114.85,
    "speaker": "彥君",
    "text": "嗶嗶 掉進陷阱了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.05,
    "end": 117.77,
    "speaker": "彥君",
    "text": "船 在海裡跟河裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.97,
    "end": 121.02,
    "speaker": "彥君",
    "text": "是不是 都浮在水面上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.22,
    "end": 124.5,
    "speaker": "曉臻",
    "text": "對耶 都是浮體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.7,
    "end": 128.26,
    "speaker": "彥君",
    "text": "既然是浮體 船有變輕嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.46,
    "end": 132.21,
    "speaker": "曉臻",
    "text": "沒有 所以浮力一樣大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.41,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{海入河} \\rightarrow \\text{浮力不變}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 136.98,
    "end": 140.14,
    "speaker": "彥君",
    "text": "可是 淡水密度比較小啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.34,
    "end": 143.32,
    "speaker": "彥君",
    "text": "為了 維持一樣大的浮力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.52,
    "end": 146.58,
    "speaker": "彥君",
    "text": "船 只能排開更多水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.78,
    "end": 150.82,
    "speaker": "曉臻",
    "text": "喔 所以船會往下沉一點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.02,
    "end": 153.52,
    "speaker": "曉臻",
    "text": "吃水 變得更深了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.72,
    "end": 158.55,
    "speaker": "彥君",
    "text": "完全正確 這就是大考最愛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.75,
    "end": 162.19,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.39,
    "end": 164.99,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.19,
    "end": 167.53,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 167.73,
    "end": 171.24,
    "speaker": "合聲",
    "text": "浮體看重 沉體看體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.44,
    "end": 174.98,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
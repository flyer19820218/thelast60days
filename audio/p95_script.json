[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.74,
    "speaker": "彥君",
    "text": "各位即將衝A的會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.94,
    "end": 8.54,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.74,
    "end": 11.91,
    "speaker": "彥君",
    "text": "今天來到 第九十五集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.11,
    "end": 13.85,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.05,
    "end": 16.38,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.58,
    "end": 19.04,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.24,
    "end": 22.18,
    "speaker": "彥君",
    "text": "這集要講 可逆反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.38,
    "end": 25.17,
    "speaker": "曉臻",
    "text": "老師 上面寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.37,
    "end": 27.94,
    "speaker": "曉臻",
    "text": "平衡時 顏色不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.14,
    "end": 30.74,
    "speaker": "曉臻",
    "text": "難道 反應停下來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.94,
    "end": 33.71,
    "speaker": "彥君",
    "text": "這是 最大的陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.91,
    "end": 36.87,
    "speaker": "彥君",
    "text": "過去跟回來的 速度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.07,
    "end": 39.89,
    "speaker": "彥君",
    "text": "變成 一模一樣快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.09,
    "end": 43.34,
    "speaker": "彥君",
    "text": "反應 其實還在進行",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.54,
    "end": 46.4,
    "speaker": "彥君",
    "text": "來看 上面第一題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.6,
    "end": 49.66,
    "speaker": "彥君",
    "text": "戰士們 眼睛看上面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.86,
    "end": 52.36,
    "speaker": "曉臻",
    "text": "鉻酸根 加氫離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.56,
    "end": 55.62,
    "speaker": "彥君",
    "text": "如果我們 增加氫離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.82,
    "end": 58.94,
    "speaker": "彥君",
    "text": "左邊的濃度 就會變大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.14,
    "end": 62.1,
    "speaker": "曉臻",
    "text": "哪邊變濃 就往另一邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.3,
    "end": 64.86,
    "speaker": "曉臻",
    "text": "傾斜過去 對不對",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.06,
    "end": 69.36,
    "speaker": "彥君",
    "text": "沒錯 擠不下的時候",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.56,
    "end": 72.57,
    "speaker": "彥君",
    "text": "反應 就會向右邊跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.77,
    "end": 80.89,
    "speaker": "彥君",
    "text": "左邊變濃} \\rightarrow \\text$]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.09,
    "end": 84.07,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.27,
    "end": 87.23,
    "speaker": "彥君",
    "text": "接著看 下面第二題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.43,
    "end": 90.03,
    "speaker": "彥君",
    "text": "眼睛 往下移動喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.23,
    "end": 93.29,
    "speaker": "曉臻",
    "text": "老師 右邊寫著熱耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.49,
    "end": 96.42,
    "speaker": "彥君",
    "text": "這代表 往右是放熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.62,
    "end": 99.51,
    "speaker": "彥君",
    "text": "如果我們 把溫度升高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.71,
    "end": 102.86,
    "speaker": "彥君",
    "text": "系統會 想把熱消耗掉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.06,
    "end": 105.64,
    "speaker": "曉臻",
    "text": "所以 就會往左邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.84,
    "end": 108.63,
    "speaker": "曉臻",
    "text": "吸熱的 方向退回去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.83,
    "end": 111.22,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.42,
    "end": 119.7,
    "speaker": "彥君",
    "text": "溫度上升} \\rightarrow \\text$]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.9,
    "end": 122.89,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.09,
    "end": 126.29,
    "speaker": "彥君",
    "text": "戰士們， 陷阱來了！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.49,
    "end": 129.4,
    "speaker": "彥君",
    "text": "講義括號裡 寫著什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.6,
    "end": 132.15,
    "speaker": "曉臻",
    "text": "寫著 放熱也變快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.35,
    "end": 136.63,
    "speaker": "彥君",
    "text": "沒錯 只要溫度升高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.83,
    "end": 140.01,
    "speaker": "彥君",
    "text": "不管是 吸熱還是放熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.21,
    "end": 143.31,
    "speaker": "彥君",
    "text": "速度 通通都會變快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.51,
    "end": 146.78,
    "speaker": "曉臻",
    "text": "咦 兩邊都變快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.98,
    "end": 149.8,
    "speaker": "曉臻",
    "text": "那為什麼 會往左邊跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.0,
    "end": 153.03,
    "speaker": "彥君",
    "text": "因為 吸熱那邊變快的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.23,
    "end": 155.74,
    "speaker": "彥君",
    "text": "程度 比較多啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.94,
    "end": 158.97,
    "speaker": "彥君",
    "text": "千萬 不要被題目騙了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.17,
    "end": 162.58,
    "speaker": "曉臻",
    "text": "哇 這觀念太神了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.78,
    "end": 165.67,
    "speaker": "曉臻",
    "text": "老師 最下面還有",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.87,
    "end": 168.59,
    "speaker": "曉臻",
    "text": "催化劑 不影響平衡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.79,
    "end": 171.37,
    "speaker": "彥君",
    "text": "因為 催化劑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.57,
    "end": 174.84,
    "speaker": "彥君",
    "text": "會讓過去 跟回來的速度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.04,
    "end": 177.76,
    "speaker": "彥君",
    "text": "兩邊 一起變快了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.96,
    "end": 181.04,
    "speaker": "彥君",
    "text": "所以 平衡不會移動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.24,
    "end": 184.68,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 184.88,
    "end": 187.48,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 187.68,
    "end": 190.02,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 190.22,
    "end": 193.68,
    "speaker": "合聲",
    "text": "濃度破壞 反向逃開",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 193.88,
    "end": 197.42,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.74,
    "speaker": "彥君",
    "text": "各位即將衝A的會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.94,
    "end": 8.54,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.74,
    "end": 11.91,
    "speaker": "彥君",
    "text": "今天來到 第九十五集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.11,
    "end": 13.85,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.05,
    "end": 16.38,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.58,
    "end": 19.04,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.24,
    "end": 22.18,
    "speaker": "彥君",
    "text": "這集要講 可逆反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.38,
    "end": 25.17,
    "speaker": "曉臻",
    "text": "老師 上面寫著",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.37,
    "end": 27.94,
    "speaker": "曉臻",
    "text": "平衡時 顏色不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.14,
    "end": 30.74,
    "speaker": "曉臻",
    "text": "難道 反應停下來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.94,
    "end": 33.71,
    "speaker": "彥君",
    "text": "這是 最大的陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.91,
    "end": 36.87,
    "speaker": "彥君",
    "text": "過去跟回來的 速度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.07,
    "end": 39.89,
    "speaker": "彥君",
    "text": "變成 一模一樣快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.09,
    "end": 43.34,
    "speaker": "彥君",
    "text": "反應 其實還在進行",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.54,
    "end": 46.4,
    "speaker": "彥君",
    "text": "來看 上面第一題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.6,
    "end": 49.66,
    "speaker": "彥君",
    "text": "戰士們 眼睛看上面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.86,
    "end": 52.36,
    "speaker": "曉臻",
    "text": "鉻酸根 加氫離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.56,
    "end": 55.62,
    "speaker": "彥君",
    "text": "如果我們 增加氫離子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.82,
    "end": 58.94,
    "speaker": "彥君",
    "text": "左邊的濃度 就會變大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.14,
    "end": 62.1,
    "speaker": "曉臻",
    "text": "哪邊變濃 就往另一邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.3,
    "end": 64.86,
    "speaker": "曉臻",
    "text": "傾斜過去 對不對",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.06,
    "end": 69.36,
    "speaker": "彥君",
    "text": "沒錯 擠不下的時候",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.56,
    "end": 72.57,
    "speaker": "彥君",
    "text": "反應 就會向右邊跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.77,
    "end": 84.25,
    "speaker": "彥君",
    "text": "$\\text{第一題：左邊變濃} \\rightarrow \\text{向右傾斜}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 78.06,
    "end": 81.05,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.25,
    "end": 87.21,
    "speaker": "彥君",
    "text": "接著看 下面第二題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.41,
    "end": 90.01,
    "speaker": "彥君",
    "text": "眼睛 往下移動喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.21,
    "end": 93.26,
    "speaker": "曉臻",
    "text": "老師 右邊寫著熱耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.46,
    "end": 96.4,
    "speaker": "彥君",
    "text": "這代表 往右是放熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.6,
    "end": 99.49,
    "speaker": "彥君",
    "text": "如果我們 把溫度升高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.69,
    "end": 102.84,
    "speaker": "彥君",
    "text": "系統會 想把熱消耗掉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.04,
    "end": 105.62,
    "speaker": "曉臻",
    "text": "所以 就會往左邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.82,
    "end": 108.61,
    "speaker": "曉臻",
    "text": "吸熱的 方向退回去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.81,
    "end": 111.19,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.39,
    "end": 123.02,
    "speaker": "彥君",
    "text": "$\\text{第二題：溫度上升} \\rightarrow \\text{向左移動}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 116.83,
    "end": 119.82,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.02,
    "end": 126.22,
    "speaker": "彥君",
    "text": "戰士們 陷阱來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.42,
    "end": 129.33,
    "speaker": "彥君",
    "text": "講義括號裡 寫著什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.53,
    "end": 132.08,
    "speaker": "曉臻",
    "text": "寫著 放熱也變快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.28,
    "end": 136.56,
    "speaker": "彥君",
    "text": "沒錯 只要溫度升高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.76,
    "end": 139.94,
    "speaker": "彥君",
    "text": "不管是 吸熱還是放熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.14,
    "end": 143.24,
    "speaker": "彥君",
    "text": "速度 通通都會變快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.44,
    "end": 146.71,
    "speaker": "曉臻",
    "text": "咦 兩邊都變快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.91,
    "end": 149.73,
    "speaker": "曉臻",
    "text": "那為什麼 會往左邊跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.93,
    "end": 152.96,
    "speaker": "彥君",
    "text": "因為 吸熱那邊變快的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.16,
    "end": 155.66,
    "speaker": "彥君",
    "text": "程度 比較多啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.86,
    "end": 158.9,
    "speaker": "彥君",
    "text": "千萬 不要被題目騙了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.1,
    "end": 162.51,
    "speaker": "曉臻",
    "text": "哇 這觀念太神了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.71,
    "end": 165.6,
    "speaker": "曉臻",
    "text": "老師 最下面還有",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.8,
    "end": 168.52,
    "speaker": "曉臻",
    "text": "催化劑 不影響平衡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.72,
    "end": 171.3,
    "speaker": "彥君",
    "text": "因為 催化劑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.5,
    "end": 174.77,
    "speaker": "彥君",
    "text": "會讓過去 跟回來的速度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 174.97,
    "end": 177.69,
    "speaker": "彥君",
    "text": "兩邊 一起變快了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.89,
    "end": 180.97,
    "speaker": "彥君",
    "text": "所以 平衡不會移動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.17,
    "end": 184.61,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 184.81,
    "end": 187.41,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 187.61,
    "end": 189.94,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 190.14,
    "end": 193.61,
    "speaker": "合聲",
    "text": "濃度破壞 反向逃開",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 193.81,
    "end": 197.34,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
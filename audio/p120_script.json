[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.74,
    "speaker": "彥君",
    "text": "第一屆 君臻盃羽球大賽",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.94,
    "end": 9.98,
    "speaker": "彥君",
    "text": "我是 賽評彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 10.18,
    "end": 11.91,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.11,
    "end": 15.0,
    "speaker": "曉臻",
    "text": "我是 轉播員曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.2,
    "end": 17.66,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 17.86,
    "end": 20.79,
    "speaker": "彥君",
    "text": "今天 不只是看比賽",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.99,
    "end": 24.17,
    "speaker": "彥君",
    "text": "我們要 用羽毛球來破解",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.37,
    "end": 27.57,
    "speaker": "彥君",
    "text": "會考 最經典的物理題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.77,
    "end": 31.52,
    "speaker": "曉臻",
    "text": "哇 幾年前的會考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.72,
    "end": 34.34,
    "speaker": "曉臻",
    "text": "真的考過 羽毛球耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.54,
    "end": 38.54,
    "speaker": "彥君",
    "text": "沒錯 準備好了嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.74,
    "end": 41.48,
    "speaker": "彥君",
    "text": "比賽 正式開始",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.68,
    "end": 44.62,
    "speaker": "曉臻",
    "text": "老師 對手發球了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.82,
    "end": 47.56,
    "speaker": "曉臻",
    "text": "是一個 超高的長球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.76,
    "end": 50.41,
    "speaker": "曉臻",
    "text": "羽毛球 越飛越高了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.61,
    "end": 54.07,
    "speaker": "彥君",
    "text": "戰士們 注意它的能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.27,
    "end": 57.47,
    "speaker": "彥君",
    "text": "球 剛離開球拍的時候",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.67,
    "end": 61.06,
    "speaker": "彥君",
    "text": "速度最快 動能最大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.26,
    "end": 64.18,
    "speaker": "曉臻",
    "text": "可是 它往上飛的過程",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.38,
    "end": 67.12,
    "speaker": "曉臻",
    "text": "速度 好像變慢了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.32,
    "end": 71.72,
    "speaker": "彥君",
    "text": "沒錯 因為高度增加了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.92,
    "end": 75.02,
    "speaker": "彥君",
    "text": "動能 正在瘋狂轉換",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.22,
    "end": 78.3,
    "speaker": "彥君",
    "text": "全部 變成了重力位能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.5,
    "end": 119.12,
    "speaker": "彥君",
    "text": "$\\text{上升} \\rightarrow \\text{動能換位能}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 82.58,
    "end": 85.78,
    "speaker": "曉臻",
    "text": "老師 球飛到最高點了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 85.98,
    "end": 88.94,
    "speaker": "曉臻",
    "text": "好像 停在空中一瞬間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.14,
    "end": 92.19,
    "speaker": "彥君",
    "text": "這就是 能量的轉折點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.39,
    "end": 95.76,
    "speaker": "彥君",
    "text": "在最高點 高度最大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.96,
    "end": 99.21,
    "speaker": "彥君",
    "text": "所以 重力位能達到頂峰",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.41,
    "end": 102.18,
    "speaker": "曉臻",
    "text": "那動能 跑到哪裡去了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.38,
    "end": 105.46,
    "speaker": "彥君",
    "text": "幾乎 全部都轉換掉了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.66,
    "end": 108.74,
    "speaker": "彥君",
    "text": "所以 速度變得非常慢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.94,
    "end": 119.12,
    "speaker": "彥君",
    "text": "$\\text{最高點} \\rightarrow \\text{位能最大}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 112.91,
    "end": 115.92,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘截圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.12,
    "end": 122.3,
    "speaker": "曉臻",
    "text": "接著 球開始往下掉了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.5,
    "end": 124.9,
    "speaker": "曉臻",
    "text": "速度 越來越快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.1,
    "end": 128.28,
    "speaker": "彥君",
    "text": "因為 力學能守恆啟動了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.48,
    "end": 131.8,
    "speaker": "彥君",
    "text": "累積在 高空的重力位能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.0,
    "end": 135.2,
    "speaker": "彥君",
    "text": "現在 全部釋放出來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.4,
    "end": 138.77,
    "speaker": "彥君",
    "text": "高度下降 位能減少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.97,
    "end": 142.26,
    "speaker": "彥君",
    "text": "速度變快 動能增加",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.46,
    "end": 171.3,
    "speaker": "彥君",
    "text": "$\\text{下降} \\rightarrow \\text{位能換動能}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 146.63,
    "end": 150.17,
    "speaker": "曉臻",
    "text": "哇 這樣上上下下",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.37,
    "end": 153.21,
    "speaker": "曉臻",
    "text": "能量 根本就在玩變身",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.41,
    "end": 158.05,
    "speaker": "彥君",
    "text": "沒錯 只要沒有空氣阻力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.25,
    "end": 161.28,
    "speaker": "彥君",
    "text": "動能 加位能的總和",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.48,
    "end": 164.68,
    "speaker": "彥君",
    "text": "從頭到尾 都不會改變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.88,
    "end": 168.1,
    "speaker": "彥君",
    "text": "戰士們 屏息以待",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.3,
    "end": 175.1,
    "speaker": "曉臻",
    "text": "老師 選手跳起來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.3,
    "end": 177.98,
    "speaker": "曉臻",
    "text": "他在最高點 揮拍了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 178.18,
    "end": 181.02,
    "speaker": "曉臻",
    "text": "是一記 超猛的殺球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.22,
    "end": 185.38,
    "speaker": "彥君",
    "text": "來了 最熱血的瞬間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.58,
    "end": 188.63,
    "speaker": "彥君",
    "text": "選手 為什麼要跳這麼高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 188.83,
    "end": 191.82,
    "speaker": "曉臻",
    "text": "為了 爭取最高的擊球點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 192.02,
    "end": 194.66,
    "speaker": "彥君",
    "text": "從物理學 來看",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 194.86,
    "end": 198.18,
    "speaker": "彥君",
    "text": "他是為了 儲存最大的位能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 198.38,
    "end": 246.18,
    "speaker": "彥君",
    "text": "$\\text{起跳} \\rightarrow \\text{儲存最大位能}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 202.53,
    "end": 205.87,
    "speaker": "曉臻",
    "text": "碰 球被往下砸了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 206.07,
    "end": 209.03,
    "speaker": "曉臻",
    "text": "速度 簡直像一顆子彈",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 209.23,
    "end": 212.65,
    "speaker": "彥君",
    "text": "殺球的軌跡 是直線往下",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 212.85,
    "end": 216.29,
    "speaker": "彥君",
    "text": "高度 在一瞬間急速下降",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 216.49,
    "end": 219.33,
    "speaker": "曉臻",
    "text": "所以 龐大的重力位能",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 219.53,
    "end": 222.78,
    "speaker": "曉臻",
    "text": "在一瞬間 全部變成動能了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 222.98,
    "end": 225.36,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 225.56,
    "end": 228.78,
    "speaker": "彥君",
    "text": "狠狠地 砸向對手場地",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 228.98,
    "end": 246.18,
    "speaker": "彥君",
    "text": "$\\text{殺球} \\rightarrow \\text{位能急降換動能}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 233.73,
    "end": 236.98,
    "speaker": "曉臻",
    "text": "漂亮 壓線得分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 237.18,
    "end": 239.87,
    "speaker": "曉臻",
    "text": "這球 實在太精彩了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 240.07,
    "end": 242.98,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘歡呼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 246.18,
    "end": 249.53,
    "speaker": "彥君",
    "text": "戰士們 我們用數字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 249.73,
    "end": 253.07,
    "speaker": "彥君",
    "text": "來回放一次 剛才的殺球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 253.27,
    "end": 256.81,
    "speaker": "曉臻",
    "text": "老師 要用 VAR 嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 257.01,
    "end": 261.82,
    "speaker": "彥君",
    "text": "沒錯 物理重播輔助判決",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 262.02,
    "end": 265.46,
    "speaker": "彥君",
    "text": "假設 剛剛那顆高遠球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 265.66,
    "end": 268.42,
    "speaker": "彥君",
    "text": "離開球拍的 瞬間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 268.62,
    "end": 271.7,
    "speaker": "彥君",
    "text": "它的動能 是 100 焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 271.9,
    "end": 274.96,
    "speaker": "彥君",
    "text": "位能 我們當作 0 焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 275.16,
    "end": 318.25,
    "speaker": "彥君",
    "text": "$\\text{擊出瞬間} \\rightarrow \\text{總和 } 100\\text{J}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 279.52,
    "end": 282.41,
    "speaker": "曉臻",
    "text": "所以 它的力學能總和",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 282.61,
    "end": 284.97,
    "speaker": "曉臻",
    "text": "就是 100 焦耳囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 285.17,
    "end": 289.62,
    "speaker": "彥君",
    "text": "沒錯 接著球往上飛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 289.82,
    "end": 292.42,
    "speaker": "彥君",
    "text": "飛到了 最高點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 292.62,
    "end": 296.06,
    "speaker": "曉臻",
    "text": "速度最慢 動能變成 0 了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 296.26,
    "end": 299.12,
    "speaker": "彥君",
    "text": "那消失的 100 焦耳呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 299.32,
    "end": 302.26,
    "speaker": "曉臻",
    "text": "全部 跑去變成位能了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 302.46,
    "end": 306.98,
    "speaker": "彥君",
    "text": "非常好 總和還是 100",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 307.18,
    "end": 318.25,
    "speaker": "彥君",
    "text": "$\\text{最高點} \\rightarrow \\text{位能 } 100\\text{J}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 311.63,
    "end": 315.05,
    "speaker": "彥君",
    "text": "戰士們 最愛考的來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 318.25,
    "end": 321.33,
    "speaker": "彥君",
    "text": "如果球 掉到一半的高度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 321.53,
    "end": 325.71,
    "speaker": "彥君",
    "text": "一半喔 能量變多少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 325.91,
    "end": 328.18,
    "speaker": "曉臻",
    "text": "高度 剩下一半",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 328.38,
    "end": 331.55,
    "speaker": "曉臻",
    "text": "代表 位能只剩下 50 焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 331.75,
    "end": 335.62,
    "speaker": "彥君",
    "text": "漂亮 那動能呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 335.82,
    "end": 338.64,
    "speaker": "曉臻",
    "text": "總和 必須是 100 焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 338.84,
    "end": 341.82,
    "speaker": "曉臻",
    "text": "所以 動能也是 50 焦耳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 342.02,
    "end": 344.36,
    "speaker": "彥君",
    "text": "完全命中",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 344.56,
    "end": 347.35,
    "speaker": "彥君",
    "text": "能量 各佔了一半",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 347.55,
    "end": 9999.0,
    "speaker": "彥君",

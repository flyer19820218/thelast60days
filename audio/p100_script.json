    "pin_level": 0,
    "commands": []
  },
  {
    "start": 147.24,
    "end": 149.98,
    "speaker": "彥君",
    "text": "絕對是伸長量",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 150.18,
    "end": 153.7,
    "speaker": "彥君",
    "text": "也就是拉扯後多出來的長度",

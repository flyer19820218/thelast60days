    "pin_level": 0,
    "commands": []
  },
  {
    "start": 162.11,
    "end": 165.07,
    "speaker": "彥君",
    "text": "F 代表施加的外力",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 165.27,
    "end": 168.57,
    "speaker": "彥君",
    "text": "而 X 代表著伸長量",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 168.77,
    "end": 172.18,
    "speaker": "彥君",
    "text": "把這兩個數字互相除一除",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 172.38,
    "end": 176.14,
    "speaker": "彥君",
    "text": "算出來就會等於一個固定的值",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 176.34,
    "end": 226.04,
    "speaker": "彥君",
    "text": "③ $\\frac{F_1}{X_1} = \\frac{F_2}{X_2}$",
    "is_pinned": true,
    "pin_level": 3,
    "commands": [
      "釘選",
      "③ $\\frac{F_1}{X_1} = \\frac{F_2}{X_2}$"
    ]
  },
  {
    "start": 181.51,
    "end": 185.14,
    "speaker": "曉臻",
    "text": "老師 可以舉個實際的例子嗎",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 185.34,
    "end": 189.38,
    "speaker": "彥君",
    "text": "沒問題 看好了",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 189.58,
    "end": 192.86,
    "speaker": "彥君",
    "text": "如果我們掛上 10g 砝碼",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "10g"
    ]
  },
  {
    "start": 193.06,
    "end": 196.4,
    "speaker": "彥君",
    "text": "發現彈簧伸長了 2cm",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "2cm"
    ]
  },
  {
    "start": 196.6,
    "end": 199.1,
    "speaker": "曉臻",
    "text": "$10 \\div 2 = 5$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$10 \\div 2 = 5$"
    ]
  },
  {
    "start": 199.3,
    "end": 203.87,

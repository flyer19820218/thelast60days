[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 13.32,
    "speaker": "彥君",
    "text": "恭喜大家",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.52,
    "end": 16.14,
    "speaker": "彥君",
    "text": "來到 第一百集啦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.34,
    "end": 18.08,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.28,
    "end": 20.62,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.82,
    "end": 23.34,
    "speaker": "曉臻",
    "text": "第一百集 太感動了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.54,
    "end": 26.0,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.2,
    "end": 29.09,
    "speaker": "彥君",
    "text": "第一百集 我們講力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.29,
    "end": 32.25,
    "speaker": "曉臻",
    "text": "老師 力看不見耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.45,
    "end": 35.1,
    "speaker": "曉臻",
    "text": "怎麼 知道它的存在",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.3,
    "end": 37.85,
    "speaker": "彥君",
    "text": "透過 力的效應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.05,
    "end": 40.91,
    "speaker": "彥君",
    "text": "左邊 講了力的種類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.11,
    "end": 43.57,
    "speaker": "曉臻",
    "text": "第一種 是接觸力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.77,
    "end": 46.8,
    "speaker": "彥君",
    "text": "必須 碰到才有作用",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.0,
    "end": 50.25,
    "speaker": "彥君",
    "text": "像是 打棒球踢足球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.45,
    "end": 53.24,
    "speaker": "彥君",
    "text": "還有 拉開橡皮筋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.44,
    "end": 56.42,
    "speaker": "曉臻",
    "text": "喔 那第二種",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.62,
    "end": 59.13,
    "speaker": "曉臻",
    "text": "超距力 又是什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.33,
    "end": 62.14,
    "speaker": "彥君",
    "text": "也就是 非接觸力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.34,
    "end": 65.23,
    "speaker": "彥君",
    "text": "不用碰到 就能發功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.43,
    "end": 67.96,
    "speaker": "曉臻",
    "text": "像 萬磁王那樣嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.16,
    "end": 72.42,
    "speaker": "彥君",
    "text": "沒錯 磁鐵的磁力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.62,
    "end": 75.6,
    "speaker": "彥君",
    "text": "還有 摩擦塑膠尺的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.8,
    "end": 77.97,
    "speaker": "彥君",
    "text": "靜電力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.17,
    "end": 80.84,
    "speaker": "曉臻",
    "text": "還有 蘋果掉下來的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.04,
    "end": 83.52,
    "speaker": "曉臻",
    "text": "地球引力 對不對",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.72,
    "end": 86.1,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.3,
    "end": 99.58,
    "speaker": "彥君",
    "text": "接觸力",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 93.4,
    "end": 96.38,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.58,
    "end": 102.45,
    "speaker": "曉臻",
    "text": "老師 右邊的彈簧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.65,
    "end": 105.06,
    "speaker": "曉臻",
    "text": "寫著 虎克定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.26,
    "end": 108.46,
    "speaker": "彥君",
    "text": "我們用 彈簧來測量力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.66,
    "end": 111.42,
    "speaker": "彥君",
    "text": "彈簧 拉得越長",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.62,
    "end": 114.22,
    "speaker": "彥君",
    "text": "代表 力量越大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.42,
    "end": 116.86,
    "speaker": "曉臻",
    "text": "可是 到底有多大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.06,
    "end": 120.06,
    "speaker": "彥君",
    "text": "這就是 虎克發現的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.26,
    "end": 122.94,
    "speaker": "彥君",
    "text": "在 彈力極限內",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.14,
    "end": 126.29,
    "speaker": "彥君",
    "text": "外力 跟彈簧的伸長量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.49,
    "end": 128.85,
    "speaker": "彥君",
    "text": "會 成正比",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.05,
    "end": 132.9,
    "speaker": "曉臻",
    "text": "伸長量 不是總長度嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 133.1,
    "end": 136.3,
    "speaker": "彥君",
    "text": "戰士們 陷阱來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.5,
    "end": 139.24,
    "speaker": "彥君",
    "text": "絕對 是伸長量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.44,
    "end": 142.5,
    "speaker": "彥君",
    "text": "也就是 多出來的長度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.7,
    "end": 226.0,
    "speaker": "彥君",
    "text": "虎克定律：外力與「伸長量」成正比",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 147.18,
    "end": 149.75,
    "speaker": "曉臻",
    "text": "那下面 那個公式呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.95,
    "end": 153.82,
    "speaker": "彥君",
    "text": "F（Ｆ） 代表外力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.02,
    "end": 158.33,
    "speaker": "彥君",
    "text": "X（Ｘ） 代表伸長量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.53,
    "end": 161.46,
    "speaker": "彥君",
    "text": "把它們 互相除一除",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.66,
    "end": 164.53,
    "speaker": "彥君",
    "text": "就會 等於固定的值",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.73,
    "end": 226.0,
    "speaker": "彥君",
    "text": "F₁/X₁ = F₂/X₂",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 169.9,
    "end": 173.03,
    "speaker": "曉臻",
    "text": "老師 可以舉個例子嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.23,
    "end": 179.79,
    "speaker": "彥君",
    "text": "沒問題 如果掛 10g（十克）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 179.99,
    "end": 185.04,
    "speaker": "彥君",
    "text": "彈簧 伸長了 2cm（兩公分）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.24,
    "end": 190.74,
    "speaker": "曉臻",
    "text": "10 ÷ 2 = 5（十除以二等於五）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 190.94,
    "end": 195.13,
    "speaker": "彥君",
    "text": "沒錯 那如果改掛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 195.33,
    "end": 200.3,
    "speaker": "彥君",
    "text": "20g（二十克） 的砝碼呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 200.5,
    "end": 203.97,
    "speaker": "曉臻",
    "text": "因為 相除要等於 5（五）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 204.17,
    "end": 210.32,
    "speaker": "曉臻",
    "text": "所以 20 ÷ 5 = 4（二十除以五等於四）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 210.52,
    "end": 215.16,
    "speaker": "曉臻",
    "text": "伸長量 變成 4cm（四公分）",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 215.36,
    "end": 219.62,
    "speaker": "彥君",
    "text": "非常好 完全命中",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 219.82,
    "end": 222.8,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 226.0,
    "end": 228.98,
    "speaker": "曉臻",
    "text": "老師 彈簧上面寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 229.18,
    "end": 231.76,
    "speaker": "曉臻",
    "text": "注意 彈力極限耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 231.96,
    "end": 234.85,
    "speaker": "彥君",
    "text": "這是 物理學的底線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 235.05,
    "end": 237.94,
    "speaker": "彥君",
    "text": "如果你 用力拉過頭",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 238.14,
    "end": 240.47,
    "speaker": "曉臻",
    "text": "彈簧 就壞掉了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 240.67,
    "end": 243.42,
    "speaker": "曉臻",
    "text": "鬆手 也回不到原狀",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 243.62,
    "end": 248.28,
    "speaker": "彥君",
    "text": "沒錯 超過彈力極限",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 248.48,
    "end": 251.42,
    "speaker": "彥君",
    "text": "公式 就完全失效了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 251.62,
    "end": 254.26,
    "speaker": "彥君",
    "text": "所以 測量力量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 254.46,
    "end": 257.26,
    "speaker": "彥君",
    "text": "千萬 不能太暴力喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 257.46,
    "end": 268.41,
    "speaker": "彥君",
    "text": "彈力極限：超過後彈簧無法恢復原狀",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 262.22,
    "end": 265.21,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 268.41,
    "end": 271.63,
    "speaker": "彥君",
    "text": "恭喜大家 完成一百集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 271.83,
    "end": 275.27,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 275.47,
    "end": 278.07,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 278.27,
    "end": 280.61,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 280.81,
    "end": 284.32,
    "speaker": "合聲",
    "text": "伸長正比 注意極限",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 284.52,
    "end": 288.06,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
    "commands": []
  },
  {
    "start": 116.54,
    "end": 119.86,
    "speaker": "彥君",
    "text": "就代表施加的外力力量越大",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 120.06,
    "end": 124.1,
    "speaker": "曉臻",
    "text": "可是到底有多大 怎麼算啊",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 124.3,
    "end": 127.93,
    "speaker": "彥君",
    "text": "這就是物理學家虎克發現的",

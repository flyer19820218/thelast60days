    "pin_level": 0,
    "commands": []
  },
  {
    "start": 109.38,
    "end": 112.94,
    "speaker": "彥君",
    "text": "我們就是利用彈簧來測量力",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 113.14,
    "end": 116.34,
    "speaker": "彥君",
    "text": "彈簧如果被拉得越長",

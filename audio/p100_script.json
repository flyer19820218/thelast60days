[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 6.17,
    "speaker": "彥君",
    "text": "各位即將衝A的會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.37,
    "end": 8.97,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.17,
    "end": 11.38,
    "speaker": "彥君",
    "text": "恭喜大家",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.58,
    "end": 14.21,
    "speaker": "彥君",
    "text": "來到 第一百集啦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.41,
    "end": 16.14,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.34,
    "end": 18.68,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.88,
    "end": 21.41,
    "speaker": "曉臻",
    "text": "第一百集 太感動了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.61,
    "end": 24.06,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.26,
    "end": 27.15,
    "speaker": "彥君",
    "text": "第一百集 我們講力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.35,
    "end": 30.31,
    "speaker": "曉臻",
    "text": "老師 力看不見耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.51,
    "end": 33.16,
    "speaker": "曉臻",
    "text": "怎麼 知道它的存在",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.36,
    "end": 35.91,
    "speaker": "彥君",
    "text": "透過 力的效應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.11,
    "end": 38.98,
    "speaker": "彥君",
    "text": "左邊 講了力的種類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.18,
    "end": 41.63,
    "speaker": "曉臻",
    "text": "第一種 是接觸力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.83,
    "end": 44.86,
    "speaker": "彥君",
    "text": "必須 碰到才有作用",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.06,
    "end": 48.31,
    "speaker": "彥君",
    "text": "像是 打棒球踢足球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.51,
    "end": 51.3,
    "speaker": "彥君",
    "text": "還有 拉開橡皮筋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.5,
    "end": 54.49,
    "speaker": "曉臻",
    "text": "喔 那第二種",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.69,
    "end": 57.19,
    "speaker": "曉臻",
    "text": "超距力 又是什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.39,
    "end": 60.21,
    "speaker": "彥君",
    "text": "也就是 非接觸力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.41,
    "end": 63.3,
    "speaker": "彥君",
    "text": "不用碰到 就能發功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.5,
    "end": 66.02,
    "speaker": "曉臻",
    "text": "像 萬磁王那樣嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.22,
    "end": 70.48,
    "speaker": "彥君",
    "text": "沒錯 磁鐵的磁力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.68,
    "end": 73.66,
    "speaker": "彥君",
    "text": "還有 摩擦塑膠尺的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.86,
    "end": 76.03,
    "speaker": "彥君",
    "text": "靜電力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.23,
    "end": 78.9,
    "speaker": "曉臻",
    "text": "還有 蘋果掉下來的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.1,
    "end": 81.58,
    "speaker": "曉臻",
    "text": "地球引力 對不對",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.78,
    "end": 84.17,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.37,
    "end": 94.72,
    "speaker": "彥君",
    "text": "接觸力→要碰到、超距力→免碰到",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 88.54,
    "end": 91.52,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.72,
    "end": 97.58,
    "speaker": "曉臻",
    "text": "老師 右邊的彈簧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.78,
    "end": 100.19,
    "speaker": "曉臻",
    "text": "寫著 虎克定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.39,
    "end": 103.59,
    "speaker": "彥君",
    "text": "我們用 彈簧來測量力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.79,
    "end": 106.56,
    "speaker": "彥君",
    "text": "彈簧 拉得越長",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.76,
    "end": 109.36,
    "speaker": "彥君",
    "text": "代表 力量越大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.56,
    "end": 111.99,
    "speaker": "曉臻",
    "text": "可是 到底有多大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.19,
    "end": 115.2,
    "speaker": "彥君",
    "text": "這就是 虎克發現的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.4,
    "end": 118.07,
    "speaker": "彥君",
    "text": "在 彈力極限內",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.27,
    "end": 121.42,
    "speaker": "彥君",
    "text": "外力 跟彈簧的伸長量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.62,
    "end": 123.98,
    "speaker": "彥君",
    "text": "會 成正比",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.18,
    "end": 128.03,
    "speaker": "曉臻",
    "text": "伸長量 不是總長度嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.23,
    "end": 131.43,
    "speaker": "彥君",
    "text": "戰士們 陷阱來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.63,
    "end": 134.38,
    "speaker": "彥君",
    "text": "絕對 是伸長量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.58,
    "end": 137.63,
    "speaker": "彥君",
    "text": "也就是 多出來的長度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.83,
    "end": 199.42,
    "speaker": "彥君",
    "text": "虎克定律：外力與「伸長量」成正比",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 142.31,
    "end": 144.89,
    "speaker": "曉臻",
    "text": "那下面 那個公式呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.09,
    "end": 147.62,
    "speaker": "彥君",
    "text": "Ｆ 代表外力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.82,
    "end": 150.58,
    "speaker": "彥君",
    "text": "Ｘ 代表伸長量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.78,
    "end": 153.72,
    "speaker": "彥君",
    "text": "把它們 互相除一除",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.92,
    "end": 156.78,
    "speaker": "彥君",
    "text": "就會 等於固定的值",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.98,
    "end": 199.42,
    "speaker": "彥君",
    "text": "$$\\frac{F_1}{X_1} = \\frac{F_2}{X_2}$$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 162.16,
    "end": 165.29,
    "speaker": "曉臻",
    "text": "老師 可以舉個例子嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.49,
    "end": 167.37,
    "speaker": "彥君",
    "text": "沒問題 如果掛 10g",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 167.57,
    "end": 171.03,
    "speaker": "彥君",
    "text": "彈簧 伸長了 2cm",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.23,
    "end": 173.69,
    "speaker": "曉臻",
    "text": "$10 \\div 2 = 5$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.89,
    "end": 178.07,
    "speaker": "彥君",
    "text": "沒錯 那如果改掛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 178.27,
    "end": 181.14,
    "speaker": "彥君",
    "text": "那20g的砝碼呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.34,
    "end": 182.71,
    "speaker": "曉臻",
    "text": "因為 相除要等於 5",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 182.91,
    "end": 185.51,
    "speaker": "曉臻",
    "text": "所以 $20 \\div 5 = 4$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.71,
    "end": 188.58,
    "speaker": "曉臻",
    "text": "伸長量 變成 4cm",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 188.78,
    "end": 193.03,
    "speaker": "彥君",
    "text": "非常好 完全命中",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 193.23,
    "end": 196.22,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 199.42,
    "end": 202.4,
    "speaker": "曉臻",
    "text": "老師 彈簧上面寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 202.6,
    "end": 205.18,
    "speaker": "曉臻",
    "text": "注意 彈力極限耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 205.38,
    "end": 208.26,
    "speaker": "彥君",
    "text": "這是 物理學的底線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 208.46,
    "end": 211.35,
    "speaker": "彥君",
    "text": "如果你 用力拉過頭",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 211.55,
    "end": 213.89,
    "speaker": "曉臻",
    "text": "彈簧 就壞掉了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 214.09,
    "end": 216.83,
    "speaker": "曉臻",
    "text": "鬆手 也回不到原狀",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 217.03,
    "end": 221.7,
    "speaker": "彥君",
    "text": "沒錯 超過彈力極限",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 221.9,
    "end": 224.83,
    "speaker": "彥君",
    "text": "公式 就完全失效了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 225.03,
    "end": 227.68,
    "speaker": "彥君",
    "text": "所以 測量力量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 227.88,
    "end": 230.67,
    "speaker": "彥君",
    "text": "千萬 不能太暴力喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 230.87,
    "end": 241.82,
    "speaker": "彥君",
    "text": "彈力極限：超過後彈簧無法恢復原狀",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 235.64,
    "end": 238.62,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 241.82,
    "end": 245.05,
    "speaker": "彥君",
    "text": "恭喜大家 完成一百集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 245.25,
    "end": 248.69,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 248.89,
    "end": 251.49,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 251.69,
    "end": 254.02,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 254.22,
    "end": 257.74,
    "speaker": "合聲",
    "text": "伸長正比 注意極限",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 257.94,
    "end": 261.47,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
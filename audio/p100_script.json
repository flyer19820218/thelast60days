    "text": "沒錯 比例固定就是五",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 204.07,
    "end": 207.34,
    "speaker": "彥君",
    "text": "那如果改掛 20g 的砝碼呢",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "20g"
    ]
  },
  {
    "start": 207.54,
    "end": 210.79,
    "speaker": "曉臻",
    "text": "因為相除的結果必須等於五",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 210.99,
    "end": 214.07,
    "speaker": "曉臻",
    "text": "所以 $20 \\div 5 = 4$",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "$20 \\div 5 = 4$"
    ]
  },
  {
    "start": 214.27,
    "end": 217.64,
    "speaker": "曉臻",
    "text": "伸長量就會變成 4cm 啦",
    "is_pinned": false,
    "pin_level": 0,
    "commands": [
      "4cm"
    ]
  },

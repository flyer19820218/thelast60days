    "pin_level": 0,
    "commands": []
  },
  {
    "start": 153.9,
    "end": 226.04,
    "speaker": "彥君",
    "text": "② 虎克定律：外力與「伸長量」成正比",
    "is_pinned": true,
    "pin_level": 2,
    "commands": [
      "釘選",
      "② 虎克定律：外力與「伸長量」成正比"

    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.88,
    "end": 18.01,
    "speaker": "曉臻",
    "text": "畫面上整理了三種面鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.21,
    "end": 20.71,
    "speaker": "曉臻",
    "text": "但右邊的蘋果圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 20.91,
    "end": 23.18,
    "speaker": "曉臻",
    "text": "是要考什麼呀",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.38,
    "end": 26.43,
    "speaker": "彥君",
    "text": "戰士們， 注意看！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.63,
    "end": 29.76,
    "speaker": "彥君",
    "text": "這是一個經典陷阱題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.96,
    "end": 32.85,
    "speaker": "彥君",
    "text": "左邊筆記雖然寫了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.05,
    "end": 36.9,
    "speaker": "彥君",
    "text": "平面、 凹面、 凸面鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.1,
    "end": 39.94,
    "speaker": "彥君",
    "text": "但右邊的三個黑框",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.14,
    "end": 43.07,
    "speaker": "彥君",
    "text": "其實都是平面鏡喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.27,
    "end": 44.67,
    "speaker": "曉臻",
    "text": "咦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.87,
    "end": 47.4,
    "speaker": "曉臻",
    "text": "三面都是平面鏡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.6,
    "end": 50.06,
    "speaker": "曉臻",
    "text": "蘋果向左邊移動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.26,
    "end": 52.78,
    "speaker": "曉臻",
    "text": "像會往哪裡跑呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.98,
    "end": 56.06,
    "speaker": "彥君",
    "text": "記住平面鏡的原則",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.26,
    "end": 59.34,
    "speaker": "彥君",
    "text": "永遠是物距等於像距",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.54,
    "end": 62.38,
    "speaker": "彥君",
    "text": "蘋果往左邊移動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.58,
    "end": 65.71,
    "speaker": "彥君",
    "text": "離右邊鏡子越來越遠",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.91,
    "end": 68.61,
    "speaker": "曉臻",
    "text": "所以右邊的蘋果像",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.81,
    "end": 71.26,
    "speaker": "曉臻",
    "text": "會向右邊退後",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.46,
    "end": 73.54,
    "speaker": "彥君",
    "text": "答對了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.74,
    "end": 76.5,
    "speaker": "彥君",
    "text": "那上下兩面鏡子呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.7,
    "end": 79.14,
    "speaker": "曉臻",
    "text": "蘋果向左平移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.34,
    "end": 82.1,
    "speaker": "曉臻",
    "text": "和上下鏡子的距離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.3,
    "end": 84.78,
    "speaker": "曉臻",
    "text": "完全沒有改變耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.98,
    "end": 88.26,
    "speaker": "彥君",
    "text": "沒錯 距離不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.46,
    "end": 91.46,
    "speaker": "彥君",
    "text": "所以上下的蘋果像",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.66,
    "end": 94.12,
    "speaker": "彥君",
    "text": "會跟著本尊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.32,
    "end": 97.09,
    "speaker": "彥君",
    "text": "一起向左邊平移喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.29,
    "end": 100.22,
    "speaker": "彥君",
    "text": "老師把這題的答案",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.42,
    "end": 102.76,
    "speaker": "彥君",
    "text": "釘選起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.96,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "上下像左移， 右像右移",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 107.42,
    "end": 110.5,
    "speaker": "曉臻",
    "text": "哇 分開來看",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 110.7,
    "end": 113.27,

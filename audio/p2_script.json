[
  {
    "start": 0.0,
    "end": 2.3,
    "speaker": "彥君",
    "text": "哈囉"
  },
  {
    "start": 2.3,
    "end": 7.1,
    "speaker": "彥君",
    "text": "各位衝 A 的戰士們 我是彥君老師"
  },
  {
    "start": 7.1,
    "end": 10.02,
    "speaker": "彥君",
    "text": "解決了顯微鏡"
  },
  {
    "start": 10.02,
    "end": 14.0,
    "speaker": "彥君",
    "text": "我們現在要 縮小鑽進細胞裡了"
  },
  {
    "start": 14.0,
    "end": 16.59,
    "speaker": "曉臻",
    "text": "戰士們大家好"
  },
  {
    "start": 16.59,
    "end": 19.22,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 19.22,
    "end": 22.1,
    "speaker": "曉臻",
    "text": "細胞構造雖然多"
  },
  {
    "start": 22.1,
    "end": 25.41,
    "speaker": "曉臻",
    "text": "但把它想像成一個工廠"
  },
  {
    "start": 25.41,
    "end": 28.26,
    "speaker": "曉臻",
    "text": "其實非常好記喔"
  },
  {
    "start": 28.26,
    "end": 32.14,
    "speaker": "彥君",
    "text": "第一個要看 工廠的總理辦公室"
  },
  {
    "start": 32.14,
    "end": 35.36,
    "speaker": "彥君",
    "text": "就是『細胞核』"
  },
  {
    "start": 35.36,
    "end": 38.18,
    "speaker": "彥君",
    "text": "它是生命中樞"
  },
  {
    "start": 38.18,
    "end": 42.74,
    "speaker": "彥君",
    "text": "裡面藏著控制工廠的 滴、恩、A"
  },
  {
    "start": 42.74,
    "end": 47.01,
    "speaker": "曉臻",
    "text": "老師 所有的細胞 都有辦公室嗎"
  },
  {
    "start": 47.01,
    "end": 49.91,
    "speaker": "彥君",
    "text": "會考陷阱來了"
  },
  {
    "start": 49.91,
    "end": 53.34,
    "speaker": "彥君",
    "text": "原核生物 像是細菌"
  },
  {
    "start": 53.34,
    "end": 57.2,
    "speaker": "彥君",
    "text": "它們就沒有 核膜包圍的辦公室"
  },
  {
    "start": 57.2,
    "end": 60.02,
    "speaker": "曉臻",
    "text": "細菌沒有 細胞核"
  },
  {
    "start": 60.02,
    "end": 63.43,
    "speaker": "彥君",
    "text": "接著看工廠的發電廠"
  },
  {
    "start": 63.43,
    "end": 66.71,
    "speaker": "彥君",
    "text": "就是『粒線體』"
  },
  {
    "start": 66.71,
    "end": 70.09,
    "speaker": "彥君",
    "text": "它是行 呼吸作用的地方"
  },
  {
    "start": 70.09,
    "end": 73.81,
    "speaker": "彥君",
    "text": "負責把養分 轉化成能量"
  },
  {
    "start": 73.81,
    "end": 77.16,
    "speaker": "曉臻",
    "text": "所以活動力越強的細胞"
  },
  {
    "start": 77.16,
    "end": 79.8,
    "speaker": "曉臻",
    "text": "發電廠就越多"
  },
  {
    "start": 79.8,
    "end": 83.18,
    "speaker": "曉臻",
    "text": "像是運動員的 肌肉細胞"
  },
  {
    "start": 83.18,
    "end": 85.6,
    "speaker": "彥君",
    "text": "沒錯"
  },
  {
    "start": 85.6,
    "end": 89.68,
    "speaker": "彥君",
    "text": "接下來是工廠的 圍牆與大門"
  },
  {
    "start": 89.68,
    "end": 93.66,
    "speaker": "彥君",
    "text": "『細胞膜』 負責控制 物質進出"
  },
  {
    "start": 93.66,
    "end": 96.6,
    "speaker": "彥君",
    "text": "它是全自動門"
  },
  {
    "start": 96.6,
    "end": 99.6,
    "speaker": "彥君",
    "text": "氧氣養分進來"
  },
  {
    "start": 99.6,
    "end": 102.4,
    "speaker": "彥君",
    "text": "廢物排出去"
  },
  {
    "start": 102.4,
    "end": 105.47,
    "speaker": "彥君",
    "text": "通通由它把關"
  },
  {
    "start": 105.47,
    "end": 108.47,
    "speaker": "曉臻",
    "text": "老師 那植物的"
  },
  {
    "start": 108.47,
    "end": 111.54,
    "speaker": "曉臻",
    "text": "『細胞壁』 也是大門嗎"
  },
  {
    "start": 111.54,
    "end": 113.81,
    "speaker": "彥君",
    "text": "不對"
  },
  {
    "start": 113.81,
    "end": 118.06,
    "speaker": "彥君",
    "text": "細胞壁只是 固定形狀的厚圍牆"
  },
  {
    "start": 118.06,
    "end": 121.48,
    "speaker": "彥君",
    "text": "它沒有控制進出的 功能喔"
  },
  {
    "start": 121.48,
    "end": 125.94,
    "speaker": "曉臻",
    "text": "懂了 細胞膜才是 保全大叔"
  },
  {
    "start": 125.94,
    "end": 129.18,
    "speaker": "曉臻",
    "text": "細胞壁只是 堅固的牆"
  },
  {
    "start": 129.18,
    "end": 132.99,
    "speaker": "彥君",
    "text": "接下來看 植物工廠的特產"
  },
  {
    "start": 132.99,
    "end": 135.7,
    "speaker": "彥君",
    "text": "『葉綠體』"
  },
  {
    "start": 135.7,
    "end": 139.49,
    "speaker": "彥君",
    "text": "它利用太陽能 生產養分"
  },
  {
    "start": 139.49,
    "end": 143.11,
    "speaker": "彥君",
    "text": "只有綠色植物細胞 才有喔"
  },
  {
    "start": 143.11,
    "end": 145.89,
    "speaker": "曉臻",
    "text": "那工廠的倉庫呢"
  },
  {
    "start": 145.89,
    "end": 149.22,
    "speaker": "彥君",
    "text": "倉庫就是 『液胞』"
  },
  {
    "start": 149.22,
    "end": 152.26,
    "speaker": "彥君",
    "text": "植物的液胞 很大"
  },
  {
    "start": 152.26,
    "end": 155.55,
    "speaker": "彥君",
    "text": "佔了細胞大半空間"
  },
  {
    "start": 155.55,
    "end": 159.19,
    "speaker": "彥君",
    "text": "用來儲存水分與廢物"
  },
  {
    "start": 159.19,
    "end": 162.67,
    "speaker": "曉臻",
    "text": "植物液胞大 動物液胞小"
  },
  {
    "start": 162.67,
    "end": 166.31,
    "speaker": "彥君",
    "text": "最後我們來 做個大總結"
  },
  {
    "start": 166.31,
    "end": 170.58,
    "speaker": "彥君",
    "text": "動物植物 都有膜、 核、 質"
  },
  {
    "start": 170.58,
    "end": 173.94,
    "speaker": "彥君",
    "text": "還有發電用的 粒線體"
  },
  {
    "start": 173.94,
    "end": 177.08,
    "speaker": "曉臻",
    "text": "但只有植物 有細胞壁"
  },
  {
    "start": 177.08,
    "end": 180.6,
    "speaker": "曉臻",
    "text": "還有行光合作用的 葉綠體"
  },
  {
    "start": 180.6,
    "end": 183.69,
    "speaker": "曉臻",
    "text": "以及那個 超級大的液胞"
  },
  {
    "start": 183.69,
    "end": 186.71,
    "speaker": "彥君",
    "text": "戰士們放下筆"
  },
  {
    "start": 186.71,
    "end": 189.37,
    "speaker": "彥君",
    "text": "閉上眼睛"
  },
  {
    "start": 189.37,
    "end": 193.14,
    "speaker": "彥君",
    "text": "在腦海裡逛一次 細胞工廠"
  },
  {
    "start": 193.14,
    "end": 196.44,
    "speaker": "彥君",
    "text": "如果我是一株 仙人掌"
  },
  {
    "start": 196.44,
    "end": 199.92,
    "speaker": "彥君",
    "text": "我的細胞裡 會有細胞壁嗎"
  },
  {
    "start": 199.92,
    "end": 202.65,
    "speaker": "曉臻",
    "text": "仙人掌是植物"
  },
  {
    "start": 202.65,
    "end": 205.26,
    "speaker": "曉臻",
    "text": "絕對有細胞壁"
  },
  {
    "start": 205.26,
    "end": 207.9,
    "speaker": "曉臻",
    "text": "幫它支撐身體"
  },
  {
    "start": 207.9,
    "end": 212.34,
    "speaker": "彥君",
    "text": "漂亮 完全正確"
  },
  {
    "start": 212.34,
    "end": 215.24,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 215.24,
    "end": 217.87,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 217.87,
    "end": 220.53,
    "speaker": "曉臻",
    "text": "我們下個單元見"
  }
]
[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.26,
    "speaker": "彥君",
    "text": "今天來到 第九十八集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.46,
    "end": 16.19,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.39,
    "end": 18.73,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.93,
    "end": 21.38,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.58,
    "end": 24.66,
    "speaker": "彥君",
    "text": "這集出題率 不算太高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.86,
    "end": 27.42,
    "speaker": "彥君",
    "text": "但只要 考出來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.62,
    "end": 30.41,
    "speaker": "彥君",
    "text": "絕對是 送分題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.61,
    "end": 33.52,
    "speaker": "曉臻",
    "text": "老師 上面的分類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.72,
    "end": 36.03,
    "speaker": "曉臻",
    "text": "到底 要怎麼背啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.23,
    "end": 39.38,
    "speaker": "彥君",
    "text": "只要記住 成分和燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.58,
    "end": 42.93,
    "speaker": "彥君",
    "text": "先看 右上角的植物纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.13,
    "end": 45.92,
    "speaker": "曉臻",
    "text": "像是 棉花跟亞麻嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.12,
    "end": 50.3,
    "speaker": "彥君",
    "text": "沒錯 它的成分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.5,
    "end": 53.06,
    "speaker": "彥君",
    "text": "就是 纖維素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.26,
    "end": 55.83,
    "speaker": "曉臻",
    "text": "那 燒起來的味道呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.03,
    "end": 58.92,
    "speaker": "彥君",
    "text": "就像 燒紙張一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.12,
    "end": 66.09,
    "speaker": "彥君",
    "text": "纖維素、燒紙味",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.29,
    "end": 68.82,
    "speaker": "曉臻",
    "text": "接著看 動物纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.02,
    "end": 71.69,
    "speaker": "曉臻",
    "text": "像是 蠶絲跟羊毛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.89,
    "end": 75.11,
    "speaker": "彥君",
    "text": "動物的成分 是蛋白質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.31,
    "end": 78.42,
    "speaker": "彥君",
    "text": "燒起來 就像燒頭髮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.62,
    "end": 81.5,
    "speaker": "彥君",
    "text": "有 燒焦羽毛的味道",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.7,
    "end": 88.53,
    "speaker": "彥君",
    "text": "蛋白質、燒毛味",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.73,
    "end": 91.71,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.91,
    "end": 98.21,
    "speaker": "曉臻",
    "text": "老師 下面的人造纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.41,
    "end": 101.3,
    "speaker": "曉臻",
    "text": "再生纖維 是什麼東西",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.5,
    "end": 104.34,
    "speaker": "彥君",
    "text": "最有名的 叫做嫘縈",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.54,
    "end": 107.59,
    "speaker": "彥君",
    "text": "它是把 植物的纖維素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.79,
    "end": 110.87,
    "speaker": "彥君",
    "text": "溶解之後 重新抽絲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.07,
    "end": 114.49,
    "speaker": "曉臻",
    "text": "喔 所以它的成分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.69,
    "end": 117.53,
    "speaker": "曉臻",
    "text": "其實 還是纖維素嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.73,
    "end": 122.08,
    "speaker": "彥君",
    "text": "完全正確 燒起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.28,
    "end": 125.31,
    "speaker": "彥君",
    "text": "一樣 是燒紙張的味道",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.51,
    "end": 128.57,
    "speaker": "彥君",
    "text": "因為很亮 又叫人造絲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.77,
    "end": 135.66,
    "speaker": "彥君",
    "text": "纖維素、燒紙味",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.86,
    "end": 138.56,
    "speaker": "曉臻",
    "text": "最後一個 合成纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.76,
    "end": 141.72,
    "speaker": "曉臻",
    "text": "像是 耐綸跟聚酯纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.92,
    "end": 145.02,
    "speaker": "彥君",
    "text": "這些是 石化原料做的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.22,
    "end": 148.4,
    "speaker": "彥君",
    "text": "燒起來 會融化縮水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.6,
    "end": 151.92,
    "speaker": "彥君",
    "text": "甚至會 結成黑色硬球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.12,
    "end": 159.11,
    "speaker": "彥君",
    "text": "石化原料、結硬球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.31,
    "end": 162.22,
    "speaker": "彥君",
    "text": "只要會燒 就能拿分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.42,
    "end": 165.41,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.61,
    "end": 172.05,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 172.25,
    "end": 174.85,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.05,
    "end": 177.38,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.58,
    "end": 181.02,
    "speaker": "合聲",
    "text": "植物燒紙 動物燒毛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.22,
    "end": 184.76,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
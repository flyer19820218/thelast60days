    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.26,
    "speaker": "彥君",
    "text": "今天來到 第九十八集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.46,
    "end": 16.19,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.39,
    "end": 18.73,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.93,
    "end": 21.38,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.58,
    "end": 24.66,
    "speaker": "彥君",
    "text": "這集出題率 不算太高",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.86,
    "end": 27.42,
    "speaker": "彥君",
    "text": "但只要 考出來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.62,
    "end": 30.41,
    "speaker": "彥君",
    "text": "絕對是 送分題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.61,
    "end": 33.52,
    "speaker": "曉臻",
    "text": "老師 上面的分類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.72,
    "end": 36.03,
    "speaker": "曉臻",
    "text": "到底 要怎麼背啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.23,
    "end": 39.38,
    "speaker": "彥君",
    "text": "只要記住 成分和燃燒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.58,
    "end": 42.93,
    "speaker": "彥君",
    "text": "先看 右上角的植物纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.13,
    "end": 45.92,
    "speaker": "曉臻",
    "text": "像是 棉花跟亞麻嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.12,
    "end": 50.3,
    "speaker": "彥君",
    "text": "沒錯 它的成分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.5,
    "end": 53.06,
    "speaker": "彥君",
    "text": "就是 纖維素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.26,
    "end": 55.83,
    "speaker": "曉臻",
    "text": "那 燒起來的味道呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.03,
    "end": 58.92,
    "speaker": "彥君",
    "text": "就像 燒紙張一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.12,
    "end": 96.14,
    "speaker": "彥君",
    "text": "植物",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 66.91,
    "end": 69.44,
    "speaker": "曉臻",
    "text": "接著看 動物纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.64,
    "end": 72.31,
    "speaker": "曉臻",
    "text": "像是 蠶絲跟羊毛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.51,
    "end": 75.74,
    "speaker": "彥君",
    "text": "動物的成分 是蛋白質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.94,
    "end": 79.04,
    "speaker": "彥君",
    "text": "燒起來 就像燒頭髮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.24,
    "end": 82.13,
    "speaker": "彥君",
    "text": "有 燒焦羽毛的味道",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.33,
    "end": 96.14,
    "speaker": "彥君",
    "text": "動物",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 89.95,
    "end": 92.94,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.14,
    "end": 99.43,
    "speaker": "曉臻",
    "text": "老師 下面的人造纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.63,
    "end": 102.52,
    "speaker": "曉臻",
    "text": "再生纖維 是什麼東西",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.72,
    "end": 105.56,
    "speaker": "彥君",
    "text": "最有名的 叫做嫘縈",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.76,
    "end": 108.82,
    "speaker": "彥君",
    "text": "它是把 植物的纖維素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.02,
    "end": 112.1,
    "speaker": "彥君",
    "text": "溶解之後 重新抽絲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.3,
    "end": 115.71,
    "speaker": "曉臻",
    "text": "喔 所以它的成分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.91,
    "end": 118.75,
    "speaker": "曉臻",
    "text": "其實 還是纖維素嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.95,
    "end": 123.3,
    "speaker": "彥君",
    "text": "完全正確 燒起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.5,
    "end": 126.54,
    "speaker": "彥君",
    "text": "一樣 是燒紙張的味道",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.74,
    "end": 129.79,
    "speaker": "彥君",
    "text": "因為很亮 又叫人造絲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.99,
    "end": 171.15,
    "speaker": "彥君",
    "text": "再生",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 137.71,
    "end": 140.41,
    "speaker": "曉臻",
    "text": "最後一個 合成纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.61,
    "end": 143.57,
    "speaker": "曉臻",
    "text": "像是 耐綸跟聚酯纖維",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.77,
    "end": 146.87,
    "speaker": "彥君",
    "text": "這些是 石化原料做的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.07,
    "end": 150.25,
    "speaker": "彥君",
    "text": "燒起來 會融化縮水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.45,
    "end": 153.77,
    "speaker": "彥君",
    "text": "甚至會 結成黑色硬球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.97,
    "end": 171.15,
    "speaker": "彥君",
    "text": "合成",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 161.86,
    "end": 164.77,
    "speaker": "彥君",
    "text": "只要會燒 就能拿分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.97,
    "end": 167.95,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.15,
    "end": 174.59,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 174.79,
    "end": 177.39,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.59,
    "end": 179.93,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 180.13,
    "end": 183.57,
    "speaker": "合聲",
    "text": "植物燒紙 動物燒毛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 183.77,
    "end": 187.3,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
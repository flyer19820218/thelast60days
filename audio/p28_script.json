[
  {
    "start": 0.0,
    "end": 3.04,
    "speaker": "彥君",
    "text": "各位衝A的戰士"
  },
  {
    "start": 3.04,
    "end": 5.94,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 5.94,
    "end": 9.16,
    "speaker": "彥君",
    "text": "大家先把筆放下"
  },
  {
    "start": 9.16,
    "end": 12.03,
    "speaker": "彥君",
    "text": "聽我講個故事吧"
  },
  {
    "start": 12.03,
    "end": 15.03,
    "speaker": "彥君",
    "text": "翻開講義這一頁"
  },
  {
    "start": 15.03,
    "end": 18.1,
    "speaker": "彥君",
    "text": "這是植物界傳記"
  },
  {
    "start": 18.1,
    "end": 21.45,
    "speaker": "彥君",
    "text": "想像好幾億年前"
  },
  {
    "start": 21.45,
    "end": 24.86,
    "speaker": "彥君",
    "text": "植物都在海裡當綠藻"
  },
  {
    "start": 24.86,
    "end": 28.24,
    "speaker": "彥君",
    "text": "有批勇士想上陸地"
  },
  {
    "start": 28.24,
    "end": 31.33,
    "speaker": "彥君",
    "text": "這是演化的開始"
  },
  {
    "start": 31.33,
    "end": 34.4,
    "speaker": "彥君",
    "text": "第一批上岸的勇士"
  },
  {
    "start": 34.4,
    "end": 37.58,
    "speaker": "彥君",
    "text": "就是『苔蘚植物』喔"
  },
  {
    "start": 37.58,
    "end": 40.84,
    "speaker": "彥君",
    "text": "戰士看左邊紅框框"
  },
  {
    "start": 40.84,
    "end": 44.2,
    "speaker": "彥君",
    "text": "苔蘚其實很辛苦"
  },
  {
    "start": 44.2,
    "end": 47.27,
    "speaker": "彥君",
    "text": "它的配備很簡陋"
  },
  {
    "start": 47.27,
    "end": 50.34,
    "speaker": "彥君",
    "text": "連維管束都沒有"
  },
  {
    "start": 50.34,
    "end": 53.5,
    "speaker": "彥君",
    "text": "也就是沒有吸水管"
  },
  {
    "start": 53.5,
    "end": 56.86,
    "speaker": "彥君",
    "text": "所以長不高不漂亮"
  },
  {
    "start": 56.86,
    "end": 59.95,
    "speaker": "彥君",
    "text": "只能貼在地面上"
  },
  {
    "start": 59.95,
    "end": 63.47,
    "speaker": "彥君",
    "text": "潮濕牆角的綠色植物"
  },
  {
    "start": 63.47,
    "end": 66.64,
    "speaker": "彥君",
    "text": "其實就是苔蘚喔"
  },
  {
    "start": 66.64,
    "end": 70.06,
    "speaker": "彥君",
    "text": "沒水管就沒根莖葉"
  },
  {
    "start": 70.06,
    "end": 73.08,
    "speaker": "彥君",
    "text": "生小孩時更慘了"
  },
  {
    "start": 73.08,
    "end": 76.32,
    "speaker": "彥君",
    "text": "精子得在水裡游"
  },
  {
    "start": 76.32,
    "end": 79.82,
    "speaker": "彥君",
    "text": "所以這輩子離不開水"
  },
  {
    "start": 79.82,
    "end": 83.08,
    "speaker": "彥君",
    "text": "接著講第二段故事"
  },
  {
    "start": 83.08,
    "end": 86.6,
    "speaker": "彥君",
    "text": "大英雄『蕨類植物』"
  },
  {
    "start": 86.6,
    "end": 89.82,
    "speaker": "彥君",
    "text": "戰士看下方紅框"
  },
  {
    "start": 89.82,
    "end": 93.17,
    "speaker": "彥君",
    "text": "蕨類發明重要科技"
  },
  {
    "start": 93.17,
    "end": 96.62,
    "speaker": "彥君",
    "text": "就是這個『維管束』"
  },
  {
    "start": 96.62,
    "end": 99.64,
    "speaker": "彥君",
    "text": "有了自來水管後"
  },
  {
    "start": 99.64,
    "end": 102.81,
    "speaker": "彥君",
    "text": "終於能挺直腰桿了"
  },
  {
    "start": 102.81,
    "end": 106.09,
    "speaker": "彥君",
    "text": "山區的筆筒樹很高"
  },
  {
    "start": 106.09,
    "end": 109.18,
    "speaker": "彥君",
    "text": "因為有管子送水"
  },
  {
    "start": 109.18,
    "end": 112.32,
    "speaker": "彥君",
    "text": "有了真正的根莖葉"
  },
  {
    "start": 112.32,
    "end": 115.7,
    "speaker": "彥君",
    "text": "但觀念還是有點舊"
  },
  {
    "start": 115.7,
    "end": 119.18,
    "speaker": "彥君",
    "text": "生殖還是靠著孢子"
  },
  {
    "start": 119.18,
    "end": 122.56,
    "speaker": "彥君",
    "text": "受精得等天降甘霖"
  },
  {
    "start": 122.56,
    "end": 125.84,
    "speaker": "彥君",
    "text": "讓精子順利游過去"
  },
  {
    "start": 125.84,
    "end": 129.01,
    "speaker": "彥君",
    "text": "雖然蕨類長高了"
  },
  {
    "start": 129.01,
    "end": 132.15,
    "speaker": "彥君",
    "text": "家還是得在溪邊喔"
  },
  {
    "start": 132.15,
    "end": 135.17,
    "speaker": "曉臻",
    "text": "老師我先打岔一下"
  },
  {
    "start": 135.17,
    "end": 138.24,
    "speaker": "曉臻",
    "text": "這裡學生最常搞混"
  },
  {
    "start": 138.24,
    "end": 141.21,
    "speaker": "曉臻",
    "text": "孢子和種子差在哪"
  },
  {
    "start": 141.21,
    "end": 144.2,
    "speaker": "曉臻",
    "text": "花與花粉管差在哪"
  },
  {
    "start": 144.2,
    "end": 147.03,
    "speaker": "曉臻",
    "text": "到底有什麼不同啦"
  },
  {
    "start": 147.03,
    "end": 150.15,
    "speaker": "彥君",
    "text": "這是超棒的問題"
  },
  {
    "start": 150.15,
    "end": 153.29,
    "speaker": "彥君",
    "text": "戰士們請仔細聽"
  },
  {
    "start": 153.29,
    "end": 156.72,
    "speaker": "彥君",
    "text": "孢子就像是隨身碟"
  },
  {
    "start": 156.72,
    "end": 160.22,
    "speaker": "彥君",
    "text": "構造簡單沒保護殼"
  },
  {
    "start": 160.22,
    "end": 163.48,
    "speaker": "彥君",
    "text": "種子像是豪華便當"
  },
  {
    "start": 163.48,
    "end": 166.83,
    "speaker": "彥君",
    "text": "有外殼保護與養分"
  },
  {
    "start": 166.83,
    "end": 170.07,
    "speaker": "彥君",
    "text": "至於花粉管更厲害"
  },
  {
    "start": 170.07,
    "end": 173.45,
    "speaker": "彥君",
    "text": "它是精子專屬通道"
  },
  {
    "start": 173.45,
    "end": 176.76,
    "speaker": "彥君",
    "text": "不用靠水就能受精"
  },
  {
    "start": 176.76,
    "end": 180.23,
    "speaker": "彥君",
    "text": "花跟果實是最高級"
  },
  {
    "start": 180.23,
    "end": 183.56,
    "speaker": "彥君",
    "text": "果實用來包護種子"
  },
  {
    "start": 183.56,
    "end": 186.87,
    "speaker": "彥君",
    "text": "花則是吸引動物的"
  },
  {
    "start": 186.87,
    "end": 190.01,
    "speaker": "彥君",
    "text": "接著進入大革命了"
  },
  {
    "start": 190.01,
    "end": 193.46,
    "speaker": "彥君",
    "text": "中間框框的『裸子』"
  },
  {
    "start": 193.46,
    "end": 196.72,
    "speaker": "彥君",
    "text": "像是松柏與杉樹"
  },
  {
    "start": 196.72,
    "end": 200.1,
    "speaker": "彥君",
    "text": "發明種子與花粉管"
  },
  {
    "start": 200.1,
    "end": 203.32,
    "speaker": "彥君",
    "text": "就像蓋了地下隧道"
  },
  {
    "start": 203.32,
    "end": 206.48,
    "speaker": "彥君",
    "text": "精子空降不用水"
  },
  {
    "start": 206.48,
    "end": 209.79,
    "speaker": "彥君",
    "text": "種子包便當帶著走"
  },
  {
    "start": 209.79,
    "end": 213.24,
    "speaker": "彥君",
    "text": "終於征服高山沙漠"
  },
  {
    "start": 213.24,
    "end": 216.31,
    "speaker": "彥君",
    "text": "但它們還沒有花喔"
  },
  {
    "start": 216.31,
    "end": 219.69,
    "speaker": "彥君",
    "text": "靠毬果來傳宗接代"
  },
  {
    "start": 219.69,
    "end": 222.83,
    "speaker": "彥君",
    "text": "種子裸露在外面"
  },
  {
    "start": 222.83,
    "end": 226.16,
    "speaker": "彥君",
    "text": "所以才叫『裸子』"
  },
  {
    "start": 226.16,
    "end": 229.32,
    "speaker": "彥君",
    "text": "最後是演化的巔峰"
  },
  {
    "start": 229.32,
    "end": 232.68,
    "speaker": "彥君",
    "text": "也就是『被子植物』"
  },
  {
    "start": 232.68,
    "end": 235.75,
    "speaker": "彥君",
    "text": "看右下角紅框框"
  },
  {
    "start": 235.75,
    "end": 239.13,
    "speaker": "彥君",
    "text": "身邊最常見的植物"
  },
  {
    "start": 239.13,
    "end": 242.34,
    "speaker": "彥君",
    "text": "有種子也有管子"
  },
  {
    "start": 242.34,
    "end": 245.62,
    "speaker": "彥君",
    "text": "還有最華麗的武器"
  },
  {
    "start": 245.62,
    "end": 248.72,
    "speaker": "彥君",
    "text": "就是美麗的『花』"
  },
  {
    "start": 248.72,
    "end": 252.0,
    "speaker": "彥君",
    "text": "吸引昆蟲來做媒"
  },
  {
    "start": 252.0,
    "end": 255.21,
    "speaker": "彥君",
    "text": "結成果實給動物吃"
  },
  {
    "start": 255.21,
    "end": 258.71,
    "speaker": "彥君",
    "text": "種子被帶著全世界跑"
  },
  {
    "start": 258.71,
    "end": 261.95,
    "speaker": "彥君",
    "text": "成功征服了地球"
  },
  {
    "start": 261.95,
    "end": 264.7,
    "speaker": "曉臻",
    "text": "大家好我是曉臻"
  },
  {
    "start": 264.7,
    "end": 267.68,
    "speaker": "曉臻",
    "text": "老師講得太精彩了"
  },
  {
    "start": 267.68,
    "end": 270.77,
    "speaker": "曉臻",
    "text": "故事聽完畫好地圖"
  },
  {
    "start": 270.77,
    "end": 273.6,
    "speaker": "曉臻",
    "text": "戰士們請拿起筆"
  },
  {
    "start": 273.6,
    "end": 276.57,
    "speaker": "曉臻",
    "text": "來填奪分大表格吧"
  },
  {
    "start": 276.57,
    "end": 279.16,
    "speaker": "曉臻",
    "text": "第一欄寫『苔蘚』"
  },
  {
    "start": 279.16,
    "end": 282.01,
    "speaker": "曉臻",
    "text": "沒維管束打叉叉"
  },
  {
    "start": 282.01,
    "end": 284.88,
    "speaker": "曉臻",
    "text": "靠孢子所以打圈"
  },
  {
    "start": 284.88,
    "end": 288.07,
    "speaker": "曉臻",
    "text": "種子花粉管還有花"
  },
  {
    "start": 288.07,
    "end": 290.85,
    "speaker": "曉臻",
    "text": "通通都沒有打叉"
  },
  {
    "start": 290.85,
    "end": 293.85,
    "speaker": "曉臻",
    "text": "接著看第二欄蕨類"
  },
  {
    "start": 293.85,
    "end": 296.89,
    "speaker": "曉臻",
    "text": "維管束與孢子打圈"
  },
  {
    "start": 296.89,
    "end": 300.08,
    "speaker": "曉臻",
    "text": "種子花粉管還有花"
  },
  {
    "start": 300.08,
    "end": 303.15,
    "speaker": "曉臻",
    "text": "還沒演化出來打叉"
  },
  {
    "start": 303.15,
    "end": 306.14,
    "speaker": "曉臻",
    "text": "第三欄是裸子植物"
  },
  {
    "start": 306.14,
    "end": 309.16,
    "speaker": "曉臻",
    "text": "維管束當然要打圈"
  },
  {
    "start": 309.16,
    "end": 312.18,
    "speaker": "曉臻",
    "text": "改用種子孢子打叉"
  },
  {
    "start": 312.18,
    "end": 315.28,
    "speaker": "曉臻",
    "text": "種子與花粉管打圈"
  },
  {
    "start": 315.28,
    "end": 318.03,
    "speaker": "曉臻",
    "text": "沒有花所以打叉"
  },
  {
    "start": 318.03,
    "end": 321.08,
    "speaker": "曉臻",
    "text": "最後看第四欄被子"
  },
  {
    "start": 321.08,
    "end": 323.95,
    "speaker": "曉臻",
    "text": "孢子這格請打叉"
  },
  {
    "start": 323.95,
    "end": 327.04,
    "speaker": "曉臻",
    "text": "維管束與種子打圈"
  },
  {
    "start": 327.04,
    "end": 330.09,
    "speaker": "曉臻",
    "text": "花粉管與花也打圈"
  },
  {
    "start": 330.09,
    "end": 333.23,
    "speaker": "曉臻",
    "text": "戰士們表格填好了嗎"
  },
  {
    "start": 333.23,
    "end": 336.54,
    "speaker": "彥君",
    "text": "表格是故事的縮影"
  },
  {
    "start": 336.54,
    "end": 339.89,
    "speaker": "彥君",
    "text": "演化是慢慢累積的"
  },
  {
    "start": 339.89,
    "end": 343.27,
    "speaker": "彥君",
    "text": "越後面功能越強大"
  },
  {
    "start": 343.27,
    "end": 346.46,
    "speaker": "彥君",
    "text": "戰士們閉上眼睛"
  },
  {
    "start": 346.46,
    "end": 349.53,
    "speaker": "彥君",
    "text": "有花粉管的植物"
  },
  {
    "start": 349.53,
    "end": 352.5,
    "speaker": "彥君",
    "text": "它一定會有果實嗎"
  },
  {
    "start": 352.5,
    "end": 355.28,
    "speaker": "曉臻",
    "text": "老師這題是陷阱"
  },
  {
    "start": 355.28,
    "end": 358.3,
    "speaker": "曉臻",
    "text": "裸子植物有花粉管"
  },
  {
    "start": 358.3,
    "end": 361.37,
    "speaker": "曉臻",
    "text": "但它沒花也沒果實"
  },
  {
    "start": 361.37,
    "end": 364.34,
    "speaker": "彥君",
    "text": "漂亮完全正確喔"
  },
  {
    "start": 364.34,
    "end": 367.65,
    "speaker": "彥君",
    "text": "有種必有管是真言"
  },
  {
    "start": 367.65,
    "end": 370.88,
    "speaker": "彥君",
    "text": "大家好好消化一下"
  },
  {
    "start": 370.88,
    "end": 373.78,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 373.78,
    "end": 376.42,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 376.42,
    "end": 379.42,
    "speaker": "曉臻",
    "text": "植物演化通立大功"
  },
  {
    "start": 379.42,
    "end": 382.17,
    "speaker": "曉臻",
    "text": "戰士們下一關見"
  }
]
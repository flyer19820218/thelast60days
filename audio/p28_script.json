[
  {
    "start": 0.0,
    "end": 3.04,
    "speaker": "彥君",
    "text": "各位衝A的戰士"
  },
  {
    "start": 3.04,
    "end": 5.94,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 5.94,
    "end": 8.75,
    "speaker": "曉臻",
    "text": "戰士們大家好啊"
  },
  {
    "start": 8.75,
    "end": 11.38,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 11.38,
    "end": 14.6,
    "speaker": "彥君",
    "text": "大家先把筆放下"
  },
  {
    "start": 14.6,
    "end": 17.47,
    "speaker": "彥君",
    "text": "聽我講個故事吧"
  },
  {
    "start": 17.47,
    "end": 20.28,
    "speaker": "曉臻",
    "text": "翻開講義這一頁"
  },
  {
    "start": 20.28,
    "end": 23.1,
    "speaker": "曉臻",
    "text": "準備進入植物界"
  },
  {
    "start": 23.1,
    "end": 26.46,
    "speaker": "彥君",
    "text": "想像好幾億年前"
  },
  {
    "start": 26.46,
    "end": 29.86,
    "speaker": "彥君",
    "text": "植物都在海裡當綠藻"
  },
  {
    "start": 29.86,
    "end": 32.96,
    "speaker": "曉臻",
    "text": "有批勇士想上陸地"
  },
  {
    "start": 32.96,
    "end": 35.76,
    "speaker": "曉臻",
    "text": "這是演化的開始"
  },
  {
    "start": 35.76,
    "end": 40.36,
    "speaker": "彥君",
    "text": "沒錯第一批上岸的"
  },
  {
    "start": 40.36,
    "end": 43.55,
    "speaker": "彥君",
    "text": "就是『蘚苔植物』喔"
  },
  {
    "start": 43.55,
    "end": 47.53,
    "speaker": "曉臻",
    "text": "蘚苔是長在牆角"
  },
  {
    "start": 47.53,
    "end": 50.34,
    "speaker": "曉臻",
    "text": "綠綠扁扁的那個嗎"
  },
  {
    "start": 50.34,
    "end": 55.11,
    "speaker": "彥君",
    "text": "答對了看看左邊紅框"
  },
  {
    "start": 55.11,
    "end": 58.46,
    "speaker": "彥君",
    "text": "像是地錢和土馬騌"
  },
  {
    "start": 58.46,
    "end": 61.68,
    "speaker": "曉臻",
    "text": "老師它們看起來"
  },
  {
    "start": 61.68,
    "end": 64.46,
    "speaker": "曉臻",
    "text": "好像都長不高耶"
  },
  {
    "start": 64.46,
    "end": 67.69,
    "speaker": "彥君",
    "text": "因為它們配備簡陋"
  },
  {
    "start": 67.69,
    "end": 70.76,
    "speaker": "彥君",
    "text": "連維管束都沒有喔"
  },
  {
    "start": 70.76,
    "end": 73.64,
    "speaker": "曉臻",
    "text": "也就是沒有吸水管"
  },
  {
    "start": 73.64,
    "end": 76.68,
    "speaker": "曉臻",
    "text": "沒水管就沒真正的"
  },
  {
    "start": 76.68,
    "end": 79.53,
    "speaker": "曉臻",
    "text": "根和莖還有葉子"
  },
  {
    "start": 79.53,
    "end": 82.82,
    "speaker": "彥君",
    "text": "所以只能貼在地面"
  },
  {
    "start": 82.82,
    "end": 86.32,
    "speaker": "彥君",
    "text": "生小孩時更是辛苦"
  },
  {
    "start": 86.32,
    "end": 89.34,
    "speaker": "曉臻",
    "text": "精子必須在水裡游"
  },
  {
    "start": 89.34,
    "end": 92.36,
    "speaker": "曉臻",
    "text": "才能順利找到卵子"
  },
  {
    "start": 92.36,
    "end": 95.78,
    "speaker": "彥君",
    "text": "所以這輩子離不開水"
  },
  {
    "start": 95.78,
    "end": 99.12,
    "speaker": "彥君",
    "text": "只能住在潮濕的地方"
  },
  {
    "start": 99.12,
    "end": 102.28,
    "speaker": "曉臻",
    "text": "接著進入第二段故事"
  },
  {
    "start": 102.28,
    "end": 105.18,
    "speaker": "曉臻",
    "text": "大英雄『蕨類植物』"
  },
  {
    "start": 105.18,
    "end": 108.51,
    "speaker": "彥君",
    "text": "戰士們看下方紅框"
  },
  {
    "start": 108.51,
    "end": 111.8,
    "speaker": "彥君",
    "text": "蕨類發明了新科技"
  },
  {
    "start": 111.8,
    "end": 114.77,
    "speaker": "曉臻",
    "text": "難道是『維管束』嗎"
  },
  {
    "start": 114.77,
    "end": 119.56,
    "speaker": "彥君",
    "text": "沒錯有了自來水管"
  },
  {
    "start": 119.56,
    "end": 122.73,
    "speaker": "彥君",
    "text": "終於能挺直腰桿了"
  },
  {
    "start": 122.73,
    "end": 125.75,
    "speaker": "曉臻",
    "text": "山區的筆筒樹超高"
  },
  {
    "start": 125.75,
    "end": 128.94,
    "speaker": "曉臻",
    "text": "就是因為有管子送水"
  },
  {
    "start": 128.94,
    "end": 132.2,
    "speaker": "彥君",
    "text": "也有了真正的根莖葉"
  },
  {
    "start": 132.2,
    "end": 135.5,
    "speaker": "彥君",
    "text": "但觀念還是有點舊喔"
  },
  {
    "start": 135.5,
    "end": 138.81,
    "speaker": "曉臻",
    "text": "老師是指生殖方式嗎"
  },
  {
    "start": 138.81,
    "end": 142.65,
    "speaker": "彥君",
    "text": "對生殖還是靠孢子"
  },
  {
    "start": 142.65,
    "end": 146.03,
    "speaker": "彥君",
    "text": "受精得等天降甘霖"
  },
  {
    "start": 146.03,
    "end": 149.12,
    "speaker": "曉臻",
    "text": "讓精子順利游過去"
  },
  {
    "start": 149.12,
    "end": 152.09,
    "speaker": "曉臻",
    "text": "難怪蕨類長得再高"
  },
  {
    "start": 152.09,
    "end": 155.04,
    "speaker": "曉臻",
    "text": "老家還是得在溪邊"
  },
  {
    "start": 155.04,
    "end": 158.06,
    "speaker": "曉臻",
    "text": "老師我先打岔一下"
  },
  {
    "start": 158.06,
    "end": 161.13,
    "speaker": "曉臻",
    "text": "這裡學生最常搞混"
  },
  {
    "start": 161.13,
    "end": 164.1,
    "speaker": "曉臻",
    "text": "孢子和種子差在哪"
  },
  {
    "start": 164.1,
    "end": 167.1,
    "speaker": "曉臻",
    "text": "花與花粉管差在哪"
  },
  {
    "start": 167.1,
    "end": 170.21,
    "speaker": "彥君",
    "text": "這是超棒的問題"
  },
  {
    "start": 170.21,
    "end": 173.35,
    "speaker": "彥君",
    "text": "戰士們請仔細聽"
  },
  {
    "start": 173.35,
    "end": 176.78,
    "speaker": "彥君",
    "text": "孢子就像是隨身碟"
  },
  {
    "start": 176.78,
    "end": 180.28,
    "speaker": "彥君",
    "text": "構造簡單沒保護殼"
  },
  {
    "start": 180.28,
    "end": 183.54,
    "speaker": "曉臻",
    "text": "那種子就是豪華便當"
  },
  {
    "start": 183.54,
    "end": 186.49,
    "speaker": "曉臻",
    "text": "有外殼保護與養分"
  },
  {
    "start": 186.49,
    "end": 189.72,
    "speaker": "彥君",
    "text": "至於花粉管更厲害"
  },
  {
    "start": 189.72,
    "end": 193.1,
    "speaker": "彥君",
    "text": "它是精子專屬通道"
  },
  {
    "start": 193.1,
    "end": 196.03,
    "speaker": "曉臻",
    "text": "等於建了地下隧道"
  },
  {
    "start": 196.03,
    "end": 199.02,
    "speaker": "曉臻",
    "text": "不用靠水就能受精"
  },
  {
    "start": 199.02,
    "end": 202.52,
    "speaker": "彥君",
    "text": "所以接著進入大革命"
  },
  {
    "start": 202.52,
    "end": 205.98,
    "speaker": "彥君",
    "text": "中間框框的『裸子』"
  },
  {
    "start": 205.98,
    "end": 209.28,
    "speaker": "曉臻",
    "text": "像是松柏與杉樹對吧"
  },
  {
    "start": 209.28,
    "end": 212.74,
    "speaker": "彥君",
    "text": "發明種子與花粉管"
  },
  {
    "start": 212.74,
    "end": 215.9,
    "speaker": "彥君",
    "text": "精子空降不用水"
  },
  {
    "start": 215.9,
    "end": 219.21,
    "speaker": "彥君",
    "text": "種子包便當帶著走"
  },
  {
    "start": 219.21,
    "end": 222.2,
    "speaker": "曉臻",
    "text": "終於征服高山沙漠"
  },
  {
    "start": 222.2,
    "end": 225.06,
    "speaker": "曉臻",
    "text": "但它們還沒有花喔"
  },
  {
    "start": 225.06,
    "end": 229.01,
    "speaker": "彥君",
    "text": "對靠毬果來傳宗接代"
  },
  {
    "start": 229.01,
    "end": 232.15,
    "speaker": "彥君",
    "text": "種子裸露在外面"
  },
  {
    "start": 232.15,
    "end": 235.48,
    "speaker": "彥君",
    "text": "所以才叫『裸子』"
  },
  {
    "start": 235.48,
    "end": 238.65,
    "speaker": "彥君",
    "text": "最後是演化的巔峰"
  },
  {
    "start": 238.65,
    "end": 242.0,
    "speaker": "彥君",
    "text": "也就是『被子植物』"
  },
  {
    "start": 242.0,
    "end": 244.98,
    "speaker": "曉臻",
    "text": "看右下角的紅框框"
  },
  {
    "start": 244.98,
    "end": 247.95,
    "speaker": "曉臻",
    "text": "身邊最常見的植物"
  },
  {
    "start": 247.95,
    "end": 251.16,
    "speaker": "彥君",
    "text": "有種子也有管子"
  },
  {
    "start": 251.16,
    "end": 254.42,
    "speaker": "彥君",
    "text": "還有最華麗的武器"
  },
  {
    "start": 254.42,
    "end": 257.03,
    "speaker": "曉臻",
    "text": "就是美麗的『花』"
  },
  {
    "start": 257.03,
    "end": 259.96,
    "speaker": "曉臻",
    "text": "吸引昆蟲來做媒"
  },
  {
    "start": 259.96,
    "end": 263.14,
    "speaker": "彥君",
    "text": "結成果實給動物吃"
  },
  {
    "start": 263.14,
    "end": 266.64,
    "speaker": "彥君",
    "text": "種子被帶著全世界跑"
  },
  {
    "start": 266.64,
    "end": 269.88,
    "speaker": "彥君",
    "text": "成功征服了地球"
  },
  {
    "start": 269.88,
    "end": 272.97,
    "speaker": "曉臻",
    "text": "故事聽完畫好地圖"
  },
  {
    "start": 272.97,
    "end": 275.82,
    "speaker": "曉臻",
    "text": "戰士們請拿起筆"
  },
  {
    "start": 275.82,
    "end": 278.8,
    "speaker": "曉臻",
    "text": "來填奪分大表格吧"
  },
  {
    "start": 278.8,
    "end": 282.3,
    "speaker": "彥君",
    "text": "曉臻助教帶大家填"
  },
  {
    "start": 282.3,
    "end": 285.12,
    "speaker": "曉臻",
    "text": "第一欄寫『蘚苔』喔"
  },
  {
    "start": 285.12,
    "end": 287.98,
    "speaker": "曉臻",
    "text": "沒維管束打叉叉"
  },
  {
    "start": 287.98,
    "end": 290.85,
    "speaker": "曉臻",
    "text": "靠孢子所以打圈"
  },
  {
    "start": 290.85,
    "end": 294.21,
    "speaker": "彥君",
    "text": "種子花粉管還有花"
  },
  {
    "start": 294.21,
    "end": 297.3,
    "speaker": "彥君",
    "text": "通通都沒有打叉"
  },
  {
    "start": 297.3,
    "end": 300.3,
    "speaker": "曉臻",
    "text": "接著看第二欄蕨類"
  },
  {
    "start": 300.3,
    "end": 303.34,
    "speaker": "曉臻",
    "text": "維管束與孢子打圈"
  },
  {
    "start": 303.34,
    "end": 306.7,
    "speaker": "彥君",
    "text": "種子花粉管還有花"
  },
  {
    "start": 306.7,
    "end": 310.0,
    "speaker": "彥君",
    "text": "還沒演化出來打叉"
  },
  {
    "start": 310.0,
    "end": 313.0,
    "speaker": "曉臻",
    "text": "第三欄是裸子植物"
  },
  {
    "start": 313.0,
    "end": 316.02,
    "speaker": "曉臻",
    "text": "維管束當然要打圈"
  },
  {
    "start": 316.02,
    "end": 319.62,
    "speaker": "彥君",
    "text": "改用種子孢子打叉"
  },
  {
    "start": 319.62,
    "end": 322.92,
    "speaker": "彥君",
    "text": "種子與花粉管打圈"
  },
  {
    "start": 322.92,
    "end": 326.04,
    "speaker": "彥君",
    "text": "沒有花所以打叉"
  },
  {
    "start": 326.04,
    "end": 329.08,
    "speaker": "曉臻",
    "text": "最後看第四欄被子"
  },
  {
    "start": 329.08,
    "end": 331.96,
    "speaker": "曉臻",
    "text": "孢子這格請打叉"
  },
  {
    "start": 331.96,
    "end": 335.05,
    "speaker": "曉臻",
    "text": "維管束與種子打圈"
  },
  {
    "start": 335.05,
    "end": 338.41,
    "speaker": "彥君",
    "text": "花粉管與花也打圈"
  },
  {
    "start": 338.41,
    "end": 341.6,
    "speaker": "彥君",
    "text": "戰士們表格填好了嗎"
  },
  {
    "start": 341.6,
    "end": 344.9,
    "speaker": "彥君",
    "text": "表格是故事的縮影"
  },
  {
    "start": 344.9,
    "end": 348.26,
    "speaker": "彥君",
    "text": "演化是慢慢累積的"
  },
  {
    "start": 348.26,
    "end": 351.28,
    "speaker": "曉臻",
    "text": "越後面功能越強大"
  },
  {
    "start": 351.28,
    "end": 354.47,
    "speaker": "彥君",
    "text": "戰士們閉上眼睛"
  },
  {
    "start": 354.47,
    "end": 357.54,
    "speaker": "彥君",
    "text": "有花粉管的植物"
  },
  {
    "start": 357.54,
    "end": 360.51,
    "speaker": "彥君",
    "text": "它一定會有果實嗎"
  },
  {
    "start": 360.51,
    "end": 363.29,
    "speaker": "曉臻",
    "text": "老師這題是陷阱"
  },
  {
    "start": 363.29,
    "end": 366.31,
    "speaker": "曉臻",
    "text": "裸子植物有花粉管"
  },
  {
    "start": 366.31,
    "end": 369.38,
    "speaker": "曉臻",
    "text": "但它沒花也沒果實"
  },
  {
    "start": 369.38,
    "end": 372.35,
    "speaker": "彥君",
    "text": "漂亮完全正確喔"
  },
  {
    "start": 372.35,
    "end": 375.66,
    "speaker": "彥君",
    "text": "有種必有管是真言"
  },
  {
    "start": 375.66,
    "end": 378.82,
    "speaker": "彥君",
    "text": "戰士們別急著走"
  },
  {
    "start": 378.82,
    "end": 381.91,
    "speaker": "彥君",
    "text": "故事還沒有結束喔"
  },
  {
    "start": 381.91,
    "end": 385.12,
    "speaker": "彥君",
    "text": "剛剛講的被子植物"
  },
  {
    "start": 385.12,
    "end": 388.26,
    "speaker": "彥君",
    "text": "其實還有分兩派喔"
  },
  {
    "start": 388.26,
    "end": 391.07,
    "speaker": "曉臻",
    "text": "老師我來猜猜看"
  },
  {
    "start": 391.07,
    "end": 394.11,
    "speaker": "曉臻",
    "text": "是單子葉跟雙子葉"
  },
  {
    "start": 394.11,
    "end": 397.56,
    "speaker": "彥君",
    "text": "沒錯就是這兩大派"
  },
  {
    "start": 397.56,
    "end": 400.87,
    "speaker": "彥君",
    "text": "這是會考必考重點"
  },
  {
    "start": 400.87,
    "end": 404.18,
    "speaker": "彥君",
    "text": "戰士們翻到下一頁"
  },
  {
    "start": 404.18,
    "end": 407.25,
    "speaker": "彥君",
    "text": "我們來比拼一下吧"
  },
  {
    "start": 407.25,
    "end": 410.1,
    "speaker": "曉臻",
    "text": "第一關比的是種子"
  },
  {
    "start": 410.1,
    "end": 413.17,
    "speaker": "彥君",
    "text": "單子葉顧名思義"
  },
  {
    "start": 413.17,
    "end": 416.43,
    "speaker": "彥君",
    "text": "種子只有一片子葉"
  },
  {
    "start": 416.43,
    "end": 419.62,
    "speaker": "彥君",
    "text": "雙子葉就有兩片喔"
  },
  {
    "start": 419.62,
    "end": 422.52,
    "speaker": "曉臻",
    "text": "像是花生跟綠豆"
  },
  {
    "start": 422.52,
    "end": 425.49,
    "speaker": "曉臻",
    "text": "剝開會分成兩半喔"
  },
  {
    "start": 425.49,
    "end": 428.58,
    "speaker": "彥君",
    "text": "第二關比的是根部"
  },
  {
    "start": 428.58,
    "end": 431.6,
    "speaker": "彥君",
    "text": "單子葉是長鬚根"
  },
  {
    "start": 431.6,
    "end": 434.43,
    "speaker": "曉臻",
    "text": "就像老爺爺的鬍鬚"
  },
  {
    "start": 434.43,
    "end": 437.76,
    "speaker": "彥君",
    "text": "雙子葉則是長軸根"
  },
  {
    "start": 437.76,
    "end": 440.97,
    "speaker": "彥君",
    "text": "有一根粗粗的主根"
  },
  {
    "start": 440.97,
    "end": 444.26,
    "speaker": "曉臻",
    "text": "第三關比維管束排列"
  },
  {
    "start": 444.26,
    "end": 447.37,
    "speaker": "彥君",
    "text": "單子葉散落一地"
  },
  {
    "start": 447.37,
    "end": 450.44,
    "speaker": "彥君",
    "text": "我們稱為散生狀"
  },
  {
    "start": 450.44,
    "end": 453.72,
    "speaker": "彥君",
    "text": "雙子葉乖乖排隊"
  },
  {
    "start": 453.72,
    "end": 456.91,
    "speaker": "彥君",
    "text": "排成漂亮的環狀喔"
  },
  {
    "start": 456.91,
    "end": 459.79,
    "speaker": "曉臻",
    "text": "還有個會考大陷阱"
  },
  {
    "start": 459.79,
    "end": 462.81,
    "speaker": "曉臻",
    "text": "雙子葉有『形成層』"
  },
  {
    "start": 462.81,
    "end": 465.85,
    "speaker": "曉臻",
    "text": "所以樹幹能變粗喔"
  },
  {
    "start": 465.85,
    "end": 468.99,
    "speaker": "彥君",
    "text": "單子葉就沒辦法了"
  },
  {
    "start": 468.99,
    "end": 472.01,
    "speaker": "曉臻",
    "text": "難怪竹子長不粗啊"
  },
  {
    "start": 472.01,
    "end": 474.96,
    "speaker": "曉臻",
    "text": "第四關比的是葉脈"
  },
  {
    "start": 474.96,
    "end": 478.15,
    "speaker": "彥君",
    "text": "單子葉是平行脈"
  },
  {
    "start": 478.15,
    "end": 481.14,
    "speaker": "曉臻",
    "text": "就像平行的斑馬線"
  },
  {
    "start": 481.14,
    "end": 484.28,
    "speaker": "彥君",
    "text": "雙子葉是網狀脈"
  },
  {
    "start": 484.28,
    "end": 487.38,
    "speaker": "曉臻",
    "text": "像蜘蛛網一樣交錯"
  },
  {
    "start": 487.38,
    "end": 490.83,
    "speaker": "彥君",
    "text": "最後一關比花瓣數"
  },
  {
    "start": 490.83,
    "end": 494.06,
    "speaker": "彥君",
    "text": "單子葉是三的倍數"
  },
  {
    "start": 494.06,
    "end": 497.13,
    "speaker": "彥君",
    "text": "雙子葉是四或五"
  },
  {
    "start": 497.13,
    "end": 500.18,
    "speaker": "曉臻",
    "text": "戰士們快點填表格"
  },
  {
    "start": 500.18,
    "end": 503.36,
    "speaker": "彥君",
    "text": "戰士們閉上眼睛"
  },
  {
    "start": 503.36,
    "end": 506.53,
    "speaker": "彥君",
    "text": "吃玉米時的玉米粒"
  },
  {
    "start": 506.53,
    "end": 509.79,
    "speaker": "彥君",
    "text": "剝不開也沒有分半"
  },
  {
    "start": 509.79,
    "end": 513.02,
    "speaker": "彥君",
    "text": "它是單還是雙子葉"
  },
  {
    "start": 513.02,
    "end": 515.95,
    "speaker": "曉臻",
    "text": "玉米剝不開是單片"
  },
  {
    "start": 515.95,
    "end": 518.97,
    "speaker": "曉臻",
    "text": "絕對是單子葉植物"
  },
  {
    "start": 518.97,
    "end": 521.94,
    "speaker": "彥君",
    "text": "漂亮完全正確喔"
  },
  {
    "start": 521.94,
    "end": 525.3,
    "speaker": "彥君",
    "text": "單雙子葉要記清楚"
  },
  {
    "start": 525.3,
    "end": 528.2,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 528.2,
    "end": 530.83,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 530.83,
    "end": 533.61,
    "speaker": "曉臻",
    "text": "植物分類拿滿分"
  },
  {
    "start": 533.61,
    "end": 536.37,
    "speaker": "曉臻",
    "text": "戰士們下一關見"
  }
]
[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.74,
    "speaker": "彥君",
    "text": "各位即將衝ㄟ的會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.94,
    "end": 8.54,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.74,
    "end": 11.94,
    "speaker": "彥君",
    "text": "今天來到 第九十三集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.14,
    "end": 13.87,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.07,
    "end": 16.41,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.61,
    "end": 19.06,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.26,
    "end": 22.01,
    "speaker": "彥君",
    "text": "酸的化學反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.21,
    "end": 25.22,
    "speaker": "彥君",
    "text": "是 會考的超級熱區",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.42,
    "end": 28.42,
    "speaker": "曉臻",
    "text": "老師 第一個反應式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.62,
    "end": 33.22,
    "speaker": "曉臻",
    "text": "XCO₃（碳酸鹽類） 加酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.42,
    "end": 35.66,
    "speaker": "曉臻",
    "text": "會產生 什麼啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.86,
    "end": 39.01,
    "speaker": "彥君",
    "text": "只要看到 碳酸兩個字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.21,
    "end": 42.17,
    "speaker": "彥君",
    "text": "遇到酸 一定會產生",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.37,
    "end": 45.26,
    "speaker": "彥君",
    "text": "二氧化碳 還有水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.46,
    "end": 65.14,
    "speaker": "彥君",
    "text": "XCO₃ + H⁺ → CO₂ + H₂O",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 49.96,
    "end": 53.28,
    "speaker": "曉臻",
    "text": "喔 就像大理石",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.48,
    "end": 56.18,
    "speaker": "曉臻",
    "text": "滴到鹽酸 會冒泡泡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.38,
    "end": 58.76,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.96,
    "end": 61.94,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.14,
    "end": 68.08,
    "speaker": "彥君",
    "text": "接著看 第二個反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.28,
    "end": 70.62,
    "speaker": "曉臻",
    "text": "字母 M 代表什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.82,
    "end": 73.85,
    "speaker": "彥君",
    "text": "M 代表 活性大的金屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.05,
    "end": 76.58,
    "speaker": "彥君",
    "text": "像是 鎂和鋅",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.78,
    "end": 79.16,
    "speaker": "彥君",
    "text": "它們 碰到酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.36,
    "end": 82.03,
    "speaker": "彥君",
    "text": "就會 產生氫氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.23,
    "end": 105.18,
    "speaker": "彥君",
    "text": "M + H⁺ → H₂",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 85.92,
    "end": 89.26,
    "speaker": "曉臻",
    "text": "哇 難怪實驗室",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.46,
    "end": 92.06,
    "speaker": "曉臻",
    "text": "都用 鋅片加鹽酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.26,
    "end": 94.43,
    "speaker": "曉臻",
    "text": "來製造 氫氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.63,
    "end": 98.79,
    "speaker": "彥君",
    "text": "沒錯 邏輯全通了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.99,
    "end": 101.98,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.18,
    "end": 108.06,
    "speaker": "彥君",
    "text": "第三個 酸鹼中和",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.26,
    "end": 111.18,
    "speaker": "彥君",
    "text": "這是 經典中的經典",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.38,
    "end": 113.78,
    "speaker": "曉臻",
    "text": "酸加鹼 會產生",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.98,
    "end": 116.1,
    "speaker": "曉臻",
    "text": "鹽類 還有水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.3,
    "end": 119.14,
    "speaker": "彥君",
    "text": "而且 一定會放熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.34,
    "end": 129.84,
    "speaker": "彥君",
    "text": "\\text + \\text → \\text + \\text + \\text",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 123.66,
    "end": 126.64,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.84,
    "end": 133.45,
    "speaker": "曉臻",
    "text": "老師 那下面的 pH 值",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 133.65,
    "end": 136.08,
    "speaker": "曉臻",
    "text": "箭頭 越往左邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.28,
    "end": 138.9,
    "speaker": "曉臻",
    "text": "數字 越接近 0 耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.1,
    "end": 142.88,
    "speaker": "彥君",
    "text": "pH 值 等於 7 是中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.08,
    "end": 145.82,
    "speaker": "彥君",
    "text": "數字 越小就越酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.02,
    "end": 148.84,
    "speaker": "彥君",
    "text": "數字 越大就越鹼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.04,
    "end": 151.76,
    "speaker": "曉臻",
    "text": "那 紅色的四個物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.96,
    "end": 154.78,
    "speaker": "曉臻",
    "text": "該怎麼 幫它們排座位",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.98,
    "end": 157.55,
    "speaker": "彥君",
    "text": "硫酸 是強酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.75,
    "end": 160.81,
    "speaker": "彥君",
    "text": "會在 最左邊的 0 附近",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.01,
    "end": 163.61,
    "speaker": "彥君",
    "text": "醋酸 是弱酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 163.81,
    "end": 166.55,
    "speaker": "彥君",
    "text": "會在 0 到 7 之間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 166.75,
    "end": 170.14,
    "speaker": "曉臻",
    "text": "喔 那氨水 是弱鹼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.34,
    "end": 173.09,
    "speaker": "曉臻",
    "text": "就在 7 到 14 之間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.29,
    "end": 175.91,
    "speaker": "曉臻",
    "text": "氫氧化鈉 是強鹼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 176.11,
    "end": 179.22,
    "speaker": "曉臻",
    "text": "就會 靠近最右邊的 14",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 179.42,
    "end": 182.45,
    "speaker": "彥君",
    "text": "助教 舉一反三太棒了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 182.65,
    "end": 186.09,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 186.29,
    "end": 188.89,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 189.09,
    "end": 191.42,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 191.62,
    "end": 194.94,
    "speaker": "合聲",
    "text": "遇碳生碳 遇金生氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 195.14,
    "end": 198.68,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
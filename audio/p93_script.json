[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.74,
    "speaker": "彥君",
    "text": "各位即將衝A的會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.94,
    "end": 8.54,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.74,
    "end": 11.94,
    "speaker": "彥君",
    "text": "今天來到 第九十三集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.14,
    "end": 13.87,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.07,
    "end": 16.41,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.61,
    "end": 19.06,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.26,
    "end": 22.01,
    "speaker": "彥君",
    "text": "酸的化學反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.21,
    "end": 25.22,
    "speaker": "彥君",
    "text": "是 會考的超級熱區",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.42,
    "end": 28.42,
    "speaker": "曉臻",
    "text": "老師 第一個反應式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.62,
    "end": 31.03,
    "speaker": "曉臻",
    "text": "XCO₃ 加酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.23,
    "end": 33.47,
    "speaker": "曉臻",
    "text": "會產生 什麼啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.67,
    "end": 36.82,
    "speaker": "彥君",
    "text": "只要看到 碳酸兩個字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.02,
    "end": 39.98,
    "speaker": "彥君",
    "text": "遇到酸 一定會產生",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.18,
    "end": 43.07,
    "speaker": "彥君",
    "text": "二氧化碳 還有水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.27,
    "end": 62.96,
    "speaker": "彥君",
    "text": "XCO₃ + H⁺ → CO₂ + H₂O",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 47.78,
    "end": 51.1,
    "speaker": "曉臻",
    "text": "喔 就像大理石",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.3,
    "end": 53.99,
    "speaker": "曉臻",
    "text": "滴到鹽酸 會冒泡泡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.19,
    "end": 56.58,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.78,
    "end": 59.76,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.96,
    "end": 65.9,
    "speaker": "彥君",
    "text": "接著看 第二個反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.1,
    "end": 68.43,
    "speaker": "曉臻",
    "text": "字母 M 代表什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.63,
    "end": 71.66,
    "speaker": "彥君",
    "text": "M 代表 活性大的金屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.86,
    "end": 74.39,
    "speaker": "彥君",
    "text": "像是 鎂和鋅",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.59,
    "end": 76.98,
    "speaker": "彥君",
    "text": "它們 碰到酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.18,
    "end": 79.85,
    "speaker": "彥君",
    "text": "就會 產生氫氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.05,
    "end": 102.99,
    "speaker": "彥君",
    "text": "M + H⁺ → H₂",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 83.74,
    "end": 87.08,
    "speaker": "曉臻",
    "text": "哇 難怪實驗室",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.28,
    "end": 89.88,
    "speaker": "曉臻",
    "text": "都用 鋅片加鹽酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.08,
    "end": 92.25,
    "speaker": "曉臻",
    "text": "來製造 氫氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.45,
    "end": 96.61,
    "speaker": "彥君",
    "text": "沒錯 邏輯全通了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.81,
    "end": 99.79,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.99,
    "end": 105.88,
    "speaker": "彥君",
    "text": "第三個 酸鹼中和",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.08,
    "end": 108.99,
    "speaker": "彥君",
    "text": "這是 經典中的經典",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.19,
    "end": 111.6,
    "speaker": "曉臻",
    "text": "酸加鹼 會產生",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.8,
    "end": 113.92,
    "speaker": "曉臻",
    "text": "鹽類 還有水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.12,
    "end": 116.96,
    "speaker": "彥君",
    "text": "而且 一定會放熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.16,
    "end": 127.66,
    "speaker": "彥君",
    "text": "酸 + 鹼 → 鹽 + 水 + 熱",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 121.47,
    "end": 124.46,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 127.66,
    "end": 131.26,
    "speaker": "曉臻",
    "text": "老師 那下面的 pH 值",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.46,
    "end": 133.9,
    "speaker": "曉臻",
    "text": "箭頭 越往左邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.1,
    "end": 136.72,
    "speaker": "曉臻",
    "text": "數字 越接近 0 耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.92,
    "end": 140.7,
    "speaker": "彥君",
    "text": "pH 值 等於 7 是中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.9,
    "end": 143.64,
    "speaker": "彥君",
    "text": "數字 越小就越酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.84,
    "end": 146.66,
    "speaker": "彥君",
    "text": "數字 越大就越鹼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.86,
    "end": 149.58,
    "speaker": "曉臻",
    "text": "那 紅色的四個物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.78,
    "end": 152.59,
    "speaker": "曉臻",
    "text": "該怎麼 幫它們排座位",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.79,
    "end": 155.37,
    "speaker": "彥君",
    "text": "硫酸 是強酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.57,
    "end": 158.62,
    "speaker": "彥君",
    "text": "會在 最左邊的 0 附近",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.82,
    "end": 161.42,
    "speaker": "彥君",
    "text": "醋酸 是弱酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.62,
    "end": 164.37,
    "speaker": "彥君",
    "text": "會在 0 到 7 之間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.57,
    "end": 167.96,
    "speaker": "曉臻",
    "text": "喔 那氨水 是弱鹼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.16,
    "end": 170.9,
    "speaker": "曉臻",
    "text": "就在 7 到 14 之間",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.1,
    "end": 173.73,
    "speaker": "曉臻",
    "text": "氫氧化鈉 是強鹼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.93,
    "end": 177.03,
    "speaker": "曉臻",
    "text": "就會 靠近最右邊的 14",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.23,
    "end": 180.26,
    "speaker": "彥君",
    "text": "助教 舉一反三太棒了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 180.46,
    "end": 183.9,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 184.1,
    "end": 186.7,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 186.9,
    "end": 189.24,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 189.44,
    "end": 192.76,
    "speaker": "合聲",
    "text": "遇碳生碳 遇金生氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 192.96,
    "end": 196.5,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
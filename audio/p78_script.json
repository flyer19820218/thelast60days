    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 404.61,
    "end": 406.94,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 407.14,
    "end": 410.54,
    "speaker": "合聲",
    "text": "眼球太長 近視報到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 410.74,
    "end": 414.08,

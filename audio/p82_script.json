[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.33,
    "speaker": "彥君",
    "text": "今天來到 第八十二集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.53,
    "end": 16.26,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.46,
    "end": 18.8,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.0,
    "end": 21.96,
    "speaker": "曉臻",
    "text": "老師 上面的公式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.16,
    "end": 24.66,
    "speaker": "曉臻",
    "text": "看起來 好複雜喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.86,
    "end": 27.78,
    "speaker": "彥君",
    "text": "戰士們， 別怕！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.98,
    "end": 31.13,
    "speaker": "彥君",
    "text": "熱量 就是三個相乘",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.33,
    "end": 34.12,
    "speaker": "彥君",
    "text": "質量 乘以比熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.32,
    "end": 37.14,
    "speaker": "彥君",
    "text": "再乘以 溫度變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.34,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\Delta H = M \\times S \\times \\Delta T",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 41.29,
    "end": 44.06,
    "speaker": "曉臻",
    "text": "那下面 熱平衡的題目",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.26,
    "end": 46.81,
    "speaker": "曉臻",
    "text": "我們 該怎麼列式子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.01,
    "end": 49.8,
    "speaker": "彥君",
    "text": "記住 一個大原則",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.0,
    "end": 52.74,
    "speaker": "彥君",
    "text": "高溫 放出來的熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.94,
    "end": 55.86,
    "speaker": "彥君",
    "text": "等於 低溫吸收的熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.06,
    "end": 58.56,
    "speaker": "曉臻",
    "text": "就像 哥哥給十塊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.76,
    "end": 61.36,
    "speaker": "曉臻",
    "text": "妹妹 就收到十塊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.56,
    "end": 66.06,
    "speaker": "彥君",
    "text": "沒錯 假設平衡是Ｔ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.26,
    "end": 69.14,
    "speaker": "彥君",
    "text": "高溫 減掉平衡的Ｔ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.34,
    "end": 72.11,
    "speaker": "彥君",
    "text": "就是 下降的溫度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.31,
    "end": 75.18,
    "speaker": "彥君",
    "text": "平衡的Ｔ 減掉低溫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.38,
    "end": 78.17,
    "speaker": "彥君",
    "text": "就是 上升的溫度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.37,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "M_1 \\times S_1 \\times (T_1-T) = M_2 \\times S_2 \\times (T-T_2)",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 83.21,
    "end": 86.48,
    "speaker": "曉臻",
    "text": "哇 這樣列出來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.68,
    "end": 89.28,
    "speaker": "曉臻",
    "text": "就可以 解方程式了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.48,
    "end": 92.56,
    "speaker": "彥君",
    "text": "接著看 右下角的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.76,
    "end": 95.67,
    "speaker": "彥君",
    "text": "這是 必考的圖表題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.87,
    "end": 98.64,
    "speaker": "曉臻",
    "text": "老師 這三條線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.84,
    "end": 101.25,
    "speaker": "曉臻",
    "text": "要怎麼 比大小啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.45,
    "end": 104.72,
    "speaker": "彥君",
    "text": "戰士們， 拿出直尺！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.92,
    "end": 108.07,
    "speaker": "彥君",
    "text": "畫一條 鉛直線下來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.27,
    "end": 111.28,
    "speaker": "彥君",
    "text": "代表 加熱時間一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.48,
    "end": 114.27,
    "speaker": "彥君",
    "text": "也就是 吸熱一樣多",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.47,
    "end": 117.91,
    "speaker": "曉臻",
    "text": "哇 黑色的那條線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.11,
    "end": 120.59,
    "speaker": "曉臻",
    "text": "溫度 衝得最高耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.79,
    "end": 123.32,
    "speaker": "彥君",
    "text": "溫度 衝得最快",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.52,
    "end": 126.31,
    "speaker": "彥君",
    "text": "代表 它很容易熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.51,
    "end": 129.28,
    "speaker": "彥君",
    "text": "也就是 比熱最小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.48,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{線越陡} \\rightarrow \\text{溫度升得快} \\rightarrow \\text{比熱小}",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 134.27,
    "end": 136.94,
    "speaker": "曉臻",
    "text": "那最下面 黃色的線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.14,
    "end": 139.55,
    "speaker": "曉臻",
    "text": "溫度 上升最慢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.75,
    "end": 142.35,
    "speaker": "曉臻",
    "text": "代表 它比熱最大囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.55,
    "end": 144.94,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.14,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{線越平} \\rightarrow \\text{溫度升得慢} \\rightarrow \\text{比熱大}",
    "is_pinned": true,
    "pin_level": 4
  },
  {
    "start": 149.93,
    "end": 153.13,
    "speaker": "曉臻",
    "text": "這樣看圖 真的秒解耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.33,
    "end": 156.77,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.97,
    "end": 159.57,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 159.77,
    "end": 162.1,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 162.3,
    "end": 165.79,
    "speaker": "合聲",
    "text": "平衡列式 陡小平大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.99,
    "end": 169.53,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
    "commands": []
  },
  {
    "start": 113.86,
    "end": 191.3,
    "speaker": "彥君",
    "text": "② $\\text{濃度} = \\frac{20\\text{g}}{100\\text{g}+20\\text{g}} \\approx 16.7\\%$",

    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.06,
    "end": 23.04,
    "speaker": "曉臻",
    "text": "老師這題一口氣問了三題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.04,
    "end": 26.23,
    "speaker": "曉臻",
    "text": "我光看題目就頭暈了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.23,
    "end": 29.73,
    "speaker": "彥君",
    "text": "題目說溶解度是",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.73,
    "end": 33.64,
    "speaker": "彥君",
    "text": "\\frac{20g}{100g\\text{水}}",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.64,
    "end": 36.39,
    "speaker": "彥君",
    "text": "兩百克的水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.39,
    "end": 39.84,
    "speaker": "彥君",
    "text": "最多可以溶解多少克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.84,
    "end": 43.99,
    "speaker": "曉臻",
    "text": "這個我會水變成兩倍",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.99,
    "end": 46.89,
    "speaker": "曉臻",
    "text": "胃口當然也變兩倍",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.89,
    "end": 50.9,
    "speaker": "曉臻",
    "text": "所以二十乘以二等於四十",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.9,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "① \\ \\frac{20g\\text{溶質}}{100g\\text{水}} \\Rightarrow \\frac{40g\\text{溶質}}{200g\\text{水}}質）",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 58.91,
    "end": 61.93,
    "speaker": "彥君",
    "text": "接著看第二題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.93,
    "end": 65.26,
    "speaker": "彥君",
    "text": "它問飽和濃度是多少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.26,
    "end": 68.83,
    "speaker": "曉臻",
    "text": "濃度就是把溶質除以全部",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.83,
    "end": 72.14,
    "speaker": "曉臻",
    "text": "溶質二十全部是",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.14,
    "end": 75.95,
    "speaker": "曉臻",
    "text": "二十加一百等於一百二十",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.95,
    "end": 78.64,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.64,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "② \\ \\text{飽和濃度} = \\frac{20g}{20g+100g} \\approx 16.7\\%",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 85.38,
    "end": 88.54,
    "speaker": "曉臻",
    "text": "老師那第三題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.54,
    "end": 91.99,
    "speaker": "曉臻",
    "text": "如果再加入 200mL 的水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.99,
    "end": 94.99,
    "speaker": "曉臻",
    "text": "濃度會變成多少呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.99,
    "end": 99.3,
    "speaker": "彥君",
    "text": "這裡有個小常識水的密度是一",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.3,
    "end": 102.64,
    "speaker": "彥君",
    "text": "所以 200mL 的水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.64,
    "end": 105.44,
    "speaker": "彥君",
    "text": "就是兩百克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.44,
    "end": 109.47,
    "speaker": "彥君",
    "text": "原本的杯子裡已經有兩百克的水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.47,
    "end": 112.82,
    "speaker": "彥君",
    "text": "現在又加了兩百克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.82,
    "end": 117.64,
    "speaker": "曉臻",
    "text": "喔所以現在水總共有四百克了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.64,
    "end": 122.22,
    "speaker": "彥君",
    "text": "沒錯那溶質還是",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.22,
    "end": 125.6,
    "speaker": "彥君",
    "text": "剛剛算出來的四十克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.6,
    "end": 129.66,
    "speaker": "彥君",
    "text": "所以新的濃度就是四十",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.66,
    "end": 135.17,
    "speaker": "彥君",
    "text": "除以全部全部是四十加四百",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.17,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "③ \\ \\text{新濃度} = \\frac{40g}{40g+(200g+200g)} \\approx 9.1\\%",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 141.91,
    "end": 145.96,

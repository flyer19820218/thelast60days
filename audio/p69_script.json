    "commands": []
  },
  {
    "start": 74.66,
    "end": 191.3,
    "speaker": "彥君",
    "text": "① $\\frac{20\\text{g}}{100\\text{g}} \\Rightarrow \\frac{40\\text{g}}{200\\text{g}}$",

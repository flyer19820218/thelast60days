  },
  {
    "start": 78.44,
    "end": 81.9,
    "speaker": "彥君",
    "text": "接著我們來看第二題的陷阱",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 82.1,
    "end": 85.71,
    "speaker": "彥君",
    "text": "它問這杯飽和濃度到底是多少",

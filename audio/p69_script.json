[
  {
    "start": 0.0,
    "end": 4.27,
    "speaker": "彥君",
    "text": "哈囉各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 4.27,
    "end": 8.3,
    "speaker": "彥君",
    "text": "會考戰士們我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 11.82,
    "speaker": "彥君",
    "text": "今天來到第六十九集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.82,
    "end": 15.46,
    "speaker": "彥君",
    "text": "我們要挑戰理化大魔王",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.46,
    "end": 18.96,
    "speaker": "曉臻",
    "text": "大家好我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.96,
    "end": 22.94,
    "speaker": "曉臻",
    "text": "老師這題一口氣問了三題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.94,
    "end": 26.13,
    "speaker": "曉臻",
    "text": "我光看題目就頭暈了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.13,
    "end": 29.63,
    "speaker": "彥君",
    "text": "題目說溶解度是",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.63,
    "end": 33.54,
    "speaker": "彥君",
    "text": "\\frac{20g}{100g\\text{水}}",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.54,
    "end": 38.1,
    "speaker": "彥君",
    "text": "兩百克的水 最多可以溶解多少克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.1,
    "end": 42.24,
    "speaker": "曉臻",
    "text": "這個我會水變成兩倍",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.24,
    "end": 45.14,
    "speaker": "曉臻",
    "text": "胃口當然也變兩倍",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.14,
    "end": 49.15,
    "speaker": "曉臻",
    "text": "所以二十乘以二等於四十",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.15,
    "end": 53.61,
    "speaker": "彥君",
    "text": "沒錯第一題答案",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.61,
    "end": 57.52,
    "speaker": "彥君",
    "text": "兩百克水可溶四十克溶質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.52,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "① \\ \\frac{20g}{100g} \\Rightarrow \\frac{40g}{200g}",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 60.82,
    "end": 63.84,
    "speaker": "彥君",
    "text": "接著看第二題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.84,
    "end": 67.18,
    "speaker": "彥君",
    "text": "它問飽和濃度是多少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.18,
    "end": 70.75,
    "speaker": "曉臻",
    "text": "濃度就是把溶質除以全部",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.75,
    "end": 74.06,
    "speaker": "曉臻",
    "text": "溶質二十全部是",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.06,
    "end": 77.87,
    "speaker": "曉臻",
    "text": "二十加一百等於一百二十",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.87,
    "end": 80.55,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.55,
    "end": 84.44,
    "speaker": "彥君",
    "text": "飽和濃度是二十除一百二十",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.44,
    "end": 88.06,
    "speaker": "彥君",
    "text": "大約是百分之十六點七",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.06,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "② \\ \\text{濃度} = \\frac{20g}{100g+20g} \\approx 16.7\\%",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 91.36,
    "end": 94.53,
    "speaker": "曉臻",
    "text": "老師那第三題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.53,
    "end": 97.98,
    "speaker": "曉臻",
    "text": "如果再加入 200mL 的水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.98,
    "end": 100.98,
    "speaker": "曉臻",
    "text": "濃度會變成多少呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.98,
    "end": 106.54,
    "speaker": "彥君",
    "text": "這裡有個小常識 水的密度是1 \\ g/cm^{3}",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.54,
    "end": 109.87,
    "speaker": "彥君",
    "text": "所以 200mL 的水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.87,
    "end": 112.68,
    "speaker": "彥君",
    "text": "就是兩百克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.68,
    "end": 116.56,
    "speaker": "彥君",
    "text": "原本的杯子裡已有兩百克水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.56,
    "end": 119.92,
    "speaker": "彥君",
    "text": "現在又加了兩百克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.92,
    "end": 124.33,
    "speaker": "曉臻",
    "text": "喔所以水總共有四百克了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.33,
    "end": 129.39,
    "speaker": "彥君",
    "text": "沒錯溶質還是四十克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.39,
    "end": 133.01,
    "speaker": "彥君",
    "text": "所以新濃度就是四十",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 133.01,
    "end": 136.65,
    "speaker": "彥君",
    "text": "除以全部四十加四百",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.65,
    "end": 139.98,
    "speaker": "彥君",
    "text": "大約是百分之九點一",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.98,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "③ \\ \\text{新濃度} = \\frac{40g}{400g+40g} \\approx 9.1\\%",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 143.29,
    "end": 147.34,
    "speaker": "曉臻",
    "text": "哇算式留在畫面上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.34,
    "end": 150.84,
    "speaker": "曉臻",
    "text": "一步一步看真的超清楚耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.84,
    "end": 155.18,
    "speaker": "彥君",
    "text": "沒錯這就是究極板書系統",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.18,
    "end": 158.08,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.08,
    "end": 160.72,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.72,
    "end": 164.56,
    "speaker": "合聲",
    "text": "算式留底濃度無敵",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.56,
    "end": 168.39,
    "speaker": "合聲",
    "text": "戰士們我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
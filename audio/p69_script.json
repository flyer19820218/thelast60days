    "pin_level": 0,
    "commands": []
  },
  {
    "start": 89.38,
    "end": 92.94,
    "speaker": "曉臻",
    "text": "溶質二十全部是二十加一百",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 93.14,
    "end": 96.61,
    "speaker": "曉臻",
    "text": "也就是二十除以一百二十克",
    "is_pinned": false,
    "pin_level": 0,
    "commands": []
  },
  {
    "start": 96.81,
    "end": 101.81,
    "speaker": "彥君",
    "text": "完全正確 戰士們特別注意",
    "is_pinned": false,

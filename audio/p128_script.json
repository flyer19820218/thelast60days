[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.12,
    "speaker": "彥君",
    "text": "第 128 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.32,
    "end": 9.26,
    "speaker": "彥君",
    "text": "電流 會產生磁場",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.46,
    "end": 12.54,
    "speaker": "彥君",
    "text": "就像 你的堅持與努力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.74,
    "end": 15.67,
    "speaker": "彥君",
    "text": "雖然 眼睛看不見",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.87,
    "end": 19.19,
    "speaker": "彥君",
    "text": "卻能 產生巨大的影響力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.39,
    "end": 21.99,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.19,
    "end": 23.93,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.13,
    "end": 26.46,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.66,
    "end": 29.12,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.32,
    "end": 32.23,
    "speaker": "彥君",
    "text": "隱形的 電磁奧秘來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.43,
    "end": 35.27,
    "speaker": "曉臻",
    "text": "老師 為什麼電線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.47,
    "end": 38.19,
    "speaker": "曉臻",
    "text": "竟然會 產生磁場啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.39,
    "end": 41.86,
    "speaker": "彥君",
    "text": "這就是 厄斯特發現的奇蹟",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.06,
    "end": 45.26,
    "speaker": "彥君",
    "text": "只要 導線有電流通過",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.46,
    "end": 48.54,
    "speaker": "彥君",
    "text": "旁邊 就會出現磁場",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.74,
    "end": 51.98,
    "speaker": "曉臻",
    "text": "電流越大 磁場就越強",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.18,
    "end": 55.48,
    "speaker": "曉臻",
    "text": "距離越遠 磁場就越弱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.68,
    "end": 60.54,
    "speaker": "彥君",
    "text": "沒錯 就像 離熱源越遠越冷",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.74,
    "end": 72.31,
    "speaker": "彥君",
    "text": "$B \\propto \\frac{I}{r}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 66.15,
    "end": 69.11,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘記住",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.31,
    "end": 75.32,
    "speaker": "曉臻",
    "text": "老師 方向要怎麼看",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.52,
    "end": 78.72,
    "speaker": "彥君",
    "text": "記住 補教天王的口訣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.92,
    "end": 82.53,
    "speaker": "彥君",
    "text": "直的給拇指 彎的給四指",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.73,
    "end": 86.26,
    "speaker": "曉臻",
    "text": "喔 長直導線 是直的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.46,
    "end": 89.42,
    "speaker": "曉臻",
    "text": "所以 大拇指就是電流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.62,
    "end": 93.83,
    "speaker": "彥君",
    "text": "漂亮 那四根手指",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.03,
    "end": 97.81,
    "speaker": "彥君",
    "text": "繞圈圈的方向 就是磁場",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.01,
    "end": 131.45,
    "speaker": "彥君",
    "text": "$\\text{直導線} \\rightarrow \\text{拇指 } I, \\text{ 四指 } B$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 103.28,
    "end": 106.24,
    "speaker": "曉臻",
    "text": "那如果是 捲起來的線圈",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.44,
    "end": 109.59,
    "speaker": "彥君",
    "text": "現在 電流在繞圈圈了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.79,
    "end": 113.11,
    "speaker": "彥君",
    "text": "所以 四根手指是電流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.31,
    "end": 116.34,
    "speaker": "曉臻",
    "text": "喔 那大拇指",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.54,
    "end": 119.53,
    "speaker": "曉臻",
    "text": "指向的地方 就是北極",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.73,
    "end": 131.45,
    "speaker": "彥君",
    "text": "$\\text{線圈} \\rightarrow \\text{四指 } I, \\text{ 拇指 } N$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 125.07,
    "end": 128.25,
    "speaker": "彥君",
    "text": "戰士們 換個手勢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.45,
    "end": 134.41,
    "speaker": "曉臻",
    "text": "老師 電磁鐵裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.61,
    "end": 137.3,
    "speaker": "曉臻",
    "text": "為什麼要 塞一根鐵釘",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.5,
    "end": 140.44,
    "speaker": "彥君",
    "text": "為了 讓磁力瞬間爆發",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.64,
    "end": 144.1,
    "speaker": "彥君",
    "text": "記住 這裡有大陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.3,
    "end": 147.77,
    "speaker": "彥君",
    "text": "只有 鐵、 鈷、 鎳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.97,
    "end": 151.29,
    "speaker": "彥君",
    "text": "塞進去 才有磁化效果",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.49,
    "end": 154.38,
    "speaker": "曉臻",
    "text": "老師 那如果我塞",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.58,
    "end": 157.54,
    "speaker": "曉臻",
    "text": "鋁罐 或是塑膠吸管呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.74,
    "end": 161.73,
    "speaker": "彥君",
    "text": "嗶嗶 門都沒有",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.93,
    "end": 165.06,
    "speaker": "彥君",
    "text": "放入 鐵鈷鎳以外的東西",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.26,
    "end": 168.41,
    "speaker": "彥君",
    "text": "磁力 完全不會變強",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.61,
    "end": 171.98,
    "speaker": "彥君",
    "text": "那 簡直等於「沒有放」",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 172.18,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{非鐵鈷鎳} \\rightarrow \\text{等於沒放}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 177.62,
    "end": 181.39,
    "speaker": "曉臻",
    "text": "哇 原來不能 亂塞東西",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.59,
    "end": 184.34,
    "speaker": "曉臻",
    "text": "只有 鐵、 鈷、 鎳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 184.54,
    "end": 187.16,
    "speaker": "曉臻",
    "text": "才是 電磁鐵的真心",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 187.36,
    "end": 192.6,
    "speaker": "彥君",
    "text": "沒錯 觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 192.8,
    "end": 195.4,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 195.6,
    "end": 197.94,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 198.14,
    "end": 201.36,
    "speaker": "合聲",
    "text": "鐵鈷鎳心 磁力倍增",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 201.56,
    "end": 205.1,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
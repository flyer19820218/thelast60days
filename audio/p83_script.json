    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.35,
    "speaker": "彥君",
    "text": "今天來到 第八十三集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.55,
    "end": 16.29,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.49,
    "end": 18.82,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.02,
    "end": 21.62,
    "speaker": "曉臻",
    "text": "老師 這張圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.82,
    "end": 24.35,
    "speaker": "曉臻",
    "text": "階梯 爬來爬去的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.55,
    "end": 26.86,
    "speaker": "曉臻",
    "text": "是什麼 意思啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.06,
    "end": 30.12,
    "speaker": "彥君",
    "text": "戰士們， 注意看！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.32,
    "end": 32.66,
    "speaker": "彥君",
    "text": "這是物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.86,
    "end": 35.72,
    "speaker": "彥君",
    "text": "加熱時的 溫度變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.92,
    "end": 38.23,
    "speaker": "彥君",
    "text": "仔細看圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.43,
    "end": 41.25,
    "speaker": "彥君",
    "text": "有兩段 平平的線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.45,
    "end": 44.53,
    "speaker": "曉臻",
    "text": "對耶 為什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.73,
    "end": 47.23,
    "speaker": "曉臻",
    "text": "明明一直 在加熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.43,
    "end": 49.89,
    "speaker": "曉臻",
    "text": "溫度卻 停住了呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.09,
    "end": 52.88,
    "speaker": "彥君",
    "text": "這就是 必考重點！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.08,
    "end": 55.75,
    "speaker": "彥君",
    "text": "因為 吸進來的熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 55.95,
    "end": 58.67,
    "speaker": "彥君",
    "text": "拿去 改變狀態了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.87,
    "end": 61.42,
    "speaker": "彥君",
    "text": "沒有拿去 升溫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.62,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{狀態改變} \\rightarrow \\text{溫度不變}",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 65.72,
    "end": 67.7,
    "speaker": "曉臻",
    "text": "改變狀態",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.9,
    "end": 70.66,
    "speaker": "曉臻",
    "text": "是指 融化跟沸騰嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.86,
    "end": 75.43,
    "speaker": "彥君",
    "text": "沒錯 像第一段平線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.63,
    "end": 78.64,
    "speaker": "彥君",
    "text": "冰塊 正在變成水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.84,
    "end": 81.97,
    "speaker": "彥君",
    "text": "這時候 是固液共存",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.17,
    "end": 84.62,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.82,
    "end": 87.62,
    "speaker": "彥君",
    "text": "經典會考題 來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.82,
    "end": 90.3,
    "speaker": "彥君",
    "text": "一杯水 裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.5,
    "end": 93.17,
    "speaker": "彥君",
    "text": "如果 浮著冰塊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.37,
    "end": 96.09,
    "speaker": "彥君",
    "text": "請問 是幾度Ｃ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.29,
    "end": 98.29,
    "speaker": "曉臻",
    "text": "浮著冰塊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.49,
    "end": 101.11,
    "speaker": "曉臻",
    "text": "那就是 固液共存啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.31,
    "end": 103.89,
    "speaker": "曉臻",
    "text": "所以 絕對是零度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.09,
    "end": 106.47,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.67,
    "end": 109.44,
    "speaker": "彥君",
    "text": "只要 還有冰塊在",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.64,
    "end": 112.41,
    "speaker": "彥君",
    "text": "溫度 永遠是零度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.61,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{冰水共存} \\rightarrow 0^{\\circ}\\text{C}",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 116.51,
    "end": 119.5,
    "speaker": "曉臻",
    "text": "哇 這個陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.7,
    "end": 122.15,
    "speaker": "曉臻",
    "text": "真的 很容易被騙",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.35,
    "end": 125.07,
    "speaker": "曉臻",
    "text": "那上面 第二段平線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.27,
    "end": 127.82,
    "speaker": "曉臻",
    "text": "就是 一百度沸騰囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.02,
    "end": 132.21,
    "speaker": "彥君",
    "text": "對 那是 液氣共存",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 132.41,
    "end": 135.49,
    "speaker": "彥君",
    "text": "水 正在變成水蒸氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.69,
    "end": 138.62,
    "speaker": "曉臻",
    "text": "老師 左邊還有寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.82,
    "end": 141.4,
    "speaker": "曉臻",
    "text": "純物質 和混合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.6,
    "end": 144.03,
    "speaker": "曉臻",
    "text": "這要 怎麼看出來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.23,
    "end": 146.76,
    "speaker": "彥君",
    "text": "找平線 就對了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.96,
    "end": 149.51,
    "speaker": "彥君",
    "text": "只有 純物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.71,
    "end": 152.58,
    "speaker": "彥君",
    "text": "才有 固定的熔點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.78,
    "end": 155.57,
    "speaker": "彥君",
    "text": "還有 固定的沸點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.77,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{純物質} \\rightarrow \\text{固定熔沸點}",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 159.72,
    "end": 163.16,
    "speaker": "曉臻",
    "text": "喔 如果是混合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 163.36,
    "end": 166.01,
    "speaker": "曉臻",
    "text": "線就會 歪歪斜斜的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 166.21,
    "end": 168.66,
    "speaker": "彥君",
    "text": "助教 一百分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.86,
    "end": 172.3,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 172.5,
    "end": 175.1,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.3,
    "end": 177.64,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.84,
    "end": 181.26,
    "speaker": "合聲",
    "text": "狀態改變 溫度不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.46,
    "end": 184.99,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }

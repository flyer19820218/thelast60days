[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.33,
    "speaker": "彥君",
    "text": "今天來到 第八十二集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.53,
    "end": 16.26,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.46,
    "end": 18.8,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.0,
    "end": 21.46,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.66,
    "end": 24.76,
    "speaker": "彥君",
    "text": "這集是 送分題單元！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.96,
    "end": 26.7,
    "speaker": "曉臻",
    "text": "太棒了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.9,
    "end": 29.76,
    "speaker": "曉臻",
    "text": "老師 第一個問題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.96,
    "end": 32.58,
    "speaker": "曉臻",
    "text": "為什麼 會看到東西",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.78,
    "end": 36.03,
    "speaker": "彥君",
    "text": "很簡單 因為光線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.23,
    "end": 39.1,
    "speaker": "彥君",
    "text": "打在 你的視網膜上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.3,
    "end": 41.32,
    "speaker": "曉臻",
    "text": "原來如此",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.52,
    "end": 44.24,
    "speaker": "曉臻",
    "text": "難怪 關燈就看不見",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.44,
    "end": 47.42,
    "speaker": "彥君",
    "text": "接著看 顏色的秘密",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.62,
    "end": 50.61,
    "speaker": "彥君",
    "text": "白色 反射所有的光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.81,
    "end": 54.06,
    "speaker": "彥君",
    "text": "所以 夏天穿白衣服",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.26,
    "end": 56.98,
    "speaker": "彥君",
    "text": "比較 不容易吸熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.18,
    "end": 60.78,
    "speaker": "曉臻",
    "text": "喔 那黑色 相反對吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.98,
    "end": 63.68,
    "speaker": "曉臻",
    "text": "黑色 吸收所有的光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.88,
    "end": 66.29,
    "speaker": "曉臻",
    "text": "所以 容易吸熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.49,
    "end": 68.66,
    "speaker": "曉臻",
    "text": "也容易 散熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.86,
    "end": 73.14,
    "speaker": "彥君",
    "text": "沒錯 觀念很清楚",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.34,
    "end": 76.22,
    "speaker": "曉臻",
    "text": "老師 那最下面的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 76.42,
    "end": 79.31,
    "speaker": "曉臻",
    "text": "RGB 是什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.51,
    "end": 82.33,
    "speaker": "彥君",
    "text": "那是 光的三原色",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.53,
    "end": 86.09,
    "speaker": "彥君",
    "text": "紅、 綠、 藍三種光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.29,
    "end": 89.22,
    "speaker": "彥君",
    "text": "它們三個 加在一起",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.42,
    "end": 92.29,
    "speaker": "彥君",
    "text": "就會變成 白色的光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.49,
    "end": 96.1,
    "speaker": "曉臻",
    "text": "哇 跟水彩 不一樣耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.3,
    "end": 98.92,
    "speaker": "曉臻",
    "text": "水彩是 越加越黑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.12,
    "end": 102.7,
    "speaker": "彥君",
    "text": "沒錯 光是越加越亮",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.9,
    "end": 105.36,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.56,
    "end": 108.52,
    "speaker": "彥君",
    "text": "剛剛學完 顏色與光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.72,
    "end": 111.92,
    "speaker": "彥君",
    "text": "我們立刻來 隨堂測驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.12,
    "end": 115.32,
    "speaker": "曉臻",
    "text": "哇 隨堂測驗",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.52,
    "end": 117.59,
    "speaker": "曉臻",
    "text": "我準備好了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.79,
    "end": 120.18,
    "speaker": "彥君",
    "text": "想像一下",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.38,
    "end": 122.88,
    "speaker": "彥君",
    "text": "老師穿了一雙",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 123.08,
    "end": 126.06,
    "speaker": "彥君",
    "text": "超帥的 紅色球鞋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.26,
    "end": 128.38,
    "speaker": "彥君",
    "text": "第一題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.58,
    "end": 131.52,
    "speaker": "彥君",
    "text": "用白光 照這雙鞋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.72,
    "end": 134.3,
    "speaker": "彥君",
    "text": "它是 什麼顏色",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.5,
    "end": 136.47,
    "speaker": "曉臻",
    "text": "白光裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.67,
    "end": 138.86,
    "speaker": "曉臻",
    "text": "什麼光 都有",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.06,
    "end": 141.21,
    "speaker": "曉臻",
    "text": "紅色球鞋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.41,
    "end": 143.77,
    "speaker": "曉臻",
    "text": "只會反射 紅光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.97,
    "end": 146.76,
    "speaker": "曉臻",
    "text": "所以 看起來是紅色",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.96,
    "end": 149.03,
    "speaker": "彥君",
    "text": "答對了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.23,
    "end": 151.5,
    "speaker": "彥君",
    "text": "那第二題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.7,
    "end": 154.44,
    "speaker": "彥君",
    "text": "如果用 純紅光照呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.64,
    "end": 157.12,
    "speaker": "曉臻",
    "text": "當然 還是紅色啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.32,
    "end": 160.23,
    "speaker": "曉臻",
    "text": "它最喜歡 反射紅光了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.43,
    "end": 164.33,
    "speaker": "彥君",
    "text": "很好 第三題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.53,
    "end": 167.39,
    "speaker": "彥君",
    "text": "換成 純藍光 照射呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 167.59,
    "end": 169.74,
    "speaker": "曉臻",
    "text": "紅色球鞋",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 169.94,
    "end": 172.18,
    "speaker": "曉臻",
    "text": "不會反射 藍光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 172.38,
    "end": 175.07,
    "speaker": "曉臻",
    "text": "所以 藍光被吸收了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 175.27,
    "end": 177.82,
    "speaker": "曉臻",
    "text": "沒有光 反射出來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 178.02,
    "end": 180.6,
    "speaker": "曉臻",
    "text": "看起來 就是黑色",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 180.8,
    "end": 183.18,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 183.38,
    "end": 185.72,
    "speaker": "彥君",
    "text": "那第四題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.92,
    "end": 188.78,
    "speaker": "彥君",
    "text": "換成 純綠光 照射呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 188.98,
    "end": 191.13,
    "speaker": "曉臻",
    "text": "跟藍光 一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 191.33,
    "end": 193.83,
    "speaker": "曉臻",
    "text": "綠光 也會被吸收",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 194.03,
    "end": 196.44,
    "speaker": "曉臻",
    "text": "所以 還是黑色",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 196.64,
    "end": 199.84,
    "speaker": "彥君",
    "text": "戰士們， 陷阱來了！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 200.04,
    "end": 203.55,
    "speaker": "彥君",
    "text": "第五題 終極魔王題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 203.75,
    "end": 206.52,
    "speaker": "彥君",
    "text": "如果用 黃光照射呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 206.72,
    "end": 208.31,
    "speaker": "曉臻",
    "text": "黃光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 208.51,
    "end": 211.38,
    "speaker": "曉臻",
    "text": "吸收黃光 變黑色嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 211.58,
    "end": 215.57,
    "speaker": "彥君",
    "text": "錯 仔細回想",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 215.77,
    "end": 218.44,
    "speaker": "彥君",
    "text": "黃光 是怎麼來的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 218.64,
    "end": 221.79,
    "speaker": "曉臻",
    "text": "啊 我想起來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 221.99,
    "end": 224.21,
    "speaker": "曉臻",
    "text": "光的三原色",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 224.41,
    "end": 226.79,
    "speaker": "曉臻",
    "text": "紅光 加上綠光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 226.99,
    "end": 229.33,
    "speaker": "曉臻",
    "text": "就會變成 黃光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 229.53,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "\\text{紅光} + \\text{綠光} \\rightarrow \\text{黃光}",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 235.16,
    "end": 238.0,
    "speaker": "彥君",
    "text": "所以 黃光裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 238.2,
    "end": 240.87,
    "speaker": "彥君",
    "text": "其實 藏著紅光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 241.07,
    "end": 242.76,
    "speaker": "曉臻",
    "text": "我懂了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 242.96,
    "end": 245.51,
    "speaker": "曉臻",
    "text": "球鞋 會吸收綠光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 245.71,
    "end": 248.02,
    "speaker": "曉臻",
    "text": "但是 會把紅光",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 248.22,
    "end": 250.39,
    "speaker": "曉臻",
    "text": "給 反射出來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 250.59,
    "end": 253.07,
    "speaker": "曉臻",
    "text": "所以 在黃光下",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 253.27,
    "end": 255.94,
    "speaker": "曉臻",
    "text": "球鞋 還是紅色的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 256.14,
    "end": 258.7,
    "speaker": "彥君",
    "text": "助教 太聰明了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 258.9,
    "end": 261.98,
    "speaker": "彥君",
    "text": "只要破解 黃光的秘密",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 262.18,
    "end": 264.99,
    "speaker": "彥君",
    "text": "會考 絕對拿滿分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 265.19,
    "end": 267.79,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 267.99,
    "end": 270.33,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 270.53,
    "end": 274.02,
    "speaker": "合聲",
    "text": "黃光藏紅 遇紅則紅",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 274.22,
    "end": 277.75,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.3,
    "end": 8.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.1,
    "end": 10.83,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.03,
    "end": 13.37,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.57,
    "end": 16.02,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.22,
    "end": 18.9,
    "speaker": "彥君",
    "text": "牛一 大魔王來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.1,
    "end": 21.98,
    "speaker": "曉臻",
    "text": "老師 上面的圖形",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.18,
    "end": 24.76,
    "speaker": "曉臻",
    "text": "怎麼 都有兩條線啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.96,
    "end": 28.06,
    "speaker": "彥君",
    "text": "助教 觀察非常敏銳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.26,
    "end": 31.03,
    "speaker": "彥君",
    "text": "因為 牛頓第一定律",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.23,
    "end": 34.07,
    "speaker": "彥君",
    "text": "包含了 兩種狀態",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.27,
    "end": 37.76,
    "speaker": "彥君",
    "text": "動者恆動 靜者恆靜",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.96,
    "end": 79.8,
    "speaker": "彥君",
    "text": "$\\text{牛一} \\rightarrow \\text{等速或靜止}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 42.54,
    "end": 46.02,
    "speaker": "曉臻",
    "text": "喔 所以位置圖裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.22,
    "end": 48.92,
    "speaker": "曉臻",
    "text": "藍色的平線 是靜止",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.12,
    "end": 52.01,
    "speaker": "曉臻",
    "text": "紅色的斜線 是等速度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.21,
    "end": 56.68,
    "speaker": "彥君",
    "text": "完全正確 換速度圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.88,
    "end": 59.41,
    "speaker": "曉臻",
    "text": "速度圖的 藍色線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.61,
    "end": 62.62,
    "speaker": "曉臻",
    "text": "貼在地板 代表靜止",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 62.82,
    "end": 65.97,
    "speaker": "曉臻",
    "text": "紅色平線 則是等速",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.17,
    "end": 70.52,
    "speaker": "彥君",
    "text": "沒錯 那藍色的面積",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.72,
    "end": 73.46,
    "speaker": "彥君",
    "text": "代表的 就是位移",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.66,
    "end": 76.6,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘對照",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 79.8,
    "end": 83.0,
    "speaker": "彥君",
    "text": "戰士們 陷阱來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.2,
    "end": 86.16,
    "speaker": "彥君",
    "text": "為什麼 最右邊的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.36,
    "end": 89.54,
    "speaker": "彥君",
    "text": "加速度 只剩下一條線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.74,
    "end": 92.19,
    "speaker": "曉臻",
    "text": "因為 不管是靜止",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.39,
    "end": 94.9,
    "speaker": "曉臻",
    "text": "還是 等速度運動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.1,
    "end": 97.62,
    "speaker": "曉臻",
    "text": "速度 都沒有改變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.82,
    "end": 101.94,
    "speaker": "彥君",
    "text": "答對了 速度不變",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.14,
    "end": 105.19,
    "speaker": "彥君",
    "text": "加速度 當然等於 0",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.39,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\Delta V = 0 \\rightarrow a = 0$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 109.9,
    "end": 112.88,
    "speaker": "彥君",
    "text": "而且 速度沒有變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.08,
    "end": 115.87,
    "speaker": "彥君",
    "text": "外力作功 也是 0 喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.07,
    "end": 119.51,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 119.71,
    "end": 122.31,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.51,
    "end": 124.85,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.05,
    "end": 128.49,
    "speaker": "合聲",
    "text": "動靜兩態 三圖秒解",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.69,
    "end": 132.22,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }

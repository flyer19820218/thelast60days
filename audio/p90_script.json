[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.11,
    "speaker": "彥君",
    "text": "今天來到 第九十集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.31,
    "end": 16.05,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.25,
    "end": 18.58,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.78,
    "end": 21.24,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.44,
    "end": 24.52,
    "speaker": "彥君",
    "text": "右邊 這個活性表格",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.72,
    "end": 27.46,
    "speaker": "彥君",
    "text": "必須 倒背如流",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.66,
    "end": 30.86,
    "speaker": "曉臻",
    "text": "老師 上面好多空格",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.06,
    "end": 34.14,
    "speaker": "彥君",
    "text": "我們現在 就來填滿它",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.34,
    "end": 37.35,
    "speaker": "曉臻",
    "text": "第一排 鉀鈉鈣鎂鋁",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.55,
    "end": 64.57,
    "speaker": "彥君",
    "text": "$K > Na > Ca > Mg > Al$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 41.05,
    "end": 44.27,
    "speaker": "曉臻",
    "text": "第二排 碳鋅鐵錫鉛氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 44.47,
    "end": 64.57,
    "speaker": "彥君",
    "text": "$C > Zn > Cr > Fe > Sn > Pb > H$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 48.4,
    "end": 51.36,
    "speaker": "曉臻",
    "text": "第三排 銅汞銀鉑金",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.56,
    "end": 64.57,
    "speaker": "彥君",
    "text": "$Cu > Hg > Ag > Pt > Au$",
    "is_pinned": true,
    "pin_level": 3
  },
  {
    "start": 55.15,
    "end": 57.94,
    "speaker": "彥君",
    "text": "助教 背得非常熟",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.14,
    "end": 61.37,
    "speaker": "彥君",
    "text": "戰士們 快抄起來",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.57,
    "end": 67.58,
    "speaker": "彥君",
    "text": "接著 來看左邊重點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.78,
    "end": 70.18,
    "speaker": "彥君",
    "text": "什麼是 氧化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 70.38,
    "end": 72.48,
    "speaker": "曉臻",
    "text": "就是 得到氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.68,
    "end": 75.04,
    "speaker": "曉臻",
    "text": "或是 失去電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.24,
    "end": 79.95,
    "speaker": "彥君",
    "text": "沒錯 那還原 剛好相反",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.15,
    "end": 82.56,
    "speaker": "曉臻",
    "text": "還原 是失去氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.76,
    "end": 85.07,
    "speaker": "曉臻",
    "text": "或是 得到電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 85.27,
    "end": 88.69,
    "speaker": "彥君",
    "text": "記住 氧化跟還原",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.89,
    "end": 91.49,
    "speaker": "彥君",
    "text": "一定會 一起發生",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.69,
    "end": 94.7,
    "speaker": "彥君",
    "text": "我們看 下面的方程式",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.9,
    "end": 97.83,
    "speaker": "彥君",
    "text": "鎂 加上二氧化碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.03,
    "end": 100.54,
    "speaker": "曉臻",
    "text": "鎂 變成了氧化鎂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.74,
    "end": 103.19,
    "speaker": "曉臻",
    "text": "它 把氧搶過來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.39,
    "end": 106.33,
    "speaker": "彥君",
    "text": "所以 鎂發生了氧化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.53,
    "end": 108.62,
    "speaker": "曉臻",
    "text": "那 二氧化碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.82,
    "end": 111.4,
    "speaker": "曉臻",
    "text": "失去氧 變成了碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.6,
    "end": 114.01,
    "speaker": "曉臻",
    "text": "就是 發生還原",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.21,
    "end": 116.59,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 116.79,
    "end": 119.85,
    "speaker": "彥君",
    "text": "為什麼 鎂可以搶走氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.05,
    "end": 122.26,
    "speaker": "曉臻",
    "text": "因為 鎂的活性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.46,
    "end": 124.61,
    "speaker": "曉臻",
    "text": "比碳 還要大",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.81,
    "end": 128.13,
    "speaker": "彥君",
    "text": "戰士們 隨堂考來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.33,
    "end": 131.24,
    "speaker": "彥君",
    "text": "如果 把鎂換成銅",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.44,
    "end": 134.16,
    "speaker": "彥君",
    "text": "丟進 二氧化碳裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.36,
    "end": 136.84,
    "speaker": "彥君",
    "text": "會發生 反應嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.04,
    "end": 138.78,
    "speaker": "曉臻",
    "text": "我想想...",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 138.98,
    "end": 141.48,
    "speaker": "曉臻",
    "text": "銅的活性 比碳小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.68,
    "end": 144.06,
    "speaker": "曉臻",
    "text": "所以 搶不走氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.26,
    "end": 148.57,
    "speaker": "彥君",
    "text": "答對了 完全不反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.77,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$Cu + CO_2 \\rightarrow \\text{不反應}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 152.89,
    "end": 156.52,
    "speaker": "曉臻",
    "text": "哇 這樣觀念 超清楚",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.72,
    "end": 160.16,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.36,
    "end": 162.96,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 163.16,
    "end": 165.5,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.7,
    "end": 169.11,
    "speaker": "合聲",
    "text": "搶氧大戰 活性來判",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 169.31,
    "end": 172.85,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
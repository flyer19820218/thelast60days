[
  {
    "start": 0.0,
    "end": 3.12,
    "speaker": "彥君",
    "text": "各位衝A的戰士們"
  },
  {
    "start": 3.12,
    "end": 6.02,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 6.02,
    "end": 8.82,
    "speaker": "曉臻",
    "text": "戰士們大家好啊"
  },
  {
    "start": 8.82,
    "end": 11.46,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 11.46,
    "end": 14.74,
    "speaker": "彥君",
    "text": "翻開二十七頁講義"
  },
  {
    "start": 14.74,
    "end": 17.42,
    "speaker": "彥君",
    "text": "這是動物界"
  },
  {
    "start": 17.42,
    "end": 20.32,
    "speaker": "彥君",
    "text": "最終的大決戰喔"
  },
  {
    "start": 20.32,
    "end": 23.27,
    "speaker": "彥君",
    "text": "格子多不要慌張"
  },
  {
    "start": 23.27,
    "end": 26.12,
    "speaker": "彥君",
    "text": "快拿起你的筆"
  },
  {
    "start": 26.12,
    "end": 29.24,
    "speaker": "彥君",
    "text": "一起填寫英雄榜"
  },
  {
    "start": 29.24,
    "end": 32.21,
    "speaker": "曉臻",
    "text": "老師資訊太多了啦"
  },
  {
    "start": 32.21,
    "end": 34.9,
    "speaker": "曉臻",
    "text": "光是寫『硬骨魚』"
  },
  {
    "start": 34.9,
    "end": 37.77,
    "speaker": "曉臻",
    "text": "學生手就要斷了"
  },
  {
    "start": 37.77,
    "end": 41.01,
    "speaker": "彥君",
    "text": "沒關係我們慢一點"
  },
  {
    "start": 41.01,
    "end": 43.79,
    "speaker": "彥君",
    "text": "第一列看過來喔"
  },
  {
    "start": 43.79,
    "end": 47.36,
    "speaker": "彥君",
    "text": "『硬骨魚』與『軟骨魚』"
  },
  {
    "start": 47.36,
    "end": 50.33,
    "speaker": "彥君",
    "text": "呼吸都是用鰓"
  },
  {
    "start": 50.33,
    "end": 53.11,
    "speaker": "彥君",
    "text": "多為體外受精"
  },
  {
    "start": 53.11,
    "end": 56.32,
    "speaker": "彥君",
    "text": "卵生且是變溫的"
  },
  {
    "start": 56.32,
    "end": 59.01,
    "speaker": "曉臻",
    "text": "硬骨魚有鰓蓋喔"
  },
  {
    "start": 59.01,
    "end": 61.86,
    "speaker": "曉臻",
    "text": "老師我請問一下"
  },
  {
    "start": 61.86,
    "end": 64.86,
    "speaker": "曉臻",
    "text": "軟骨魚代表是鯊魚"
  },
  {
    "start": 64.86,
    "end": 68.21,
    "speaker": "彥君",
    "text": "沒錯鯊魚很特別"
  },
  {
    "start": 68.21,
    "end": 71.38,
    "speaker": "彥君",
    "text": "有些還是卵胎生喔"
  },
  {
    "start": 71.38,
    "end": 74.49,
    "speaker": "彥君",
    "text": "鰓裂與體外受精"
  },
  {
    "start": 74.49,
    "end": 77.44,
    "speaker": "彥君",
    "text": "還有變溫動物"
  },
  {
    "start": 77.44,
    "end": 80.12,
    "speaker": "曉臻",
    "text": "大家字寫快一點"
  },
  {
    "start": 80.12,
    "end": 82.98,
    "speaker": "曉臻",
    "text": "鯊魚正在看你喔"
  },
  {
    "start": 82.98,
    "end": 85.88,
    "speaker": "彥君",
    "text": "接著看第二列"
  },
  {
    "start": 85.88,
    "end": 89.04,
    "speaker": "彥君",
    "text": "『兩生類』代表青蛙"
  },
  {
    "start": 89.04,
    "end": 92.37,
    "speaker": "彥君",
    "text": "小時候用鰓呼吸"
  },
  {
    "start": 92.37,
    "end": 95.49,
    "speaker": "彥君",
    "text": "長大用肺和皮膚"
  },
  {
    "start": 95.49,
    "end": 98.56,
    "speaker": "彥君",
    "text": "因為沒脫離水域"
  },
  {
    "start": 98.56,
    "end": 101.72,
    "speaker": "彥君",
    "text": "所以是體外受精"
  },
  {
    "start": 101.72,
    "end": 104.55,
    "speaker": "彥君",
    "text": "一樣是變溫的喔"
  },
  {
    "start": 104.55,
    "end": 107.33,
    "speaker": "曉臻",
    "text": "記得寫肺和皮膚"
  },
  {
    "start": 107.33,
    "end": 110.2,
    "speaker": "曉臻",
    "text": "青蛙皮膚要保濕"
  },
  {
    "start": 110.2,
    "end": 112.98,
    "speaker": "曉臻",
    "text": "才能順利的呼吸"
  },
  {
    "start": 112.98,
    "end": 115.86,
    "speaker": "曉臻",
    "text": "不能離開水太遠喔"
  },
  {
    "start": 115.86,
    "end": 118.66,
    "speaker": "彥君",
    "text": "大家都寫完了嗎"
  },
  {
    "start": 118.66,
    "end": 121.37,
    "speaker": "彥君",
    "text": "我們要登陸了"
  },
  {
    "start": 121.37,
    "end": 124.56,
    "speaker": "彥君",
    "text": "真正的『爬蟲類』了"
  },
  {
    "start": 124.56,
    "end": 127.8,
    "speaker": "彥君",
    "text": "呼吸完全改用肺"
  },
  {
    "start": 127.8,
    "end": 130.91,
    "speaker": "彥君",
    "text": "因為在陸地生活"
  },
  {
    "start": 130.91,
    "end": 133.98,
    "speaker": "彥君",
    "text": "變成體內受精了"
  },
  {
    "start": 133.98,
    "end": 136.98,
    "speaker": "彥君",
    "text": "保護卵不乾掉"
  },
  {
    "start": 136.98,
    "end": 140.02,
    "speaker": "彥君",
    "text": "產下有殼的卵喔"
  },
  {
    "start": 140.02,
    "end": 142.68,
    "speaker": "曉臻",
    "text": "老師我問一下"
  },
  {
    "start": 142.68,
    "end": 145.63,
    "speaker": "曉臻",
    "text": "烏龜跟蛇也是變溫"
  },
  {
    "start": 145.63,
    "end": 148.82,
    "speaker": "彥君",
    "text": "是的所以要冬眠喔"
  },
  {
    "start": 148.82,
    "end": 151.72,
    "speaker": "彥君",
    "text": "肺和體內受精"
  },
  {
    "start": 151.72,
    "end": 154.76,
    "speaker": "彥君",
    "text": "有殼卵以及變溫"
  },
  {
    "start": 154.76,
    "end": 157.52,
    "speaker": "曉臻",
    "text": "這格內容比較多"
  },
  {
    "start": 157.52,
    "end": 160.27,
    "speaker": "曉臻",
    "text": "大家可以慢慢寫"
  },
  {
    "start": 160.27,
    "end": 163.0,
    "speaker": "曉臻",
    "text": "我們稍微等一下"
  },
  {
    "start": 163.0,
    "end": 166.17,
    "speaker": "彥君",
    "text": "下一列是『鳥類』了"
  },
  {
    "start": 166.17,
    "end": 169.72,
    "speaker": "彥君",
    "text": "那就是厲害的『氣囊』"
  },
  {
    "start": 169.72,
    "end": 173.05,
    "speaker": "彥君",
    "text": "飛翔時補足氧氣"
  },
  {
    "start": 173.05,
    "end": 176.28,
    "speaker": "彥君",
    "text": "體內受精有殼卵"
  },
  {
    "start": 176.28,
    "end": 179.52,
    "speaker": "彥君",
    "text": "重點是鳥類開始"
  },
  {
    "start": 179.52,
    "end": 182.56,
    "speaker": "彥君",
    "text": "變成恆溫動物了"
  },
  {
    "start": 182.56,
    "end": 185.37,
    "speaker": "曉臻",
    "text": "戰士們注意小字"
  },
  {
    "start": 185.37,
    "end": 188.15,
    "speaker": "曉臻",
    "text": "企鵝與骨骼中空"
  },
  {
    "start": 188.15,
    "end": 190.9,
    "speaker": "曉臻",
    "text": "『氣囊』還有瞬膜"
  },
  {
    "start": 190.9,
    "end": 193.9,
    "speaker": "曉臻",
    "text": "都是適應環境特徵"
  },
  {
    "start": 193.9,
    "end": 196.73,
    "speaker": "曉臻",
    "text": "記得把它圈起來"
  },
  {
    "start": 196.73,
    "end": 199.68,
    "speaker": "彥君",
    "text": "最後一個壓軸"
  },
  {
    "start": 199.68,
    "end": 203.03,
    "speaker": "彥君",
    "text": "就是我們『哺乳類』"
  },
  {
    "start": 203.03,
    "end": 206.27,
    "speaker": "彥君",
    "text": "用肺呼吸體內受精"
  },
  {
    "start": 206.27,
    "end": 209.14,
    "speaker": "彥君",
    "text": "最特別是胎生"
  },
  {
    "start": 209.14,
    "end": 211.9,
    "speaker": "彥君",
    "text": "還有會哺乳喔"
  },
  {
    "start": 211.9,
    "end": 215.02,
    "speaker": "彥君",
    "text": "我們也是恆溫動物"
  },
  {
    "start": 215.02,
    "end": 217.99,
    "speaker": "曉臻",
    "text": "那蝙蝠還有鯨魚呢"
  },
  {
    "start": 217.99,
    "end": 220.53,
    "speaker": "曉臻",
    "text": "也是哺乳類嗎"
  },
  {
    "start": 220.53,
    "end": 223.76,
    "speaker": "彥君",
    "text": "沒錯會飛又會游"
  },
  {
    "start": 223.76,
    "end": 226.86,
    "speaker": "彥君",
    "text": "但只要牠們會餵奶"
  },
  {
    "start": 226.86,
    "end": 230.0,
    "speaker": "彥君",
    "text": "通通都是恆溫的"
  },
  {
    "start": 230.0,
    "end": 232.73,
    "speaker": "曉臻",
    "text": "表格填完之後"
  },
  {
    "start": 232.73,
    "end": 235.41,
    "speaker": "曉臻",
    "text": "脊椎動物的觀念"
  },
  {
    "start": 235.41,
    "end": 238.05,
    "speaker": "曉臻",
    "text": "絕對就無敵啦"
  },
  {
    "start": 238.05,
    "end": 240.95,
    "speaker": "曉臻",
    "text": "鰓變成肺與氣囊"
  },
  {
    "start": 240.95,
    "end": 243.78,
    "speaker": "曉臻",
    "text": "體外演變成體內"
  },
  {
    "start": 243.78,
    "end": 246.58,
    "speaker": "曉臻",
    "text": "變溫演化成恆溫"
  },
  {
    "start": 246.58,
    "end": 249.77,
    "speaker": "彥君",
    "text": "戰士們閉上眼睛"
  },
  {
    "start": 249.77,
    "end": 253.2,
    "speaker": "彥君",
    "text": "鯨魚一生住在水裡"
  },
  {
    "start": 253.2,
    "end": 256.46,
    "speaker": "彥君",
    "text": "用鰓還是用肺呼吸"
  },
  {
    "start": 256.46,
    "end": 259.38,
    "speaker": "曉臻",
    "text": "鯨魚可是哺乳類喔"
  },
  {
    "start": 259.38,
    "end": 262.35,
    "speaker": "曉臻",
    "text": "絕對是用肺呼吸的"
  },
  {
    "start": 262.35,
    "end": 265.44,
    "speaker": "曉臻",
    "text": "還要浮出水面換氣"
  },
  {
    "start": 265.44,
    "end": 268.42,
    "speaker": "彥君",
    "text": "漂亮完全正確喔"
  },
  {
    "start": 268.42,
    "end": 271.8,
    "speaker": "彥君",
    "text": "這是分類核心邏輯"
  },
  {
    "start": 271.8,
    "end": 274.7,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 274.7,
    "end": 277.33,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 277.33,
    "end": 280.3,
    "speaker": "曉臻",
    "text": "脊椎分清楚擋不住"
  },
  {
    "start": 280.3,
    "end": 283.06,
    "speaker": "曉臻",
    "text": "戰士們下一關見"
  }
]
[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.66,
    "speaker": "彥君",
    "text": "各位即將衝A的 會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.86,
    "end": 8.46,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.66,
    "end": 11.86,
    "speaker": "彥君",
    "text": "今天來到 第九十六集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.06,
    "end": 13.8,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.0,
    "end": 16.34,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.54,
    "end": 18.99,
    "speaker": "彥君",
    "text": "戰士們注意， ",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.19,
    "end": 22.27,
    "speaker": "彥君",
    "text": "有機化學 內容非常多",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.47,
    "end": 25.48,
    "speaker": "彥君",
    "text": "它是 會考超級熱區",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.68,
    "end": 28.45,
    "speaker": "曉臻",
    "text": "老師 講義第一行",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.65,
    "end": 31.06,
    "speaker": "曉臻",
    "text": "寫著 生命物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.26,
    "end": 34.14,
    "speaker": "彥君",
    "text": "早期 科學家認為",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.34,
    "end": 36.82,
    "speaker": "彥君",
    "text": "只有 生命體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.02,
    "end": 39.94,
    "speaker": "彥君",
    "text": "才能 製造有機物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.14,
    "end": 42.33,
    "speaker": "曉臻",
    "text": "那 後來怎麼了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.53,
    "end": 45.32,
    "speaker": "彥君",
    "text": "後來 有位科學家",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.52,
    "end": 47.74,
    "speaker": "彥君",
    "text": "叫做 烏拉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.94,
    "end": 50.75,
    "speaker": "彥君",
    "text": "他在 實驗室裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.95,
    "end": 53.77,
    "speaker": "彥君",
    "text": "意外 合成了尿素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.97,
    "end": 57.46,
    "speaker": "曉臻",
    "text": "哇 尿素是有機物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.66,
    "end": 60.78,
    "speaker": "曉臻",
    "text": "竟然 用人工合成出來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.98,
    "end": 65.26,
    "speaker": "彥君",
    "text": "沒錯 所以定義改了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.46,
    "end": 68.4,
    "speaker": "彥君",
    "text": "現在的 有機化合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.6,
    "end": 71.51,
    "speaker": "彥君",
    "text": "就是 含碳的化合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.71,
    "end": 74.5,
    "speaker": "曉臻",
    "text": "只要有碳 就是有機物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.7,
    "end": 77.9,
    "speaker": "彥君",
    "text": "戰士們， 陷阱來了！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.1,
    "end": 80.8,
    "speaker": "彥君",
    "text": "有幾個 叛徒例外",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.0,
    "end": 83.7,
    "speaker": "彥君",
    "text": "像是 一氧化碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.9,
    "end": 86.62,
    "speaker": "彥君",
    "text": "還有 二氧化碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.82,
    "end": 89.75,
    "speaker": "曉臻",
    "text": "還有 碳酸鹽類對不對",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.95,
    "end": 94.45,
    "speaker": "彥君",
    "text": "沒錯 這些雖然有碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.65,
    "end": 97.61,
    "speaker": "彥君",
    "text": "但它們 卻是無機物喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.81,
    "end": 108.55,
    "speaker": "彥君",
    "text": "有機物必含碳 但含碳不一定是有機物",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 105.55,
    "end": 108.54,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.74,
    "end": 112.06,
    "speaker": "曉臻",
    "text": "老師 接著看木材乾餾",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.26,
    "end": 115.24,
    "speaker": "曉臻",
    "text": "為什麼要 隔絕空氣加熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.44,
    "end": 118.38,
    "speaker": "彥君",
    "text": "如果 你直接燒木材",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.58,
    "end": 121.25,
    "speaker": "彥君",
    "text": "它就 變成灰燼了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.45,
    "end": 124.7,
    "speaker": "彥君",
    "text": "隔絕空氣 才能把它悶烤",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.9,
    "end": 127.71,
    "speaker": "彥君",
    "text": "逼出 裡面的成分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 127.91,
    "end": 130.8,
    "speaker": "曉臻",
    "text": "所以 這是化學變化嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.0,
    "end": 135.47,
    "speaker": "彥君",
    "text": "沒錯 產生了新物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.67,
    "end": 139.09,
    "speaker": "彥君",
    "text": "像是 焦油還有可燃氣體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.29,
    "end": 142.61,
    "speaker": "彥君",
    "text": "最後 剩下的黑色固體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.81,
    "end": 145.84,
    "speaker": "彥君",
    "text": "就能 檢驗出碳元素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.04,
    "end": 150.49,
    "speaker": "彥君",
    "text": "化學變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 150.69,
    "end": 152.93,
    "speaker": "曉臻",
    "text": "那 石油分餾呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.13,
    "end": 155.61,
    "speaker": "曉臻",
    "text": "也是 加熱分離耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.81,
    "end": 158.34,
    "speaker": "彥君",
    "text": "這裡 絕對必考",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 158.54,
    "end": 161.76,
    "speaker": "彥君",
    "text": "石油分餾 是物理變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.96,
    "end": 164.58,
    "speaker": "曉臻",
    "text": "為什麼 是物理變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.78,
    "end": 167.72,
    "speaker": "彥君",
    "text": "它是 利用沸點不同",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 167.92,
    "end": 171.22,
    "speaker": "彥君",
    "text": "沸點低的 變氣體往上跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.42,
    "end": 174.35,
    "speaker": "彥君",
    "text": "像是 瓦斯跟汽油",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 174.55,
    "end": 177.61,
    "speaker": "彥君",
    "text": "沸點高的 留在底下",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.81,
    "end": 180.14,
    "speaker": "彥君",
    "text": "像是 瀝青",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 180.34,
    "end": 183.93,
    "speaker": "曉臻",
    "text": "喔 只是把它們分開",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 184.13,
    "end": 186.68,
    "speaker": "曉臻",
    "text": "沒有 產生新物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 186.88,
    "end": 191.02,
    "speaker": "彥君",
    "text": "對 分出來的產物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 191.22,
    "end": 193.89,
    "speaker": "彥君",
    "text": "依然 是混合物喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 194.09,
    "end": 200.43,
    "speaker": "彥君",
    "text": "物理變化、混合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 200.63,
    "end": 203.62,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 203.82,
    "end": 206.7,
    "speaker": "曉臻",
    "text": "老師 種類好多喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 206.9,
    "end": 208.98,
    "speaker": "曉臻",
    "text": "烴醇酸酯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 209.18,
    "end": 211.18,
    "speaker": "曉臻",
    "text": "到底 怎麼分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 211.38,
    "end": 214.12,
    "speaker": "彥君",
    "text": "先看 第一個烴類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 214.32,
    "end": 216.9,
    "speaker": "彥君",
    "text": "烴 只有碳跟氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 217.1,
    "end": 220.3,
    "speaker": "彥君",
    "text": "像是 甲烷還有丙烷",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 220.5,
    "end": 223.36,
    "speaker": "曉臻",
    "text": "講義說 它們不溶於水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 223.56,
    "end": 228.03,
    "speaker": "彥君",
    "text": "沒錯 而且碳數越少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 228.23,
    "end": 230.59,
    "speaker": "彥君",
    "text": "它是 氣態的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 230.79,
    "end": 233.97,
    "speaker": "彥君",
    "text": "碳數越多 變液態跟固態",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 234.17,
    "end": 236.48,
    "speaker": "曉臻",
    "text": "第二個 是醇類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 236.68,
    "end": 239.71,
    "speaker": "曉臻",
    "text": "它有 OH 原子團耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 239.91,
    "end": 242.56,
    "speaker": "曉臻",
    "text": "那它 是不是鹼性啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 242.76,
    "end": 246.13,
    "speaker": "彥君",
    "text": "戰士們， 這是大陷阱！",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 246.33,
    "end": 249.14,
    "speaker": "彥君",
    "text": "醇類的 OH",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 249.34,
    "end": 253.77,
    "speaker": "彥君",
    "text": "不會解離 所以是中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 253.97,
    "end": 257.17,
    "speaker": "彥君",
    "text": "像是 酒精就是醇類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 257.37,
    "end": 260.04,
    "speaker": "彥君",
    "text": "它 可以溶於水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 260.24,
    "end": 262.94,
    "speaker": "曉臻",
    "text": "原來 酒精是中性的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 263.14,
    "end": 265.04,
    "speaker": "曉臻",
    "text": "那 酸類呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 265.24,
    "end": 269.02,
    "speaker": "彥君",
    "text": "酸類 有 COOH",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 269.22,
    "end": 271.62,
    "speaker": "彥君",
    "text": "像是 醋酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 271.82,
    "end": 274.78,
    "speaker": "彥君",
    "text": "溶於水 就是酸性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 274.98,
    "end": 285.01,
    "speaker": "彥君",
    "text": "烴、醇、酸",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 282.01,
    "end": 284.99,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫。",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 285.19,
    "end": 287.86,
    "speaker": "曉臻",
    "text": "最後 進入大魔王了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 288.06,
    "end": 290.52,
    "speaker": "曉臻",
    "text": "右邊的 酯化反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 290.72,
    "end": 293.39,
    "speaker": "彥君",
    "text": "這是 必考五顆星",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 293.59,
    "end": 296.6,
    "speaker": "彥君",
    "text": "有機酸 加上醇類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 296.8,
    "end": 299.9,
    "speaker": "彥君",
    "text": "會變成 酯類加上水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 300.1,
    "end": 373.86,
    "speaker": "彥君",
    "text": "有機酸 + 醇 → 酯 + 水",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 304.22,
    "end": 307.16,
    "speaker": "曉臻",
    "text": "箭頭上面 寫著硫酸耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 307.36,
    "end": 310.25,
    "speaker": "彥君",
    "text": "這裡 必須用濃硫酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 310.45,
    "end": 312.88,
    "speaker": "曉臻",
    "text": "為什麼 是濃硫酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 313.08,
    "end": 316.21,
    "speaker": "彥君",
    "text": "因為 濃硫酸可以脫水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 316.41,
    "end": 319.61,
    "speaker": "彥君",
    "text": "它可以 把產物的水吸走",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 319.81,
    "end": 323.1,
    "speaker": "彥君",
    "text": "讓反應 一直往右邊進行",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 323.3,
    "end": 328.45,
    "speaker": "彥君",
    "text": "它 也是催化劑伴演雙重角色",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 328.65,

[
  {
    "start": 0.0,
    "end": 1.98,
    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.66,
    "speaker": "彥君",
    "text": "各位即將衝A的 會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.86,
    "end": 8.46,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.66,
    "end": 11.86,
    "speaker": "彥君",
    "text": "今天來到 第九十六集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.06,
    "end": 13.8,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.0,
    "end": 16.34,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.54,
    "end": 18.99,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.19,
    "end": 22.27,
    "speaker": "彥君",
    "text": "有機化學 內容非常多",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.47,
    "end": 25.48,
    "speaker": "彥君",
    "text": "它是 會考超級熱區",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.68,
    "end": 28.45,
    "speaker": "曉臻",
    "text": "老師 講義第一行",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.65,
    "end": 31.06,
    "speaker": "曉臻",
    "text": "寫著 生命物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 31.26,
    "end": 34.14,
    "speaker": "彥君",
    "text": "早期 科學家認為",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.34,
    "end": 36.82,
    "speaker": "彥君",
    "text": "只有 生命體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.02,
    "end": 39.94,
    "speaker": "彥君",
    "text": "才能 製造有機物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.14,
    "end": 42.33,
    "speaker": "曉臻",
    "text": "那 後來怎麼了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 42.53,
    "end": 45.32,
    "speaker": "彥君",
    "text": "後來 有位科學家",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.52,
    "end": 47.74,
    "speaker": "彥君",
    "text": "叫做 烏拉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.94,
    "end": 50.75,
    "speaker": "彥君",
    "text": "他在 實驗室裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 50.95,
    "end": 53.77,
    "speaker": "彥君",
    "text": "意外 合成了尿素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.97,
    "end": 57.46,
    "speaker": "曉臻",
    "text": "哇 尿素是有機物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.66,
    "end": 60.78,
    "speaker": "曉臻",
    "text": "竟然 用人工合成出來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.98,
    "end": 65.26,
    "speaker": "彥君",
    "text": "沒錯 所以定義改了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.46,
    "end": 68.4,
    "speaker": "彥君",
    "text": "現在的 有機化合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.6,
    "end": 71.51,
    "speaker": "彥君",
    "text": "就是 含碳的化合物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.71,
    "end": 74.5,
    "speaker": "曉臻",
    "text": "只要有碳 就是有機物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.7,
    "end": 77.9,
    "speaker": "彥君",
    "text": "戰士們 陷阱來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.1,
    "end": 80.8,
    "speaker": "彥君",
    "text": "有幾個 叛徒例外",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.0,
    "end": 83.7,
    "speaker": "彥君",
    "text": "像是 一氧化碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.9,
    "end": 86.62,
    "speaker": "彥君",
    "text": "還有 二氧化碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.82,
    "end": 89.75,
    "speaker": "曉臻",
    "text": "還有 碳酸鹽類對不對",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 89.95,
    "end": 94.45,
    "speaker": "彥君",
    "text": "沒錯 這些雖然有碳",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.65,
    "end": 97.61,
    "speaker": "彥君",
    "text": "但它們 卻是無機物喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.81,
    "end": 108.9,
    "speaker": "彥君",
    "text": "有機物必含碳， 但含碳不一定是有機物",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 102.72,
    "end": 105.7,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.9,
    "end": 112.22,
    "speaker": "曉臻",
    "text": "老師 接著看木材乾餾",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.42,
    "end": 115.41,
    "speaker": "曉臻",
    "text": "為什麼要 隔絕空氣加熱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.61,
    "end": 118.54,
    "speaker": "彥君",
    "text": "如果 你直接燒木材",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.74,
    "end": 121.42,
    "speaker": "彥君",
    "text": "它就 變成灰燼了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.62,
    "end": 124.86,
    "speaker": "彥君",
    "text": "隔絕空氣 才能把它悶烤",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.06,
    "end": 127.88,
    "speaker": "彥君",
    "text": "逼出 裡面的成分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.08,
    "end": 130.97,
    "speaker": "曉臻",
    "text": "所以 這是化學變化嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.17,
    "end": 135.64,
    "speaker": "彥君",
    "text": "沒錯 產生了新物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 135.84,
    "end": 139.26,
    "speaker": "彥君",
    "text": "像是 焦油還有可燃氣體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.46,
    "end": 142.78,
    "speaker": "彥君",
    "text": "最後 剩下的黑色固體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.98,
    "end": 146.01,
    "speaker": "彥君",
    "text": "就能 檢驗出碳元素",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.21,
    "end": 204.8,
    "speaker": "彥君",
    "text": "木材乾餾：化學變化",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 150.04,
    "end": 152.28,
    "speaker": "曉臻",
    "text": "那 石油分餾呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.48,
    "end": 154.96,
    "speaker": "曉臻",
    "text": "也是 加熱分離耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 155.16,
    "end": 157.69,
    "speaker": "彥君",
    "text": "這裡 絕對必考",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.89,
    "end": 161.11,
    "speaker": "彥君",
    "text": "石油分餾 是物理變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.31,
    "end": 163.94,
    "speaker": "曉臻",
    "text": "為什麼 是物理變化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.14,
    "end": 167.07,
    "speaker": "彥君",
    "text": "它是 利用沸點不同",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 167.27,
    "end": 170.57,
    "speaker": "彥君",
    "text": "沸點低的 變氣體往上跑",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 170.77,
    "end": 173.7,
    "speaker": "彥君",
    "text": "像是 瓦斯跟汽油",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.9,
    "end": 176.96,
    "speaker": "彥君",
    "text": "沸點高的 留在底下",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.16,
    "end": 179.5,
    "speaker": "彥君",
    "text": "像是 瀝青",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 179.7,
    "end": 183.28,
    "speaker": "曉臻",
    "text": "喔 只是把它們分開",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 183.48,
    "end": 186.03,
    "speaker": "曉臻",
    "text": "沒有 產生新物質",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 186.23,
    "end": 190.37,
    "speaker": "彥君",
    "text": "對 分出來的產物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 190.57,
    "end": 193.24,
    "speaker": "彥君",
    "text": "依然 是混合物喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 193.44,
    "end": 204.8,
    "speaker": "彥君",
    "text": "石油分餾：物理變化、混合物",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 198.62,
    "end": 201.6,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 204.8,
    "end": 207.69,
    "speaker": "曉臻",
    "text": "老師 種類好多喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 207.89,
    "end": 209.96,
    "speaker": "曉臻",
    "text": "烴醇酸酯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 210.16,
    "end": 212.16,
    "speaker": "曉臻",
    "text": "到底 怎麼分",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 212.36,
    "end": 215.1,
    "speaker": "彥君",
    "text": "先看 第一個烴類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 215.3,
    "end": 217.88,
    "speaker": "彥君",
    "text": "烴 只有碳跟氫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 218.08,
    "end": 221.28,
    "speaker": "彥君",
    "text": "像是 甲烷還有丙烷",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 221.48,
    "end": 224.34,
    "speaker": "曉臻",
    "text": "講義說 它們不溶於水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 224.54,
    "end": 229.02,
    "speaker": "彥君",
    "text": "沒錯 而且碳數越少",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 229.22,
    "end": 231.58,
    "speaker": "彥君",
    "text": "它是 氣態的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 231.78,
    "end": 234.95,
    "speaker": "彥君",
    "text": "碳數越多 變液態跟固態",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 235.15,
    "end": 237.46,
    "speaker": "曉臻",
    "text": "第二個 是醇類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 237.66,
    "end": 241.61,
    "speaker": "曉臻",
    "text": "它有 $OH$（Ｏ、Ｈ） 原子團耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 241.81,
    "end": 244.46,
    "speaker": "曉臻",
    "text": "那它 是不是鹼性啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 244.66,
    "end": 248.02,
    "speaker": "彥君",
    "text": "戰士們 這是大陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 248.22,
    "end": 250.44,
    "speaker": "彥君",
    "text": "醇類的 $OH$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 250.64,
    "end": 255.06,
    "speaker": "彥君",
    "text": "不會解離 所以是中性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 255.26,
    "end": 258.46,
    "speaker": "彥君",
    "text": "像是 酒精就是醇類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 258.66,
    "end": 261.34,
    "speaker": "彥君",
    "text": "它 可以溶於水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 261.54,
    "end": 264.23,
    "speaker": "曉臻",
    "text": "原來 酒精是中性的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 264.43,
    "end": 266.34,
    "speaker": "曉臻",
    "text": "那 酸類呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 266.54,
    "end": 269.9,
    "speaker": "彥君",
    "text": "酸類 有 $COOH$",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 270.1,
    "end": 272.51,
    "speaker": "彥君",
    "text": "像是 醋酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 272.71,
    "end": 275.67,
    "speaker": "彥君",
    "text": "溶於水 就是酸性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 275.87,
    "end": 290.62,
    "speaker": "彥君",
    "text": "烴",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 284.43,
    "end": 287.42,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 290.62,
    "end": 293.29,
    "speaker": "曉臻",
    "text": "最後 進入大魔王了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 293.49,
    "end": 295.94,
    "speaker": "曉臻",
    "text": "右邊的 酯化反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 296.14,
    "end": 298.82,
    "speaker": "彥君",
    "text": "這是 必考五顆星",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 299.02,
    "end": 302.02,
    "speaker": "彥君",
    "text": "有機酸 加上醇類",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 302.22,
    "end": 305.33,
    "speaker": "彥君",
    "text": "會變成 酯類加上水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 305.53,
    "end": 380.19,
    "speaker": "彥君",
    "text": "$\\text{有機酸} + \\text{醇} \\rightarrow \\text{酯} + \\text{水}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 309.65,
    "end": 312.58,
    "speaker": "曉臻",
    "text": "箭頭上面 寫著硫酸耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 312.78,
    "end": 315.67,
    "speaker": "彥君",
    "text": "這裡 必須用濃硫酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 315.87,
    "end": 318.3,
    "speaker": "曉臻",
    "text": "為什麼 是濃硫酸",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 318.5,
    "end": 321.63,
    "speaker": "彥君",
    "text": "因為 濃硫酸可以脫水",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 321.83,
    "end": 325.03,
    "speaker": "彥君",
    "text": "它可以 把產物的水吸走",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 325.23,
    "end": 328.53,
    "speaker": "彥君",
    "text": "讓反應 一直往右邊進行",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 328.73,
    "end": 333.87,
    "speaker": "彥君",
    "text": "它 也是催化劑伴演雙重角色",

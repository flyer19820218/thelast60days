[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.07,
    "speaker": "彥君",
    "text": "第 118 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.27,
    "end": 9.9,
    "speaker": "彥君",
    "text": "遇到人生的彎道 不要害怕",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 10.1,
    "end": 13.14,
    "speaker": "彥君",
    "text": "只要找到 你的向心力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 13.34,
    "end": 16.13,
    "speaker": "彥君",
    "text": "就能 穩穩地轉彎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.33,
    "end": 19.29,
    "speaker": "彥君",
    "text": "絕對不會 飛出軌道",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.49,
    "end": 22.09,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.29,
    "end": 24.02,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 24.22,
    "end": 26.56,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.76,
    "end": 29.22,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 29.42,
    "end": 32.3,
    "speaker": "彥君",
    "text": "今天要來 轉圈圈了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.5,
    "end": 35.46,
    "speaker": "曉臻",
    "text": "老師 講義第一點說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.66,
    "end": 38.77,
    "speaker": "曉臻",
    "text": "只要轉彎 就需要向心力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.97,
    "end": 43.46,
    "speaker": "彥君",
    "text": "沒錯 看看左邊的圓",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.66,
    "end": 46.55,
    "speaker": "彥君",
    "text": "不管球 走到哪裡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.75,
    "end": 49.76,
    "speaker": "彥君",
    "text": "力量永遠 指向圓心",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.96,
    "end": 84.52,
    "speaker": "彥君",
    "text": "$\\text{轉彎} \\rightarrow \\text{需要向心力}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 53.91,
    "end": 56.61,
    "speaker": "曉臻",
    "text": "可是 講義第四點說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.81,
    "end": 59.74,
    "speaker": "曉臻",
    "text": "向心力 竟然不作功耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 59.94,
    "end": 62.86,
    "speaker": "彥君",
    "text": "助教 觀察力太強了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.06,
    "end": 66.16,
    "speaker": "彥君",
    "text": "看看 球的速度箭頭",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.36,
    "end": 69.51,
    "speaker": "彥君",
    "text": "永遠跟 向心力垂直",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.71,
    "end": 73.25,
    "speaker": "彥君",
    "text": "互相垂直 就是不作功",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 73.45,
    "end": 84.52,
    "speaker": "彥君",
    "text": "$\\text{向心力} \\rightarrow \\text{垂直不作功}$",
    "is_pinned": true,
    "pin_level": 2
  },
  {
    "start": 78.19,
    "end": 81.32,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘畫直角",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.52,
    "end": 87.67,
    "speaker": "曉臻",
    "text": "老師 下面有一行字",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.87,
    "end": 90.69,
    "speaker": "曉臻",
    "text": "如果 繩子突然斷掉呢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.89,
    "end": 93.63,
    "speaker": "彥君",
    "text": "這是 必考的陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.83,
    "end": 97.1,
    "speaker": "彥君",
    "text": "很多人以為 球會往外飛",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.3,
    "end": 100.38,
    "speaker": "彥君",
    "text": "其實 向心力一消失",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.58,
    "end": 103.93,
    "speaker": "彥君",
    "text": "球就會 順著原本的速度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.13,
    "end": 107.4,
    "speaker": "彥君",
    "text": "沿著 切線方向飛出去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.6,
    "end": 110.85,
    "speaker": "彥君",
    "text": "這就是 我們學過的慣性",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.05,
    "end": 122.38,
    "speaker": "彥君",
    "text": "$\\text{失去向心力} \\rightarrow \\text{切線飛出}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 115.96,
    "end": 119.18,
    "speaker": "彥君",
    "text": "戰士們 趕快抄寫",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.38,
    "end": 125.32,
    "speaker": "曉臻",
    "text": "最後 右邊有一台車子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 125.52,
    "end": 128.24,
    "speaker": "曉臻",
    "text": "它在 斜坡上轉彎耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.44,
    "end": 133.15,
    "speaker": "彥君",
    "text": "沒錯 這是經典選擇題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 133.35,
    "end": 136.48,
    "speaker": "彥君",
    "text": "甲乙丙丁 四個箭頭",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.68,
    "end": 139.47,
    "speaker": "彥君",
    "text": "哪一個 是向心力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.67,
    "end": 142.42,
    "speaker": "曉臻",
    "text": "向心力 要指向圓心",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.62,
    "end": 145.96,
    "speaker": "曉臻",
    "text": "車子 是在水平面上繞圈圈",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.16,
    "end": 149.31,
    "speaker": "曉臻",
    "text": "所以 圓心在水平的左邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.51,
    "end": 153.77,
    "speaker": "彥君",
    "text": "答對了 答案就是乙",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.97,
    "end": 157.19,
    "speaker": "彥君",
    "text": "絕對不是 順著斜坡的丙喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.39,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{水平轉彎} \\rightarrow \\text{向心力為水平}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 162.06,
    "end": 165.5,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 165.7,
    "end": 168.3,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.5,
    "end": 170.84,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.04,
    "end": 174.46,
    "speaker": "合聲",
    "text": "轉彎向心 斷裂切線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 174.66,
    "end": 178.19,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
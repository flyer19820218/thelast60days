[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.1,
    "speaker": "彥君",
    "text": "第 121 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.3,
    "end": 9.18,
    "speaker": "彥君",
    "text": "給我一個 穩固的支點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.38,
    "end": 12.73,
    "speaker": "彥君",
    "text": "加上 夠長的方法與力臂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.93,
    "end": 15.43,
    "speaker": "彥君",
    "text": "會考的重擔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.63,
    "end": 18.59,
    "speaker": "彥君",
    "text": "我們 也能輕鬆舉起",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.79,
    "end": 21.39,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.59,
    "end": 23.33,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.53,
    "end": 25.86,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 26.06,
    "end": 28.52,
    "speaker": "彥君",
    "text": "戰士們注意",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.72,
    "end": 31.82,
    "speaker": "彥君",
    "text": "今天要教 槓桿原理",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.02,
    "end": 35.34,
    "speaker": "曉臻",
    "text": "老師 看看右邊這張圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 35.54,
    "end": 38.36,
    "speaker": "曉臻",
    "text": "那個力臂 畫了一個直角",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 38.56,
    "end": 42.94,
    "speaker": "彥君",
    "text": "沒錯 這是全國學生",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.14,
    "end": 46.07,
    "speaker": "彥君",
    "text": "最容易 死掉的陷阱",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 46.27,
    "end": 49.64,
    "speaker": "彥君",
    "text": "力臂 絕對不是棍子的長度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 49.84,
    "end": 53.16,
    "speaker": "彥君",
    "text": "它是從支點 到施力線的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 53.36,
    "end": 56.13,
    "speaker": "彥君",
    "text": "垂直 最短距離",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.33,
    "end": 74.22,
    "speaker": "彥君",
    "text": "$\\text{力臂} \\rightarrow \\text{支點到施力線的垂直距離}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 61.12,
    "end": 64.7,
    "speaker": "曉臻",
    "text": "哇 只要乖乖找直角",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 64.9,
    "end": 67.7,
    "speaker": "曉臻",
    "text": "就不會 被大考給騙了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.9,
    "end": 71.02,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘畫直角",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.22,
    "end": 77.47,
    "speaker": "彥君",
    "text": "戰士們 來看左邊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 77.67,
    "end": 80.63,
    "speaker": "曉臻",
    "text": "左下角 是翹翹板遊戲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.83,
    "end": 83.22,
    "speaker": "曉臻",
    "text": "左邊的人 比較重",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.42,
    "end": 86.57,
    "speaker": "曉臻",
    "text": "可是 右邊的人坐得比較遠",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 86.77,
    "end": 91.29,
    "speaker": "彥君",
    "text": "沒錯 力量乘上力臂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.49,
    "end": 94.69,
    "speaker": "彥君",
    "text": "只要 順時針等於逆時針",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.89,
    "end": 98.11,
    "speaker": "彥君",
    "text": "翹翹板 就會平衡不動",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.31,
    "end": 108.62,
    "speaker": "彥君",
    "text": "$\\text{力矩} = \\text{力} \\times \\text{力臂}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 102.36,
    "end": 105.42,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘想像",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.62,
    "end": 111.74,
    "speaker": "彥君",
    "text": "最後一個 經典大考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.94,
    "end": 114.28,
    "speaker": "曉臻",
    "text": "推圓球 上階梯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 114.48,
    "end": 117.73,
    "speaker": "曉臻",
    "text": "老師 這裡有四個箭頭",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.93,
    "end": 121.2,
    "speaker": "曉臻",
    "text": "$F_{1}$ 到 $F_{4}$ 哪個最省力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.4,
    "end": 124.22,
    "speaker": "彥君",
    "text": "記住 破題第一步",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.42,
    "end": 127.69,
    "speaker": "彥君",
    "text": "先把 階梯碰到球的直角",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 127.89,
    "end": 130.7,
    "speaker": "彥君",
    "text": "當作 旋轉的支點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.9,
    "end": 133.65,
    "speaker": "曉臻",
    "text": "喔 找到了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 133.85,
    "end": 136.9,
    "speaker": "彥君",
    "text": "既然要把球 推上去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.1,
    "end": 140.62,
    "speaker": "彥君",
    "text": "力臂越長 施力就越小",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.82,
    "end": 144.02,
    "speaker": "彥君",
    "text": "看看哪條線 離支點最遠",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 144.22,
    "end": 147.49,
    "speaker": "曉臻",
    "text": "絕對是 畫出直徑的那條線",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 147.69,
    "end": 152.57,
    "speaker": "彥君",
    "text": "漂亮 直徑就是最長力臂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 152.77,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{力臂最長} \\rightarrow \\text{施力最小}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 157.2,
    "end": 161.12,
    "speaker": "彥君",
    "text": "找對直徑 就能輕鬆滾上去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.32,
    "end": 164.76,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.96,
    "end": 168.21,
    "speaker": "彥君",
    "text": "補教天王 換我們當",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 168.41,
    "end": 171.01,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.21,
    "end": 173.54,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 173.74,
    "end": 177.28,
    "speaker": "合聲",
    "text": "尋找支點 垂直力臂",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.48,
    "end": 181.02,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
[
  {
    "start": 0.0,
    "end": 2.9,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 2.9,
    "end": 5.7,
    "speaker": "曉臻",
    "text": "戰士們大家好啊"
  },
  {
    "start": 5.7,
    "end": 8.34,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 8.34,
    "end": 11.91,
    "speaker": "彥君",
    "text": "歡迎來到科學大冒險"
  },
  {
    "start": 11.91,
    "end": 15.53,
    "speaker": "彥君",
    "text": "今天要帶大家鑽進地心"
  },
  {
    "start": 15.53,
    "end": 19.01,
    "speaker": "曉臻",
    "text": "老師地底下黑漆漆的"
  },
  {
    "start": 19.01,
    "end": 22.39,
    "speaker": "曉臻",
    "text": "我們怎麼知道裡面長怎樣？"
  },
  {
    "start": 22.39,
    "end": 25.67,
    "speaker": "彥君",
    "text": "我們可是有透視眼的"
  },
  {
    "start": 25.67,
    "end": 29.17,
    "speaker": "彥君",
    "text": "靠的就是『地震波』"
  },
  {
    "start": 29.17,
    "end": 33.08,
    "speaker": "曉臻",
    "text": "就像幫地球照超音波一樣對吧"
  },
  {
    "start": 33.08,
    "end": 37.85,
    "speaker": "彥君",
    "text": "沒錯地球從外到內"
  },
  {
    "start": 37.85,
    "end": 41.81,
    "speaker": "彥君",
    "text": "分成地殼、地函跟地核"
  },
  {
    "start": 41.81,
    "end": 45.52,
    "speaker": "曉臻",
    "text": "戰士們快看投影片上的成分"
  },
  {
    "start": 45.52,
    "end": 48.78,
    "speaker": "彥君",
    "text": "地殼主要是氧和矽"
  },
  {
    "start": 48.78,
    "end": 52.72,
    "speaker": "彥君",
    "text": "地函則是氧、矽還有鋁"
  },
  {
    "start": 52.72,
    "end": 56.19,
    "speaker": "彥君",
    "text": "最深的地核是鐵和鎳"
  },
  {
    "start": 56.19,
    "end": 60.29,
    "speaker": "曉臻",
    "text": "哇越往裡面重金屬就越多耶"
  },
  {
    "start": 60.29,
    "end": 64.03,
    "speaker": "彥君",
    "text": "接著看右邊這張必考圖"
  },
  {
    "start": 64.03,
    "end": 67.7,
    "speaker": "彥君",
    "text": "這是用『軟硬狀態』來分的喔"
  },
  {
    "start": 67.7,
    "end": 71.49,
    "speaker": "曉臻",
    "text": "表面 100 公里厚硬梆梆的"
  },
  {
    "start": 71.49,
    "end": 74.03,
    "speaker": "曉臻",
    "text": "叫做『岩石圈』"
  },
  {
    "start": 74.03,
    "end": 77.62,
    "speaker": "彥君",
    "text": "岩石圈包含了整個地殼"
  },
  {
    "start": 77.62,
    "end": 80.93,
    "speaker": "彥君",
    "text": "還有地函的最上層"
  },
  {
    "start": 80.93,
    "end": 83.83,
    "speaker": "曉臻",
    "text": "那岩石圈的下面呢？"
  },
  {
    "start": 83.83,
    "end": 87.74,
    "speaker": "彥君",
    "text": "就是會考最愛的『軟流圈』"
  },
  {
    "start": 87.74,
    "end": 90.88,
    "speaker": "彥君",
    "text": "戰士們想像一下"
  },
  {
    "start": 90.88,
    "end": 95.17,
    "speaker": "彥君",
    "text": "軟流圈就像是一杯『熱巧克力』"
  },
  {
    "start": 95.17,
    "end": 98.82,
    "speaker": "曉臻",
    "text": "哇濃濃稠稠的"
  },
  {
    "start": 98.82,
    "end": 102.1,
    "speaker": "曉臻",
    "text": "還會熱騰騰地慢慢流動"
  },
  {
    "start": 102.1,
    "end": 107.06,
    "speaker": "彥君",
    "text": "沒錯硬梆梆的岩石圈就像餅乾"
  },
  {
    "start": 107.06,
    "end": 110.71,
    "speaker": "彥君",
    "text": "浮在熱巧克力上面漂移"
  },
  {
    "start": 110.71,
    "end": 114.81,
    "speaker": "曉臻",
    "text": "天啊這畫面太有感了"
  },
  {
    "start": 114.81,
    "end": 118.55,
    "speaker": "曉臻",
    "text": "這就是板塊運動的動力來源"
  },
  {
    "start": 118.55,
    "end": 122.31,
    "speaker": "彥君",
    "text": "戰士們紅筆拿出來"
  },
  {
    "start": 122.31,
    "end": 125.93,
    "speaker": "彥君",
    "text": "軟流圈就是岩漿的故鄉"
  },
  {
    "start": 125.93,
    "end": 129.14,
    "speaker": "彥君",
    "text": "戰士們閉上眼睛"
  },
  {
    "start": 129.14,
    "end": 132.96,
    "speaker": "彥君",
    "text": "帶動地球板塊移動的引擎"
  },
  {
    "start": 132.96,
    "end": 136.46,
    "speaker": "彥君",
    "text": "到底是地核還是軟流圈？"
  },
  {
    "start": 136.46,
    "end": 140.17,
    "speaker": "曉臻",
    "text": "當然是像熱巧克力的『軟流圈』"
  },
  {
    "start": 140.17,
    "end": 145.14,
    "speaker": "彥君",
    "text": "漂亮這就是秒殺的直覺"
  },
  {
    "start": 145.14,
    "end": 148.04,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 148.04,
    "end": 150.67,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 150.67,
    "end": 155.06,
    "speaker": "曉臻",
    "text": "地球構造記清楚會考拿分擋不住"
  },
  {
    "start": 155.06,
    "end": 159.33,
    "speaker": "曉臻",
    "text": "戰士們 881我們下一關見"
  }
]
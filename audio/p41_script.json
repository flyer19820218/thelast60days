[
  {
    "start": 0.0,
    "end": 3.55,
    "speaker": "彥君",
    "text": "各位衝 A 的戰士們"
  },
  {
    "start": 3.55,
    "end": 6.45,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 6.45,
    "end": 9.25,
    "speaker": "曉臻",
    "text": "戰士們大家好啊"
  },
  {
    "start": 9.25,
    "end": 11.89,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 11.89,
    "end": 15.46,
    "speaker": "彥君",
    "text": "歡迎來到科學大冒險"
  },
  {
    "start": 15.46,
    "end": 19.08,
    "speaker": "彥君",
    "text": "今天要帶大家鑽進地心"
  },
  {
    "start": 19.08,
    "end": 22.56,
    "speaker": "曉臻",
    "text": "老師地底下黑漆漆的"
  },
  {
    "start": 22.56,
    "end": 25.94,
    "speaker": "曉臻",
    "text": "我們怎麼知道裡面長怎樣？"
  },
  {
    "start": 25.94,
    "end": 29.22,
    "speaker": "彥君",
    "text": "我們可是有透視眼的"
  },
  {
    "start": 29.22,
    "end": 32.72,
    "speaker": "彥君",
    "text": "靠的就是『地震波』"
  },
  {
    "start": 32.72,
    "end": 36.63,
    "speaker": "曉臻",
    "text": "就像幫地球照超音波一樣對吧"
  },
  {
    "start": 36.63,
    "end": 41.4,
    "speaker": "彥君",
    "text": "沒錯地球從外到內"
  },
  {
    "start": 41.4,
    "end": 45.36,
    "speaker": "彥君",
    "text": "分成地殼、地函跟地核"
  },
  {
    "start": 45.36,
    "end": 49.07,
    "speaker": "曉臻",
    "text": "戰士們快看投影片上的成分"
  },
  {
    "start": 49.07,
    "end": 52.33,
    "speaker": "彥君",
    "text": "地殼主要是氧和矽"
  },
  {
    "start": 52.33,
    "end": 56.26,
    "speaker": "彥君",
    "text": "地函則是氧、矽還有鋁"
  },
  {
    "start": 56.26,
    "end": 59.74,
    "speaker": "彥君",
    "text": "最深的地核是鐵和鎳"
  },
  {
    "start": 59.74,
    "end": 63.84,
    "speaker": "曉臻",
    "text": "哇越往裡面重金屬就越多耶"
  },
  {
    "start": 63.84,
    "end": 67.58,
    "speaker": "彥君",
    "text": "接著看右邊這張必考圖"
  },
  {
    "start": 67.58,
    "end": 71.25,
    "speaker": "彥君",
    "text": "這是用『軟硬狀態』來分的喔"
  },
  {
    "start": 71.25,
    "end": 75.04,
    "speaker": "曉臻",
    "text": "表面 100 公里厚硬梆梆的"
  },
  {
    "start": 75.04,
    "end": 77.58,
    "speaker": "曉臻",
    "text": "叫做『岩石圈』"
  },
  {
    "start": 77.58,
    "end": 81.17,
    "speaker": "彥君",
    "text": "岩石圈包含了整個地殼"
  },
  {
    "start": 81.17,
    "end": 84.48,
    "speaker": "彥君",
    "text": "還有地函的最上層"
  },
  {
    "start": 84.48,
    "end": 87.38,
    "speaker": "曉臻",
    "text": "那岩石圈的下面呢？"
  },
  {
    "start": 87.38,
    "end": 91.29,
    "speaker": "彥君",
    "text": "就是會考最愛的『軟流圈』"
  },
  {
    "start": 91.29,
    "end": 94.43,
    "speaker": "彥君",
    "text": "戰士們想像一下"
  },
  {
    "start": 94.43,
    "end": 98.72,
    "speaker": "彥君",
    "text": "軟流圈就像是一杯『熱巧克力』"
  },
  {
    "start": 98.72,
    "end": 102.36,
    "speaker": "曉臻",
    "text": "哇濃濃稠稠的"
  },
  {
    "start": 102.36,
    "end": 105.65,
    "speaker": "曉臻",
    "text": "還會熱騰騰地慢慢流動"
  },
  {
    "start": 105.65,
    "end": 110.61,
    "speaker": "彥君",
    "text": "沒錯硬梆梆的岩石圈就像餅乾"
  },
  {
    "start": 110.61,
    "end": 114.26,
    "speaker": "彥君",
    "text": "浮在熱巧克力上面漂移"
  },
  {
    "start": 114.26,
    "end": 118.36,
    "speaker": "曉臻",
    "text": "天啊這畫面太有感了"
  },
  {
    "start": 118.36,
    "end": 122.1,
    "speaker": "曉臻",
    "text": "這就是板塊運動的動力來源"
  },
  {
    "start": 122.1,
    "end": 125.86,
    "speaker": "彥君",
    "text": "戰士們紅筆拿出來"
  },
  {
    "start": 125.86,
    "end": 129.48,
    "speaker": "彥君",
    "text": "軟流圈就是岩漿的故鄉"
  },
  {
    "start": 129.48,
    "end": 132.69,
    "speaker": "彥君",
    "text": "戰士們閉上眼睛"
  },
  {
    "start": 132.69,
    "end": 136.5,
    "speaker": "彥君",
    "text": "帶動地球板塊移動的引擎"
  },
  {
    "start": 136.5,
    "end": 140.0,
    "speaker": "彥君",
    "text": "到底是地核還是軟流圈？"
  },
  {
    "start": 140.0,
    "end": 143.72,
    "speaker": "曉臻",
    "text": "當然是像熱巧克力的『軟流圈』"
  },
  {
    "start": 143.72,
    "end": 148.68,
    "speaker": "彥君",
    "text": "漂亮這就是秒殺的直覺"
  },
  {
    "start": 148.68,
    "end": 151.58,
    "speaker": "彥君",
    "text": "我是彥君老師"
  },
  {
    "start": 151.58,
    "end": 154.22,
    "speaker": "曉臻",
    "text": "我是曉臻助教"
  },
  {
    "start": 154.22,
    "end": 158.61,
    "speaker": "曉臻",
    "text": "地球構造記清楚會考拿分擋不住"
  },
  {
    "start": 158.61,
    "end": 162.88,
    "speaker": "曉臻",
    "text": "戰士們 881我們下一關見"
  }
]
[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.26,
    "speaker": "彥君",
    "text": "第 133 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.46,
    "end": 8.99,
    "speaker": "彥君",
    "text": "真正的 強者",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.19,
    "end": 12.1,
    "speaker": "彥君",
    "text": "不是 擁有多少能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.3,
    "end": 14.88,
    "speaker": "彥君",
    "text": "而是 能把能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.08,
    "end": 18.42,
    "speaker": "彥君",
    "text": "轉化成 改變世界的動力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.62,
    "end": 21.22,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.42,
    "end": 23.16,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.36,
    "end": 25.7,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.9,
    "end": 28.76,
    "speaker": "彥君",
    "text": "電解 三大魔王來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.96,
    "end": 31.82,
    "speaker": "曉臻",
    "text": "老師 講義上的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.02,
    "end": 34.65,
    "speaker": "曉臻",
    "text": "泡泡 畫得好精美喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.85,
    "end": 39.39,
    "speaker": "彥君",
    "text": "沒錯 記住 電子的心法",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.59,
    "end": 43.32,
    "speaker": "彥君",
    "text": "負極端 得到電子 還原",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.52,
    "end": 47.25,
    "speaker": "彥君",
    "text": "正極端 失去電子 氧化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.45,
    "end": 57.58,
    "speaker": "彥君",
    "text": "$\\text{負得還原， 正失氧化}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 51.38,
    "end": 54.38,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘記牢",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 57.58,
    "end": 60.76,
    "speaker": "曉臻",
    "text": "老師 來看左邊第一杯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.96,
    "end": 63.63,
    "speaker": "曉臻",
    "text": "這是 電解水 實驗嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.83,
    "end": 68.3,
    "speaker": "彥君",
    "text": "沒錯 兩邊 都有泡泡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 68.5,
    "end": 71.85,
    "speaker": "彥君",
    "text": "記住 補教界最強口訣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.05,
    "end": 74.38,
    "speaker": "彥君",
    "text": "負氫正氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.58,
    "end": 78.1,
    "speaker": "曉臻",
    "text": "喔 負極 產生氫氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.3,
    "end": 80.78,
    "speaker": "曉臻",
    "text": "正極 產生氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 80.98,
    "end": 83.72,
    "speaker": "彥君",
    "text": "體積 則是 2 比 1",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 83.92,
    "end": 93.79,
    "speaker": "彥君",
    "text": "$\\text{負氫正氧， 氫二氧一}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 87.54,
    "end": 90.59,
    "speaker": "彥君",
    "text": "給你們 3 秒鐘想像",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.79,
    "end": 96.58,
    "speaker": "曉臻",
    "text": "老師 中間那杯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.78,
    "end": 99.72,
    "speaker": "曉臻",
    "text": "是電解 硫酸銅溶液耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.92,
    "end": 102.81,
    "speaker": "彥君",
    "text": "而且 電極是碳棒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 103.01,
    "end": 105.46,
    "speaker": "曉臻",
    "text": "負極 有紅色的銅",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 105.66,
    "end": 108.0,
    "speaker": "曉臻",
    "text": "正極 也有泡泡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 108.2,
    "end": 111.62,
    "speaker": "彥君",
    "text": "紅色 就是銅離子還原",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 111.82,
    "end": 114.94,
    "speaker": "彥君",
    "text": "正極 則是產生氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.14,
    "end": 117.94,
    "speaker": "曉臻",
    "text": "因為 碳棒不參與反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.14,
    "end": 121.05,
    "speaker": "曉臻",
    "text": "所以 只能拆水來產氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.25,
    "end": 125.86,
    "speaker": "彥君",
    "text": "漂亮 此時 藍色會變淡喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.06,
    "end": 136.73,
    "speaker": "彥君",
    "text": "$\\text{電解硫酸銅} \\rightarrow \\text{負銅正氧}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 130.3,
    "end": 133.53,
    "speaker": "彥君",
    "text": "戰士們 來看電鍍",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 136.73,
    "end": 139.5,
    "speaker": "曉臻",
    "text": "最右邊 這杯最重要",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 139.7,
    "end": 142.27,
    "speaker": "曉臻",
    "text": "兩邊 都是銅片耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 142.47,
    "end": 145.62,
    "speaker": "彥君",
    "text": "這是 為了要把銅鍍上去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.82,
    "end": 149.02,
    "speaker": "曉臻",
    "text": "老師 電鍍口訣是什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 149.22,
    "end": 151.46,
    "speaker": "彥君",
    "text": "負被 正欲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 151.66,
    "end": 153.9,
    "speaker": "曉臻",
    "text": "負極 接被鍍物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.1,
    "end": 156.58,
    "speaker": "曉臻",
    "text": "正極 接欲鍍金屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.78,
    "end": 161.3,
    "speaker": "彥君",
    "text": "沒錯 正極 溶解變瘦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 161.5,
    "end": 164.25,
    "speaker": "彥君",
    "text": "負極 長肉變胖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 164.45,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "$\\text{負被正欲， 負長正溶}$",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 168.09,
    "end": 171.55,
    "speaker": "曉臻",
    "text": "哇 這樣 藍色濃度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.75,
    "end": 174.16,
    "speaker": "曉臻",
    "text": "就不會 改變了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 174.36,
    "end": 179.6,
    "speaker": "彥君",
    "text": "沒錯 觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 179.8,
    "end": 182.64,
    "speaker": "彥君",
    "text": "答案 釘在黑板上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 182.84,
    "end": 185.44,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 185.64,
    "end": 187.98,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 188.18,
    "end": 191.62,
    "speaker": "合聲",
    "text": "負得還原 正失氧化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 191.82,
    "end": 195.35,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
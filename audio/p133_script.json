[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.26,
    "speaker": "彥君",
    "text": "第 133 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.46,
    "end": 8.99,
    "speaker": "彥君",
    "text": "真正的 強者",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.19,
    "end": 12.1,
    "speaker": "彥君",
    "text": "不是 擁有多少能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.3,
    "end": 14.88,
    "speaker": "彥君",
    "text": "而是 能把能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.08,
    "end": 18.42,
    "speaker": "彥君",
    "text": "轉化成 改變世界的動力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.62,
    "end": 21.22,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.42,
    "end": 23.16,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.36,
    "end": 25.7,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.9,
    "end": 28.76,
    "speaker": "彥君",
    "text": "電解 三大魔王來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.96,
    "end": 31.82,
    "speaker": "曉臻",
    "text": "老師 講義上的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.02,
    "end": 36.28,
    "speaker": "曉臻",
    "text": "泡泡 畫得好精美喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 36.48,
    "end": 41.02,
    "speaker": "彥君",
    "text": "沒錯 記住 電子的心法",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 41.22,
    "end": 47.98,
    "speaker": "彥君",
    "text": "負極 得到電子 還原",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.18,
    "end": 52.77,
    "speaker": "彥君",
    "text": "正極 失去電子 氧化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 52.97,
    "end": 67.34,
    "speaker": "彥君",
    "text": "[$\\text{負得還原， 正失氧化}$]極得還原 正極失氧化)",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 64.34,
    "end": 67.7,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘記牢]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 67.9,
    "end": 71.08,
    "speaker": "曉臻",
    "text": "老師 來看左邊第一杯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.28,
    "end": 73.95,
    "speaker": "曉臻",
    "text": "這是 電解水 實驗嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 74.15,
    "end": 78.62,
    "speaker": "彥君",
    "text": "沒錯 兩邊 都有泡泡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.82,
    "end": 82.17,
    "speaker": "彥君",
    "text": "記住 補教界最強口訣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 82.37,
    "end": 87.58,
    "speaker": "彥君",
    "text": "負氫 正氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.78,
    "end": 92.47,
    "speaker": "曉臻",
    "text": "喔 負極 產生氫氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 92.67,
    "end": 96.66,
    "speaker": "曉臻",
    "text": "正極 產生氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 96.86,
    "end": 99.61,
    "speaker": "彥君",
    "text": "體積 則是 2 比 1",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 99.81,
    "end": 109.18,
    "speaker": "彥君",
    "text": "[$\\text{負氫正氧， 氫二氧一}$]氫正氧 氫二氧一)",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 106.18,
    "end": 109.5,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘想像]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.7,
    "end": 112.5,
    "speaker": "曉臻",
    "text": "老師 中間那杯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.7,
    "end": 115.63,
    "speaker": "曉臻",
    "text": "是電解 硫酸銅溶液耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.83,
    "end": 118.72,
    "speaker": "彥君",
    "text": "而且 電極是碳棒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 118.92,
    "end": 121.38,
    "speaker": "曉臻",
    "text": "負極 有紅色的銅",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 121.58,
    "end": 123.91,
    "speaker": "曉臻",
    "text": "正極 也有泡泡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 124.11,
    "end": 129.14,
    "speaker": "彥君",
    "text": "紅色 就是銅離子還原",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 129.34,
    "end": 134.0,
    "speaker": "彥君",
    "text": "正極 則是產生氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.2,
    "end": 136.99,
    "speaker": "曉臻",
    "text": "因為 碳棒不參與反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.19,
    "end": 140.1,
    "speaker": "曉臻",
    "text": "所以 只能拆水來產氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 140.3,
    "end": 144.92,
    "speaker": "彥君",
    "text": "漂亮 此時 藍色會變淡喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 145.12,
    "end": 153.87,
    "speaker": "彥君",
    "text": "[$\\text{電解硫酸銅} \\rightarrow \\text{負銅正氧}$]銅正氧)",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 150.87,
    "end": 154.38,
    "speaker": "彥君",
    "text": "[戰士們 來看電鍍]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 154.58,
    "end": 157.35,
    "speaker": "曉臻",
    "text": "最右邊 這杯最重要",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 157.55,
    "end": 160.13,
    "speaker": "曉臻",
    "text": "兩邊 都是銅片耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 160.33,
    "end": 163.48,
    "speaker": "彥君",
    "text": "這是 為了要把銅鍍上去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 163.68,
    "end": 166.88,
    "speaker": "曉臻",
    "text": "老師 電鍍口訣是什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 167.08,
    "end": 172.18,
    "speaker": "彥君",
    "text": "負被 正欲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 172.38,
    "end": 177.52,
    "speaker": "曉臻",
    "text": "負極 接被鍍物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 177.72,
    "end": 183.25,
    "speaker": "曉臻",
    "text": "正極 接欲鍍金屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 183.45,
    "end": 187.97,
    "speaker": "彥君",
    "text": "沒錯 正極 溶解變瘦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 188.17,
    "end": 192.45,
    "speaker": "彥君",
    "text": "負極 長肉變胖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 192.65,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$\\text{負被正欲， 負長正溶}$]正欲 負長正溶)",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 200.34,
    "end": 203.81,
    "speaker": "曉臻",
    "text": "哇 這樣 藍色濃度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 204.01,
    "end": 208.0,
    "speaker": "曉臻",
    "text": "就不會 改變了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 208.2,
    "end": 213.44,
    "speaker": "彥君",
    "text": "沒錯 觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 213.64,
    "end": 216.48,
    "speaker": "彥君",
    "text": "答案 釘在黑板上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 216.68,
    "end": 220.07,
    "speaker": "彥君",
    "text": "補教王者 非你莫屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 220.27,
    "end": 222.87,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 223.07,
    "end": 225.41,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 225.61,
    "end": 233.54,
    "speaker": "合聲",
    "text": "負得還原 正失氧化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 233.74,
    "end": 237.27,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
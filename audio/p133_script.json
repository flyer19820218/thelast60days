[
  {
    "start": 0.0,
    "end": 3.25,
    "speaker": "彥君",
    "text": "戰士們 歡迎來到",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 3.45,
    "end": 6.26,
    "speaker": "彥君",
    "text": "第 133 集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 6.46,
    "end": 8.99,
    "speaker": "彥君",
    "text": "真正的 強者",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 9.19,
    "end": 12.1,
    "speaker": "彥君",
    "text": "不是 擁有多少能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 12.3,
    "end": 14.88,
    "speaker": "彥君",
    "text": "而是 能把能量",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 15.08,
    "end": 18.42,
    "speaker": "彥君",
    "text": "轉化成 改變世界的動力",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 18.62,
    "end": 21.22,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 21.42,
    "end": 23.16,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 23.36,
    "end": 25.7,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.9,
    "end": 28.76,
    "speaker": "彥君",
    "text": "電解 三大魔王來了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 28.96,
    "end": 31.82,
    "speaker": "曉臻",
    "text": "老師 講義上的圖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 32.02,
    "end": 34.65,
    "speaker": "曉臻",
    "text": "泡泡 畫得好精美喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 34.85,
    "end": 39.39,
    "speaker": "彥君",
    "text": "沒錯 記住 電子的心法",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 39.59,
    "end": 43.32,
    "speaker": "彥君",
    "text": "負極端 得到電子 還原",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.52,
    "end": 47.25,
    "speaker": "彥君",
    "text": "正極端 失去電子 氧化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 47.45,
    "end": 54.38,
    "speaker": "彥君",
    "text": "[$\\text{負得還原， 正失氧化}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 51.38,
    "end": 54.74,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘記牢]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.94,
    "end": 58.12,
    "speaker": "曉臻",
    "text": "老師 來看左邊第一杯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 58.32,
    "end": 60.99,
    "speaker": "曉臻",
    "text": "這是 電解水 實驗嗎",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 61.19,
    "end": 65.66,
    "speaker": "彥君",
    "text": "沒錯 兩邊 都有泡泡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 65.86,
    "end": 69.21,
    "speaker": "彥君",
    "text": "記住 補教界最強口訣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.41,
    "end": 71.74,
    "speaker": "彥君",
    "text": "負氫正氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 71.94,
    "end": 75.46,
    "speaker": "曉臻",
    "text": "喔 負極 產生氫氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.66,
    "end": 78.14,
    "speaker": "曉臻",
    "text": "正極 產生氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.34,
    "end": 81.08,
    "speaker": "彥君",
    "text": "體積 則是 2 比 1",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.28,
    "end": 87.9,
    "speaker": "彥君",
    "text": "[$\\text{負氫正氧， 氫二氧一}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 84.9,
    "end": 88.22,
    "speaker": "彥君",
    "text": "[給你們 3 秒鐘想像]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 88.42,
    "end": 91.21,
    "speaker": "曉臻",
    "text": "老師 中間那杯",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 91.41,
    "end": 94.34,
    "speaker": "曉臻",
    "text": "是電解 硫酸銅溶液耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 94.54,
    "end": 97.43,
    "speaker": "彥君",
    "text": "而且 電極是碳棒",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 97.63,
    "end": 100.09,
    "speaker": "曉臻",
    "text": "負極 有紅色的銅",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 100.29,
    "end": 102.62,
    "speaker": "曉臻",
    "text": "正極 也有泡泡",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 102.82,
    "end": 106.24,
    "speaker": "彥君",
    "text": "紅色 就是銅離子還原",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 106.44,
    "end": 109.57,
    "speaker": "彥君",
    "text": "正極 則是產生氧氣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 109.77,
    "end": 112.56,
    "speaker": "曉臻",
    "text": "因為 碳棒不參與反應",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 112.76,
    "end": 115.67,
    "speaker": "曉臻",
    "text": "所以 只能拆水來產氧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 115.87,
    "end": 120.49,
    "speaker": "彥君",
    "text": "漂亮 此時 藍色會變淡喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.69,
    "end": 127.93,
    "speaker": "彥君",
    "text": "[$\\text{電解硫酸銅} \\rightarrow \\text{負銅正氧}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 124.93,
    "end": 128.44,
    "speaker": "彥君",
    "text": "[戰士們 來看電鍍]",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 128.64,
    "end": 131.41,
    "speaker": "曉臻",
    "text": "最右邊 這杯最重要",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 131.61,
    "end": 134.18,
    "speaker": "曉臻",
    "text": "兩邊 都是銅片耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 134.38,
    "end": 137.54,
    "speaker": "彥君",
    "text": "這是 為了要把銅鍍上去",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 137.74,
    "end": 140.94,
    "speaker": "曉臻",
    "text": "老師 電鍍口訣是什麼",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 141.14,
    "end": 143.38,
    "speaker": "彥君",
    "text": "負被 正欲",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 143.58,
    "end": 145.82,
    "speaker": "曉臻",
    "text": "負極 接被鍍物",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 146.02,
    "end": 148.5,
    "speaker": "曉臻",
    "text": "正極 接欲鍍金屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 148.7,
    "end": 153.22,
    "speaker": "彥君",
    "text": "沒錯 正極 溶解變瘦",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 153.42,
    "end": 156.16,
    "speaker": "彥君",
    "text": "負極 長肉變胖",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 156.36,
    "end": 9999.0,
    "speaker": "彥君",
    "text": "[$\\text{負被正欲， 負長正溶}$]",
    "is_pinned": true,
    "pin_level": 1
  },
  {
    "start": 160.0,
    "end": 163.46,
    "speaker": "曉臻",
    "text": "哇 這樣 藍色濃度",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 163.66,
    "end": 166.07,
    "speaker": "曉臻",
    "text": "就不會 改變了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 166.27,
    "end": 171.51,
    "speaker": "彥君",
    "text": "沒錯 觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 171.71,
    "end": 174.55,
    "speaker": "彥君",
    "text": "答案 釘在黑板上",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 174.75,
    "end": 178.14,
    "speaker": "彥君",
    "text": "補教王者 非你莫屬",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 178.34,
    "end": 180.94,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 181.14,
    "end": 183.48,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 183.68,
    "end": 187.12,
    "speaker": "合聲",
    "text": "負得還原 正失氧化",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 187.32,
    "end": 190.86,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]
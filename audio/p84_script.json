    "speaker": "彥君",
    "text": "哈囉",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 2.18,
    "end": 5.45,
    "speaker": "彥君",
    "text": "各位即將衝 A 的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 5.65,
    "end": 8.1,
    "speaker": "彥君",
    "text": "會考戰士們",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 8.3,
    "end": 10.9,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 11.1,
    "end": 14.4,
    "speaker": "彥君",
    "text": "今天來到 第八十四集",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 14.6,
    "end": 16.34,
    "speaker": "曉臻",
    "text": "大家好",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 16.54,
    "end": 18.87,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 19.07,
    "end": 21.94,
    "speaker": "曉臻",
    "text": "老師 上面的四點",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 22.14,
    "end": 25.07,
    "speaker": "曉臻",
    "text": "不能分割 還有比例",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 25.27,
    "end": 27.63,
    "speaker": "曉臻",
    "text": "這是 誰的理論啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 27.83,
    "end": 30.74,
    "speaker": "彥君",
    "text": "這是 第一代祖師爺",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 30.94,
    "end": 33.57,
    "speaker": "彥君",
    "text": "道耳吞的 原子說",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 33.77,
    "end": 36.97,
    "speaker": "彥君",
    "text": "他認為 原子像撞球",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 37.17,
    "end": 40.15,
    "speaker": "彥君",
    "text": "是一顆 實心的球體",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 40.35,
    "end": 43.1,
    "speaker": "曉臻",
    "text": "可是 第一點不能分割",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 43.3,
    "end": 45.73,
    "speaker": "曉臻",
    "text": "好像 被打破了耶",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 45.93,
    "end": 48.6,
    "speaker": "彥君",
    "text": "助教 突破盲點了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 48.8,
    "end": 51.3,
    "speaker": "彥君",
    "text": "第二代 湯木生",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 51.5,
    "end": 54.3,
    "speaker": "彥君",
    "text": "發現了 帶負電的",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 54.5,
    "end": 56.5,
    "speaker": "彥君",
    "text": "電子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 56.7,
    "end": 60.14,
    "speaker": "曉臻",
    "text": "喔 就像西瓜 裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 60.34,
    "end": 63.01,
    "speaker": "曉臻",
    "text": "塞滿了 西瓜子一樣",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 63.21,
    "end": 66.1,
    "speaker": "曉臻",
    "text": "接著是 第三代拉塞福",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 66.3,
    "end": 68.92,
    "speaker": "曉臻",
    "text": "為什麼 叫行星式啊",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 69.12,
    "end": 72.03,
    "speaker": "彥君",
    "text": "因為 他打穿了原子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 72.23,
    "end": 75.02,
    "speaker": "彥君",
    "text": "發現 正中央有",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 75.22,
    "end": 78.11,
    "speaker": "彥君",
    "text": "原子核 還有質子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 78.31,
    "end": 81.73,
    "speaker": "曉臻",
    "text": "喔 電子就像行星",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 81.93,
    "end": 84.7,
    "speaker": "曉臻",
    "text": "繞著 原子核轉對吧",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 84.9,
    "end": 87.28,
    "speaker": "彥君",
    "text": "完全正確",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 87.48,
    "end": 90.06,
    "speaker": "曉臻",
    "text": "最後一位 查兌克",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 90.26,
    "end": 92.93,
    "speaker": "曉臻",
    "text": "他的圖 變好複雜喔",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 93.13,
    "end": 95.61,
    "speaker": "彥君",
    "text": "因為 他找到了",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 95.81,
    "end": 98.7,
    "speaker": "彥君",
    "text": "躲在 原子核裡面",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 98.9,
    "end": 101.42,
    "speaker": "彥君",
    "text": "不帶電的 中子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 101.62,
    "end": 104.39,
    "speaker": "彥君",
    "text": "到這裡 整個原子",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 104.59,
    "end": 107.53,
    "speaker": "彥君",
    "text": "才終於 拼湊完整",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 107.73,
    "end": 110.64,
    "speaker": "曉臻",
    "text": "道、 湯、 拉、 查",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 110.84,
    "end": 113.63,
    "speaker": "曉臻",
    "text": "這個順序 絕對不忘記",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 113.83,
    "end": 117.27,
    "speaker": "彥君",
    "text": "觀念通了 秒殺考題",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 117.47,
    "end": 120.07,
    "speaker": "彥君",
    "text": "我是彥君老師",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 120.27,
    "end": 122.61,
    "speaker": "曉臻",
    "text": "我是曉臻助教",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 122.81,
    "end": 126.3,
    "speaker": "合聲",
    "text": "湯木找電 拉塞找核",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 126.5,
    "end": 129.98,
    "speaker": "合聲",
    "text": "查兌找中 原子集合",
    "is_pinned": false,
    "pin_level": 0
  },
  {
    "start": 130.18,
    "end": 133.72,
    "speaker": "合聲",
    "text": "戰士們 我們頂峰相見",
    "is_pinned": false,
    "pin_level": 0
  }
]